---
import Layout from '../layouts/Layout.astro';
---

<Layout title="포트폴리오 | MK Stock Lab" activePath="/portfolio">
  <header class="page-header">
    <div>
      <p class="eyebrow">포트폴리오</p>
      <h1>내 투자 포트폴리오</h1>
      <p class="lead">국내와 미국 주식, ETF 보유 종목을 간단히 관리합니다. 시세 평가, 성과 분석, 시장 데이터 갱신은 이후 단계에서 연결합니다.</p>
    </div>
  </header>

  <section class="portfolio-status-bar" id="portfolio-readiness" data-state="checking">
    <div class="portfolio-status-items" aria-label="포트폴리오 상태">
      <span class="status-pill" data-status-key="login"><i aria-hidden="true"></i><span>로그인</span><strong id="portfolio-login-status">확인 중</strong></span>
      <span class="status-pill" data-status-key="profile"><i aria-hidden="true"></i><span>프로필</span><strong id="portfolio-profile-status">확인 중</strong></span>
      <span class="status-pill" data-status-key="api"><i aria-hidden="true"></i><span>API</span><strong id="portfolio-api-status">대기 중</strong></span>
      <span class="status-pill neutral"><i aria-hidden="true"></i><span>평가</span><strong>준비 중</strong></span>
    </div>
    <p id="portfolio-readiness-copy">로그인과 프로필 준비가 완료되면 포트폴리오 데이터를 불러옵니다.</p>
    <button class="text-button hidden" id="portfolio-login-action" type="button">로그인</button>
  </section>

  <section class="portfolio-mvp hidden" id="portfolio-mvp">
    <aside class="portfolio-sidebar panel">
      <div class="portfolio-panel-header">
        <div>
          <p class="eyebrow">포트폴리오</p>
          <h2>내 포트폴리오</h2>
        </div>
        <button class="text-button" id="portfolio-refresh" type="button">새로고침</button>
      </div>

      <form class="compact-form" id="portfolio-form">
        <input type="hidden" id="portfolio-id" />
        <label>
          이름
          <input id="portfolio-name" name="name" type="text" maxlength="120" required placeholder="핵심 보유 종목" />
        </label>
        <label>
          기준 통화
          <select id="portfolio-base-currency" name="baseCurrency">
            <option value="KRW">KRW</option>
            <option value="USD">USD</option>
          </select>
        </label>
        <div class="form-actions">
          <button class="primary-action" id="portfolio-submit" type="submit">포트폴리오 만들기</button>
          <button class="text-button hidden" id="portfolio-cancel-edit" type="button">수정 취소</button>
        </div>
      </form>

      <div class="empty-state hidden" id="portfolio-empty">아직 등록된 포트폴리오가 없습니다.</div>
      <div class="portfolio-list" id="portfolio-list" aria-live="polite"></div>
    </aside>

    <section class="portfolio-detail panel">
      <div class="portfolio-panel-header">
        <div>
          <p class="eyebrow">보유 종목</p>
          <h2 id="selected-portfolio-title">포트폴리오를 선택하세요</h2>
          <p id="selected-portfolio-meta">포트폴리오를 선택하면 보유 종목 관리 영역이 표시됩니다.</p>
        </div>
      </div>

      <form class="position-form hidden" id="position-form">
        <input type="hidden" id="position-id" />
        <input type="hidden" id="position-symbol" />
        <input type="hidden" id="position-asset-type" value="stock" />
        <div class="form-grid">
          <label class="form-field-wide">
            종목명 또는 티커
            <input id="position-security-input" maxlength="160" required placeholder="삼성전자 또는 005930" />
          </label>
          <label>
            시장
            <select id="position-market">
              <option value="KR">KR</option>
              <option value="US">US</option>
            </select>
          </label>
          <label>
            통화
            <select id="position-currency">
              <option value="KRW">KRW</option>
              <option value="USD">USD</option>
            </select>
          </label>
          <label>
            매수일
            <input id="position-buy-date" type="date" />
          </label>
          <label>
            매수가
            <input id="position-buy-price" type="number" min="0" step="0.0001" required />
          </label>
          <label>
            수량
            <input id="position-quantity" type="number" min="0.0001" step="0.0001" required />
          </label>
        </div>
        <label>
          메모
          <textarea id="position-memo" maxlength="500" rows="3" placeholder="선택 입력"></textarea>
        </label>
        <div class="form-actions">
          <button class="primary-action" id="position-submit" type="submit">종목 추가</button>
          <button class="text-button hidden" id="position-cancel-edit" type="button">수정 취소</button>
        </div>
      </form>

      <div class="empty-state" id="positions-empty">포트폴리오를 선택하면 보유 종목을 관리할 수 있습니다.</div>
      <div class="table-wrap hidden" id="positions-table-wrap">
        <table class="data-table compact-table">
          <thead>
            <tr>
              <th>종목</th>
              <th>시장</th>
              <th>수량</th>
              <th>매수가</th>
              <th>현재가</th>
              <th>평가금액</th>
              <th>수익률</th>
              <th>관리</th>
            </tr>
          </thead>
          <tbody id="positions-table-body"></tbody>
        </table>
      </div>
    </section>
  </section>

  <div class="toast hidden" id="portfolio-toast" role="status" aria-live="polite"></div>

  <script>
    import { bootstrapProfileForCurrentSession } from '../lib/profileBootstrap';
    import { portfolioApi, PortfolioApiError, type Portfolio, type PortfolioPosition } from '../lib/portfolioClient';
    import { getBrowserSupabaseClient, isSupabaseConfigured } from '../lib/supabase';

    type PortfolioState =
      | 'checking'
      | 'public_config_missing'
      | 'signed_out'
      | 'signed_in'
      | 'profile_pending'
      | 'profile_ready'
      | 'profile_failed'
      | 'profile_config_missing'
      | 'api_pending'
      | 'portfolio_config_missing'
      | 'ready';
    type AppState = {
      portfolios: Portfolio[];
      positions: PortfolioPosition[];
      selectedPortfolioId: string | null;
      loading: boolean;
    };

    const state: AppState = {
      portfolios: [],
      positions: [],
      selectedPortfolioId: null,
      loading: false,
    };

    const stateContent: Record<PortfolioState, { title: string; copy: string; login: string; profile: string; api: string; showLogin: boolean; showApp: boolean }> = {
      checking: {
        title: '로그인 상태 확인 중',
        copy: '로그인과 프로필 준비가 완료되면 포트폴리오 데이터를 불러옵니다.',
        login: '확인 중',
        profile: '확인 중',
        api: '대기 중',
        showLogin: false,
        showApp: false,
      },
      public_config_missing: {
        title: '로그인 설정 필요',
        copy: '로그인 설정이 아직 완료되지 않아 포트폴리오를 사용할 수 없습니다.',
        login: '설정 필요',
        profile: '대기 중',
        api: '대기 중',
        showLogin: false,
        showApp: false,
      },
      signed_out: {
        title: '로그인이 필요합니다',
        copy: '로그인하면 프로필을 준비하고 포트폴리오를 불러옵니다.',
        login: '필요',
        profile: '대기 중',
        api: '대기 중',
        showLogin: true,
        showApp: false,
      },
      signed_in: {
        title: '로그인 확인 완료',
        copy: '프로필 상태를 확인하고 있습니다.',
        login: '로그인됨',
        profile: '확인 중',
        api: '대기 중',
        showLogin: false,
        showApp: false,
      },
      profile_pending: {
        title: '프로필 준비 중',
        copy: '프로필 준비가 끝나면 포트폴리오 데이터를 불러옵니다.',
        login: '로그인됨',
        profile: '준비 중',
        api: '대기 중',
        showLogin: false,
        showApp: false,
      },
      api_pending: {
        title: '포트폴리오 API 확인 중',
        copy: '프로필 준비가 완료되어 포트폴리오 데이터를 불러오고 있습니다.',
        login: '로그인됨',
        profile: '준비 완료',
        api: '확인 중',
        showLogin: false,
        showApp: false,
      },
      profile_ready: {
        title: '프로필 준비 완료',
        copy: '포트폴리오 API 상태를 확인하고 있습니다.',
        login: '로그인됨',
        profile: '준비 완료',
        api: '확인 중',
        showLogin: false,
        showApp: false,
      },
      profile_failed: {
        title: '프로필 설정 확인 필요',
        copy: '프로필 설정이 완료되지 않아 포트폴리오 데이터를 불러오지 않았습니다.',
        login: '로그인됨',
        profile: '확인 필요',
        api: '대기 중',
        showLogin: false,
        showApp: false,
      },
      profile_config_missing: {
        title: '프로필 API 설정 필요',
        copy: '프로필 API 설정이 아직 완료되지 않아 포트폴리오를 사용할 수 없습니다.',
        login: '로그인됨',
        profile: '설정 필요',
        api: '대기 중',
        showLogin: false,
        showApp: false,
      },
      portfolio_config_missing: {
        title: '포트폴리오 API 설정 필요',
        copy: '포트폴리오 API 설정이 아직 완료되지 않았습니다.',
        login: '로그인됨',
        profile: '준비 완료',
        api: '설정 필요',
        showLogin: false,
        showApp: false,
      },
      ready: {
        title: '포트폴리오 준비 완료',
        copy: '포트폴리오 MVP를 사용할 수 있습니다. 시세, 평가금액, 성과 분석은 아직 구현되지 않았습니다.',
        login: '로그인됨',
        profile: '준비 완료',
        api: '사용 가능',
        showLogin: false,
        showApp: true,
      },
    };

    const money = new Intl.NumberFormat('en-US', { maximumFractionDigits: 4 });

    const getElement = <T extends HTMLElement>(id: string) => document.getElementById(id) as T | null;
    const selectedPortfolio = () => state.portfolios.find((portfolio) => portfolio.id === state.selectedPortfolioId) ?? null;
    const escapeHtml = (value: string | null | undefined) =>
      String(value || '').replace(/[&<>"']/g, (char) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;',
      })[char] || char);
    const tickerLikePattern = /^[A-Za-z0-9.-]{1,16}$/;
    const toInternalSymbol = (value: string) => {
      const normalized = value.trim();
      if (tickerLikePattern.test(normalized)) return normalized.toUpperCase();
      return normalized.slice(0, 32);
    };
    const toPositionIdentity = (value: string) => {
      const normalized = value.trim();
      const symbol = toInternalSymbol(normalized);
      return {
        symbol,
        name: tickerLikePattern.test(normalized) ? '' : normalized,
      };
    };
    const getPositionPrimaryLabel = (position: PortfolioPosition) => position.name || position.symbol || '종목명 미입력';
    const getPositionSecondaryLabel = (position: PortfolioPosition) => {
      if (position.name && position.symbol && position.name !== position.symbol) return position.symbol;
      if (!position.name && position.symbol) return '티커 직접 입력';
      return '티커 미확인';
    };
    const getValuationPlaceholder = (portfolio: Portfolio, position: PortfolioPosition) =>
      portfolio.baseCurrency === 'KRW' && position.currency === 'USD' ? '원화 환산 예정' : '데이터 대기';

    const showToast = (message: string) => {
      const toast = getElement<HTMLDivElement>('portfolio-toast');
      if (!toast) return;
      toast.textContent = message;
      toast.classList.remove('hidden');
      window.setTimeout(() => toast.classList.add('hidden'), 3200);
    };

    const normalizeError = (error: unknown) => {
      if (error instanceof PortfolioApiError) return error.message;
      return '포트폴리오 요청에 실패했습니다.';
    };

    const mapProfileStatus = (status: string): PortfolioState => {
      if (status === 'ready') return 'profile_ready';
      if (status === 'server_config_missing') return 'profile_config_missing';
      if (status === 'public_config_missing') return 'public_config_missing';
      if (status === 'signed_out') return 'signed_out';
      if (status === 'pending') return 'profile_pending';
      return 'profile_failed';
    };

    const setPortfolioState = (nextState: PortfolioState) => {
      const content = stateContent[nextState];
      const root = getElement<HTMLElement>('portfolio-readiness');
      const title = getElement<HTMLElement>('portfolio-readiness-title');
      const copy = getElement<HTMLElement>('portfolio-readiness-copy');
      const login = getElement<HTMLElement>('portfolio-login-status');
      const profile = getElement<HTMLElement>('portfolio-profile-status');
      const api = getElement<HTMLElement>('portfolio-api-status');
      const loginAction = getElement<HTMLButtonElement>('portfolio-login-action');
      const app = getElement<HTMLElement>('portfolio-mvp');

      if (root) root.dataset.state = nextState;
      if (title) title.textContent = content.title;
      if (copy) copy.textContent = content.copy;
      if (login) login.textContent = content.login;
      if (profile) profile.textContent = content.profile;
      if (api) api.textContent = content.api;
      loginAction?.classList.toggle('hidden', !content.showLogin);
      app?.classList.toggle('hidden', !content.showApp);
    };

    const clearPortfolioData = () => {
      state.portfolios = [];
      state.positions = [];
      state.selectedPortfolioId = null;
      state.loading = false;
      resetPortfolioForm();
      resetPositionForm();
      renderAll();
    };

    const resetPortfolioForm = () => {
      getElement<HTMLInputElement>('portfolio-id')!.value = '';
      getElement<HTMLInputElement>('portfolio-name')!.value = '';
      getElement<HTMLSelectElement>('portfolio-base-currency')!.value = 'KRW';
      getElement<HTMLButtonElement>('portfolio-submit')!.textContent = '포트폴리오 만들기';
      getElement<HTMLButtonElement>('portfolio-cancel-edit')?.classList.add('hidden');
    };

    const resetPositionForm = () => {
      getElement<HTMLInputElement>('position-id')!.value = '';
      getElement<HTMLInputElement>('position-security-input')!.value = '';
      getElement<HTMLInputElement>('position-symbol')!.value = '';
      getElement<HTMLSelectElement>('position-market')!.value = 'KR';
      getElement<HTMLInputElement>('position-asset-type')!.value = 'stock';
      getElement<HTMLSelectElement>('position-currency')!.value = 'KRW';
      getElement<HTMLInputElement>('position-buy-date')!.value = '';
      getElement<HTMLInputElement>('position-buy-price')!.value = '';
      getElement<HTMLInputElement>('position-quantity')!.value = '';
      getElement<HTMLTextAreaElement>('position-memo')!.value = '';
      getElement<HTMLButtonElement>('position-submit')!.textContent = '종목 추가';
      getElement<HTMLButtonElement>('position-cancel-edit')?.classList.add('hidden');
    };

    const renderPortfolios = () => {
      const list = getElement<HTMLDivElement>('portfolio-list');
      const empty = getElement<HTMLDivElement>('portfolio-empty');
      if (!list || !empty) return;

      empty.classList.toggle('hidden', state.portfolios.length > 0);
      list.innerHTML = '';

      state.portfolios.forEach((portfolio) => {
        const item = document.createElement('article');
        item.className = `portfolio-item${portfolio.id === state.selectedPortfolioId ? ' active' : ''}`;
        item.innerHTML = `
          <button class="portfolio-select" type="button" data-action="select" data-id="${portfolio.id}">
            <strong>${escapeHtml(portfolio.name)}</strong>
            <span>${portfolio.baseCurrency}</span>
          </button>
          <div class="portfolio-item-actions">
            <button class="text-button" type="button" data-action="edit-portfolio" data-id="${portfolio.id}">수정</button>
            <button class="text-button danger" type="button" data-action="delete-portfolio" data-id="${portfolio.id}">삭제</button>
          </div>
        `;
        list.appendChild(item);
      });
    };

    const renderPositions = () => {
      const portfolio = selectedPortfolio();
      const title = getElement<HTMLElement>('selected-portfolio-title');
      const meta = getElement<HTMLElement>('selected-portfolio-meta');
      const form = getElement<HTMLFormElement>('position-form');
      const empty = getElement<HTMLDivElement>('positions-empty');
      const wrap = getElement<HTMLDivElement>('positions-table-wrap');
      const body = getElement<HTMLTableSectionElement>('positions-table-body');
      if (!title || !meta || !form || !empty || !wrap || !body) return;

      body.innerHTML = '';

      if (!portfolio) {
        title.textContent = '포트폴리오를 선택하세요';
        meta.textContent = '포트폴리오를 선택하면 보유 종목 관리 영역이 표시됩니다.';
        form.classList.add('hidden');
        empty.textContent = '포트폴리오를 선택하면 보유 종목을 관리할 수 있습니다.';
        empty.classList.remove('hidden');
        wrap.classList.add('hidden');
        return;
      }

      title.textContent = portfolio.name;
      meta.textContent = `기준 통화: ${portfolio.baseCurrency}`;
      form.classList.remove('hidden');

      empty.textContent = '아직 등록된 보유 종목이 없습니다.';
      empty.classList.toggle('hidden', state.positions.length > 0);
      wrap.classList.toggle('hidden', state.positions.length === 0);

      state.positions.forEach((position) => {
        const row = document.createElement('tr');
        const primaryLabel = getPositionPrimaryLabel(position);
        const secondaryLabel = getPositionSecondaryLabel(position);
        row.innerHTML = `
          <td class="position-name-cell">
            <strong>${escapeHtml(primaryLabel)}</strong>
            <small>${escapeHtml(secondaryLabel)}</small>
          </td>
          <td>${position.market}</td>
          <td>${money.format(position.quantity)}</td>
          <td>${position.currency} ${money.format(position.buyPrice)}</td>
          <td><span class="metric-placeholder">연동 예정</span></td>
          <td><span class="metric-placeholder">${getValuationPlaceholder(portfolio, position)}</span></td>
          <td><span class="metric-placeholder">-</span></td>
          <td class="table-actions">
            <button class="table-action-button" type="button" data-action="edit-position" data-id="${position.id}">수정</button>
            <button class="table-action-button danger" type="button" data-action="delete-position" data-id="${position.id}">삭제</button>
          </td>
        `;
        body.appendChild(row);
      });
    };

    const renderAll = () => {
      renderPortfolios();
      renderPositions();
    };

    const loadPositions = async (portfolioId: string) => {
      state.positions = await portfolioApi.listPositions(portfolioId);
      renderPositions();
    };

    const loadPortfolios = async () => {
      state.portfolios = await portfolioApi.listPortfolios();
      if (!state.selectedPortfolioId || !state.portfolios.some((portfolio) => portfolio.id === state.selectedPortfolioId)) {
        state.selectedPortfolioId = state.portfolios[0]?.id ?? null;
      }
      renderAll();
      if (state.selectedPortfolioId) await loadPositions(state.selectedPortfolioId);
    };

    const loadPortfolioMvp = async () => {
      if (state.loading) return;
      try {
        state.loading = true;
        setPortfolioState('api_pending');
        await loadPortfolios();
        setPortfolioState('ready');
      } catch (error) {
        setPortfolioState(error instanceof PortfolioApiError && error.status === 503 ? 'portfolio_config_missing' : 'profile_failed');
        showToast(normalizeError(error));
      } finally {
        state.loading = false;
      }
    };

    const runProfileAndPortfolioLoad = async () => {
      setPortfolioState('signed_in');
      const result = await bootstrapProfileForCurrentSession();
      const ready = result.status === 'ready';
      setPortfolioState(ready ? 'profile_ready' : mapProfileStatus(result.status));
      if (ready) await loadPortfolioMvp();
    };

    const initPortfolioReadiness = async () => {
      const marker = window as Window & { mkPortfolioMvpReady?: boolean };
      if (marker.mkPortfolioMvpReady) return;
      marker.mkPortfolioMvpReady = true;

      getElement<HTMLButtonElement>('portfolio-login-action')?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('mk:open-auth'));
      });

      if (!isSupabaseConfigured()) {
        setPortfolioState('public_config_missing');
        return;
      }

      const supabase = getBrowserSupabaseClient();
      if (!supabase) {
        setPortfolioState('public_config_missing');
        return;
      }

      const { data } = await supabase.auth.getSession();
      if (!data.session) {
        clearPortfolioData();
        setPortfolioState('signed_out');
        return;
      }

      await runProfileAndPortfolioLoad();
    };

    getElement<HTMLButtonElement>('portfolio-refresh')?.addEventListener('click', () => {
      void loadPortfolioMvp();
    });

    getElement<HTMLButtonElement>('portfolio-cancel-edit')?.addEventListener('click', resetPortfolioForm);
    getElement<HTMLButtonElement>('position-cancel-edit')?.addEventListener('click', resetPositionForm);

    getElement<HTMLSelectElement>('position-market')?.addEventListener('change', (event) => {
      const market = (event.currentTarget as HTMLSelectElement).value;
      getElement<HTMLSelectElement>('position-currency')!.value = market === 'KR' ? 'KRW' : 'USD';
    });

    getElement<HTMLFormElement>('portfolio-form')?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const id = getElement<HTMLInputElement>('portfolio-id')!.value;
      const input = {
        name: getElement<HTMLInputElement>('portfolio-name')!.value,
        baseCurrency: getElement<HTMLSelectElement>('portfolio-base-currency')!.value as 'KRW' | 'USD',
      };

      try {
        if (id) {
          await portfolioApi.updatePortfolio({ id, ...input });
          showToast('포트폴리오가 수정되었습니다.');
        } else {
          const created = await portfolioApi.createPortfolio(input);
          state.selectedPortfolioId = created.id;
          showToast('포트폴리오가 생성되었습니다.');
        }
        resetPortfolioForm();
        await loadPortfolios();
      } catch (error) {
        showToast(normalizeError(error));
      }
    });

    getElement<HTMLDivElement>('portfolio-list')?.addEventListener('click', async (event) => {
      const target = (event.target as HTMLElement).closest<HTMLButtonElement>('button[data-action]');
      if (!target) return;
      const id = target.dataset.id;
      if (!id) return;

      if (target.dataset.action === 'select') {
        state.selectedPortfolioId = id;
        resetPositionForm();
        renderAll();
        await loadPositions(id);
      }

      if (target.dataset.action === 'edit-portfolio') {
        const portfolio = state.portfolios.find((item) => item.id === id);
        if (!portfolio) return;
        getElement<HTMLInputElement>('portfolio-id')!.value = portfolio.id;
        getElement<HTMLInputElement>('portfolio-name')!.value = portfolio.name;
        getElement<HTMLSelectElement>('portfolio-base-currency')!.value = portfolio.baseCurrency;
        getElement<HTMLButtonElement>('portfolio-submit')!.textContent = '포트폴리오 수정';
        getElement<HTMLButtonElement>('portfolio-cancel-edit')?.classList.remove('hidden');
      }

      if (target.dataset.action === 'delete-portfolio') {
        const portfolio = state.portfolios.find((item) => item.id === id);
        if (!portfolio) return;
        const confirmed = window.confirm(`"${portfolio.name}" 포트폴리오와 보유 종목을 삭제할까요?`);
        if (!confirmed) return;
        try {
          await portfolioApi.deletePortfolio(id);
          if (state.selectedPortfolioId === id) state.selectedPortfolioId = null;
          resetPortfolioForm();
          resetPositionForm();
          showToast('포트폴리오가 삭제되었습니다.');
          await loadPortfolios();
        } catch (error) {
          showToast(normalizeError(error));
        }
      }
    });

    getElement<HTMLFormElement>('position-form')?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!state.selectedPortfolioId) return;

      const id = getElement<HTMLInputElement>('position-id')!.value;
      const securityInput = getElement<HTMLInputElement>('position-security-input')!.value.trim();
      if (!securityInput) {
        showToast('종목명 또는 티커를 입력하세요.');
        return;
      }
      const identity = toPositionIdentity(securityInput);
      const input = {
        portfolioId: state.selectedPortfolioId,
        symbol: identity.symbol,
        market: getElement<HTMLSelectElement>('position-market')!.value as 'KR' | 'US',
        assetType: 'stock' as const,
        name: identity.name,
        buyPrice: Number(getElement<HTMLInputElement>('position-buy-price')!.value),
        quantity: Number(getElement<HTMLInputElement>('position-quantity')!.value),
        buyDate: getElement<HTMLInputElement>('position-buy-date')!.value,
        memo: getElement<HTMLTextAreaElement>('position-memo')!.value,
        currency: getElement<HTMLSelectElement>('position-currency')!.value as 'KRW' | 'USD',
      };

      try {
        if (id) {
          await portfolioApi.updatePosition({ id, ...input });
          showToast('종목이 수정되었습니다.');
        } else {
          await portfolioApi.createPosition(input);
          showToast('종목이 추가되었습니다.');
        }
        resetPositionForm();
        await loadPositions(state.selectedPortfolioId);
      } catch (error) {
        showToast(normalizeError(error));
      }
    });

    getElement<HTMLTableSectionElement>('positions-table-body')?.addEventListener('click', async (event) => {
      const target = (event.target as HTMLElement).closest<HTMLButtonElement>('button[data-action]');
      if (!target) return;
      const id = target.dataset.id;
      if (!id) return;

      const position = state.positions.find((item) => item.id === id);
      if (!position) return;

      if (target.dataset.action === 'edit-position') {
        getElement<HTMLInputElement>('position-id')!.value = position.id;
        getElement<HTMLInputElement>('position-security-input')!.value = position.name || position.symbol;
        getElement<HTMLInputElement>('position-symbol')!.value = position.symbol;
        getElement<HTMLSelectElement>('position-market')!.value = position.market;
        getElement<HTMLInputElement>('position-asset-type')!.value = position.assetType || 'stock';
        getElement<HTMLSelectElement>('position-currency')!.value = position.currency;
        getElement<HTMLInputElement>('position-buy-date')!.value = position.buyDate || '';
        getElement<HTMLInputElement>('position-buy-price')!.value = String(position.buyPrice);
        getElement<HTMLInputElement>('position-quantity')!.value = String(position.quantity);
        getElement<HTMLTextAreaElement>('position-memo')!.value = position.memo || '';
        getElement<HTMLButtonElement>('position-submit')!.textContent = '종목 수정';
        getElement<HTMLButtonElement>('position-cancel-edit')?.classList.remove('hidden');
      }

      if (target.dataset.action === 'delete-position') {
        const confirmed = window.confirm(`"${getPositionPrimaryLabel(position)}" 종목을 삭제할까요?`);
        if (!confirmed || !state.selectedPortfolioId) return;
        try {
          await portfolioApi.deletePosition(id);
          showToast('종목이 삭제되었습니다.');
          await loadPositions(state.selectedPortfolioId);
        } catch (error) {
          showToast(normalizeError(error));
        }
      }
    });

    window.addEventListener('mk:profile-bootstrap', (event) => {
      const detail = (event as CustomEvent).detail;
      if (!detail?.status) return;
      if (detail.status === 'signed_out') {
        clearPortfolioData();
        setPortfolioState('signed_out');
        return;
      }
      setPortfolioState(detail.status === 'ready' ? 'profile_ready' : mapProfileStatus(detail.status));
      if (detail.status === 'ready') void loadPortfolioMvp();
    });

    window.addEventListener('mk:auth-state', (event) => {
      const detail = (event as CustomEvent).detail;
      if (detail?.status === 'checking') {
        setPortfolioState('checking');
      }
      if (detail?.status === 'signed_out') {
        clearPortfolioData();
        setPortfolioState('signed_out');
      }
      if (detail?.status === 'signed_in') {
        void runProfileAndPortfolioLoad();
      }
    });

    document.addEventListener('astro:page-load', initPortfolioReadiness);
    initPortfolioReadiness();
  </script>
</Layout>
