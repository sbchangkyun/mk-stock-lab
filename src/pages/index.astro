---
import HomeIndexCards from '../components/HomeIndexCards.astro';
import HomeMobileAd from '../components/HomeMobileAd.astro';
import HomeRailAd from '../components/HomeRailAd.astro';
import HomeMarketNews from '../components/HomeMarketNews.astro';
import HomePortfolioPanel from '../components/HomePortfolioPanel.astro';
import HomeRetentionPanel from '../components/HomeRetentionPanel.astro';
import Layout from '../layouts/Layout.astro';

// SSR fetch: /api/news/market-feed?mode=home (no source param — uses fixture default)
// eslint-disable-next-line @typescript-eslint/no-explicit-any
let newsArticles: any[] = [];
try {
  const newsUrl = new URL('/api/news/market-feed?mode=home', Astro.url);
  const res = await fetch(newsUrl);
  if (res.ok) {
    const data = await res.json() as Record<string, unknown>;
    if (Array.isArray(data?.articles)) {
      newsArticles = data.articles.slice(0, 6);
    }
  }
} catch {
  // SSR fetch failed — HomeMarketNews renders empty fallback state
}
---

<Layout title="MK Stock Lab | 투자 데이터 플랫폼" activePath="/" pageClass="home-page">
  <div class="home-shell">
    <div class="home-main-column">

  <section class="hero-section">
    <div class="hero-copy">
      <p class="eyebrow">MK Stock Lab Preview</p>
      <h1>시장 데이터, AI 차트 리뷰, 포트폴리오 관리를 한 곳에서</h1>
      <p class="lead">
        국내와 미국 주식, ETF 투자자를 위한 공개 투자 데이터 플랫폼입니다. Chart AI, 시장, Lab 리서치, 포트폴리오 관리 기능을 단계적으로 연결합니다.
      </p>
      <div class="hero-actions">
        <a class="button-link" href="/chart-ai">Chart AI 열기</a>
        <a class="button-link secondary" href="/market">시장 보기</a>
      </div>
    </div>

    <HomePortfolioPanel />
  </section>

  <section class="grid-4 home-feature-grid">
    <a class="feature-card" href="/chart-ai">
      <h2>Chart AI</h2>
      <p>선택한 종목의 차트 준비 상태를 기준으로 서버 사용량 가드를 확인하는 분석 진입 화면입니다.</p>
    </a>
    <a class="feature-card" href="/market">
      <h2>시장</h2>
      <p>KOSPI200, KOSDAQ150, S&amp;P500, NASDAQ100, 포트폴리오를 Treemap과 Momentum/Trend 산점도로 비교합니다.</p>
    </a>
    <a class="feature-card" href="/lab">
      <h2>Lab</h2>
      <p>섹터 수익률, 자산군 수익률, 국민연금 보유 현황, 국회의원 보유 주식 데이터를 모아보는 공개 리서치 허브입니다.</p>
    </a>
    <a class="feature-card" href="/portfolio">
      <h2>포트폴리오</h2>
      <p>로그인 후 보유 종목, 메모, 배분 관리를 시작하는 개인 포트폴리오 작업 공간입니다.</p>
    </a>
  </section>

  <HomeMobileAd />

  <HomeIndexCards />

  <HomeRetentionPanel />

  <HomeMarketNews articles={newsArticles} />

    </div>

    <div class="home-sidebar-column" aria-label="Home advertising sidebar">
      <HomeRailAd />
    </div>
  </div>
</Layout>
