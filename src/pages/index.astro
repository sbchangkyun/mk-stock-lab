---
import Layout from '../layouts/Layout.astro';
---

<Layout title="MK Stock Lab | Investment Data Platform" activePath="/">
  <section class="hero-section">
    <div class="hero-copy">
      <p class="eyebrow">MK Stock Lab rebuild preview</p>
      <h1>Market data, AI chart review, and portfolio tools in one workspace.</h1>
      <p class="lead">
        A public investment data platform for Korean and US stock and ETF investors. The MVP shell is ready for Chart AI, heatmaps, Lab research, and portfolio management.
      </p>
      <div class="hero-actions">
        <a class="button-link" href="/chart-ai">Open Chart AI</a>
        <a class="button-link secondary" href="/lab">Explore Lab</a>
      </div>
    </div>

    <aside class="panel market-panel">
      <p class="eyebrow">Market snapshot</p>
      <h2>Core coverage</h2>
      <div class="metric-list">
        <div class="metric-row"><span>Korean stocks</span><strong>KOSPI / KOSDAQ</strong></div>
        <div class="metric-row"><span>US stocks</span><strong>NYSE / Nasdaq</strong></div>
        <div class="metric-row"><span>ETFs</span><strong>KR / US listed</strong></div>
        <div class="metric-row"><span>Crypto</span><strong class="neutral">Excluded from main product</strong></div>
      </div>
    </aside>
  </section>

  <section class="grid-4">
    <a class="feature-card" href="/chart-ai">
      <h2>Chart AI</h2>
      <p>Route shell for market-data-based AI chart analysis with login gating and daily usage limits in a later phase.</p>
    </a>
    <a class="feature-card" href="/heatmap">
      <h2>Heatmap</h2>
      <p>Desktop-first market heatmap shell for index universes and a future portfolio view.</p>
    </a>
    <a class="feature-card" href="/lab">
      <h2>Lab</h2>
      <p>Public data-content hub for sector returns, asset-class returns, NPS holdings, and Congress stocks.</p>
    </a>
    <a class="feature-card" href="/portfolio">
      <h2>Portfolio</h2>
      <p>Login-required portfolio workspace shell for holdings, risk notes, and allocation views.</p>
    </a>
  </section>
</Layout>
