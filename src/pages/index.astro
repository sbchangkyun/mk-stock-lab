---
/* src/pages/index.astro */
import Layout from '../layouts/Layout.astro';
import SlideAd from '../components/SlideAd.astro';
import Header from '../components/Header.astro';
import Ticker from '../components/Ticker.astro';
import Nav from '../components/Nav.astro';
import ChartArea from '../components/ChartArea.astro';
import Footer from '../components/Footer.astro';
import AddStockModal from '../components/Portfolio/AddStockModal.astro';
import { supabase } from '../lib/supabase';

// ── 인증 확인 ──────────────────────────────────────────
const { data: { session } } = await supabase.auth.getSession();
const isLoggedIn = !!session;

// ── 포트폴리오 그룹 목록 fetch (로그인 시에만) ──────────
let portfolios: { id: string; name: string; created_at: string }[] = [];
if (isLoggedIn && session) {
  const { data, error } = await supabase
    .from('portfolios')
    .select('id, name, created_at')
    .eq('user_id', session.user.id)
    .order('created_at', { ascending: false });

  if (!error && data) {
    portfolios = data;
  }
}
---

<Layout title="MK Stock Lab - 실시간 투자·경제 뉴스">
    <SlideAd />
    <Header />
    <Ticker />
    <Nav />

    <div id="toast">힝 속았지?</div>

    <!-- ── 미로그인: 안내 섹션 ───────────────────────── -->
    {!isLoggedIn && (
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6">
            <div class="flex flex-col items-center justify-center bg-gray-50 dark:bg-gray-800/50 p-12 rounded-2xl border border-dashed border-gray-200 dark:border-gray-700 text-center gap-4">
                <div class="w-14 h-14 bg-indigo-100 dark:bg-indigo-900/50 rounded-full flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                </div>
                <div>
                    <h3 class="text-lg font-bold text-gray-800 dark:text-white">로그인이 필요합니다</h3>
                    <p class="text-sm text-gray-500 mt-1">포트폴리오를 관리하려면 먼저 로그인하세요.</p>
                </div>
                <a href="/login" class="mt-2 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold py-2.5 px-6 rounded-lg transition-all active:scale-95 shadow-sm">
                    로그인하기
                </a>
            </div>
        </div>
    )}

    <!-- ── 로그인: 포트폴리오 그룹 섹션 ──────────────── -->
    {isLoggedIn && (
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6">

            <!-- 섹션 헤더 -->
            <div class="flex justify-between items-center mb-5">
                <div>
                    <h2 class="text-lg font-bold text-gray-800 dark:text-white">나의 포트폴리오</h2>
                    <p class="text-xs text-gray-500 mt-0.5">그룹을 선택해 종목을 추가하세요.</p>
                </div>
                <button
                    id="createPortfolioBtn"
                    class="bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold py-2.5 px-5 rounded-lg shadow-sm transition-all active:scale-95 flex items-center gap-2"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                    새 포트폴리오
                </button>
            </div>

            <!-- 포트폴리오 카드 그리드 -->
            {portfolios.length === 0 ? (
                <div class="flex flex-col items-center justify-center bg-gray-50 dark:bg-gray-800/30 py-16 rounded-2xl border border-dashed border-gray-200 dark:border-gray-700 text-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10 text-gray-300 dark:text-gray-600 mb-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                    </svg>
                    <p class="text-gray-400 dark:text-gray-500 text-sm font-medium">포트폴리오 그룹이 없습니다.</p>
                    <p class="text-gray-400 dark:text-gray-600 text-xs">위의 버튼으로 첫 번째 그룹을 만들어보세요!</p>
                </div>
            ) : (
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                    {portfolios.map((portfolio) => (
                        <button
                            class="portfolio-card group text-left w-full bg-white dark:bg-gray-800/60 border border-gray-100 dark:border-gray-700 rounded-xl p-5 shadow-sm hover:shadow-md hover:border-indigo-300 dark:hover:border-indigo-500 transition-all duration-200 cursor-pointer"
                            data-portfolio-id={portfolio.id}
                            data-portfolio-name={portfolio.name}
                        >
                            <div class="flex items-start justify-between mb-3">
                                <div class="w-10 h-10 bg-indigo-50 dark:bg-indigo-900/40 group-hover:bg-indigo-100 dark:group-hover:bg-indigo-900/70 rounded-lg flex items-center justify-center transition-colors">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-indigo-500 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                                    </svg>
                                </div>
                                <span class="text-xs text-indigo-400 dark:text-indigo-400 font-medium opacity-0 group-hover:opacity-100 transition-opacity flex items-center gap-1">
                                    종목 추가
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                    </svg>
                                </span>
                            </div>
                            <h3 class="font-bold text-gray-800 dark:text-white text-base leading-snug">{portfolio.name}</h3>
                            <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">
                                {new Date(portfolio.created_at).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })} 생성
                            </p>
                        </button>
                    ))}
                </div>
            )}
        </div>
    )}

    <ChartArea />
    <Footer />

    {isLoggedIn && <AddStockModal />}

    <script is:inline src="https://cdn.jsdelivr.net/gh/timdream/wordcloud2.js@gh-pages/src/wordcloud2.js"></script>

    <script>
        import { supabase } from '../lib/supabase';

        // ── 새 포트폴리오 그룹 생성 ────────────────────────
        document.getElementById('createPortfolioBtn')?.addEventListener('click', async () => {
            const name = prompt('새 포트폴리오 이름을 입력하세요.\n(예: 미국 주식, 국내 성장주, ETF 모음)');
            if (!name?.trim()) return;

            const { data: { user } } = await supabase.auth.getUser();
            if (!user) {
                alert('로그인이 필요합니다.');
                return;
            }

            const { error } = await supabase
                .from('portfolios')
                .insert([{ user_id: user.id, name: name.trim() }]);

            if (error) {
                alert('생성 실패: ' + error.message);
            } else {
                window.location.reload();
            }
        });

        // ── 포트폴리오 카드 클릭 → 모달 열기 ──────────────
        const modal = document.getElementById('addStockModal');

        document.querySelectorAll<HTMLElement>('.portfolio-card').forEach((card) => {
            card.addEventListener('click', () => {
                const portfolioId   = card.dataset.portfolioId   || '';
                const portfolioName = card.dataset.portfolioName || '';

                // 모달에 선택된 portfolio_id 주입
                const hiddenInput = document.getElementById('currentPortfolioId') as HTMLInputElement | null;
                if (hiddenInput) hiddenInput.value = portfolioId;

                // 모달 타이틀에 그룹명 표시
                const nameSpan = document.getElementById('modalPortfolioName');
                if (nameSpan) nameSpan.textContent = portfolioName;

                // 모달 열기
                modal?.classList.remove('hidden');
                modal?.classList.add('flex');
                document.body.style.overflow = 'hidden';
            });
        });
    </script>
</Layout>