---
import Layout from '../layouts/Layout.astro';
---

<Layout title="비밀번호 재설정 | MK Stock Lab" activePath="">
  <header class="page-header">
    <div>
      <p class="eyebrow">Account</p>
      <h1>비밀번호 재설정</h1>
      <p class="lead">메일로 받은 재설정 링크를 통해 새 비밀번호를 설정합니다.</p>
    </div>
  </header>

  <div class="reset-pw-wrap">

    <!-- Checking state (default visible while waiting for recovery session) -->
    <div id="rp-checking" class="panel reset-pw-panel">
      <p class="reset-pw-status">재설정 링크를 확인하는 중입니다...</p>
    </div>

    <!-- Invalid / expired link state -->
    <div id="rp-invalid" class="panel reset-pw-panel hidden">
      <p class="reset-pw-status reset-pw-status--err">
        재설정 링크가 만료되었거나 유효하지 않습니다. 다시 요청해 주세요.
      </p>
      <div class="reset-pw-actions">
        <a class="header-button" href="/">홈으로 돌아가기</a>
      </div>
    </div>

    <!-- Password form state -->
    <div id="rp-form-panel" class="panel reset-pw-panel hidden">
      <form class="reset-pw-form" id="rp-form" novalidate>
        <label class="reset-pw-field">
          새 비밀번호
          <input id="rp-password" type="password" autocomplete="new-password"
            placeholder="8자 이상" minlength="8" required />
        </label>
        <label class="reset-pw-field">
          새 비밀번호 확인
          <input id="rp-password-confirm" type="password" autocomplete="new-password"
            placeholder="비밀번호 재입력" required />
        </label>
        <p class="auth-error hidden" id="rp-error" role="alert"></p>
        <button class="primary-action" type="submit" id="rp-submit">새 비밀번호 저장</button>
      </form>
    </div>

    <!-- Success state -->
    <div id="rp-success" class="panel reset-pw-panel hidden">
      <p class="reset-pw-status reset-pw-status--ok">
        비밀번호가 변경되었습니다. 새 비밀번호로 로그인해 주세요.
      </p>
      <div class="reset-pw-actions">
        <a class="header-button" href="/">홈으로 돌아가기</a>
      </div>
    </div>

  </div>

  <p class="reset-pw-back-link"><a href="/">← 로그인 화면으로 돌아가기</a></p>
</Layout>

<script>
  import { getBrowserSupabaseClient, isSupabaseConfigured } from '../lib/supabase';

  const setupResetPage = () => {
    const checkingEl = document.getElementById('rp-checking') as HTMLElement | null;
    if (!checkingEl || checkingEl.dataset.ready === 'true') return;
    checkingEl.dataset.ready = 'true';

    const invalidEl = document.getElementById('rp-invalid') as HTMLElement | null;
    const formPanel = document.getElementById('rp-form-panel') as HTMLElement | null;
    const successEl = document.getElementById('rp-success') as HTMLElement | null;
    const form = document.getElementById('rp-form') as HTMLFormElement | null;
    const passwordInput = document.getElementById('rp-password') as HTMLInputElement | null;
    const passwordConfirmInput = document.getElementById('rp-password-confirm') as HTMLInputElement | null;
    const submitBtn = document.getElementById('rp-submit') as HTMLButtonElement | null;
    const errorEl = document.getElementById('rp-error') as HTMLElement | null;

    const showState = (state: 'checking' | 'invalid' | 'form' | 'success') => {
      checkingEl.classList.toggle('hidden', state !== 'checking');
      invalidEl?.classList.toggle('hidden', state !== 'invalid');
      formPanel?.classList.toggle('hidden', state !== 'form');
      successEl?.classList.toggle('hidden', state !== 'success');
    };

    const setError = (msg: string) => {
      if (!errorEl) return;
      errorEl.textContent = msg;
      errorEl.classList.toggle('hidden', !msg);
    };

    if (!isSupabaseConfigured()) {
      showState('invalid');
      return;
    }

    const supabase = getBrowserSupabaseClient();
    if (!supabase) {
      showState('invalid');
      return;
    }

    let recoveryDetected = false;
    let invalidTimer: ReturnType<typeof setTimeout>;

    supabase.auth.onAuthStateChange((event, session) => {
      if (event === 'PASSWORD_RECOVERY' && session) {
        recoveryDetected = true;
        clearTimeout(invalidTimer);
        showState('form');
      }
    });

    invalidTimer = setTimeout(() => {
      if (!recoveryDetected) {
        showState('invalid');
      }
    }, 2500);

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      setError('');

      const password = passwordInput?.value ?? '';
      const passwordConfirm = passwordConfirmInput?.value ?? '';

      if (password.length < 8) {
        setError('비밀번호는 8자 이상이어야 합니다.');
        return;
      }
      if (password !== passwordConfirm) {
        setError('비밀번호가 일치하지 않습니다.');
        return;
      }

      if (submitBtn) submitBtn.setAttribute('disabled', 'true');

      const { error } = await supabase.auth.updateUser({ password });

      if (submitBtn) submitBtn.removeAttribute('disabled');

      if (error) {
        setError('비밀번호 변경에 실패했습니다. 다시 시도해 주세요.');
        return;
      }

      await supabase.auth.signOut();
      showState('success');
    });
  };

  document.addEventListener('astro:page-load', setupResetPage);
  setupResetPage();
</script>
