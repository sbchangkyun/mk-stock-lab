            renderMi(mi);
            if (miStartBtn) miStartBtn.textContent = '다시 분석';
          } catch (err) {
            if (seq !== miSeq) return;
            if (err && (err as any).name === 'AbortError') return;
            showMiStatus('네트워크 상태를 확인한 뒤 다시 시도해 주세요.');
            setMiState('error');
            if (miStartBtn) miStartBtn.textContent = '다시 시도';
          } finally {
            window.clearTimeout(timeoutId);
            miInFlight = false;
            if (miStartBtn) miStartBtn.disabled = !integrity.canRunAnalysis();
          }
        };

        if (miStartBtn && productionRealChartEnabled) {
          miStartBtn.addEventListener('click', runMi);
        }
      }


      // Chart analysis workspace page-swap: local class/attribute toggling only, no network/storage.
      const similarityTab = document.getElementById('chartAiSimilarityTab') as HTMLButtonElement | null;
      const mkAiTab = document.getElementById('chartAiMkAiTab') as HTMLButtonElement | null;
      const similarityPanel = document.getElementById('chartAiSimilarityPanel');
      const mkAiPanel = document.getElementById('chartAiMkAiPanel');
      const analysisTabs = [similarityTab, mkAiTab].filter((tab): tab is HTMLButtonElement => tab !== null);

      type ChartAiAnalysisKind = 'similar-pattern' | 'mk-ai';
      type ChartAiAnalysisState =
        | 'idle'
        | 'login_required'
        | 'loading'
        | 'success'
        | 'usage_limited'
        | 'blocked'
        | 'error';
      type ChartAiAnalysisCooldown = {
        cooldownUntil: number | null;
        cooldownRemainingMs: number;
        cooldownTimer: number | null;
        isCooldownActive: boolean;
      };

      // Mocked client-side cooldown UX only. Production protection must be enforced server-side before real KIS/LLM activation.
      const ANALYSIS_COOLDOWN_MS = 5 * 60 * 1000;

      // Mocked client-side auth placeholder only: not production auth, no Supabase client, and no
      // cookie/header/session/JWT parsing. The static page defaults to its existing signed-in look.
      const mockedAnalysisAuth = {
        authenticated: mockedChartAiAccess.capabilities.canAccessChartAi,
        source: 'mocked-client-only' as const,
      };
      const analysisUsagePlaceholder = {
        dailyLimitEnabled: false,
        dailyLimit: null as number | null,
        dailyUsed: null as number | null,
        dailyRemaining: null as number | null,
        usageWindow: 'daily' as const,
        usageResetAt: null as string | null,
        usageDisplay: '오늘 사용 가능 횟수: 베타 기간 제한 없음',
      };
      const analysisStates: Record<ChartAiAnalysisKind, ChartAiAnalysisState> = {
        'similar-pattern': 'idle',
        'mk-ai': 'idle',
      };
      const analysisCooldowns: Record<ChartAiAnalysisKind, ChartAiAnalysisCooldown> = {
        'similar-pattern': {
          cooldownUntil: null,
          cooldownRemainingMs: 0,
          cooldownTimer: null,
          isCooldownActive: false,
        },
        'mk-ai': {
          cooldownUntil: null,
          cooldownRemainingMs: 0,
          cooldownTimer: null,
          isCooldownActive: false,
        },
      };
      let activeAnalysisRun: ChartAiAnalysisKind | null = null;
      let analysisMockedDelayTimer: number | null = null;
      const OWNER_LOCAL_SIMILAR_PATTERN_TIMEOUT_MS = 8000;
      let ownerLocalSimilarPatternRequestInFlight = false;
      let ownerLocalSimilarPatternAbortController: AbortController | null = null;
      let ownerLocalSimilarPatternRunId = 0;

      type OwnerLocalSimilarPatternMatch = {
        rank: number;
        label: string;
        scoreLabel: string;
        forwardReturn5Label: string;
        forwardReturn20Label: string;
        drawdownLabel: string;
      };
      type OwnerLocalSimilarPatternSuccessResponse = {
        ok: true;
        status: 'owner_local_similarity_success';
        mode: 'owner-local-similar-pattern-route';
        data: {
          summary: {
            resultSource: 'synthetic_sample_only';
            matchCount: number;
            currentWindowSize: number;
            scoreLabel: string;
          };
          matches: OwnerLocalSimilarPatternMatch[];
        };
        error: null;
      };
      type OwnerLocalSimilarPatternBlockedResponse = {
        ok: false;
        status: string;
        mode: 'owner-local-similar-pattern-route';
        data: null;
        error: { code: string; message: string };
      };

      const isOwnerLocalSimilarPatternMatch = (value: unknown): value is OwnerLocalSimilarPatternMatch => {
        if (!value || typeof value !== 'object') return false;
        const match = value as Record<string, unknown>;
        return (
          typeof match.rank === 'number' &&
          typeof match.label === 'string' &&
          typeof match.scoreLabel === 'string' &&
          typeof match.forwardReturn5Label === 'string' &&
          typeof match.forwardReturn20Label === 'string' &&
          typeof match.drawdownLabel === 'string'
        );
      };

      const isOwnerLocalSimilarPatternSuccessResponse = (
        value: unknown,
      ): value is OwnerLocalSimilarPatternSuccessResponse => {
        if (!value || typeof value !== 'object') return false;
        const response = value as Record<string, unknown>;
        if (response.ok !== true || response.status !== 'owner_local_similarity_success') return false;
        if (response.mode !== 'owner-local-similar-pattern-route' || response.error !== null) return false;
        if (!response.data || typeof response.data !== 'object') return false;
        const data = response.data as Record<string, unknown>;
        if (!data.summary || typeof data.summary !== 'object' || !Array.isArray(data.matches)) return false;
        const summary = data.summary as Record<string, unknown>;
        return (
          summary.resultSource === 'synthetic_sample_only' &&
          typeof summary.matchCount === 'number' &&
          typeof summary.currentWindowSize === 'number' &&
          typeof summary.scoreLabel === 'string' &&
          data.matches.every(isOwnerLocalSimilarPatternMatch)
        );
      };

      const isOwnerLocalSimilarPatternBlockedResponse = (
        value: unknown,
      ): value is OwnerLocalSimilarPatternBlockedResponse => {
        if (!value || typeof value !== 'object') return false;
        const response = value as Record<string, unknown>;
        if (response.ok !== false || typeof response.status !== 'string') return false;
        if (response.mode !== 'owner-local-similar-pattern-route' || response.data !== null) return false;
        if (!response.error || typeof response.error !== 'object') return false;
        const error = response.error as Record<string, unknown>;
        return typeof error.code === 'string' && typeof error.message === 'string';
      };

      const renderOwnerLocalSimilarPatternSuccess = (response: OwnerLocalSimilarPatternSuccessResponse) => {
        if (ownerLocalSimilarPatternRouteStatus) ownerLocalSimilarPatternRouteStatus.textContent = '합성 샘플 라우트 분석 완료';
        if (!ownerLocalSimilarPatternRouteResult) return;
        ownerLocalSimilarPatternRouteResult.hidden = false;
        ownerLocalSimilarPatternRouteResult.replaceChildren();
        const summary = document.createElement('dl');
        const rows: Array<[string, string]> = [
          ['결과 소스', response.data.summary.resultSource],
          ['매칭 수', String(response.data.summary.matchCount)],
          ['현재 구간', String(response.data.summary.currentWindowSize)],
          ['최상위 점수', response.data.summary.scoreLabel],
        ];
        for (const [label, value] of rows) {
          const term = document.createElement('dt');
          term.textContent = label;
          const detail = document.createElement('dd');
          detail.textContent = value;
          summary.append(term, detail);
        }
        ownerLocalSimilarPatternRouteResult.append(summary);
      };

      const analysisCopy = {
        'similar-pattern': {
          button: '유사 패턴 분석 시작',
          idle: '현재 차트와 유사한 과거 패턴을 분석합니다.',
          login: '로그인 후 유사 패턴 분석을 실행할 수 있습니다.',
          loading: '유사 패턴 분석을 진행 중입니다. 잠시만 기다려주세요.',
          loadingSubtext: '현재 차트 데이터를 기준으로 과거 유사 구간을 탐색하고 있습니다.',
        },
        'mk-ai': {
          button: 'MK AI 분석 시작',
          idle: '차트 흐름과 유사 패턴 결과를 바탕으로 AI 해석을 제공합니다.',
          login: '로그인 후 MK AI 분석을 실행할 수 있습니다.',
          loading: 'MK AI 분석을 생성 중입니다. 잠시만 기다려주세요.',
          loadingSubtext: '차트 흐름과 유사 패턴 결과를 바탕으로 해석을 구성하고 있습니다.',
        },
      } as const;

      const formatAnalysisCooldown = (remainingMs: number) => {
        const remainingSeconds = Math.max(0, Math.ceil(remainingMs / 1000));
        const minutes = Math.floor(remainingSeconds / 60).toString().padStart(2, '0');
        const seconds = (remainingSeconds % 60).toString().padStart(2, '0');
        return `${minutes}:${seconds} 후 다시 분석 가능`;
      };

      const clearAnalysisCooldownTimer = (kind: ChartAiAnalysisKind) => {
        const cooldown = analysisCooldowns[kind];
        if (cooldown.cooldownTimer !== null) window.clearInterval(cooldown.cooldownTimer);
        cooldown.cooldownTimer = null;
      };

      const renderMockedAnalysisState = (kind: ChartAiAnalysisKind) => {
        const state = analysisStates[kind];
        const card = document.querySelector<HTMLElement>(`[data-chart-ai-analysis-state="${kind}"]`);
        const message = document.querySelector<HTMLElement>(`[data-chart-ai-analysis-message="${kind}"]`);
        const subtext = document.querySelector<HTMLElement>(`[data-chart-ai-analysis-subtext="${kind}"]`);
        const usage = document.querySelector<HTMLElement>(`[data-chart-ai-usage-status="${kind}"]`);
        const trigger = document.querySelector<HTMLButtonElement>(`[data-chart-ai-analysis-trigger="${kind}"]`);
        const loading = document.querySelector<HTMLElement>(`[data-chart-ai-analysis-loading="${kind}"]`);
        const result = document.querySelector<HTMLElement>(`[data-chart-ai-analysis-result="${kind}"]`);
        const cooldownStatus = document.querySelector<HTMLElement>(`[data-chart-ai-cooldown="${kind}"]`);
        const cooldownLabel = document.querySelector<HTMLElement>(`[data-chart-ai-cooldown-label="${kind}"]`);
        const cooldownRemaining = document.querySelector<HTMLElement>(`[data-chart-ai-cooldown-remaining="${kind}"]`);
        const cooldownSupport = document.querySelector<HTMLElement>(`[data-chart-ai-cooldown-support="${kind}"]`);
        if (!card || !message || !subtext || !usage || !trigger || !loading || !result || !cooldownStatus || !cooldownLabel || !cooldownRemaining || !cooldownSupport) return;

        const cooldown = analysisCooldowns[kind];
        const showCooldownStatus = state === 'success';

        card.dataset.state = state;
        card.dataset.cooldownActive = String(cooldown.isCooldownActive);
        card.setAttribute('aria-busy', String(state === 'loading'));
        result.hidden = state !== 'success';
        loading.hidden = state !== 'loading';
        loading.setAttribute('aria-hidden', String(state !== 'loading'));
        cooldownStatus.hidden = !showCooldownStatus;
        cooldownLabel.textContent = cooldown.isCooldownActive ? '다시 분석 가능까지' : '다시 분석할 수 있습니다.';
        cooldownRemaining.hidden = !cooldown.isCooldownActive;
        cooldownRemaining.textContent = formatAnalysisCooldown(cooldown.cooldownRemainingMs);
        cooldownSupport.hidden = !cooldown.isCooldownActive;
        usage.textContent = analysisUsagePlaceholder.usageDisplay;
        trigger.disabled = state === 'loading' || activeAnalysisRun !== null || cooldown.isCooldownActive;
        trigger.textContent = cooldown.isCooldownActive
          ? '재분석 대기 중'
          : state === 'loading'
            ? '분석 중'
            : analysisCopy[kind].button;

        if (state === 'idle') {
          message.textContent = analysisCopy[kind].idle;
          subtext.textContent = analysisCopy[kind].login;
        } else if (state === 'login_required') {
          message.textContent = analysisCopy[kind].login;
          subtext.textContent = '로그인 상태를 확인한 뒤 다시 실행해 주세요.';
        } else if (state === 'loading') {
          message.textContent = analysisCopy[kind].loading;
          subtext.textContent = analysisCopy[kind].loadingSubtext;
        } else if (state === 'success') {
          message.textContent = '분석이 완료되었습니다. 아래 결과를 확인해 주세요.';
          subtext.textContent = '표시된 내용은 샘플·모의 분석이며 투자 조언이 아닙니다.';
        } else if (state === 'usage_limited') {
          message.textContent = '오늘 사용할 수 있는 분석 횟수를 모두 사용했습니다.';
          subtext.textContent = '사용 횟수 제한은 향후 계정 정책 적용 시 활성화됩니다.';
        } else if (state === 'blocked') {
          message.textContent = kind === 'mk-ai'
            ? '먼저 유사 패턴 분석을 실행하면 MK AI 분석을 사용할 수 있습니다.'
            : '현재 분석을 실행할 수 없습니다.';
          subtext.textContent = '필요한 단계를 확인한 뒤 다시 시도해 주세요.';
        } else {
          message.textContent = '분석을 완료하지 못했습니다.';
          subtext.textContent = '잠시 후 다시 실행해 주세요.';
        }
      };

      const renderAllMockedAnalysisStates = () => {
        renderMockedAnalysisState('similar-pattern');
        renderMockedAnalysisState('mk-ai');
      };

      const updateAnalysisCooldown = (kind: ChartAiAnalysisKind) => {
        const cooldown = analysisCooldowns[kind];
        cooldown.cooldownRemainingMs = Math.max(0, (cooldown.cooldownUntil ?? 0) - Date.now());
        if (cooldown.cooldownRemainingMs === 0) {
          cooldown.cooldownUntil = null;
          cooldown.isCooldownActive = false;
          clearAnalysisCooldownTimer(kind);
        }
        renderMockedAnalysisState(kind);
      };

      const startAnalysisCooldown = (kind: ChartAiAnalysisKind) => {
        const cooldown = analysisCooldowns[kind];
        clearAnalysisCooldownTimer(kind);
        cooldown.cooldownUntil = Date.now() + ANALYSIS_COOLDOWN_MS;
        cooldown.cooldownRemainingMs = ANALYSIS_COOLDOWN_MS;
        cooldown.isCooldownActive = true;
        cooldown.cooldownTimer = window.setInterval(() => updateAnalysisCooldown(kind), 1000);
        renderMockedAnalysisState(kind);
      };

      const runMockedAnalysisTrigger = (kind: ChartAiAnalysisKind) => {
        // Duplicate and simultaneous run prevention for this mocked-only trigger flow.
        if (activeAnalysisRun !== null || analysisStates[kind] === 'loading' || analysisCooldowns[kind].isCooldownActive) return;
        if (!mockedAnalysisAuth.authenticated || !mockedChartAiAccess.capabilities.canAccessChartAi) {
          analysisStates[kind] = 'login_required';
          renderAllMockedAnalysisStates();
          return;
        }
        if (kind === 'similar-pattern' && !mockedChartAiAccess.capabilities.canRunSimilarPattern) return;
        if (kind === 'mk-ai' && !mockedChartAiAccess.capabilities.canRunMkAi) return;
        if (kind === 'mk-ai' && analysisStates['similar-pattern'] !== 'success') {
          analysisStates[kind] = 'blocked';
          renderAllMockedAnalysisStates();
          return;
        }
        if (analysisUsagePlaceholder.dailyLimitEnabled && analysisUsagePlaceholder.dailyRemaining === 0) {
          analysisStates[kind] = 'usage_limited';
          renderAllMockedAnalysisStates();
          return;
        }

        activeAnalysisRun = kind;
        analysisStates[kind] = 'loading';
        renderAllMockedAnalysisStates();
        analysisMockedDelayTimer = window.setTimeout(() => {
          analysisStates[kind] = 'success';
          activeAnalysisRun = null;
          analysisMockedDelayTimer = null;
          if (mockedChartAiAccess.capabilities.canBypassAnalysisCooldown) {
            clearAnalysisCooldownTimer(kind);
            analysisCooldowns[kind].cooldownUntil = null;
            analysisCooldowns[kind].cooldownRemainingMs = 0;
            analysisCooldowns[kind].isCooldownActive = false;
          } else {
            startAnalysisCooldown(kind);
          }
          renderAllMockedAnalysisStates();
        }, 900);
      };

      const runOwnerLocalSimilarPatternRoute = async () => {
        const kind: ChartAiAnalysisKind = 'similar-pattern';
        if (
          ownerLocalSimilarPatternRequestInFlight ||
          activeAnalysisRun !== null ||
          analysisStates[kind] === 'loading' ||
          analysisCooldowns[kind].isCooldownActive
        ) return;
        if (!mockedAnalysisAuth.authenticated || !mockedChartAiAccess.capabilities.canRunSimilarPattern) {
          analysisStates[kind] = 'login_required';
          renderAllMockedAnalysisStates();
          return;
        }

        ownerLocalSimilarPatternRequestInFlight = true;
        activeAnalysisRun = kind;
        analysisStates[kind] = 'loading';
        if (ownerLocalSimilarPatternRouteStatus) ownerLocalSimilarPatternRouteStatus.textContent = '라우트 분석 요청 중';
        if (ownerLocalSimilarPatternRouteResult) {
          ownerLocalSimilarPatternRouteResult.hidden = true;
          ownerLocalSimilarPatternRouteResult.replaceChildren();
        }
        renderAllMockedAnalysisStates();

        const runId = ++ownerLocalSimilarPatternRunId;
        const abortController = new AbortController();
        ownerLocalSimilarPatternAbortController = abortController;
        const timeoutId = window.setTimeout(
          () => abortController.abort(),
          OWNER_LOCAL_SIMILAR_PATTERN_TIMEOUT_MS,
        );

        try {
          const response = await fetch('/api/chart-ai/similarity', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              mode: 'guarded-runtime-scaffold',
              source: 'mocked-provider-compatible',
              guardedRuntimeScaffold: true,
              ownerLocalSimilarPatternRouteActivation: true,
              requestKind: 'similar_pattern',
              subjectRole: mockedChartAiAccess.role,
            }),
            signal: abortController.signal,
          });
          const parsedResponse: unknown = await response.json();
          if (runId !== ownerLocalSimilarPatternRunId) return;

          if (isOwnerLocalSimilarPatternSuccessResponse(parsedResponse)) {
            renderOwnerLocalSimilarPatternSuccess(parsedResponse);
            analysisStates[kind] = 'success';
            activeAnalysisRun = null;
            if (mockedChartAiAccess.capabilities.canBypassAnalysisCooldown) {
              clearAnalysisCooldownTimer(kind);
              analysisCooldowns[kind].cooldownUntil = null;
              analysisCooldowns[kind].cooldownRemainingMs = 0;
              analysisCooldowns[kind].isCooldownActive = false;
            } else {
              startAnalysisCooldown(kind);
            }
          } else if (isOwnerLocalSimilarPatternBlockedResponse(parsedResponse)) {
            analysisStates[kind] = parsedResponse.status === 'blocked_usage_limited'
              ? 'usage_limited'
              : 'blocked';
            if (ownerLocalSimilarPatternRouteStatus) ownerLocalSimilarPatternRouteStatus.textContent = '안전 차단됨';
          } else {
            analysisStates[kind] = 'error';
            if (ownerLocalSimilarPatternRouteStatus) ownerLocalSimilarPatternRouteStatus.textContent = '응답 검증 실패';
          }
        } catch {
          if (runId !== ownerLocalSimilarPatternRunId) return;
          analysisStates[kind] = 'error';
          if (ownerLocalSimilarPatternRouteStatus) ownerLocalSimilarPatternRouteStatus.textContent = '요청 실패 또는 시간 초과';
        } finally {
          window.clearTimeout(timeoutId);
          if (runId === ownerLocalSimilarPatternRunId) {
            ownerLocalSimilarPatternAbortController = null;
            ownerLocalSimilarPatternRequestInFlight = false;
            activeAnalysisRun = null;
            renderAllMockedAnalysisStates();
          }
        }
      };

      document.querySelectorAll<HTMLButtonElement>('[data-chart-ai-analysis-trigger]').forEach((button) => {
        button.addEventListener('click', () => {
          const kind = button.dataset.chartAiAnalysisTrigger;
          if (kind === 'similar-pattern' && ownerLocalSimilarPatternRouteEnabled) {
            void runOwnerLocalSimilarPatternRoute();
          } else if (kind === 'similar-pattern' || kind === 'mk-ai') {
            runMockedAnalysisTrigger(kind);
          }
        });
      });

      resetAnalysisTriggers = () => {
        if (analysisMockedDelayTimer !== null) window.clearTimeout(analysisMockedDelayTimer);
        analysisMockedDelayTimer = null;
        ownerLocalSimilarPatternRunId += 1;
        ownerLocalSimilarPatternAbortController?.abort();
        ownerLocalSimilarPatternAbortController = null;
        ownerLocalSimilarPatternRequestInFlight = false;
        if (ownerLocalSimilarPatternRouteStatus) ownerLocalSimilarPatternRouteStatus.textContent = '실행 대기';
        if (ownerLocalSimilarPatternRouteResult) {
          ownerLocalSimilarPatternRouteResult.hidden = true;
          ownerLocalSimilarPatternRouteResult.replaceChildren();
        }
        activeAnalysisRun = null;
        (['similar-pattern', 'mk-ai'] as const).forEach((kind) => {
          clearAnalysisCooldownTimer(kind);
          analysisCooldowns[kind].cooldownUntil = null;
          analysisCooldowns[kind].cooldownRemainingMs = 0;
          analysisCooldowns[kind].isCooldownActive = false;
        });
        analysisStates['similar-pattern'] = 'idle';
        analysisStates['mk-ai'] = 'idle';
        renderAllMockedAnalysisStates();
      };
      window.addEventListener('pagehide', () => {
        ownerLocalSimilarPatternAbortController?.abort();
        clearAnalysisCooldownTimer('similar-pattern');
        clearAnalysisCooldownTimer('mk-ai');
      });
      window.addEventListener('pageshow', () => {
        (['similar-pattern', 'mk-ai'] as const).forEach((kind) => {
          if (!analysisCooldowns[kind].isCooldownActive) return;
          updateAnalysisCooldown(kind);
          if (analysisCooldowns[kind].isCooldownActive && analysisCooldowns[kind].cooldownTimer === null) {
            analysisCooldowns[kind].cooldownTimer = window.setInterval(() => updateAnalysisCooldown(kind), 1000);
          }
        });
      });
      renderAllMockedAnalysisStates();

      const activateAnalysisTab = (tab: 'similarity' | 'mk-ai', options: { focusTab?: boolean } = {}) => {
        const isSimilarity = tab === 'similarity';
        similarityTab?.classList.toggle('active', isSimilarity);
        mkAiTab?.classList.toggle('active', !isSimilarity);
        similarityTab?.setAttribute('aria-selected', String(isSimilarity));
        mkAiTab?.setAttribute('aria-selected', String(!isSimilarity));
        similarityTab?.setAttribute('tabindex', isSimilarity ? '0' : '-1');
        mkAiTab?.setAttribute('tabindex', !isSimilarity ? '0' : '-1');
        similarityPanel?.classList.toggle('active', isSimilarity);
        mkAiPanel?.classList.toggle('active', !isSimilarity);
        if (similarityPanel) similarityPanel.hidden = !isSimilarity;
        if (mkAiPanel) mkAiPanel.hidden = isSimilarity;
        if (options.focusTab) {
          (isSimilarity ? similarityTab : mkAiTab)?.focus();
        }
      };

      similarityTab?.addEventListener('click', () => activateAnalysisTab('similarity'));
      mkAiTab?.addEventListener('click', () => activateAnalysisTab('mk-ai'));

      const analysisTagKeyToTarget: Record<string, 'similarity' | 'mk-ai'> = {
        Home: 'similarity',
        End: 'mk-ai',
      };

      analysisTabs.forEach((tab) => {
        tab.addEventListener('keydown', (event) => {
          if (event.key === 'ArrowLeft' || event.key === 'ArrowRight') {
            event.preventDefault();
            const currentIsSimilarity = tab === similarityTab;
            activateAnalysisTab(currentIsSimilarity ? 'mk-ai' : 'similarity', { focusTab: true });
            return;
          }
          const homeEndTarget = analysisTagKeyToTarget[event.key];
          if (homeEndTarget) {
            event.preventDefault();
            activateAnalysisTab(homeEndTarget, { focusTab: true });
          }
        });
      });

      // Owner-local KIS quote preview. Gated: never auto-fetches, and only fetches the gated
      // owner-local preview route when the page URL carries source=owner-local.
      const previewBtn = document.getElementById('chartAiQuotePreviewBtn') as HTMLButtonElement | null;
      const previewResult = document.getElementById('chartAiQuotePreviewResult');
      const previewEyebrow = document.getElementById('chartAiQuotePreviewEyebrow');
      const previewGuide = document.getElementById('chartAiQuotePreviewGuide');
      const ownerLocalPreview = new URLSearchParams(window.location.search).get('source') === 'owner-local';

      if (previewEyebrow && previewGuide) {
        if (ownerLocalPreview) {
          previewEyebrow.textContent = '오너 로컬 KIS 연결 모드';
          previewGuide.textContent = '오너 로컬 환경에서 KIS 연결 프리뷰를 사용할 수 있습니다. 버튼을 눌러 지연 시세와 OHLC를 확인하세요.';
        } else {
          previewEyebrow.textContent = '오너 로컬 전용';
          previewGuide.textContent = '공개 화면은 샘플 모드입니다. KIS 연결 프리뷰는 오너 로컬 환경에서만 사용할 수 있습니다.';
        }
      }
      updateOverviewDataStatus();
      updateMkAiPanel();

      resetQuotePreview = () => {
        if (previewResult) {
          previewResult.hidden = true;
          previewResult.replaceChildren();
        }
      };

      const formatNumber = (value: number | null): string =>
        typeof value === 'number' ? value.toLocaleString('ko-KR') : '—';

      const showPreviewMessage = (text: string, detail?: string) => {
        if (!previewResult) return;
        previewResult.hidden = false;
        previewResult.replaceChildren();
        const message = document.createElement('p');
        message.className = 'chart-quote-preview-msg';
        message.textContent = text;
        previewResult.append(message);
        if (detail) {
          const small = document.createElement('small');
          small.textContent = detail;
          previewResult.append(small);
        }
      };

      const renderPreview = (data: {
        status?: string;
        providerStatus?: string;
        quote?: {
          lastPrice: number | null; previousClose: number | null; change: number | null;
          changeRate: number | null; volume: number | null; asOf: string | null; currency: string;
        } | null;
      }) => {
        if (!previewResult) return;
        if (data.status === 'ok' && data.quote) {
          ownerLocalConnected = true;
          updateOverviewDataStatus();
          updateMkAiPanel();
          const quote = data.quote;
          previewResult.hidden = false;
          previewResult.replaceChildren();
          const rows: Array<[string, string]> = [
            ['현재가', formatNumber(quote.lastPrice)],
            ['전일종가', formatNumber(quote.previousClose)],
            ['전일대비', formatNumber(quote.change)],
            ['등락률', typeof quote.changeRate === 'number' ? `${quote.changeRate}%` : '—'],
            ['거래량', formatNumber(quote.volume)],
            ['기준시각', quote.asOf ?? '—'],
          ];
          const list = document.createElement('dl');
          list.className = 'chart-quote-preview-dl';
          for (const [label, value] of rows) {
            const term = document.createElement('dt');
            term.textContent = label;
            const detail = document.createElement('dd');
            detail.textContent = value;
            list.append(term, detail);
          }
          const tag = document.createElement('p');
          tag.className = 'chart-quote-preview-tag';
          tag.textContent = `지연 시세 · 오너 로컬 전용 · ${quote.currency ?? 'KRW'}`;
          previewResult.append(list, tag);
        } else if (data.status === 'unavailable' || data.status === 'error') {
          showPreviewMessage('현재 KIS 데이터를 불러오지 못했습니다. 샘플 데이터로 계속 표시합니다.');
        } else {
          showPreviewMessage('오너 로컬 환경에서만 KIS 연결 프리뷰를 사용할 수 있습니다.');
        }
      };

      if (previewBtn) {
        if (ownerLocalPreview) {
          previewBtn.disabled = false;
          previewBtn.addEventListener('click', async () => {
            if (selectedAssetType !== 'stock' && selectedAssetType !== 'etf') {
              showPreviewMessage('해당 종목 유형은 아직 프리뷰가 지원되지 않습니다.');
              return;
            }
            previewBtn.disabled = true;
            const previousLabel = previewBtn.textContent;
            previewBtn.textContent = '불러오는 중…';
            try {
              const params = new URLSearchParams({
                symbol: selectedSymbol,
                market: 'KR',
                assetType: selectedAssetType,
                source: 'owner-local',
                preview: 'quote',
              });
              const response = await fetch(`/api/chart-ai/owner-local-quote-preview?${params.toString()}`, {
                headers: { accept: 'application/json' },
              });
              const data = await response.json();
              renderPreview(data);
            } catch {
              showPreviewMessage('현재 KIS 데이터를 불러오지 못했습니다. 샘플 데이터로 계속 표시합니다.');
            } finally {
              previewBtn.disabled = false;
              previewBtn.textContent = previousLabel ?? 'KIS 시세 프리뷰 확인';
            }
          });
        } else {
          previewBtn.disabled = true;
        }
      }

      // Owner-local KIS OHLC preview. Gated: never auto-fetches, and only fetches the gated
      // owner-local OHLC preview route when the page URL carries source=owner-local. On any
      // blocked/unavailable/malformed/insufficient response, falls back to the sample chart with
      // a safe Korean message — never a raw error, provider payload, or stack trace.
      const ohlcPreviewBtn = document.getElementById('chartAiOhlcPreviewBtn') as HTMLButtonElement | null;
      const ohlcPreviewTag = document.getElementById('chartAiOhlcPreviewTag');
      const ohlcPreviewMessage = document.getElementById('chartAiOhlcPreviewMessage');
      const ownerLocalOhlcPreview = new URLSearchParams(window.location.search).get('source') === 'owner-local';

      const showOhlcPreviewMessage = (text: string) => {
        if (!ohlcPreviewMessage) return;
        ohlcPreviewMessage.hidden = false;
        ohlcPreviewMessage.textContent = text;
      };

      const clearOhlcPreviewMessage = () => {
        if (!ohlcPreviewMessage) return;
        ohlcPreviewMessage.hidden = true;
        ohlcPreviewMessage.textContent = '';
      };

      resetOhlcPreview = () => {
        if (ohlcPreviewTag) ohlcPreviewTag.hidden = true;
        clearOhlcPreviewMessage();
      };

      const fallbackToSampleChart = (message: string) => {
        resetOhlcPreview();
        showOhlcPreviewMessage(message);
        renderChart();
      };

      if (ohlcPreviewBtn) {
        if (ownerLocalOhlcPreview) {
          ohlcPreviewBtn.disabled = false;
          ohlcPreviewBtn.addEventListener('click', async () => {
            if (selectedAssetType !== 'stock' && selectedAssetType !== 'etf') {
              fallbackToSampleChart('오너 로컬 환경에서만 KIS 연결 프리뷰를 사용할 수 있습니다.');
              return;
            }
            ohlcPreviewBtn.disabled = true;
            const previousLabel = ohlcPreviewBtn.textContent;
            ohlcPreviewBtn.textContent = '불러오는 중…';
            try {
              const params = new URLSearchParams({
                symbol: selectedSymbol,
                market: 'KR',
                assetType: selectedAssetType,
                period: activePeriod,
                source: 'owner-local',
                preview: 'ohlc',
              });
              const response = await fetch(`/api/chart-ai/owner-local-ohlc-preview?${params.toString()}`, {
                headers: { accept: 'application/json' },
              });
              const data = await response.json();
              if (data?.status === 'ok' && data?.renderable && Array.isArray(data?.points) && data.points.length > 0) {
                const rendered = renderOhlcChart(data.points as OwnerLocalOhlcPreviewPoint[]);
                if (rendered) {
                  ownerLocalConnected = true;
                  updateOverviewDataStatus();
                  updateMkAiPanel();
                  setChartStatus('지연 시세 · KIS OHLC · KRW', '오너 로컬 전용');
                  showOhlcPreviewMessage('KIS OHLC 차트가 반영되었습니다.');
                  if (ohlcPreviewTag) ohlcPreviewTag.hidden = false;
                } else {
                  fallbackToSampleChart('KIS 응답을 차트에 표시할 수 없어 샘플 차트를 유지합니다.');
                }
              } else if (data?.status === 'blocked') {
                fallbackToSampleChart('오너 로컬 환경에서만 KIS 연결 프리뷰를 사용할 수 있습니다.');
              } else {
                fallbackToSampleChart('현재 KIS 데이터를 불러오지 못했습니다. 샘플 데이터로 계속 표시합니다.');
              }
            } catch {
              fallbackToSampleChart('현재 KIS 데이터를 불러오지 못했습니다. 샘플 데이터로 계속 표시합니다.');
            } finally {
              ohlcPreviewBtn.disabled = false;
              ohlcPreviewBtn.textContent = previousLabel ?? 'KIS 차트 프리뷰 확인';
            }
          });
        } else {
          ohlcPreviewBtn.disabled = true;
        }
      }

      // Owner-local mocked similarity API execution panel (Phase 3FB-C, hardened in 3FB-D).
      // Local-only, explicit opt-in: hidden unless hostname is localhost/127.0.0.1/::1 AND the
      // URL carries `?ownerLocalMocked=1`. Never auto-runs; the API call only happens on
      // explicit click. Calls the owner-local mocked branch of `/api/chart-ai/similarity`
      // (Phase 3FB-B) and renders only sanitized, bucketed fields — never raw provider payload,
      // OHLC values, prices, volume, real timestamps, raw matches, similarity scores, returns,
      // or raw response/error data. Phase 3FB-D adds: a response shape guard, an 8s request
      // timeout via AbortController, repeated-click prevention, and aria-busy loading /
      // retry-ready state handling.
      const ownerLocalMockedPanel = document.getElementById('chartAiOwnerLocalMockedPanel');
      const ownerLocalMockedRunBtn = document.getElementById('chartAiOwnerLocalMockedRunBtn') as HTMLButtonElement | null;
      const ownerLocalMockedResult = document.getElementById('chartAiOwnerLocalMockedResult');
      if (ownerLocalMockedResult) ownerLocalMockedResult.tabIndex = -1;

      const ownerLocalMockedOptIn = new URLSearchParams(window.location.search).get('ownerLocalMocked') === '1';
      const ownerLocalMockedEnabled = mockedChartAiAccess.capabilities.canAccessChartAi && isLocalOwnerHostname() && ownerLocalMockedOptIn;

      if (ownerLocalMockedPanel) ownerLocalMockedPanel.hidden = !ownerLocalMockedEnabled;

      const OWNER_LOCAL_MOCKED_TIMEOUT_MS = 8000;
      let ownerLocalMockedRequestInFlight = false;

      const showOwnerLocalMockedMessage = (text: string) => {
        if (!ownerLocalMockedResult) return;
        ownerLocalMockedResult.hidden = false;
        ownerLocalMockedResult.replaceChildren();
        const message = document.createElement('p');
        message.className = 'chart-owner-local-mocked-msg';
        message.textContent = text;
        ownerLocalMockedResult.append(message);
      };

      // Response shape guard (Phase 3FB-D): validates the parsed body is exactly the sanitized
      // owner-local mocked success shape before anything is rendered. Any missing or
      // wrong-typed field falls through to the safe static error path below — never a partial
      // or best-effort render of an unvalidated response.
      type OwnerLocalMockedSuccessResponse = {
        status: string;
        mode: string;
        request: { source: string };
        data: {
          engineStatus: string;
          normalizedBarsAvailable: boolean;
          normalizedBarCountBucket: string;
          matchCountBucket: string;
          disclaimer: string;
          dataPolicy: {
            ownerLocalOnly?: boolean;
            allowLiveKis?: boolean;
            allowRouteSuccess?: boolean;
            allowPublicExecution?: boolean;
            allowBetaExecution?: boolean;
          };
        };
      };

      const isOwnerLocalMockedSuccessResponse = (value: unknown): value is OwnerLocalMockedSuccessResponse => {
        if (!value || typeof value !== 'object') return false;
        const record = value as Record<string, unknown>;
        if (record.ok !== true) return false;
        if (record.status !== 'success') return false;
        if (record.mode !== 'owner-local-mocked') return false;
        const request = record.request;
        if (!request || typeof request !== 'object') return false;
        if ((request as Record<string, unknown>).source !== 'mocked-provider-compatible') return false;
        const data = record.data;
        if (!data || typeof data !== 'object') return false;
        const resultData = data as Record<string, unknown>;
        if (typeof resultData.engineStatus !== 'string') return false;
        if (typeof resultData.normalizedBarsAvailable !== 'boolean') return false;
        if (typeof resultData.normalizedBarCountBucket !== 'string') return false;
        if (typeof resultData.matchCountBucket !== 'string') return false;
        if (!resultData.dataPolicy || typeof resultData.dataPolicy !== 'object') return false;
        if (typeof resultData.disclaimer !== 'string') return false;
        return true;
      };

      const renderOwnerLocalMockedSuccess = (data: OwnerLocalMockedSuccessResponse) => {
        if (!ownerLocalMockedResult) return;
        const resultData = data.data;
        ownerLocalMockedResult.hidden = false;
        ownerLocalMockedResult.replaceChildren();

        const summaryList = document.createElement('dl');
        summaryList.className = 'chart-owner-local-mocked-dl';
        const summaryRows: Array<[string, string]> = [
          ['상태', data.status ?? '-'],
          ['모드', data.mode ?? '-'],
          ['데이터 소스', data.request?.source ?? '-'],
          ['엔진 상태', resultData.engineStatus ?? '-'],
          ['정규화 데이터 여부', resultData.normalizedBarsAvailable ? '있음' : '없음'],
          ['정규화 구간 버킷', resultData.normalizedBarCountBucket ?? '-'],
          ['매칭 구간 버킷', resultData.matchCountBucket ?? '-'],
        ];
        for (const [label, value] of summaryRows) {
          const dt = document.createElement('dt');
          dt.textContent = label;
          const dd = document.createElement('dd');
          dd.textContent = value;
          summaryList.append(dt, dd);
        }
        ownerLocalMockedResult.append(summaryList);

        if (resultData.dataPolicy) {
          const policy = resultData.dataPolicy;
          const policyList = document.createElement('ul');
          policyList.className = 'chart-owner-local-mocked-policy-list';
          const policyRows: Array<[string, boolean | undefined]> = [
            ['오너 로컬 전용', policy.ownerLocalOnly],
            ['실시간 KIS 허용', policy.allowLiveKis],
            ['라우트 성공 허용', policy.allowRouteSuccess],
            ['공개 실행 허용', policy.allowPublicExecution],
            ['베타 실행 허용', policy.allowBetaExecution],
          ];
          for (const [label, value] of policyRows) {
            const li = document.createElement('li');
            li.textContent = `${label}: ${value ? '예' : '아니오'}`;
            policyList.append(li);
          }
          ownerLocalMockedResult.append(policyList);
        }

        if (resultData.disclaimer) {
          const disclaimer = document.createElement('p');
          disclaimer.className = 'chart-owner-local-mocked-disclaimer';
          disclaimer.textContent = resultData.disclaimer;
          ownerLocalMockedResult.append(disclaimer);
        }
      };

      if (ownerLocalMockedRunBtn && ownerLocalMockedEnabled) {
        ownerLocalMockedRunBtn.addEventListener('click', async () => {
          if (ownerLocalMockedRequestInFlight) return;
          ownerLocalMockedRequestInFlight = true;
          ownerLocalMockedRunBtn.disabled = true;
          if (ownerLocalMockedResult) ownerLocalMockedResult.setAttribute('aria-busy', 'true');
          showOwnerLocalMockedMessage('불러오는 중… (mocked/sample 데이터, 로컬 개발 검증용)');

          const abortController = new AbortController();
          const timeoutId = window.setTimeout(() => abortController.abort(), OWNER_LOCAL_MOCKED_TIMEOUT_MS);

          try {
            const response = await fetch('/api/chart-ai/similarity', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                mode: 'owner-local-mocked',
                source: 'mocked-provider-compatible',
                ownerLocalMocked: true,
                symbol: selectedSymbol || 'MOCKSYM',
              }),
              signal: abortController.signal,
            });
            let parsedResponse: unknown = null;
            try {
              parsedResponse = await response.json();
            } catch {
              parsedResponse = null;
            }
            if (isOwnerLocalMockedSuccessResponse(parsedResponse)) {
              renderOwnerLocalMockedSuccess(parsedResponse);
            } else {
              showOwnerLocalMockedMessage('Owner-local mocked 실행 결과를 불러오지 못했습니다. (기본 화면은 기능 비활성화 상태이며, 실제 KIS 데이터가 아닙니다.) 다시 실행 버튼으로 재시도해 주세요.');
            }
          } catch (thrownError) {
            if (thrownError instanceof DOMException && thrownError.name === 'AbortError') {
              showOwnerLocalMockedMessage('요청 시간이 초과되었습니다. 다시 실행 버튼으로 재시도해 주세요.');
            } else {
              showOwnerLocalMockedMessage('Owner-local mocked 실행 결과를 불러오지 못했습니다. 다시 실행 버튼으로 재시도해 주세요.');
            }
          } finally {
            window.clearTimeout(timeoutId);
            ownerLocalMockedRequestInFlight = false;
            ownerLocalMockedRunBtn.disabled = false;
            ownerLocalMockedRunBtn.textContent = '다시 실행';
            if (ownerLocalMockedResult) ownerLocalMockedResult.removeAttribute('aria-busy');
          }
        });
      }

      // Owner-local KIS current_price -> Chart AI context execution panel (Phase
      // 3GG-E-INTEGRATE). Local-only, explicit opt-in: hidden unless hostname is
      // localhost/127.0.0.1/::1 AND the URL carries `?ownerLocalKisIntegration=1`. Never
      // auto-runs; the request only happens on an explicit click, to
      // `/api/chart-ai/local-only-kis-current-price.json?ownerLocalKisIntegration=1`, which
      // itself fails closed unless local-only + opt-in + the Phase 3GG-D-FAST live-KIS gate
      // all allow it. Renders only sanitized Chart AI context fields -- never raw provider
      // payload, credential flags, headers, account/order/balance data, or investment advice.
      const ownerLocalKisIntegrationRunBtn = document.getElementById(
        'chartAiOwnerLocalKisIntegrationRunBtn',
      ) as HTMLButtonElement | null;
      const ownerLocalKisIntegrationResult = document.getElementById('chartAiOwnerLocalKisIntegrationResult');
      if (ownerLocalKisIntegrationResult) ownerLocalKisIntegrationResult.tabIndex = -1;

      const OWNER_LOCAL_KIS_INTEGRATION_TIMEOUT_MS = 8000;
      let ownerLocalKisIntegrationRequestInFlight = false;

      // Phase 3GG-F-FAST: readable state variants (loading / unavailable) for the message
      // element -- text + class only, no additional data ever attached.
      const showOwnerLocalKisIntegrationMessage = (
        text: string,
        variant: 'loading' | 'unavailable' = 'unavailable',
      ) => {
        if (!ownerLocalKisIntegrationResult) return;
        ownerLocalKisIntegrationResult.hidden = false;
        ownerLocalKisIntegrationResult.replaceChildren();
        const message = document.createElement('p');
        message.className = `chart-owner-local-kis-integration-msg chart-owner-local-kis-integration-msg-${variant}`;
        message.textContent = text;
        ownerLocalKisIntegrationResult.append(message);
      };

      // Phase 3GG-F-FAST: friendly Korean text per sanitized error code (never the raw
      // provider payload or an internal error trace). Falls back to a generic fail-closed
      // message for any unrecognized code.
      const OWNER_LOCAL_KIS_INTEGRATION_ERROR_MESSAGES: Record<string, string> = {
        NON_LOCAL_REQUEST: '로컬 전용 접근 조건이 충족되지 않았습니다.',
        MISSING_CREDENTIAL: '로컬 환경에 KIS 자격 증명이 설정되어 있지 않습니다.',
        ENDPOINT_NOT_ALLOWLISTED: '허용되지 않은 요청입니다.',
        ENDPOINT_FORBIDDEN: '허용되지 않은 요청입니다.',
        INVALID_SYMBOL: '종목코드가 올바르지 않습니다.',
        RATE_LIMITED: '요청 횟수 제한을 초과했습니다. 잠시 후 다시 시도해 주세요.',
        PROVIDER_TIMEOUT: '응답 시간이 초과되었습니다. 다시 실행 버튼으로 재시도해 주세요.',
        PROVIDER_UNAVAILABLE: '실시간 KIS 연동이 꺼져 있어 사용할 수 없습니다.',
        MALFORMED_RESPONSE: '응답 형식이 올바르지 않아 표시할 수 없습니다.',
      };

      const describeOwnerLocalKisIntegrationUnavailable = (
        code: string | null,
        sourceStatus: string,
      ): string => {
        if (code && OWNER_LOCAL_KIS_INTEGRATION_ERROR_MESSAGES[code]) {
          return OWNER_LOCAL_KIS_INTEGRATION_ERROR_MESSAGES[code];
        }
        return `사용할 수 없음 (${sourceStatus}). 로컬 전용 조건 또는 실시간 KIS 연동 설정을 확인해 주세요.`;
      };

      const formatOwnerLocalKisIntegrationNumber = (value: number | null): string =>
        value !== null && Number.isFinite(value) ? value.toLocaleString('ko-KR') : '-';

      type OwnerLocalKisIntegrationContext = {
        symbol: string | null;
        market: string | null;
        currentPrice: number | null;
        volume: number | null;
        timestamp: string | number | null;
        sourceStatus: string;
        cacheStatus: string;
        sanitizedErrorCode: string | null;
        warnings: string[];
      };

      // Response shape guard: validates the parsed body is exactly the sanitized Chart AI KIS
      // context shape before anything is rendered. Any missing or wrong-typed field falls
      // through to the safe static error path below -- never a partial/best-effort render.
      const isOwnerLocalKisIntegrationResponse = (
        value: unknown,
      ): value is { ok: true; context: OwnerLocalKisIntegrationContext } => {
        if (!value || typeof value !== 'object') return false;
        const record = value as Record<string, unknown>;
        if (record.ok !== true) return false;
        const context = record.context;
        if (!context || typeof context !== 'object') return false;
        const c = context as Record<string, unknown>;
        if (typeof c.sourceStatus !== 'string') return false;
        if (typeof c.cacheStatus !== 'string') return false;
        if (!Array.isArray(c.warnings)) return false;
        return true;
      };

      const renderOwnerLocalKisIntegrationResult = (context: OwnerLocalKisIntegrationContext) => {
        if (!ownerLocalKisIntegrationResult) return;
        ownerLocalKisIntegrationResult.hidden = false;
        ownerLocalKisIntegrationResult.replaceChildren();

        if (context.sourceStatus !== 'ok') {
          showOwnerLocalKisIntegrationMessage(
            describeOwnerLocalKisIntegrationUnavailable(context.sanitizedErrorCode, context.sourceStatus),
            'unavailable',
          );
          return;
        }

        const summaryList = document.createElement('dl');
        summaryList.className = 'chart-owner-local-kis-integration-dl';
        const summaryRows: Array<[string, string]> = [
          ['종목', context.symbol ?? '-'],
          ['시장', context.market ?? '-'],
          [
            '현재가',
            context.currentPrice !== null ? `${formatOwnerLocalKisIntegrationNumber(context.currentPrice)}원` : '-',
          ],
          ['거래량', context.volume !== null ? `${formatOwnerLocalKisIntegrationNumber(context.volume)}주` : '-'],
          ['기준 시각', context.timestamp !== null ? String(context.timestamp) : '-'],
          ['소스 상태', context.sourceStatus],
          ['캐시 상태', context.cacheStatus],
        ];
        for (const [label, value] of summaryRows) {
          const dt = document.createElement('dt');
          dt.textContent = label;
          const dd = document.createElement('dd');
          dd.textContent = value;
          summaryList.append(dt, dd);
        }
        ownerLocalKisIntegrationResult.append(summaryList);

        if (context.warnings.length > 0) {
          const warningList = document.createElement('ul');
          warningList.className = 'chart-owner-local-kis-integration-warning-list';
          for (const warning of context.warnings) {
            const li = document.createElement('li');
            li.textContent = warning;
            warningList.append(li);
          }
          ownerLocalKisIntegrationResult.append(warningList);
        }

        const disclaimer = document.createElement('p');
        disclaimer.className = 'chart-owner-local-kis-integration-disclaimer';
        disclaimer.textContent = '실시간 시세 참고용 정보이며, 매수·매도 추천 또는 투자자문이 아닙니다.';
        ownerLocalKisIntegrationResult.append(disclaimer);
      };

      if (ownerLocalKisIntegrationRunBtn && ownerLocalKisIntegrationEnabled) {
        ownerLocalKisIntegrationRunBtn.addEventListener('click', async () => {
          if (ownerLocalKisIntegrationRequestInFlight) return;
          ownerLocalKisIntegrationRequestInFlight = true;
          ownerLocalKisIntegrationRunBtn.disabled = true;
          if (ownerLocalKisIntegrationResult) ownerLocalKisIntegrationResult.setAttribute('aria-busy', 'true');
          showOwnerLocalKisIntegrationMessage('불러오는 중… (로컬 전용 KIS 현재가 연동, current_price)', 'loading');

          const abortController = new AbortController();
          const timeoutId = window.setTimeout(
            () => abortController.abort(),
            OWNER_LOCAL_KIS_INTEGRATION_TIMEOUT_MS,
          );

          try {
            const response = await fetch(
              '/api/chart-ai/local-only-kis-current-price.json?ownerLocalKisIntegration=1&symbol=005930',
              { method: 'GET', signal: abortController.signal },
            );
            let parsedResponse: unknown = null;
            try {
              parsedResponse = await response.json();
            } catch {
              parsedResponse = null;
            }
            if (isOwnerLocalKisIntegrationResponse(parsedResponse)) {
              renderOwnerLocalKisIntegrationResult(parsedResponse.context);
            } else {
              showOwnerLocalKisIntegrationMessage(
                '로컬 전용 KIS 현재가 결과를 불러오지 못했습니다. 다시 실행 버튼으로 재시도해 주세요.',
                'unavailable',
              );
            }
          } catch (thrownError) {
            if (thrownError instanceof DOMException && thrownError.name === 'AbortError') {
              showOwnerLocalKisIntegrationMessage(
                '요청 시간이 초과되었습니다. 다시 실행 버튼으로 재시도해 주세요.',
                'unavailable',
              );
            } else {
              showOwnerLocalKisIntegrationMessage(
                '로컬 전용 KIS 현재가 결과를 불러오지 못했습니다. 다시 실행 버튼으로 재시도해 주세요.',
                'unavailable',
              );
