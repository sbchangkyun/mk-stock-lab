  <script
    id="chartAiDomesticSymbolData"
    type="application/json"
    set:html={clientSafeDomesticSymbolPayload}
  ></script>

  <script>
    import { buildMockedChartGeometry } from '../lib/chart-ai/chartScale';
    import {
      CHART_PERIOD_LABELS,
      createMockedOhlcSeries,
      isChartPeriodKey,
      isValidMockedOhlcSeries,
      type ChartPeriodKey,
      type MockedOhlcPoint,
    } from '../lib/chart-ai/mockedOhlc';
    import { toMockedOhlcPoints, type OwnerLocalOhlcPreviewPoint } from '../lib/chart-ai/ohlcPreviewChart';
    // Phase 3GG-T-HF3A: authoritative selected-symbol / active-chart integrity state machine (pure).
    import { createSelectedSymbolIntegrityState } from '../lib/chart-ai/selected-symbol-integrity.mjs';
    // Phase 3GG-T-HF4-FAST: pure chart interaction/formatting helpers (no DOM/network/time/randomness).
    import {
      nearestCandleIndex,
      valueToY,
      buildCandleDisplayDatum,
      formatPrice,
      formatSignedPrice,
      formatPercent,
      formatDate,
    } from '../lib/chart-ai/chart-interaction-foundation.mjs';
    import { searchClientSafeDomesticSymbols } from '../lib/symbol-master/clientSymbolSearch';
    import type { ClientSafeSymbolSearchRecord, DomesticAssetType } from '../lib/symbol-master/types';
    // Phase 3GG-T-HF1: real Supabase auth gate + authenticated Chart AI API calls, reusing the same
    // browser session source as the Portfolio page (no new auth scheme).
    import { getBrowserSupabaseClient, isSupabaseConfigured, getCurrentSession } from '../lib/supabase';

    const assetTypeLabel = (assetType: DomesticAssetType): string => {
      if (assetType === 'stock') return '주식';
      if (assetType === 'etf') return 'ETF';
      if (assetType === 'etn') return 'ETN';
      return '기타';
    };

    // Simple final-character Hangul batchim check. Non-Hangul names default to '은'.
    const getTopicParticle = (name: string): string => {
      const lastChar = name.trim().slice(-1);
      const code = lastChar.charCodeAt(0);
      if (code < 0xac00 || code > 0xd7a3) return '은';
      return (code - 0xac00) % 28 === 0 ? '는' : '은';
    };

    const parseClientSafeRecords = (): ClientSafeSymbolSearchRecord[] => {
      const payload = document.getElementById('chartAiDomesticSymbolData')?.textContent ?? '[]';
      try {
        const parsed: unknown = JSON.parse(payload);
        return Array.isArray(parsed) ? parsed as ClientSafeSymbolSearchRecord[] : [];
      } catch {
        return [];
      }
    };

    const setup = () => {
      const input = document.getElementById('chartAiInput') as HTMLInputElement | null;
      const runBtn = document.getElementById('chartAiRunBtn') as HTMLButtonElement | null;
      const searchPanel = document.querySelector<HTMLElement>('.chart-lookup-search');
      const dropdown = document.getElementById('chartAiSearchDropdown');
      const resultsEl = document.getElementById('chartAiSearchResults');
      const resultCount = document.getElementById('chartAiResultCount');
      const emptyState = document.getElementById('chartAiEmptyState');
      const searchHint = document.getElementById('chartAiSearchHint');
      const filterButtons = document.querySelectorAll<HTMLButtonElement>('.chart-ai-filter-btn');
      const periodButtons = document.querySelectorAll<HTMLButtonElement>('.chart-period-controls button');
      const chart = document.getElementById('chartAiMarketChart');
      const chartSvg = document.getElementById('chartAiMarketSvg') as SVGSVGElement | null;
      // Phase 3GG-T-HF4-FAST: chart interaction DOM (Production only; safely null off-Production).
      const chartTooltip = document.getElementById('chartAiChartTooltip');
      const chartHeaderPriceRow = document.getElementById('chartAiHeaderPriceRow');
      const chartHeaderPrice = document.getElementById('chartAiHeaderPrice');
      const chartHeaderChangeAmount = document.getElementById('chartAiHeaderChangeAmount');
      const chartHeaderChangePercent = document.getElementById('chartAiHeaderChangePercent');
      const chartOhlcvStrip = document.getElementById('chartAiOhlcvStrip');
      const chartCandleSummary = document.getElementById('chartAiCandleSummary');
      const stripEls = {
        open: document.getElementById('chartAiStripOpen'),
        high: document.getElementById('chartAiStripHigh'),
        low: document.getElementById('chartAiStripLow'),
        close: document.getElementById('chartAiStripClose'),
        changeAmount: document.getElementById('chartAiStripChangeAmount'),
        changePercent: document.getElementById('chartAiStripChangePercent'),
        volume: document.getElementById('chartAiStripVolume'),
        date: document.getElementById('chartAiStripDate'),
      };
      // Closure state for the currently rendered chart's interaction layer.
      let chartInteractionPoints: MockedOhlcPoint[] = [];
      let chartInteractionGeometry: ReturnType<typeof buildMockedChartGeometry> | null = null;
      let chartInteractionCurrency: 'KRW' | 'USD' = 'KRW';
      let chartSelectedIndex = -1;
      let chartAnnouncedIndex = -1;
      let chartOverlayLayer: SVGGElement | null = null;
      let chartCrosshairLine: SVGLineElement | null = null;
      let chartPriceLine: SVGLineElement | null = null;
      let chartPriceLineLabel: SVGTextElement | null = null;
      let chartHighlightRect: SVGRectElement | null = null;
      const records = parseClientSafeRecords();
      // Phase 3GG-T-HF3A: authoritative pending/active-chart integrity state. Analyses run ONLY against
      // the instrument whose chart was explicitly loaded successfully — never a hidden default.
      const integrity = createSelectedSymbolIntegrityState();
      let activeFilter: DomesticAssetType | 'all' = 'all';
      // No hidden Production default: nothing is selected until the user explicitly searches + selects.
      let selectedSymbol = '';
      let selectedName = '';
      let selectedAssetType: DomesticAssetType = 'stock';
      // Phase 3GG-OP-FAST: universal selected-instrument state (KR default) and the active real-chart
      // range. `activePeriod` still drives the non-production sample chart unchanged.
      let selectedCountry: 'KR' | 'US' = 'KR';
      let activeRange = '3m';
      let activePeriod: ChartPeriodKey = '1d';
      let visibleRecords: any[] = [];
      let resetQuotePreview: () => void = () => {};
      let resetOhlcPreview: () => void = () => {};
      let resetAnalysisTriggers: () => void = () => {};
      // Phase 3GG-Q-FAST: reassigned by the production similarity block; stub keeps updateSelection safe.
      let resetSelectedSimilarity: () => void = () => {};
      // Phase 3GG-R-FAST: reassigned by the production MK AI analysis block.
      let resetSelectedMkAi: () => void = () => {};
      // Phase 3GG-T-FAST: reassigned by the production Market Intelligence block.
      let resetSelectedMarketIntel: () => void = () => {};
      let ownerLocalConnected = false;
      let selectedRecord: ClientSafeSymbolSearchRecord | null = null;
      const mkAiBulletsEl = document.getElementById('chartAiMkAiBullets');
      const mkAiBasisEl = document.getElementById('chartAiMkAiBasisList');
      const mkAiEvidenceEl = document.getElementById('chartAiMkAiEvidenceList');
      const mkAiChecklistEl = document.getElementById('chartAiMkAiChecklist');
      const mkAiLimitationsEl = document.getElementById('chartAiMkAiLimitations');
      const mkAiConnectedNoteEl = document.getElementById('chartAiMkAiConnectedNote');
      const mkAiScenarioPositiveEl = document.getElementById('chartAiMkAiScenarioPositive');
      const mkAiScenarioBaseEl = document.getElementById('chartAiMkAiScenarioBase');
      const mkAiScenarioCautionEl = document.getElementById('chartAiMkAiScenarioCaution');
      const mkAiRiskChecklistEl = document.getElementById('chartAiMkAiRiskChecklist');
      const mkAiConnectedScenarioNoteEl = document.getElementById('chartAiMkAiConnectedScenarioNote');

      type ChartAiMockAuthState = 'anonymous' | 'authenticated';
      type ChartAiMockRole = 'user' | 'master';
      const chartAiQuery = new URLSearchParams(window.location.search);
      const chartAiMockLoggedOut = chartAiQuery.get('chartAiMockLoggedOut') === '1';
      const chartAiMockMaster = !chartAiMockLoggedOut && chartAiQuery.get('chartAiMockMaster') === '1';
      const isLocalOwnerHostname = (): boolean => {
        const hostname = window.location.hostname;
        return hostname === 'localhost' || hostname === '127.0.0.1' || hostname === '::1' || hostname === '[::1]';
      };
      // Mocked page capability model only. It contains no real identity, session, or authorization data.
      const mockedChartAiAccess: {
        authState: ChartAiMockAuthState;
        role: ChartAiMockRole;
        capabilities: {
          canAccessChartAi: boolean;
          canBypassAnalysisCooldown: boolean;
          canRunSimilarPattern: boolean;
          canRunMkAi: boolean;
        };
      } = {
        authState: chartAiMockLoggedOut ? 'anonymous' : 'authenticated',
        role: chartAiMockMaster ? 'master' : 'user',
        capabilities: {
          canAccessChartAi: !chartAiMockLoggedOut,
          canBypassAnalysisCooldown: chartAiMockMaster,
          canRunSimilarPattern: !chartAiMockLoggedOut,
          canRunMkAi: !chartAiMockLoggedOut,
        },
      };
      const ownerLocalSimilarPatternRouteOptIn = chartAiQuery.get('ownerLocalSimilarPatternRoute') === '1';
      const ownerLocalSimilarPatternRouteEnabled =
        mockedChartAiAccess.capabilities.canAccessChartAi &&
        isLocalOwnerHostname() &&
        ownerLocalSimilarPatternRouteOptIn;
      const authShell = document.querySelector<HTMLElement>('.chart-ai-auth-shell');
      const authGate = document.querySelector<HTMLElement>('[data-chart-ai-auth-gate="locked"]');
      const authGateCta = document.querySelector<HTMLButtonElement>('[data-chart-ai-auth-gate-cta]');
      const authBody = document.querySelector<HTMLElement>('[data-chart-ai-auth-body]');
      const masterModeNotice = document.querySelector<HTMLElement>('[data-chart-ai-master-notice]');
      const ownerLocalSimilarPatternRouteNotice = document.querySelector<HTMLElement>('[data-chart-ai-owner-local-similar-pattern-route]');
      const ownerLocalSimilarPatternRouteStatus = document.querySelector<HTMLElement>('[data-chart-ai-owner-local-similar-pattern-route-status]');
      const ownerLocalSimilarPatternRouteResult = document.querySelector<HTMLElement>('[data-chart-ai-owner-local-similar-pattern-route-result]');

      if (authShell) {
        authShell.dataset.chartAiAuthState = mockedChartAiAccess.authState;
        authShell.dataset.chartAiMasterMode = String(chartAiMockMaster);
        authShell.dataset.chartAiCooldownBypass = String(mockedChartAiAccess.capabilities.canBypassAnalysisCooldown);
      }
      if (authGate) authGate.hidden = mockedChartAiAccess.capabilities.canAccessChartAi;
      if (authBody) authBody.hidden = !mockedChartAiAccess.capabilities.canAccessChartAi;
      if (masterModeNotice) masterModeNotice.hidden = !chartAiMockMaster;
      if (ownerLocalSimilarPatternRouteNotice) {
        ownerLocalSimilarPatternRouteNotice.hidden = !ownerLocalSimilarPatternRouteEnabled;
      }

      // Owner-local deterministic agents panel (Phase 3FF-A-UI-A). Local-only, explicit
      // opt-in: hidden unless hostname is localhost/127.0.0.1/::1 AND the URL carries
      // `?ownerLocalDeterministicAgents=1`. The panel content itself is fully pre-rendered
      // server-side from deterministic fixture output above — this only toggles visibility.
      // No fetch, no API call, ever, for this panel.
      const ownerLocalDeterministicAgentsOptIn = chartAiQuery.get('ownerLocalDeterministicAgents') === '1';
      const ownerLocalDeterministicAgentsEnabled =
        mockedChartAiAccess.capabilities.canAccessChartAi &&
        isLocalOwnerHostname() &&
        ownerLocalDeterministicAgentsOptIn;
      const ownerLocalDeterministicAgentsPanel = document.getElementById('chartAiOwnerLocalDeterministicAgentsPanel');
      if (ownerLocalDeterministicAgentsPanel) {
        ownerLocalDeterministicAgentsPanel.hidden = !ownerLocalDeterministicAgentsEnabled;
      }

      // Owner-local guarded productization static shell (Phase 3FG-D). Local-only, explicit
      // opt-in: hidden unless hostname is localhost/127.0.0.1/::1 AND the URL carries
      // `?ownerLocalGuardedProductizationShell=1`. All card content is pre-rendered
      // server-side from static copy above — this only toggles visibility. No fetch, no API
      // call, no scaffold import/execution, ever, for this shell.
      const ownerLocalGuardedProductizationShellOptIn =
        chartAiQuery.get('ownerLocalGuardedProductizationShell') === '1';
      const ownerLocalGuardedProductizationShellEnabled =
        mockedChartAiAccess.capabilities.canAccessChartAi &&
        isLocalOwnerHostname() &&
        ownerLocalGuardedProductizationShellOptIn;
      const ownerLocalGuardedProductizationShellPanel = document.getElementById(
        'chartAiOwnerLocalGuardedProductizationStaticShell',
      );
      if (ownerLocalGuardedProductizationShellPanel) {
        ownerLocalGuardedProductizationShellPanel.hidden = !ownerLocalGuardedProductizationShellEnabled;
      }

      // Owner-local KIS current_price -> Chart AI context panel (Phase 3GG-E-INTEGRATE).
      // Local-only, explicit opt-in: hidden unless hostname is localhost/127.0.0.1/::1 AND the
      // URL carries `?ownerLocalKisIntegration=1`. Visibility only -- the actual request only
      // happens on an explicit button click, handled further below.
      const ownerLocalKisIntegrationOptIn = chartAiQuery.get('ownerLocalKisIntegration') === '1';
      const ownerLocalKisIntegrationEnabled =
        mockedChartAiAccess.capabilities.canAccessChartAi &&
        isLocalOwnerHostname() &&
        ownerLocalKisIntegrationOptIn;
      const ownerLocalKisIntegrationPanel = document.getElementById('chartAiOwnerLocalKisIntegrationPanel');
      if (ownerLocalKisIntegrationPanel) {
        ownerLocalKisIntegrationPanel.hidden = !ownerLocalKisIntegrationEnabled;
      }

      // Phase 3GG-I-FAST: hidden by default. Only unhidden client-side when hostname is local AND
      // the URL carries `?ownerLocalKisLlm=1`. Visibility only -- the actual request only happens
      // on an explicit button click, handled further below.
      const ownerLocalKisLlmOptIn = chartAiQuery.get('ownerLocalKisLlm') === '1';
      const ownerLocalKisLlmEnabled =
        mockedChartAiAccess.capabilities.canAccessChartAi && isLocalOwnerHostname() && ownerLocalKisLlmOptIn;
      // Phase 3GG-L-BETA-ACTIVATE: on a deployed (non-local) host, an explicit `?chartAiBetaPreview=1`
      // opt-in may reveal the same panel for protected Vercel Preview beta testers. Visibility only --
      // the server H route independently enforces VERCEL_ENV=preview + CHART_AI_ENABLE_PROTECTED_PREVIEW_BETA
      // + the beta query + not-production before any KIS/LLM call, and fails closed otherwise. (The two
      // modes are mutually exclusive: local requires a local hostname, beta requires a non-local one.)
      const chartAiBetaPreviewOptIn = chartAiQuery.get('chartAiBetaPreview') === '1';
      const chartAiBetaPreviewEnabled =
        mockedChartAiAccess.capabilities.canAccessChartAi && !isLocalOwnerHostname() && chartAiBetaPreviewOptIn;
      // Phase 3GG-M-PROD-BETA-DEPLOY: on a deployed (non-local) host, an explicit `?chartAiProdBeta=1`
      // opt-in may reveal the same panel for the actual Production URL. Visibility only -- the server
      // H route independently enforces VERCEL_ENV=production + CHART_AI_ENABLE_PRODUCTION_CHART_AI_BETA
      // + the explicit query before any KIS/LLM call, and fails closed otherwise. Hidden by default;
      // no auto-fetch; button click only, same as the Preview beta and localhost owner paths.
      // Phase 3GG-N-FAST: `productionChartAiDefaultEnabled` is a server-computed signal (Astro
      // frontmatter, VERCEL_ENV=production + the Production flag) smuggled in via the auth shell's
      // dataset, not a client-guessable query param. It only ever ORs the panel into visibility here;
      // the H route's own guard (below) still independently requires `chartAiProdBeta=1` on the
      // internal fetch request regardless of how this page-visibility flag was derived.
      const productionChartAiDefaultEnabled = authShell?.dataset.chartAiProductionDefault === 'true';
      const chartAiProdBetaOptIn = chartAiQuery.get('chartAiProdBeta') === '1';
      const chartAiProdBetaEnabled =
        mockedChartAiAccess.capabilities.canAccessChartAi &&
        !isLocalOwnerHostname() &&
        (chartAiProdBetaOptIn || productionChartAiDefaultEnabled);
      const ownerLocalKisLlmSummaryPanelEnabled =
        ownerLocalKisLlmEnabled || chartAiBetaPreviewEnabled || chartAiProdBetaEnabled;
      // Phase 3GG-N-FAST: the Production Chart AI beta path (default route or legacy
      // `?chartAiProdBeta=1`) always reaches real end users, unlike the localhost owner and Preview
      // tester paths -- so it renders a stripped-down, user-facing summary card instead of the
      // owner-local diagnostics view (no `sanitized=true`, no raw llmStatus/sourceStatus labels, no
      // internal warning codes/diagnostics allowlist fields).
      const useProductionFacingSummaryPresentation = chartAiProdBetaEnabled;
      const ownerLocalKisLlmSummaryRequestQuery = ownerLocalKisLlmEnabled
        ? 'ownerLocalKisLlm=1'
        : chartAiBetaPreviewEnabled
          ? 'chartAiBetaPreview=1'
          : 'chartAiProdBeta=1';
      // Phase 3GG-OP-FAST: the real OHLCV chart is driven only on the Production deployment (the
      // production-facing markup). Owner-local/Preview keep the existing sample chart. The OHLCV
      // route carries the same access opt-in the summary route does.
      const productionRealChartEnabled = chartAiProdBetaEnabled;
      const marketDataRequestQuery = ownerLocalKisLlmEnabled
        ? 'ownerLocalOhlcv=1'
        : chartAiBetaPreviewEnabled
          ? 'chartAiBetaPreview=1'
          : 'chartAiProdBeta=1';
      const ownerLocalKisLlmPanel = document.getElementById('chartAiOwnerLocalKisLlmSummaryPanel');
      if (ownerLocalKisLlmPanel) {
        ownerLocalKisLlmPanel.hidden = !ownerLocalKisLlmSummaryPanelEnabled;
      }

      authGateCta?.addEventListener('click', () => {
        window.dispatchEvent(new CustomEvent('mk:open-auth'));
      });

      // Phase 3GG-T-HF1: every authenticated Chart AI API call carries the Supabase Bearer token, the
      // same way portfolioClient.ts does. The server routes fail closed (401) without it. Read the
      // session per call so an auto-refreshed token is always current.
      const chartAiAuthHeaders = async (): Promise<Record<string, string>> => {
        try {
          const session = await getCurrentSession();
          return session ? { Authorization: `Bearer ${session.access_token}` } : {};
        } catch {
          return {};
        }
      };

      if (!input || !runBtn || !searchPanel || !dropdown || !resultsEl || !resultCount || !emptyState || !chart || !chartSvg) return;
      if (runBtn.dataset.ready === 'true') return;
      runBtn.dataset.ready = 'true';

      const setText = (id: string, text: string) => {
        const element = document.getElementById(id);
        if (element) element.textContent = text;
      };

      const setChartStatus = (status: string, strongLabel: string) => {
        setText('chartAiChartStatus', status);
        setText('chartAiChartStatusStrong', strongLabel);
      };

      const createSvgElement = <K extends keyof SVGElementTagNameMap>(
        name: K,
        attributes: Record<string, string | number>,
        className?: string,
      ): SVGElementTagNameMap[K] => {
        const element = document.createElementNS('http://www.w3.org/2000/svg', name);
        Object.entries(attributes).forEach(([key, value]) => element.setAttribute(key, String(value)));
        if (className) element.setAttribute('class', className);
        return element;
      };

      const renderChartFromPoints = (points: MockedOhlcPoint[], periodLabel: string, ariaLabel: string) => {
        const geometry = buildMockedChartGeometry(points, activePeriod);
        const gridLayer = createSvgElement('g', {}, 'chart-svg-grid');
        const volumeLayer = createSvgElement('g', {}, 'chart-svg-volume');
        const candleLayer = createSvgElement('g', {}, 'chart-svg-candles');
        const axisLayer = createSvgElement('g', {}, 'chart-svg-axis');

        geometry.priceLabels.forEach(({ y, label }) => {
          if (y === undefined) return;
          gridLayer.append(createSvgElement('line', {
            x1: geometry.plotLeft, y1: y, x2: geometry.plotRight, y2: y,
          }, 'chart-grid-line'));
          const axisText = createSvgElement('text', { x: geometry.plotRight + 14, y: y + 4 }, 'chart-axis-text');
          axisText.textContent = label;
          axisLayer.append(axisText);
        });

        gridLayer.append(createSvgElement('line', {
          x1: geometry.plotLeft,
          y1: geometry.volumeTop - 14,
          x2: geometry.plotRight,
          y2: geometry.volumeTop - 14,
        }, 'chart-volume-divider'));

        geometry.dateLabels.forEach(({ x, label }) => {
          if (x === undefined) return;
          gridLayer.append(createSvgElement('line', {
            x1: x, y1: geometry.priceTop, x2: x, y2: geometry.volumeBottom,
          }, 'chart-grid-line chart-grid-line-vertical'));
          const axisText = createSvgElement('text', { x, y: 430, 'text-anchor': 'middle' }, 'chart-axis-text');
          axisText.textContent = label;
          axisLayer.append(axisText);
        });

        geometry.candles.forEach((candle) => {
          const directionClass = candle.direction === 'up' ? 'is-up' : candle.direction === 'down' ? 'is-down' : 'is-flat';
          candleLayer.append(createSvgElement('line', {
            x1: candle.x,
            y1: candle.wickTop,
            x2: candle.x,
            y2: candle.wickBottom,
          }, `chart-candle-wick ${directionClass}`));
          candleLayer.append(createSvgElement('rect', {
            x: candle.x - candle.bodyWidth / 2,
            y: candle.bodyTop,
            width: candle.bodyWidth,
            height: candle.bodyHeight,
            rx: 0.8,
          }, `chart-candle-body ${directionClass}`));
          volumeLayer.append(createSvgElement('rect', {
            x: candle.x - candle.bodyWidth / 2,
            y: candle.volumeY,
            width: candle.bodyWidth,
            height: candle.volumeHeight,
            rx: 0.6,
          }, `chart-volume-bar ${directionClass}`));
        });

        chartSvg.setAttribute('viewBox', geometry.viewBox);
        chartSvg.replaceChildren(gridLayer, volumeLayer, candleLayer, axisLayer);
        setText('chartAiChartPeriodLabel', periodLabel);
        chart.setAttribute('aria-label', ariaLabel);

        // Phase 3GG-T-HF4-FAST: chart interaction layer (Production only — chartTooltip only exists
        // in the Production-rendered DOM, so this safely no-ops for the non-Production sample chart).
        chartInteractionPoints = points;
        chartInteractionGeometry = geometry;
        chartInteractionCurrency = selectedRecord?.currency === 'USD' ? 'USD' : 'KRW';
        chartSelectedIndex = points.length - 1;
        chartAnnouncedIndex = -1;
        if (chartTooltip) {
          buildChartOverlayLayer(geometry);
          attachChartInteractionHandlers();
          selectChartCandle(points.length - 1, { commit: false });
        }
      };

      const clientToSvgPoint = (clientX: number, clientY: number): { x: number; y: number } | null => {
        if (!chartSvg) return null;
        const rect = chartSvg.getBoundingClientRect();
        if (rect.width <= 0 || rect.height <= 0) return null;
        const viewBox = chartSvg.viewBox.baseVal;
        return {
          x: ((clientX - rect.left) / rect.width) * viewBox.width,
          y: ((clientY - rect.top) / rect.height) * viewBox.height,
        };
      };

      const buildChartOverlayLayer = (geometry: ReturnType<typeof buildMockedChartGeometry>) => {
        if (!chartSvg) return;
        const overlay = createSvgElement('g', {}, 'chart-svg-overlay chart-overlay-layer');
        const highlight = createSvgElement('rect', {
          x: 0, y: geometry.priceTop, width: 0, height: geometry.volumeBottom - geometry.priceTop,
        }, 'chart-candle-highlight');
        highlight.setAttribute('fill', 'currentColor');
        highlight.setAttribute('opacity', '0.08');
        const crosshair = createSvgElement('line', {
          x1: 0, y1: geometry.priceTop, x2: 0, y2: geometry.volumeBottom,
        }, 'chart-crosshair-line');
        const latestClose = chartInteractionPoints.length
          ? chartInteractionPoints[chartInteractionPoints.length - 1].close
          : NaN;
        const priceLineY = valueToY(
          latestClose, geometry.priceMin, geometry.priceMax, geometry.priceTop, geometry.priceBottom - geometry.priceTop,
        );
        const clampedLabelY = Math.min(geometry.priceBottom - 4, Math.max(geometry.priceTop + 10, priceLineY));
        const priceLine = createSvgElement('line', {
          x1: geometry.plotLeft, y1: priceLineY, x2: geometry.plotRight, y2: priceLineY,
        }, 'chart-price-line');
        const priceLabel = createSvgElement('text', {
          x: geometry.plotRight + 6, y: clampedLabelY + 4,
        }, 'chart-price-line-label');
        priceLabel.textContent = formatPrice(latestClose, chartInteractionCurrency);
        overlay.append(highlight, crosshair, priceLine, priceLabel);
        chartSvg.append(overlay);
        chartOverlayLayer = overlay;
        chartHighlightRect = highlight;
        chartCrosshairLine = crosshair;
        chartPriceLine = priceLine;
        chartPriceLineLabel = priceLabel;
      };

      const updateChartHeaderPrice = (datum: ReturnType<typeof buildCandleDisplayDatum>) => {
        if (!datum || !chartHeaderPriceRow) return;
        chartHeaderPriceRow.hidden = false;
        if (chartHeaderPrice) chartHeaderPrice.textContent = datum.formatted.close;
        if (chartHeaderChangeAmount) {
          chartHeaderChangeAmount.textContent = datum.changeAvailable ? datum.formatted.change : '변동 없음';
          chartHeaderChangeAmount.classList.toggle('is-up', datum.changeAvailable && datum.direction === 'up');
          chartHeaderChangeAmount.classList.toggle('is-down', datum.changeAvailable && datum.direction === 'down');
        }
        if (chartHeaderChangePercent) {
          chartHeaderChangePercent.textContent = datum.changeAvailable ? datum.formatted.changePercent : '—';
          chartHeaderChangePercent.classList.toggle('is-up', datum.changeAvailable && (datum.changePercent ?? 0) > 0);
          chartHeaderChangePercent.classList.toggle('is-down', datum.changeAvailable && (datum.changePercent ?? 0) < 0);
        }
      };

      const updateChartStrip = (datum: ReturnType<typeof buildCandleDisplayDatum>) => {
        if (!datum || !chartOhlcvStrip) return;
        chartOhlcvStrip.hidden = false;
        if (stripEls.open) stripEls.open.textContent = datum.formatted.open;
        if (stripEls.high) stripEls.high.textContent = datum.formatted.high;
        if (stripEls.low) stripEls.low.textContent = datum.formatted.low;
        if (stripEls.close) stripEls.close.textContent = datum.formatted.close;
        if (stripEls.changeAmount) {
          stripEls.changeAmount.textContent = datum.formatted.change;
          stripEls.changeAmount.classList.toggle('is-up', datum.changeAvailable && datum.direction === 'up');
          stripEls.changeAmount.classList.toggle('is-down', datum.changeAvailable && datum.direction === 'down');
        }
        if (stripEls.changePercent) {
          stripEls.changePercent.textContent = datum.formatted.changePercent;
          stripEls.changePercent.classList.toggle('is-up', datum.changeAvailable && (datum.changePercent ?? 0) > 0);
          stripEls.changePercent.classList.toggle('is-down', datum.changeAvailable && (datum.changePercent ?? 0) < 0);
        }
        if (stripEls.volume) stripEls.volume.textContent = datum.formatted.volume;
        if (stripEls.date) stripEls.date.textContent = datum.formatted.date;
      };

      const applyCandleEmphasis = (index: number) => {
        if (!chartSvg) return;
        chartSvg.querySelectorAll('.chart-candle-body.is-selected, .chart-volume-bar.is-selected').forEach((el) => {
          el.classList.remove('is-selected');
        });
        const bodies = chartSvg.querySelectorAll('.chart-svg-candles .chart-candle-body');
        const bars = chartSvg.querySelectorAll('.chart-svg-volume .chart-volume-bar');
        bodies[index]?.classList.add('is-selected');
        bars[index]?.classList.add('is-selected');
      };

      const showChartTooltipAt = (svgX: number, svgY: number, html: string) => {
        if (!chartTooltip || !chart || !chartSvg) return;
        chartTooltip.innerHTML = html;
        chartTooltip.hidden = false;
        const chartRect = chart.getBoundingClientRect();
        const viewBox = chartSvg.viewBox.baseVal;
        if (viewBox.width <= 0 || viewBox.height <= 0) return;
        const scaleX = chartRect.width / viewBox.width;
        const scaleY = chartRect.height / viewBox.height;
        const tooltipWidth = (chartTooltip as HTMLElement).offsetWidth || 160;
        const tooltipHeight = (chartTooltip as HTMLElement).offsetHeight || 60;
        let left = svgX * scaleX + 12;
        if (left + tooltipWidth > chartRect.width) left = svgX * scaleX - tooltipWidth - 12;
        left = Math.max(4, Math.min(chartRect.width - tooltipWidth - 4, left));
        let top = svgY * scaleY - 8;
        top = Math.max(4, Math.min(chartRect.height - tooltipHeight - 4, top));
        (chartTooltip as HTMLElement).style.left = `${left}px`;
        (chartTooltip as HTMLElement).style.top = `${top}px`;
      };

      const selectChartCandle = (
        index: number,
        opts: { commit: boolean; svgPoint?: { x: number; y: number } },
      ) => {
        const points = chartInteractionPoints;
        const geometry = chartInteractionGeometry;
        if (!geometry || !points.length || index < 0 || index >= points.length) return;
        chartSelectedIndex = index;
        const datum = buildCandleDisplayDatum(points, index, chartInteractionCurrency);
        if (!datum) return;
        updateChartHeaderPrice(datum);
        updateChartStrip(datum);
        applyCandleEmphasis(index);

        const candle = geometry.candles[index];
        if (chartCrosshairLine && candle) {
          chartCrosshairLine.setAttribute('x1', String(candle.x));
          chartCrosshairLine.setAttribute('x2', String(candle.x));
        }
        if (chartHighlightRect && candle) {
          chartHighlightRect.setAttribute('x', String(candle.x - candle.bodyWidth / 2 - 2));
          chartHighlightRect.setAttribute('width', String(candle.bodyWidth + 4));
        }

        if (opts.svgPoint && candle) {
          if (chartOverlayLayer) chartOverlayLayer.classList.add('is-visible');
          const region: 'price' | 'volume' = opts.svgPoint.y >= geometry.volumeTop - 14 ? 'volume' : 'price';
          const changeCell = datum.changeAvailable
            ? `${datum.formatted.change} (${datum.formatted.changePercent})`
            : '—';
          const tooltipHtml = region === 'volume'
            ? `<dl><dt>날짜</dt><dd>${datum.formatted.date}</dd><dt>거래량</dt><dd>${datum.formatted.volume}</dd></dl>${
                datum.formatted.turnoverEstimate
                  ? `<p class="chart-tooltip-turnover">추정 거래대금 ${datum.formatted.turnoverEstimate}</p>`
                  : ''
              }`
            : `<dl><dt>날짜</dt><dd>${datum.formatted.date}</dd><dt>시</dt><dd>${datum.formatted.open}</dd><dt>고</dt><dd>${datum.formatted.high}</dd><dt>저</dt><dd>${datum.formatted.low}</dd><dt>종</dt><dd>${datum.formatted.close}</dd><dt>변동</dt><dd>${changeCell}</dd></dl>`;
          showChartTooltipAt(candle.x, opts.svgPoint.y, tooltipHtml);
        }

        if (opts.commit && chartCandleSummary && index !== chartAnnouncedIndex) {
          chartAnnouncedIndex = index;
          chartCandleSummary.textContent = `${datum.formatted.date} 시가 ${datum.formatted.open}, 고가 ${datum.formatted.high}, 저가 ${datum.formatted.low}, 종가 ${datum.formatted.close}, ${
            datum.changeAvailable ? `전일 대비 ${datum.formatted.change} (${datum.formatted.changePercent})` : '전일 대비 정보 없음'
          }, 거래량 ${datum.formatted.volume}`;
        }
      };

      const resetChartCandleToLatest = () => {
        if (!chartInteractionPoints.length) return;
        selectChartCandle(chartInteractionPoints.length - 1, { commit: false });
        if (chartOverlayLayer) chartOverlayLayer.classList.remove('is-visible');
        if (chartTooltip) chartTooltip.hidden = true;
      };

      let chartInteractionHandlersAttached = false;
      const attachChartInteractionHandlers = () => {
        if (chartInteractionHandlersAttached || !chart || !chartSvg) return;
        chartInteractionHandlersAttached = true;

        const resolveIndexFromEvent = (event: PointerEvent) => {
          const svgPoint = clientToSvgPoint(event.clientX, event.clientY);
          if (!svgPoint || !chartInteractionGeometry || !chartInteractionPoints.length) return null;
          const geometry = chartInteractionGeometry;
          const index = nearestCandleIndex(
            svgPoint.x, geometry.plotLeft, geometry.plotRight - geometry.plotLeft, chartInteractionPoints.length,
          );
          if (index < 0) return null;
          return { index, svgPoint };
        };

        chart.addEventListener('pointermove', (event) => {
          const resolved = resolveIndexFromEvent(event as PointerEvent);
          if (!resolved) return;
          selectChartCandle(resolved.index, { commit: false, svgPoint: resolved.svgPoint });
        });

        chart.addEventListener('pointerleave', (event) => {
          if ((event as PointerEvent).pointerType === 'touch') return;
          resetChartCandleToLatest();
        });

        chart.addEventListener('pointerdown', (event) => {
          const resolved = resolveIndexFromEvent(event as PointerEvent);
          if (!resolved) return;
          selectChartCandle(resolved.index, { commit: true, svgPoint: resolved.svgPoint });
        });

        chart.addEventListener('keydown', (event) => {
          const keyEvent = event as KeyboardEvent;
          if (!chartInteractionPoints.length) return;
          if (keyEvent.key === 'ArrowLeft') {
            keyEvent.preventDefault();
            selectChartCandle(Math.max(0, chartSelectedIndex - 1), { commit: true });
          } else if (keyEvent.key === 'ArrowRight') {
            keyEvent.preventDefault();
            selectChartCandle(Math.min(chartInteractionPoints.length - 1, chartSelectedIndex + 1), { commit: true });
          } else if (keyEvent.key === 'Escape') {
            resetChartCandleToLatest();
          }
        });
      };

      const resetChartInteractionState = () => {
        chartInteractionPoints = [];
        chartInteractionGeometry = null;
        chartSelectedIndex = -1;
        chartAnnouncedIndex = -1;
        if (chartHeaderPriceRow) chartHeaderPriceRow.hidden = true;
        if (chartHeaderPrice) chartHeaderPrice.textContent = '—';
        if (chartHeaderChangeAmount) {
          chartHeaderChangeAmount.textContent = '—';
          chartHeaderChangeAmount.classList.remove('is-up', 'is-down');
        }
        if (chartHeaderChangePercent) {
          chartHeaderChangePercent.textContent = '—';
          chartHeaderChangePercent.classList.remove('is-up', 'is-down');
        }
        if (chartOhlcvStrip) chartOhlcvStrip.hidden = true;
        if (chartTooltip) chartTooltip.hidden = true;
        if (chartCandleSummary) chartCandleSummary.textContent = '';
        if (chartOverlayLayer && chartOverlayLayer.parentNode) chartOverlayLayer.parentNode.removeChild(chartOverlayLayer);
        chartOverlayLayer = null;
        chartCrosshairLine = null;
        chartPriceLine = null;
        chartPriceLineLabel = null;
        chartHighlightRect = null;
      };

      const renderChart = () => {
        // Phase 3GG-T-HF3A: no hidden default — the non-production sample chart stays empty until the
        // user explicitly selects a symbol.
        if (!selectedSymbol) return;
        const points = createMockedOhlcSeries(selectedSymbol, activePeriod);
        if (!isValidMockedOhlcSeries(points)) return;
        setChartStatus('샘플 OHLC·거래량 데이터', '실제 시세 아님');
        renderChartFromPoints(
          points,
          `${CHART_PERIOD_LABELS[activePeriod]} 샘플`,
          `${selectedName} ${selectedSymbol}, ${CHART_PERIOD_LABELS[activePeriod]} 선택 종목의 샘플 캔들 차트와 거래량. 실제 시세 아님.`,
        );
      };

      const renderOhlcChart = (rawPoints: OwnerLocalOhlcPreviewPoint[]): boolean => {
        const points = toMockedOhlcPoints(rawPoints);
        if (!isValidMockedOhlcSeries(points)) return false;
        renderChartFromPoints(
          points,
          `${CHART_PERIOD_LABELS[activePeriod]} · KIS OHLC`,
          `${selectedName} ${selectedSymbol}, ${CHART_PERIOD_LABELS[activePeriod]} KIS OHLC 프리뷰 차트와 거래량. 지연 시세, 실제 투자 판단용 아님.`,
        );
        return true;
      };

      const closeDropdown = () => {
        visibleRecords = [];
        resultsEl.replaceChildren();
        resultCount.textContent = '0개';
        emptyState.hidden = true;
        dropdown.hidden = true;
        searchPanel.classList.remove('open');
        input.setAttribute('aria-expanded', 'false');
      };

      const buildSelectedSymbolOverview = (record: any): string => {
        // Phase 3GG-T-HF1: factual identity only, from verified normalized instrument metadata. No
        // sample/scaffold copy and no unverified company-profile prose.
        const particle = getTopicParticle(record.nameKo);
        const marketWord = record.country === 'US' ? '미국' : '국내';
        const kind = record.assetType === 'etf' ? 'ETF' : '주식';
        return `${record.nameKo}${particle} ${record.exchange}에 상장된 ${marketWord} ${kind}입니다.`;
      };

      const updateOverviewDataStatus = () => {
        // Phase 3GG-T-HF1: the Production page now uses REAL delayed market data, so the card reflects
        // that instead of the old sample/scaffold label.
        if (productionRealChartEnabled) {
          setText('chartAiOverviewDataStatus', '실제 지연 시세 데이터');
          return;
        }
        if (!ownerLocalPreview) {
          setText('chartAiOverviewDataStatus', '샘플·구조화 데이터');
          return;
        }
        setText('chartAiOverviewDataStatus', ownerLocalConnected ? '오너 로컬 KIS 연결 확인' : '오너 로컬 연결 대기');
      };

      const buildMockMkAiAnalysis = (
        record: ClientSafeSymbolSearchRecord,
        context: { ownerLocalPreview: boolean; ownerLocalConnected: boolean },
      ): {
        summary: string;
        keyInterpretation: string[];
        evidence: string[];
        checklist: string[];
        limitations: string[];
        basis: string[];
        status: string;
        connectedNote: string | null;
        scenarios: { label: string; tone: 'positive' | 'base' | 'caution'; text: string }[];
        riskChecklist: string[];
        scenarioNote: string;
        connectedScenarioNote: string | null;
      } => {
        const name = record.nameKo;
        const exchange = record.exchange;
        const particle = getTopicParticle(name);
        let summary: string;
        let keyInterpretation: string[];
        let limitations: string[];
        let scenarioTexts: { positive: string; base: string; caution: string };
        let riskChecklist: string[];

        const defaultLimitations = [
          '실제 가격, 거래량, 재무제표, 공시 정보는 분석에 반영하지 않았습니다.',
          '본 패널은 외부 AI API를 호출하지 않는 샘플 분석 로직입니다.',
