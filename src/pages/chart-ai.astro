      // Owner-local KIS current_price + LLM summary execution panel (Phase 3GG-I-FAST).
      // Local-only, explicit opt-in: hidden unless hostname is localhost/127.0.0.1/::1 AND the
      // URL carries `?ownerLocalKisLlm=1`. Never auto-runs; the request only happens on an
      // explicit click, to
      // `/api/chart-ai/local-only-kis-llm-summary.json?ownerLocalKisLlm=1&symbol=005930` (Phase
      // 3GG-H-FAST / 3GG-H-HF1), which itself fails closed unless local-only + opt-in + the
      // local LLM env gate all allow it. Renders only sanitized summary fields on success, or a
      // narrow, explicitly-allowlisted diagnostics subset on failure -- never the raw KIS
      // payload, never the actual currentPrice numeric value, never the prompt, never the raw
      // OpenAI response, never credentials.
      const ownerLocalKisLlmSummaryButton = document.getElementById(
        'chartAiOwnerLocalKisLlmSummaryButton',
      ) as HTMLButtonElement | null;
      const ownerLocalKisLlmSummaryOutput = document.getElementById('chartAiOwnerLocalKisLlmSummaryOutput');
      const ownerLocalKisLlmSummaryStatus = document.getElementById('chartAiOwnerLocalKisLlmSummaryStatus');
      if (ownerLocalKisLlmSummaryOutput) ownerLocalKisLlmSummaryOutput.tabIndex = -1;

      const OWNER_LOCAL_KIS_LLM_SUMMARY_TIMEOUT_MS = 15000;
      let ownerLocalKisLlmSummaryRequestInFlight = false;

      // UI-facing diagnostics display allowlist -- deliberately narrower than the bridge's
      // server-side ALLOWED_LLM_DIAGNOSTICS_FIELDS (Phase 3GG-H-HF1); openAiErrorType /
      // openAiErrorCode / openAiErrorParam are never rendered here.
      const OWNER_LOCAL_KIS_LLM_SUMMARY_DIAGNOSTICS_UI_ALLOWLIST = [
        'httpStatus',
        'openAiErrorMessageClass',
        'responseShapeKind',
        'outputTextPresent',
      ];

      const showOwnerLocalKisLlmSummaryMessage = (
        text: string,
        variant: 'loading' | 'unavailable' = 'unavailable',
      ) => {
        if (ownerLocalKisLlmSummaryStatus) ownerLocalKisLlmSummaryStatus.textContent = text;
        if (variant === 'loading') {
          if (ownerLocalKisLlmSummaryOutput) {
            ownerLocalKisLlmSummaryOutput.hidden = true;
            ownerLocalKisLlmSummaryOutput.replaceChildren();
          }
          return;
        }
        if (!ownerLocalKisLlmSummaryOutput) return;
        ownerLocalKisLlmSummaryOutput.hidden = false;
        ownerLocalKisLlmSummaryOutput.replaceChildren();
        const message = document.createElement('p');
        message.className = `chart-owner-local-kis-llm-summary-msg chart-owner-local-kis-llm-summary-msg-${variant}`;
        message.textContent = text;
        ownerLocalKisLlmSummaryOutput.append(message);
      };

      type OwnerLocalKisLlmSummary = {
        ok: boolean;
        symbol: string | null;
        market: string | null;
        llmStatus: string | null;
        summaryText: string | null;
        sanitizedErrorCode: string | null;
        sourceStatus: string;
        currentPricePresent: boolean | null;
        volumePresent: boolean | null;
        diagnostics: Record<string, unknown> | null;
      };

      // Response shape guard: validates the parsed body is exactly the sanitized LLM summary
      // response shape before anything is rendered. Any missing or wrong-typed field falls
      // through to the safe static "unexpected response" path below -- never a partial render.
      const isOwnerLocalKisLlmSummaryResponse = (
        value: unknown,
      ): value is { ok: true; summary: OwnerLocalKisLlmSummary } => {
        if (!value || typeof value !== 'object') return false;
        const record = value as Record<string, unknown>;
        if (record.ok !== true) return false;
        const summary = record.summary;
        if (!summary || typeof summary !== 'object') return false;
        const s = summary as Record<string, unknown>;
        if (typeof s.ok !== 'boolean') return false;
        if (typeof s.sourceStatus !== 'string') return false;
        return true;
      };

      const renderOwnerLocalKisLlmSummarySuccess = (summary: OwnerLocalKisLlmSummary) => {
        if (!ownerLocalKisLlmSummaryOutput) return;
        ownerLocalKisLlmSummaryOutput.hidden = false;
        ownerLocalKisLlmSummaryOutput.replaceChildren();

        const summaryText = document.createElement('p');
        summaryText.className = 'chart-owner-local-kis-llm-summary-text';
        summaryText.textContent = typeof summary.summaryText === 'string' ? summary.summaryText : '-';
        ownerLocalKisLlmSummaryOutput.append(summaryText);

        const summaryList = document.createElement('dl');
        summaryList.className = 'chart-owner-local-kis-llm-summary-dl';
        const rows: Array<[string, string]> = useProductionFacingSummaryPresentation
          ? [
              ['종목', summary.symbol ?? '-'],
              ['시장', summary.market ?? '-'],
              ['분석 상태', '완료'],
            ]
          : [
              ['종목', summary.symbol ?? '-'],
              ['시장', summary.market ?? '-'],
              ['LLM 상태', summary.llmStatus ?? '-'],
              ['현재가 반영 여부', summary.currentPricePresent === true ? '반영됨' : '반영 안 됨'],
              ['거래량 반영 여부', summary.volumePresent === true ? '반영됨' : '반영 안 됨'],
            ];
        for (const [label, value] of rows) {
          const dt = document.createElement('dt');
          dt.textContent = label;
          const dd = document.createElement('dd');
          dd.textContent = value;
          summaryList.append(dt, dd);
        }
        ownerLocalKisLlmSummaryOutput.append(summaryList);

        const sanitizedNote = document.createElement('p');
        sanitizedNote.className = 'chart-owner-local-kis-llm-summary-sanitized-note';
        sanitizedNote.textContent = useProductionFacingSummaryPresentation
          ? '실제 시세 수치와 원문 응답은 표시되지 않습니다.'
          : '민감 정보(실제 현재가 수치, 원문 응답, 프롬프트, 자격 증명 등)는 표시되지 않습니다. (sanitized=true)';
        ownerLocalKisLlmSummaryOutput.append(sanitizedNote);

        const disclaimer = document.createElement('p');
        disclaimer.className = 'chart-owner-local-kis-llm-summary-disclaimer';
        disclaimer.textContent = '투자 자문이 아니며 매수·매도 추천을 제공하지 않습니다.';
        ownerLocalKisLlmSummaryOutput.append(disclaimer);
      };

      const renderOwnerLocalKisLlmSummaryBlocked = (summary: OwnerLocalKisLlmSummary) => {
        if (!ownerLocalKisLlmSummaryOutput) return;
        ownerLocalKisLlmSummaryOutput.hidden = false;
        ownerLocalKisLlmSummaryOutput.replaceChildren();

        if (useProductionFacingSummaryPresentation) {
          const msg = document.createElement('p');
          msg.className = 'chart-owner-local-kis-llm-summary-msg chart-owner-local-kis-llm-summary-msg-unavailable';
          msg.textContent = '지금은 시세 요약을 완료하지 못했습니다. 다시 실행 버튼으로 재시도해 주세요.';
          ownerLocalKisLlmSummaryOutput.append(msg);

          const disclaimer = document.createElement('p');
          disclaimer.className = 'chart-owner-local-kis-llm-summary-disclaimer';
          disclaimer.textContent = '투자 자문이 아니며 매수·매도 추천을 제공하지 않습니다.';
          ownerLocalKisLlmSummaryOutput.append(disclaimer);
          return;
        }

        const summaryList = document.createElement('dl');
        summaryList.className = 'chart-owner-local-kis-llm-summary-dl';
        const rows: Array<[string, string]> = [
          ['소스 상태', summary.sourceStatus ?? '-'],
          ['오류 코드', summary.sanitizedErrorCode ?? '-'],
        ];
        const diagnostics = summary.diagnostics;
        if (diagnostics && typeof diagnostics === 'object') {
          const d = diagnostics as Record<string, unknown>;
          for (const key of OWNER_LOCAL_KIS_LLM_SUMMARY_DIAGNOSTICS_UI_ALLOWLIST) {
            if (d[key] !== undefined) rows.push([key, String(d[key])]);
          }
        }
        for (const [label, value] of rows) {
          const dt = document.createElement('dt');
          dt.textContent = label;
          const dd = document.createElement('dd');
          dd.textContent = value;
          summaryList.append(dt, dd);
        }
        ownerLocalKisLlmSummaryOutput.append(summaryList);

        const msg = document.createElement('p');
        msg.className = 'chart-owner-local-kis-llm-summary-msg chart-owner-local-kis-llm-summary-msg-unavailable';
        msg.textContent = '로컬 전용 KIS + LLM 요약을 사용할 수 없습니다. 로컬 환경 설정을 확인해 주세요.';
        ownerLocalKisLlmSummaryOutput.append(msg);
      };

      if (ownerLocalKisLlmSummaryButton && ownerLocalKisLlmSummaryPanelEnabled) {
        ownerLocalKisLlmSummaryButton.addEventListener('click', async () => {
          if (ownerLocalKisLlmSummaryRequestInFlight) return;
          ownerLocalKisLlmSummaryRequestInFlight = true;
          ownerLocalKisLlmSummaryButton.disabled = true;
          if (ownerLocalKisLlmSummaryOutput) ownerLocalKisLlmSummaryOutput.setAttribute('aria-busy', 'true');
          showOwnerLocalKisLlmSummaryMessage(
            useProductionFacingSummaryPresentation ? '불러오는 중…' : '불러오는 중… (로컬 전용 KIS + LLM 요약, current_price 기반)',
            'loading',
          );

          const abortController = new AbortController();
          const timeoutId = window.setTimeout(
            () => abortController.abort(),
            OWNER_LOCAL_KIS_LLM_SUMMARY_TIMEOUT_MS,
          );

          try {
            const response = await fetch(
              `/api/chart-ai/local-only-kis-llm-summary.json?${ownerLocalKisLlmSummaryRequestQuery}&country=${selectedCountry}&symbol=${encodeURIComponent(selectedSymbol)}`,
              { method: 'GET', signal: abortController.signal, credentials: 'omit' },
            );
            let parsedResponse: unknown = null;
            try {
              parsedResponse = await response.json();
            } catch {
              parsedResponse = null;
            }
            if (isOwnerLocalKisLlmSummaryResponse(parsedResponse)) {
              if (parsedResponse.summary.ok) {
                if (ownerLocalKisLlmSummaryStatus) ownerLocalKisLlmSummaryStatus.textContent = '완료';
                renderOwnerLocalKisLlmSummarySuccess(parsedResponse.summary);
              } else {
                if (ownerLocalKisLlmSummaryStatus) ownerLocalKisLlmSummaryStatus.textContent = '사용 불가';
                renderOwnerLocalKisLlmSummaryBlocked(parsedResponse.summary);
              }
            } else {
              showOwnerLocalKisLlmSummaryMessage(
                useProductionFacingSummaryPresentation
                  ? '요약 결과를 불러오지 못했습니다. 다시 실행 버튼으로 재시도해 주세요.'
                  : '로컬 전용 KIS + LLM 요약 결과를 불러오지 못했습니다. 다시 실행 버튼으로 재시도해 주세요.',
                'unavailable',
              );
            }
          } catch (thrownError) {
            if (thrownError instanceof DOMException && thrownError.name === 'AbortError') {
              showOwnerLocalKisLlmSummaryMessage('요청 시간이 초과되었습니다. 다시 실행 버튼으로 재시도해 주세요.', 'unavailable');
            } else {
              showOwnerLocalKisLlmSummaryMessage(
                useProductionFacingSummaryPresentation
                  ? '요약 결과를 불러오지 못했습니다. 다시 실행 버튼으로 재시도해 주세요.'
                  : '로컬 전용 KIS + LLM 요약 결과를 불러오지 못했습니다. 다시 실행 버튼으로 재시도해 주세요.',
                'unavailable',
              );
            }
          } finally {
            window.clearTimeout(timeoutId);
            ownerLocalKisLlmSummaryRequestInFlight = false;
            ownerLocalKisLlmSummaryButton.disabled = false;
            ownerLocalKisLlmSummaryButton.textContent = '다시 실행';
            if (ownerLocalKisLlmSummaryOutput) ownerLocalKisLlmSummaryOutput.removeAttribute('aria-busy');
          }
        });
      }

      // Owner-local auth/usage runtime bridge verification panel (Phase 3FB-E).
      // Local-only, explicit opt-in: hidden unless hostname is localhost/127.0.0.1/::1 AND the
      // URL carries `?ownerLocalAuthUsageBridge=1`. Never auto-runs; the API call only happens on
      // an explicit scenario button click. Calls the owner-local-auth-usage-bridge branch of
      // `/api/chart-ai/similarity` (Phase 3FB-C-ALT) with caller-supplied mock auth/usage state,
      // and renders only sanitized, bucketed fields — never raw provider payload, OHLC values,
      // prices, volume, real timestamps, raw matches, similarity scores, returns, secret material,
      // env values, session/user id, IP address, or brokerage-sensitive fields.
      const authUsageBridgePanel = document.getElementById('chartAiOwnerLocalAuthUsageBridgePanel');
      const authUsageBridgeResult = document.getElementById('chartAiOwnerLocalAuthUsageBridgeResult');
      const authUsageBridgeButtons = document.querySelectorAll<HTMLButtonElement>('.chart-owner-local-auth-usage-bridge-btn');
      if (authUsageBridgeResult) authUsageBridgeResult.tabIndex = -1;

      const authUsageBridgeOptIn = new URLSearchParams(window.location.search).get('ownerLocalAuthUsageBridge') === '1';
      const authUsageBridgeEnabled = mockedChartAiAccess.capabilities.canAccessChartAi && isLocalOwnerHostname() && authUsageBridgeOptIn;

      if (authUsageBridgePanel) authUsageBridgePanel.hidden = !authUsageBridgeEnabled;

      const AUTH_USAGE_BRIDGE_TIMEOUT_MS = 8000;
      let authUsageBridgeRequestInFlight = false;

      const showAuthUsageBridgeMessage = (text: string) => {
        if (!authUsageBridgeResult) return;
        authUsageBridgeResult.hidden = false;
        authUsageBridgeResult.replaceChildren();
        const message = document.createElement('p');
        message.className = 'chart-owner-local-auth-usage-bridge-msg';
        message.textContent = text;
        authUsageBridgeResult.append(message);
      };

      type AuthUsageBridgeScenario = 'allowed' | 'anonymous' | 'usage-limited' | 'invalid';

      const buildAuthUsageBridgeRequestBody = (scenario: AuthUsageBridgeScenario) => {
        const symbol = selectedSymbol || 'MOCKSYM';
        const base = {
          mode: 'owner-local-auth-usage-bridge',
          source: 'mocked-provider-compatible',
          ownerLocalAuthUsageBridge: true,
          symbol,
          assetType: 'stock',
        };
        if (scenario === 'anonymous') {
          return {
            ...base,
            mockAuth: { state: 'anonymous', role: 'anonymous' },
            mockUsage: { window: 'daily', used: 0, limit: 3, remaining: 3 },
          };
        }
        if (scenario === 'usage-limited') {
          return {
            ...base,
            mockAuth: { state: 'authenticated', role: 'owner' },
            mockUsage: { window: 'daily', used: 50, limit: 50, remaining: 0 },
          };
        }
        if (scenario === 'invalid') {
          return {
            ...base,
            mockAuth: { state: 'authenticated', role: 'owner' },
            mockUsage: { window: 'daily', used: 10, limit: 5, remaining: 0 },
          };
        }
        return {
          ...base,
          mockAuth: { state: 'authenticated', role: 'owner' },
          mockUsage: { window: 'daily', used: 0, limit: 50, remaining: 50 },
        };
      };

      // Response shape guard (success): validates the parsed body is exactly the sanitized
      // owner-local-auth-usage-bridge success shape before anything is rendered. Any missing or
      // wrong-typed field falls through to the safe static error path below.
      type AuthUsageBridgeSuccessResponse = {
        status: string;
        mode: string;
        request: { source: string; symbol: string; assetType: string };
        data: {
          guardStatus: string;
          authState: string;
          role: string;
          usageWindow: string;
          usageRemainingBucket: string;
          engineStatus: string;
          normalizedBarsAvailable: boolean;
          normalizedBarCountBucket: string;
          matchCountBucket: string;
          disclaimer: string;
          dataPolicy: {
            ownerLocalOnly?: boolean;
            allowLiveKis?: boolean;
            allowRouteSuccess?: boolean;
            allowPublicExecution?: boolean;
            allowBetaExecution?: boolean;
          };
        };
      };

      const isAuthUsageBridgeSuccessResponse = (value: unknown): value is AuthUsageBridgeSuccessResponse => {
        if (!value || typeof value !== 'object') return false;
        const record = value as Record<string, unknown>;
        if (record.ok !== true) return false;
        if (record.status !== 'success') return false;
        if (record.mode !== 'owner-local-auth-usage-bridge') return false;
        const request = record.request;
        if (!request || typeof request !== 'object') return false;
        if ((request as Record<string, unknown>).source !== 'mocked-provider-compatible') return false;
        const data = record.data;
        if (!data || typeof data !== 'object') return false;
        const resultData = data as Record<string, unknown>;
        if (typeof resultData.guardStatus !== 'string') return false;
        if (typeof resultData.authState !== 'string') return false;
        if (typeof resultData.role !== 'string') return false;
        if (typeof resultData.usageWindow !== 'string') return false;
        if (typeof resultData.usageRemainingBucket !== 'string') return false;
        if (typeof resultData.engineStatus !== 'string') return false;
        if (typeof resultData.normalizedBarsAvailable !== 'boolean') return false;
        if (typeof resultData.normalizedBarCountBucket !== 'string') return false;
        if (typeof resultData.matchCountBucket !== 'string') return false;
        if (!resultData.dataPolicy || typeof resultData.dataPolicy !== 'object') return false;
        if (typeof resultData.disclaimer !== 'string') return false;
        return true;
      };

      const AUTH_USAGE_BRIDGE_BLOCKED_STATUSES = new Set([
        'auth_required',
        'usage_limited',
        'blocked',
        'feature_disabled',
        'error',
        'not_configured',
      ]);

      // Response shape guard (blocked): validates a safe, sanitized blocked/error shape before
      // rendering. Any missing or wrong-typed field falls through to the safe static error path.
      type AuthUsageBridgeBlockedResponse = {
        status: string;
        mode: string;
        error: { code: string; message: string; retryable: boolean };
      };

      const isAuthUsageBridgeBlockedResponse = (value: unknown): value is AuthUsageBridgeBlockedResponse => {
        if (!value || typeof value !== 'object') return false;
        const record = value as Record<string, unknown>;
        if (record.ok !== false) return false;
        if (typeof record.status !== 'string' || !AUTH_USAGE_BRIDGE_BLOCKED_STATUSES.has(record.status)) return false;
        if (record.mode !== 'owner-local-auth-usage-bridge' && record.mode !== 'feature-flag-off') return false;
        const error = record.error;
        if (!error || typeof error !== 'object') return false;
        const errorRecord = error as Record<string, unknown>;
        if (typeof errorRecord.code !== 'string') return false;
        if (typeof errorRecord.message !== 'string') return false;
        if (typeof errorRecord.retryable !== 'boolean') return false;
        return true;
      };

      const renderAuthUsageBridgeSuccess = (data: AuthUsageBridgeSuccessResponse) => {
        if (!authUsageBridgeResult) return;
        const resultData = data.data;
        authUsageBridgeResult.hidden = false;
        authUsageBridgeResult.replaceChildren();

        const summaryList = document.createElement('dl');
        summaryList.className = 'chart-owner-local-auth-usage-bridge-dl';
        const summaryRows: Array<[string, string]> = [
          ['상태', data.status ?? '-'],
          ['모드', data.mode ?? '-'],
          ['데이터 소스', data.request?.source ?? '-'],
          ['guard 상태', resultData.guardStatus ?? '-'],
          ['인증 상태', resultData.authState ?? '-'],
          ['역할', resultData.role ?? '-'],
          ['사용량 주기', resultData.usageWindow ?? '-'],
          ['잔여 사용량 버킷', resultData.usageRemainingBucket ?? '-'],
          ['엔진 상태', resultData.engineStatus ?? '-'],
          ['정규화 데이터 여부', resultData.normalizedBarsAvailable ? '있음' : '없음'],
          ['정규화 구간 버킷', resultData.normalizedBarCountBucket ?? '-'],
          ['매칭 구간 버킷', resultData.matchCountBucket ?? '-'],
        ];
        for (const [label, value] of summaryRows) {
          const dt = document.createElement('dt');
          dt.textContent = label;
          const dd = document.createElement('dd');
          dd.textContent = value;
          summaryList.append(dt, dd);
        }
        authUsageBridgeResult.append(summaryList);

        if (resultData.dataPolicy) {
          const policy = resultData.dataPolicy;
          const policyList = document.createElement('ul');
          policyList.className = 'chart-owner-local-auth-usage-bridge-policy-list';
          const policyRows: Array<[string, boolean | undefined]> = [
            ['오너 로컬 전용', policy.ownerLocalOnly],
            ['실시간 KIS 허용', policy.allowLiveKis],
            ['라우트 성공 허용', policy.allowRouteSuccess],
            ['공개 실행 허용', policy.allowPublicExecution],
            ['베타 실행 허용', policy.allowBetaExecution],
          ];
          for (const [label, value] of policyRows) {
            const li = document.createElement('li');
            li.textContent = `${label}: ${value ? '예' : '아니오'}`;
            policyList.append(li);
          }
          authUsageBridgeResult.append(policyList);
        }

        if (resultData.disclaimer) {
          const disclaimer = document.createElement('p');
          disclaimer.className = 'chart-owner-local-auth-usage-bridge-disclaimer';
          disclaimer.textContent = resultData.disclaimer;
          authUsageBridgeResult.append(disclaimer);
        }
      };

      const renderAuthUsageBridgeBlocked = (data: AuthUsageBridgeBlockedResponse) => {
        if (!authUsageBridgeResult) return;
        authUsageBridgeResult.hidden = false;
        authUsageBridgeResult.replaceChildren();

        const summaryList = document.createElement('dl');
        summaryList.className = 'chart-owner-local-auth-usage-bridge-dl';
        const summaryRows: Array<[string, string]> = [
          ['상태', data.status ?? '-'],
          ['모드', data.mode ?? '-'],
          ['오류 코드', data.error?.code ?? '-'],
          ['재시도 가능', data.error?.retryable ? '예' : '아니오'],
        ];
        for (const [label, value] of summaryRows) {
          const dt = document.createElement('dt');
          dt.textContent = label;
          const dd = document.createElement('dd');
          dd.textContent = value;
          summaryList.append(dt, dd);
        }
        authUsageBridgeResult.append(summaryList);

        if (data.error?.message) {
          const message = document.createElement('p');
          message.className = 'chart-owner-local-auth-usage-bridge-msg';
          message.textContent = data.error.message;
          authUsageBridgeResult.append(message);
        }
      };

      if (authUsageBridgeButtons.length > 0 && authUsageBridgeEnabled) {
        authUsageBridgeButtons.forEach((button) => {
          button.addEventListener('click', async () => {
            if (authUsageBridgeRequestInFlight) return;
            const scenario = (button.dataset.scenario ?? 'allowed') as AuthUsageBridgeScenario;
            authUsageBridgeRequestInFlight = true;
            authUsageBridgeButtons.forEach((btn) => { btn.disabled = true; });
            if (authUsageBridgeResult) authUsageBridgeResult.setAttribute('aria-busy', 'true');
            showAuthUsageBridgeMessage('불러오는 중… (mock auth/usage 상태, 로컬 개발 검증용)');

            const abortController = new AbortController();
            const timeoutId = window.setTimeout(() => abortController.abort(), AUTH_USAGE_BRIDGE_TIMEOUT_MS);

            try {
              const response = await fetch('/api/chart-ai/similarity', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(buildAuthUsageBridgeRequestBody(scenario)),
                signal: abortController.signal,
              });
              let parsedResponse: unknown = null;
              try {
                parsedResponse = await response.json();
              } catch {
                parsedResponse = null;
              }
              if (isAuthUsageBridgeSuccessResponse(parsedResponse)) {
                renderAuthUsageBridgeSuccess(parsedResponse);
              } else if (isAuthUsageBridgeBlockedResponse(parsedResponse)) {
                renderAuthUsageBridgeBlocked(parsedResponse);
              } else {
                showAuthUsageBridgeMessage('Auth/usage bridge 실행 결과를 불러오지 못했습니다. 다른 시나리오 버튼으로 재시도해 주세요.');
              }
            } catch (thrownError) {
              if (thrownError instanceof DOMException && thrownError.name === 'AbortError') {
                showAuthUsageBridgeMessage('요청 시간이 초과되었습니다. 다른 시나리오 버튼으로 재시도해 주세요.');
              } else {
                showAuthUsageBridgeMessage('Auth/usage bridge 실행 결과를 불러오지 못했습니다. 다른 시나리오 버튼으로 재시도해 주세요.');
              }
            } finally {
              window.clearTimeout(timeoutId);
              authUsageBridgeRequestInFlight = false;
              authUsageBridgeButtons.forEach((btn) => { btn.disabled = false; });
              if (authUsageBridgeResult) authUsageBridgeResult.removeAttribute('aria-busy');
            }
          });
        });
      }

      // Phase 3GG-OP-FAST: run the initial selection LAST, after every setup() declaration is
      // initialized (updateSelection transitively references consts defined throughout setup, so an
      // earlier call would hit a temporal-dead-zone ReferenceError). Production resolves the URL/default
      // instrument and loads the real chart; other runtimes render the non-production sample chart.
      if (productionRealChartEnabled) {
        initProductionInstrument();
      } else {
        renderChart();
      }
    };

    // Phase 3GG-T-HF1: real Supabase auth gate. Chart AI now requires login exactly like /portfolio.
    // When signed out we render the same lock card (🔐 · 접속 필요 · 로그인이 필요합니다) and DO NOT
    // initialize the workspace or issue ANY provider/KIS/token request. setup() (which owns every
    // fetch) only runs for an authenticated session, so merely opening the page is zero-request.
    const runChartAiAuthGate = async (): Promise<boolean> => {
      const authShell = document.querySelector<HTMLElement>('.chart-ai-auth-shell');
      const authGate = document.querySelector<HTMLElement>('[data-chart-ai-auth-gate="locked"]');
      const authGateCta = document.querySelector<HTMLButtonElement>('[data-chart-ai-auth-gate-cta]');
      const authBody = document.querySelector<HTMLElement>('[data-chart-ai-auth-body]');
      const showLocked = () => {
        if (authShell) authShell.dataset.chartAiAuthState = 'anonymous';
        if (authGate) authGate.hidden = false;
        if (authBody) authBody.hidden = true;
      };
      const showAuthed = () => {
        if (authShell) authShell.dataset.chartAiAuthState = 'authenticated';
        if (authGate) authGate.hidden = true;
        if (authBody) authBody.hidden = false;
      };
      if (authGateCta && authGateCta.dataset.bound !== 'true') {
        authGateCta.dataset.bound = 'true';
        authGateCta.addEventListener('click', () => window.dispatchEvent(new CustomEvent('mk:open-auth')));
      }
      if (!isSupabaseConfigured()) { showLocked(); return false; }
      const supa = getBrowserSupabaseClient();
      let session = null;
      try { session = supa ? (await supa.auth.getSession()).data.session : null; } catch { session = null; }
      if (!session) { showLocked(); return false; }
      showAuthed();
      return true;
    };

    const bootChartAi = async () => {
      const authed = await runChartAiAuthGate();
      if (authed) setup();
    };

    let chartAiAuthListenerBound = false;
    const bindChartAiAuthListener = () => {
      if (chartAiAuthListenerBound) return;
      chartAiAuthListenerBound = true;
      window.addEventListener('mk:auth-state', (event) => {
        const detail = (event as CustomEvent).detail;
        if (detail?.status === 'signed_in') void bootChartAi();
        if (detail?.status === 'signed_out') void runChartAiAuthGate();
      });
    };

    document.addEventListener('astro:page-load', () => { bindChartAiAuthListener(); void bootChartAi(); });
    bindChartAiAuthListener();
    void bootChartAi();
  </script>

