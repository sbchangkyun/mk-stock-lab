---
import Layout from '../layouts/Layout.astro';
import { getClientSafeDomesticSymbolRecords } from '../lib/symbol-master/domesticSymbolMaster';

const clientSafeDomesticSymbols = getClientSafeDomesticSymbolRecords();
const clientSafeDomesticSymbolPayload = JSON.stringify(clientSafeDomesticSymbols)
  .replaceAll('<', '\\u003c');
---

<Layout title="종목 차트 | MK Stock Lab" activePath="/chart-ai">
  <header class="page-header chart-lookup-page-header">
    <div>
      <p class="eyebrow">국내 주식·ETF</p>
      <h1>종목 차트</h1>
      <p class="lead">종목을 조회하고 차트 중심의 기본 정보를 확인하세요. 현재 화면은 안전한 샘플 데이터로 구성되어 있습니다.</p>
    </div>
  </header>

  <main class="chart-lookup-shell">
    <section class="chart-lookup-search" aria-labelledby="chart-lookup-search-heading">
      <div class="chart-ai-symbol-row">
        <label class="chart-search-shell chart-lookup-search-field" for="chartAiInput">
          <span id="chart-lookup-search-heading">종목 검색</span>
          <input
            id="chartAiInput"
            type="search"
            placeholder="종목명 또는 종목코드 입력"
            aria-label="종목명 또는 종목코드 입력"
            aria-controls="chartAiSearchResults"
            aria-describedby="chartAiSearchExamples"
            aria-autocomplete="list"
            aria-expanded="false"
            role="combobox"
            autocomplete="off"
            spellcheck="false"
          />
        </label>
        <button class="button-link chart-ai-run-btn chart-lookup-submit" id="chartAiRunBtn" type="button">조회</button>
      </div>

      <div class="chart-lookup-search-tools">
        <p id="chartAiSearchExamples">005930 · 삼성 · 000660 · 하이닉스 · 069500 · KODEX</p>
        <div class="chart-ai-filter-bar" role="group" aria-label="종목 유형 필터">
          <button class="chart-ai-filter-btn active" type="button" data-asset-filter="all" aria-pressed="true">전체</button>
          <button class="chart-ai-filter-btn" type="button" data-asset-filter="stock" aria-pressed="false">주식</button>
          <button class="chart-ai-filter-btn" type="button" data-asset-filter="etf" aria-pressed="false">ETF</button>
        </div>
      </div>

      <div class="chart-lookup-dropdown" id="chartAiSearchDropdown" hidden>
        <div class="chart-ai-results-head">
          <strong>검색 결과</strong>
          <span id="chartAiResultCount" aria-live="polite">0개</span>
        </div>
        <div
          class="chart-ai-search-results"
          id="chartAiSearchResults"
          role="listbox"
          aria-label="국내 종목 검색 결과"
        ></div>
        <p class="chart-ai-empty-state" id="chartAiEmptyState" hidden aria-live="polite">
          검색 결과가 없습니다. 종목명이나 종목코드를 다시 확인해 주세요.
        </p>
      </div>
    </section>

    <section class="chart-stock-header" aria-labelledby="chartAiSelectedName" aria-live="polite">
      <div class="chart-stock-identity">
        <div class="chart-stock-title-line">
          <h2 id="chartAiSelectedName">삼성전자</h2>
          <span id="chartAiSelectedSymbol">005930</span>
        </div>
        <div class="chart-stock-tags" aria-label="선택 종목 기본 정보">
          <span id="chartAiSelectedExchange">KOSPI</span>
          <span id="chartAiSelectedAssetType">주식</span>
          <span id="chartAiSelectedCurrency">KRW</span>
        </div>
      </div>
      <div class="chart-stock-source">
        <strong>샘플 데이터</strong>
        <span>실제 시세 아님</span>
      </div>
    </section>

    <div class="chart-lookup-content-grid">
      <section class="chart-market-panel" aria-labelledby="chart-market-heading">
        <div class="chart-market-rail">
          <div class="chart-market-heading-group">
            <button
              class="chart-mk-ai-button"
              id="chartAiMkAiBtn"
              type="button"
              aria-expanded="false"
              aria-controls="chartAiMkAiNote"
            >MK AI</button>
            <div>
              <p class="chart-market-kicker">차트</p>
              <h2 id="chart-market-heading">샘플 차트</h2>
            </div>
          </div>
          <div class="chart-market-status">
            <span>캔들 차트 준비</span>
            <strong>실제 시세 아님</strong>
          </div>
        </div>

        <div class="chart-period-controls" role="group" aria-label="차트 기간 선택">
          <button type="button" data-period="1d" aria-pressed="true" class="active">1일</button>
          <button type="button" data-period="1w" aria-pressed="false">1주</button>
          <button type="button" data-period="1m" aria-pressed="false">1개월</button>
          <button type="button" data-period="3m" aria-pressed="false">3개월</button>
          <button type="button" data-period="1y" aria-pressed="false">1년</button>
        </div>

        <div class="chart-candlestick-ready" aria-label="캔들 차트 준비 영역">
          <div class="chart-axis-labels" aria-hidden="true">
            <span>고가</span>
            <span>중간</span>
            <span>저가</span>
          </div>
          <div class="chart-candle-stage" aria-hidden="true">
            <i class="up short"></i><i class="down medium"></i><i class="up tall"></i><i class="up medium"></i>
            <i class="down short"></i><i class="down tall"></i><i class="up medium"></i><i class="up tall"></i>
            <i class="down medium"></i><i class="up short"></i><i class="up medium"></i><i class="down short"></i>
            <i class="up tall"></i><i class="down medium"></i><i class="up short"></i><i class="up tall"></i>
          </div>
          <div class="chart-volume-reserve" aria-hidden="true">
            <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
            <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
          </div>
          <div class="chart-ready-message">
            <strong>캔들·거래량 영역</strong>
            <span>HF2에서 샘플 OHLC와 거래량 데이터가 연결됩니다.</span>
          </div>
        </div>

        <div class="chart-mk-ai-note" id="chartAiMkAiNote" hidden>
          <strong>MK AI 분석 준비</strong>
          <p>MK AI 분석은 다음 단계에서 버튼 클릭 후 안내와 함께 시작됩니다.</p>
        </div>
      </section>

      <aside class="chart-stock-sidebar">
        <section class="panel chart-stock-metadata" aria-labelledby="chart-stock-metadata-heading">
          <div class="chart-sidebar-heading">
            <p class="eyebrow">기본 정보</p>
            <h2 id="chart-stock-metadata-heading">종목 정보</h2>
          </div>
          <dl>
            <div><dt>거래소</dt><dd id="chartAiMetaExchange">KOSPI</dd></div>
            <div><dt>자산 유형</dt><dd id="chartAiMetaAssetType">주식</dd></div>
            <div><dt>통화</dt><dd id="chartAiMetaCurrency">KRW</dd></div>
            <div><dt>데이터 상태</dt><dd>샘플 데이터</dd></div>
          </dl>
        </section>

        <section class="panel chart-company-placeholder" aria-labelledby="chart-company-heading">
          <div class="chart-sidebar-heading">
            <p class="eyebrow">샘플 정보</p>
            <h2 id="chart-company-heading">기업 개요</h2>
          </div>
          <p>선택한 종목의 사업 내용과 기본 정보는 이후 companyProfile 데이터와 연결될 예정입니다.</p>
          <small>샘플 정보 · 실제 투자 판단용 아님</small>
        </section>
      </aside>
    </div>

    <aside class="chart-lookup-disclaimer" aria-label="데이터 이용 안내">
      <strong>샘플 화면</strong>
      <span>차트와 종목 정보는 화면 구조 확인용이며 투자 판단이나 매수·매도 추천이 아닙니다.</span>
    </aside>
  </main>

  <script
    id="chartAiDomesticSymbolData"
    type="application/json"
    set:html={clientSafeDomesticSymbolPayload}
  ></script>

  <script>
    import { searchClientSafeDomesticSymbols } from '../lib/symbol-master/clientSymbolSearch';
    import type { ClientSafeSymbolSearchRecord, DomesticAssetType } from '../lib/symbol-master/types';

    const assetTypeLabel = (assetType: DomesticAssetType): string => {
      if (assetType === 'stock') return '주식';
      if (assetType === 'etf') return 'ETF';
      if (assetType === 'etn') return 'ETN';
      return '기타';
    };

    const parseClientSafeRecords = (): ClientSafeSymbolSearchRecord[] => {
      const payload = document.getElementById('chartAiDomesticSymbolData')?.textContent ?? '[]';
      try {
        const parsed: unknown = JSON.parse(payload);
        return Array.isArray(parsed) ? parsed as ClientSafeSymbolSearchRecord[] : [];
      } catch {
        return [];
      }
    };

    const setup = () => {
      const input = document.getElementById('chartAiInput') as HTMLInputElement | null;
      const runBtn = document.getElementById('chartAiRunBtn') as HTMLButtonElement | null;
      const dropdown = document.getElementById('chartAiSearchDropdown');
      const resultsEl = document.getElementById('chartAiSearchResults');
      const resultCount = document.getElementById('chartAiResultCount');
      const emptyState = document.getElementById('chartAiEmptyState');
      const filterButtons = document.querySelectorAll<HTMLButtonElement>('.chart-ai-filter-btn');
      const periodButtons = document.querySelectorAll<HTMLButtonElement>('[data-period]');
      const mkAiButton = document.getElementById('chartAiMkAiBtn') as HTMLButtonElement | null;
      const mkAiNote = document.getElementById('chartAiMkAiNote');
      const records = parseClientSafeRecords();
      let activeFilter: DomesticAssetType | 'all' = 'all';
      let selectedSymbol = '005930';
      let visibleRecords: ClientSafeSymbolSearchRecord[] = [];

      if (!input || !runBtn || !dropdown || !resultsEl || !resultCount || !emptyState) return;
      if (runBtn.dataset.ready === 'true') return;
      runBtn.dataset.ready = 'true';

      const setText = (id: string, text: string) => {
        const element = document.getElementById(id);
        if (element) element.textContent = text;
      };

      const closeDropdown = () => {
        dropdown.hidden = true;
        input.setAttribute('aria-expanded', 'false');
      };

      const updateSelection = (record: ClientSafeSymbolSearchRecord) => {
        selectedSymbol = record.symbol;
        setText('chartAiSelectedName', record.nameKo);
        setText('chartAiSelectedSymbol', record.symbol);
        setText('chartAiSelectedExchange', record.exchange);
        setText('chartAiSelectedAssetType', assetTypeLabel(record.assetType));
        setText('chartAiSelectedCurrency', record.currency);
        setText('chartAiMetaExchange', record.exchange);
        setText('chartAiMetaAssetType', assetTypeLabel(record.assetType));
        setText('chartAiMetaCurrency', record.currency);
        input.value = '';
        closeDropdown();
      };

      const renderResults = (open = true) => {
        visibleRecords = searchClientSafeDomesticSymbols(records, {
          query: input.value,
          limit: 15,
          assetTypes: activeFilter === 'all' ? undefined : [activeFilter],
          includeStatuses: ['active'],
        });
        resultsEl.replaceChildren();
        resultCount.textContent = `${visibleRecords.length}개`;
        emptyState.hidden = visibleRecords.length > 0;
        dropdown.hidden = !open;
        input.setAttribute('aria-expanded', String(open));

        for (const record of visibleRecords) {
          const button = document.createElement('button');
          const isSelected = record.symbol === selectedSymbol;
          button.type = 'button';
          button.className = 'chart-ai-search-result';
          button.dataset.symbol = record.symbol;
          button.setAttribute('role', 'option');
          button.setAttribute('aria-selected', String(isSelected));
          button.classList.toggle('selected', isSelected);

          const name = document.createElement('strong');
          name.textContent = record.nameKo;
          const metadata = document.createElement('span');
          metadata.textContent = record.assetType === 'etf'
            ? `${record.symbol} · ${record.exchange} · ${record.currency}`
            : `${record.symbol} · ${record.exchange} · ${assetTypeLabel(record.assetType)}`;
          button.append(name, metadata);
          button.addEventListener('click', () => updateSelection(record));
          resultsEl.append(button);
        }
      };

      filterButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const filter = button.dataset.assetFilter;
          if (filter !== 'all' && filter !== 'stock' && filter !== 'etf') return;
          activeFilter = filter;
          filterButtons.forEach((candidate) => {
            const active = candidate === button;
            candidate.classList.toggle('active', active);
            candidate.setAttribute('aria-pressed', String(active));
          });
          renderResults(true);
        });
      });

      input.addEventListener('focus', () => renderResults(true));
      input.addEventListener('input', () => renderResults(true));
      input.addEventListener('keydown', (event: KeyboardEvent) => {
        if (event.key === 'Enter') {
          event.preventDefault();
          runBtn.click();
        }
        if (event.key === 'ArrowDown') {
          const firstResult = resultsEl.querySelector<HTMLButtonElement>('.chart-ai-search-result');
          if (firstResult) {
            event.preventDefault();
            firstResult.focus();
          }
        }
        if (event.key === 'Escape') closeDropdown();
      });
      runBtn.addEventListener('click', () => {
        renderResults(true);
        if (visibleRecords[0]) updateSelection(visibleRecords[0]);
      });

      periodButtons.forEach((button) => {
        button.addEventListener('click', () => {
          periodButtons.forEach((candidate) => {
            const active = candidate === button;
            candidate.classList.toggle('active', active);
            candidate.setAttribute('aria-pressed', String(active));
          });
        });
      });

      mkAiButton?.addEventListener('click', () => {
        if (!mkAiNote) return;
        const expanded = mkAiButton.getAttribute('aria-expanded') === 'true';
        mkAiButton.setAttribute('aria-expanded', String(!expanded));
        mkAiNote.hidden = expanded;
      });
    };

    document.addEventListener('astro:page-load', setup);
    setup();
  </script>

  <style>
    .chart-lookup-page-header {
      padding-bottom: 0.2rem;
    }

    .chart-lookup-page-header .lead {
      max-width: 680px;
    }

    .chart-lookup-shell {
      display: grid;
      gap: 1rem;
      min-width: 0;
    }

    .chart-lookup-search {
      position: relative;
      z-index: 4;
      padding: 1rem;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: var(--surface);
      box-shadow: 0 10px 30px rgb(15 23 42 / 5%);
    }

    .chart-lookup-search-field span {
      font-size: 0.76rem;
      font-weight: 800;
      letter-spacing: 0.04em;
    }

    .chart-lookup-submit {
      min-width: 76px;
    }

    .chart-lookup-search-tools,
    .chart-ai-results-head,
    .chart-stock-title-line,
    .chart-market-rail,
    .chart-market-heading-group,
    .chart-market-status,
    .chart-sidebar-heading {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .chart-lookup-search-tools {
      margin-top: 0.65rem;
    }

    .chart-lookup-search-tools p {
      margin: 0;
      color: var(--text-muted);
      font-size: 0.76rem;
      overflow-wrap: anywhere;
    }

    .chart-ai-filter-bar {
      display: flex;
      flex: 0 0 auto;
      gap: 0.35rem;
    }

    .chart-ai-filter-btn {
      min-height: 30px;
      padding: 0.25rem 0.65rem;
      border: 1px solid var(--border);
      border-radius: 999px;
      background: var(--surface-muted);
      color: var(--text-muted);
      font: inherit;
      font-size: 0.74rem;
      font-weight: 750;
      cursor: pointer;
    }

    .chart-ai-filter-btn.active {
      border-color: color-mix(in srgb, var(--primary) 55%, var(--border));
      background: color-mix(in srgb, var(--primary) 10%, var(--surface));
      color: var(--primary);
    }

    .chart-lookup-dropdown {
      position: absolute;
      top: calc(100% - 0.45rem);
      right: 1rem;
      left: 1rem;
      overflow: hidden;
      border: 1px solid var(--border);
      border-radius: 12px;
      background: var(--surface);
      box-shadow: 0 20px 45px rgb(15 23 42 / 16%);
    }

    .chart-ai-results-head {
      padding: 0.55rem 0.75rem;
      border-bottom: 1px solid var(--border);
      color: var(--text-muted);
      font-size: 0.76rem;
    }

    .chart-ai-search-results {
      max-height: 250px;
      overflow-y: auto;
      overscroll-behavior: contain;
    }

    .chart-ai-search-result {
      display: grid;
      gap: 0.18rem;
      width: 100%;
      min-height: 52px;
      padding: 0.58rem 0.75rem;
      border: 0;
      border-bottom: 1px solid var(--border);
      background: transparent;
      color: var(--text);
      font: inherit;
      text-align: left;
      cursor: pointer;
    }

    .chart-ai-search-result:last-child {
      border-bottom: 0;
    }

    .chart-ai-search-result:hover,
    .chart-ai-search-result.selected {
      background: color-mix(in srgb, var(--primary) 7%, var(--surface));
    }

    .chart-ai-search-result.selected {
      box-shadow: inset 3px 0 0 var(--primary);
    }

    .chart-ai-search-result strong {
      font-size: 0.88rem;
    }

    .chart-ai-search-result span {
      color: var(--text-muted);
      font-size: 0.75rem;
    }

    .chart-ai-empty-state {
      margin: 0;
      padding: 1rem;
      color: var(--text-muted);
      font-size: 0.82rem;
      text-align: center;
    }

    .chart-stock-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.25rem;
      min-width: 0;
      padding: 1.05rem 1.2rem;
      border: 1px solid var(--border);
      border-radius: 14px;
      background: var(--surface);
    }

    .chart-stock-identity {
      min-width: 0;
    }

    .chart-stock-title-line {
      justify-content: flex-start;
      align-items: baseline;
    }

    .chart-stock-title-line h2 {
      margin: 0;
      font-size: clamp(1.35rem, 3vw, 1.85rem);
      letter-spacing: -0.035em;
    }

    .chart-stock-title-line > span {
      color: var(--text-muted);
      font-size: 0.9rem;
      font-variant-numeric: tabular-nums;
      font-weight: 700;
    }

    .chart-stock-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      margin-top: 0.45rem;
    }

    .chart-stock-tags span {
      padding: 0.2rem 0.48rem;
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text-muted);
      font-size: 0.7rem;
      font-weight: 700;
    }

    .chart-stock-source {
      display: grid;
      flex: 0 0 auto;
      gap: 0.2rem;
      text-align: right;
    }

    .chart-stock-source strong {
      color: var(--primary);
      font-size: 0.78rem;
    }

    .chart-stock-source span {
      color: var(--text-muted);
      font-size: 0.72rem;
    }

    .chart-lookup-content-grid {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(240px, 300px);
      gap: 1rem;
      min-width: 0;
    }

    .chart-market-panel {
      min-width: 0;
      overflow: hidden;
      border: 1px solid #24324a;
      border-radius: 16px;
      background: #0d1728;
      color: #e5edf8;
      box-shadow: 0 18px 42px rgb(15 23 42 / 18%);
    }

    .chart-market-rail {
      min-height: 72px;
      padding: 0.85rem 1rem;
      border-bottom: 1px solid rgb(148 163 184 / 18%);
      background: #111e32;
    }

    .chart-market-heading-group {
      justify-content: flex-start;
    }

    .chart-market-kicker,
    .chart-market-heading-group h2,
    .chart-mk-ai-note p {
      margin: 0;
    }

    .chart-market-kicker {
      color: #91a3ba;
      font-size: 0.7rem;
      font-weight: 750;
      letter-spacing: 0.08em;
    }

    .chart-market-heading-group h2 {
      margin-top: 0.12rem;
      font-size: 1rem;
    }

    .chart-mk-ai-button {
      min-height: 38px;
      padding: 0.45rem 0.72rem;
      border: 1px solid #5a78ff;
      border-radius: 8px;
      background: #3153e8;
      color: #fff;
      font: inherit;
      font-size: 0.78rem;
      font-weight: 850;
      letter-spacing: 0.02em;
      cursor: pointer;
      box-shadow: 0 7px 18px rgb(49 83 232 / 28%);
    }

    .chart-market-status {
      display: grid;
      justify-items: end;
      gap: 0.12rem;
    }

    .chart-market-status span,
    .chart-market-status strong {
      font-size: 0.7rem;
    }

    .chart-market-status span {
      color: #91a3ba;
    }

    .chart-market-status strong {
      color: #f5c96a;
    }

    .chart-period-controls {
      display: flex;
      gap: 0.3rem;
      overflow-x: auto;
      padding: 0.65rem 1rem;
      border-bottom: 1px solid rgb(148 163 184 / 14%);
      scrollbar-width: thin;
    }

    .chart-period-controls button {
      flex: 0 0 auto;
      min-width: 48px;
      min-height: 32px;
      padding: 0.25rem 0.55rem;
      border: 1px solid transparent;
      border-radius: 6px;
      background: transparent;
      color: #91a3ba;
      font: inherit;
      font-size: 0.72rem;
      font-weight: 750;
      cursor: pointer;
    }

    .chart-period-controls button.active {
      border-color: rgb(109 133 255 / 42%);
      background: rgb(90 120 255 / 14%);
      color: #dfe6ff;
    }

    .chart-candlestick-ready {
      position: relative;
      min-height: 390px;
      overflow: hidden;
      background-image:
        linear-gradient(rgb(148 163 184 / 8%) 1px, transparent 1px),
        linear-gradient(90deg, rgb(148 163 184 / 7%) 1px, transparent 1px);
      background-size: 100% 25%, 12.5% 100%;
    }

    .chart-axis-labels {
      position: absolute;
      top: 1rem;
      right: 0.8rem;
      bottom: 7rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      color: #60738e;
      font-size: 0.62rem;
    }

    .chart-candle-stage {
      position: absolute;
      top: 2.25rem;
