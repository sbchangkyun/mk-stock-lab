        if (record.assetType === 'stock') {
          summary = `${name}${particle} ${exchange} 상장 국내 주식으로, 현재 화면에서는 종목 식별 정보와 샘플 차트 구조를 기준으로 분석 미리보기를 제공합니다.`;
          keyInterpretation = [
            '선택 종목의 시장·통화·종목 유형을 기준으로 차트 화면을 구성했습니다.',
            '샘플 OHLC 데이터로 차트 표현 구조와 상태 변화를 점검할 수 있습니다.',
            '실제 재무·공시·최신 시세가 반영된 분석은 아직 제공하지 않습니다.',
          ];
          limitations = defaultLimitations;
          scenarioTexts = {
            positive: `${name}의 종목 식별 정보와 차트 구조가 정상적으로 구성된 경우, 향후 실제 재무·공시·시세 데이터가 연결되면 분석 깊이를 확장할 수 있습니다.`,
            base: '현재 단계에서는 샘플 OHLC와 종목 식별 정보를 기준으로 화면 구조와 분석 흐름을 점검합니다.',
            caution: '실제 실적, 공시, 수급, 가격 변동 데이터가 반영되지 않았으므로 투자 판단에는 사용할 수 없습니다.',
          };
          riskChecklist = [
            '실제 시세와 거래량 확인',
            '최근 공시 및 실적 이벤트 확인',
            '재무제표와 밸류에이션 지표 별도 확인',
            '시장·섹터 변동성 확인',
            '샘플 분석과 실제 투자 판단 구분',
          ];
        } else if (record.assetType === 'etf') {
          summary = `${name}${particle} ${exchange} 상장 국내 ETF로, 현재 화면에서는 ETF 식별 정보와 샘플 차트 구조를 기준으로 분석 미리보기를 제공합니다.`;
          keyInterpretation = [
            'ETF 유형에 맞춰 기업 개요가 아닌 종목 구조 중심으로 표시합니다.',
            '샘플 OHLC 데이터로 차트 표현과 데이터 상태를 점검할 수 있습니다.',
            '구성 종목, NAV, 괴리율, 추적오차는 아직 반영하지 않습니다.',
          ];
          limitations = [
            '실제 가격, 거래량, 구성 종목, NAV, 괴리율, 추적오차는 분석에 반영하지 않았습니다.',
            '본 패널은 외부 AI API를 호출하지 않는 ETF 구조 확인용 샘플 분석입니다.',
            '매수·매도 추천이나 투자 자문이 아닙니다.',
          ];
          scenarioTexts = {
            positive: `${name}의 ETF 식별 정보와 차트 구조가 정상적으로 구성된 경우, 향후 구성 종목·NAV·괴리율 데이터 연동 시 분석 범위를 확장할 수 있습니다.`,
            base: '현재 단계에서는 샘플 OHLC와 ETF 식별 정보를 기준으로 화면 구조와 분석 흐름을 점검합니다.',
            caution: '실제 구성 종목, NAV, 괴리율, 추적오차가 반영되지 않았으므로 투자 판단에는 사용할 수 없습니다.',
          };
          riskChecklist = [
            '실제 시세와 거래량 확인',
            '구성 종목 및 기초지수 확인',
            'NAV·괴리율·추적오차 확인',
            '운용보수와 유동성 확인',
            '샘플 분석과 실제 투자 판단 구분',
          ];
        } else {
          summary = `${name}${particle} 선택된 국내 종목으로, 현재 화면에서는 종목 식별 정보와 샘플 차트 구조를 기준으로 분석 미리보기를 제공합니다.`;
          keyInterpretation = [
            '종목 식별 정보와 샘플 차트 구조를 기준으로 화면을 구성합니다.',
            '실제 시세나 투자 판단 지표는 반영하지 않습니다.',
            '향후 데이터 연동 범위가 확정되면 분석 항목을 확장할 수 있습니다.',
          ];
          limitations = defaultLimitations;
          scenarioTexts = {
            positive: `${name}의 종목 식별 정보와 차트 구조가 정상적으로 구성된 경우, 향후 실제 데이터가 연결되면 분석 깊이를 확장할 수 있습니다.`,
            base: '현재 단계에서는 샘플 OHLC와 종목 식별 정보를 기준으로 화면 구조와 분석 흐름을 점검합니다.',
            caution: '실제 시세, 수급, 가격 변동 데이터가 반영되지 않았으므로 투자 판단에는 사용할 수 없습니다.',
          };
          riskChecklist = [
            '실제 시세와 거래량 확인',
            '종목 유형에 맞는 공시·기초자산 정보 확인',
            '샘플 분석과 실제 투자 판단 구분',
          ];
        }

        const evidence = [
          '종목 식별 정보: 종목명, 종목코드, 시장, 종목 유형, 통화',
          '차트 데이터: 기능 체험용 샘플 OHLC·거래량 데이터',
          '연결 상태: public 화면은 샘플 분석, owner-local 연결 성공 시 연결 상태만 반영',
        ];

        const checklist = [
          '종목 식별 정보가 의도한 종목과 일치하는지 확인',
          '차트가 샘플 데이터 기준임을 확인',
          'KIS 연결 프리뷰 사용 시 오너 로컬 연결 상태 확인',
          '투자 판단 전 실제 공시·재무·시세 데이터 별도 확인',
        ];

        const basis = ['종목 식별 정보', '샘플 OHLC·거래량 데이터'];
        let connectedNote: string | null = null;
        let connectedScenarioNote: string | null = null;
        if (context.ownerLocalConnected) {
          basis.push('오너 로컬 KIS 연결 상태');
          connectedNote = '오너 로컬 KIS 연결이 확인된 상태입니다. 단, 본 패널은 아직 샘플 분석 로직으로 표시됩니다.';
          connectedScenarioNote = '오너 로컬 KIS 연결 상태가 확인되었지만, 시나리오와 체크리스트는 아직 샘플 로직 기준입니다.';
        }

        let status = '샘플 분석';
        if (context.ownerLocalPreview) {
          status = context.ownerLocalConnected ? '오너 로컬 데이터 반영' : '오너 로컬 연결 대기';
        }

        const scenarios: { label: string; tone: 'positive' | 'base' | 'caution'; text: string }[] = [
          { label: '긍정 관찰 시나리오', tone: 'positive', text: scenarioTexts.positive },
          { label: '기준 유지 시나리오', tone: 'base', text: scenarioTexts.base },
          { label: '주의 점검 시나리오', tone: 'caution', text: scenarioTexts.caution },
        ];

        const scenarioNote = '아래 시나리오는 실제 예측이 아닌 샘플 분석 구조입니다. 실제 투자 판단 전 공시·재무·시세 데이터를 별도로 확인해야 합니다.';

        return {
          summary,
          keyInterpretation,
          evidence,
          checklist,
          limitations,
          basis,
          status,
          connectedNote,
          scenarios,
          riskChecklist,
          scenarioNote,
          connectedScenarioNote,
        };
      };

      const renderMkAiList = (element: Element | null, items: string[]) => {
        if (!element) return;
        element.replaceChildren(...items.map((text) => {
          const li = document.createElement('li');
          li.textContent = text;
          return li;
        }));
      };

      const updateMkAiPanel = () => {
        if (!selectedRecord) return;
        const analysis = buildMockMkAiAnalysis(selectedRecord, { ownerLocalPreview, ownerLocalConnected });
        setText('chartAiMkAiStatus', analysis.status);
        setText('chartAiMkAiSummary', analysis.summary);
        renderMkAiList(mkAiBulletsEl, analysis.keyInterpretation);
        renderMkAiList(mkAiEvidenceEl, analysis.evidence);
        renderMkAiList(mkAiChecklistEl, analysis.checklist);
        renderMkAiList(mkAiLimitationsEl, analysis.limitations);
        renderMkAiList(mkAiBasisEl, analysis.basis);
        if (mkAiConnectedNoteEl) {
          mkAiConnectedNoteEl.textContent = analysis.connectedNote ?? '';
          mkAiConnectedNoteEl.hidden = !analysis.connectedNote;
        }
        const scenarioByTone = new Map(analysis.scenarios.map((scenario) => [scenario.tone, scenario.text]));
        if (mkAiScenarioPositiveEl) mkAiScenarioPositiveEl.textContent = scenarioByTone.get('positive') ?? '';
        if (mkAiScenarioBaseEl) mkAiScenarioBaseEl.textContent = scenarioByTone.get('base') ?? '';
        if (mkAiScenarioCautionEl) mkAiScenarioCautionEl.textContent = scenarioByTone.get('caution') ?? '';
        renderMkAiList(mkAiRiskChecklistEl, analysis.riskChecklist);
        if (mkAiConnectedScenarioNoteEl) {
          mkAiConnectedScenarioNoteEl.textContent = analysis.connectedScenarioNote ?? '';
          mkAiConnectedScenarioNoteEl.hidden = !analysis.connectedScenarioNote;
        }
      };

      // Phase 3GG-OP-FAST: map a universal search API result to the client record shape reused by
      // the identity/overview UI (nameKo aliases displayName; country/market added).
      const mapApiResult = (r: any) => ({
        symbol: String(r.symbol ?? ''),
        nameKo: String(r.displayName ?? r.symbol ?? ''),
        englishName: r.englishName,
        country: r.country === 'US' ? 'US' : 'KR',
        exchange: String(r.exchange ?? ''),
        market: String(r.market ?? ''),
        assetType: r.assetType === 'etf' ? 'etf' : 'stock',
        currency: String(r.currency ?? (r.country === 'US' ? 'USD' : 'KRW')),
      });

      const RANGE_LABELS: Record<string, string> = { '1m': '1개월', '3m': '3개월', '6m': '6개월', '1y': '1년' };

      // ----- Real OHLCV chart (Production only) -----
      let realChartSeq = 0;
      let realChartAbort: AbortController | null = null;
      const REAL_CHART_TIMEOUT_MS = 12000;

      const setRealChartState = (title: string, message: string, mode: string) => {
        const stateEl = document.getElementById('chartAiRealChartState');
        const titleEl = document.getElementById('chartAiRealChartStateTitle');
        const messageEl = document.getElementById('chartAiRealChartStateMessage');
        const metaEl = document.getElementById('chartAiRealChartMeta');
        const loadBtn = document.getElementById('chartAiRealChartLoadBtn');
        if (titleEl && title) titleEl.textContent = title;
        if (messageEl) messageEl.textContent = message;
        if (stateEl) {
          stateEl.hidden = mode === 'ready';
          stateEl.dataset.state = mode;
        }
        // Reveal the real chart host only when data is ready; otherwise keep it hidden behind the state.
        if (chart) chart.hidden = mode !== 'ready';
        // The below-chart metadata row (데이터 기준 · 통화 · 지연 여부) shows only once real data is ready.
        if (metaEl) metaEl.hidden = mode !== 'ready';
        // Phase 3GG-T-HF3A: the explicit "이 종목 차트 불러오기" button appears whenever an instrument is
        // pending or a load can be retried (never on ready/idle/loading), so promotion is always explicit.
        if (loadBtn) loadBtn.hidden = !(mode === 'suggested' || mode === 'error' || mode === 'no-data' || mode === 'unavailable');
        // Phase 3GG-T-HF4-FAST: any non-ready transition tears down the interaction layer (header price,
        // OHLCV strip, tooltip, crosshair, price line) so stale values never linger behind a hidden chart.
        if (mode !== 'ready') resetChartInteractionState();
      };

      // Phase 3GG-T-HF3A: build the canonical instrument identity from a client-safe search record.
      const buildInstrumentFromRecord = (record: any) => ({
        country: record?.country === 'US' ? 'US' : 'KR',
        symbol: record?.symbol ?? '',
        exchange: record?.exchange ?? '',
        instrumentType: record?.assetType ?? '',
        name: record?.nameKo ?? '',
        currency: record?.currency ?? '',
      });

      // Phase 3GG-T-HF3A: single authoritative availability sync for ALL three analysis actions. Buttons
      // (and their aria-disabled state) enable ONLY when a chart is actively loaded for the current
      // selection; otherwise they are disabled with an honest instruction.
      const ANALYSIS_CONTROLS: Array<[string, string]> = [
        ['chartAiSimilarityStartBtn', 'chartAiSimilarityStatus'],
        ['chartAiMkAiStartBtn', 'chartAiMkAiRealStatus'],
        ['chartAiMiStartBtn', 'chartAiMiStatus'],
      ];
      const ANALYSIS_GUIDE_NO_INSTRUMENT = '먼저 종목을 검색해 차트를 불러와 주세요.';
      const ANALYSIS_GUIDE_PENDING = '선택한 종목의 차트를 먼저 불러와 주세요.';
      const ANALYSIS_GUIDE_LOADING = '차트를 불러오는 동안 분석 기능을 사용할 수 없습니다.';
      const analysisGuideMessage = () => {
        const snap = integrity.getSnapshot();
        if (snap.chartLoadStatus === 'loading') return ANALYSIS_GUIDE_LOADING;
        if (snap.hasPending) return ANALYSIS_GUIDE_PENDING;
        return ANALYSIS_GUIDE_NO_INSTRUMENT;
      };
      const updateAnalysisAvailability = () => {
        const enabled = integrity.canRunAnalysis();
        const guide = analysisGuideMessage();
        for (const [btnId, statusId] of ANALYSIS_CONTROLS) {
          const btn = document.getElementById(btnId) as HTMLButtonElement | null;
          if (btn) {
            btn.disabled = !enabled;
            btn.setAttribute('aria-disabled', String(!enabled));
          }
          const status = document.getElementById(statusId);
          if (!status) continue;
          if (!enabled) {
            status.textContent = guide;
            status.hidden = false;
          } else if (status.textContent === ANALYSIS_GUIDE_NO_INSTRUMENT || status.textContent === ANALYSIS_GUIDE_PENDING || status.textContent === ANALYSIS_GUIDE_LOADING) {
            status.textContent = '';
            status.hidden = true;
          }
        }
      };

      const updateRealChartMeta = (ohlcv: any) => {
        const noteEl = document.getElementById('chartAiRealChartSourceNote');
        const asOfEl = document.getElementById('chartAiRealChartAsOf');
        // Compact factual metadata below the chart — 지연 여부 + 데이터 기준 시각 + 통화. No overlay.
        if (noteEl) noteEl.textContent = ohlcv?.isDelayed === false ? '실시간 시세 · KIS' : '실시간 지연 시세 · KIS';
        if (asOfEl) {
          const currency = ohlcv?.instrument?.currency ?? '';
          const parsed = ohlcv?.asOf ? new Date(ohlcv.asOf) : null;
          const asOfText = parsed && !Number.isNaN(parsed.getTime())
            ? `데이터 기준 ${parsed.toLocaleString('ko-KR')}`
            : '데이터 기준 시각 미확인';
          asOfEl.textContent = currency ? `${asOfText} · 통화 ${currency}` : asOfText;
        }
      };

      const renderRealChart = (ohlcv: any): boolean => {
        const rawPoints = (Array.isArray(ohlcv?.candles) ? ohlcv.candles : []).map((c: any) => ({
          dateTime: c.timestamp,
          open: c.open,
          high: c.high,
          low: c.low,
          close: c.close,
          volume: c.volume,
        }));
        const points = toMockedOhlcPoints(rawPoints);
        if (!isValidMockedOhlcSeries(points)) return false;
        // buildMockedChartGeometry uses activePeriod only for date-label formatting; align it with the
        // active daily range so labels render as dates (not intraday times).
        activePeriod = (activeRange === '1y' ? '1y' : activeRange === '1m' ? '1m' : '3m') as ChartPeriodKey;
        const rangeLabel = RANGE_LABELS[activeRange] ?? activeRange;
        renderChartFromPoints(
          points,
          `${rangeLabel} · 실시간 지연 시세`,
          `${selectedName} ${selectedSymbol}, ${rangeLabel} 실제 지연 OHLCV 캔들 차트와 거래량. 지연 시세, 투자 참고용.`,
        );
        return true;
      };

      // Phase 3GG-T-HF3A: the ONLY path that promotes a pending instrument toward an active chart. It
      // requires a pending instrument, and it promotes to ACTIVE only when the response is current
      // (sequence + selection revision), successful, has ≥1 real candle, and its identity matches the
      // requested instrument. Stale/failed/empty responses never render and never enable analyses.
      async function loadRealChart() {
        if (!productionRealChartEnabled) return;
        const token = integrity.beginChartLoad();
        if (!token) {
          setRealChartState('종목을 검색해 선택하면 실제 차트를 불러옵니다.', '종목명, 티커 또는 종목코드로 검색한 뒤 결과를 선택하세요.', 'idle');
          updateAnalysisAvailability();
          return;
        }
        const seq = ++realChartSeq;
        if (realChartAbort) realChartAbort.abort();
        realChartAbort = new AbortController();
        const signal = realChartAbort.signal;
        const reqSymbol = token.instrument.symbol;
        const reqCountry = token.instrument.country;
        const reqName = token.instrument.name || selectedName;
        setRealChartState(
          '실시간 종목 차트를 불러오는 중입니다.',
          `${reqName} ${reqSymbol}의 실제 지연 OHLCV 데이터를 불러오고 있습니다.`,
          'loading',
        );
        updateAnalysisAvailability();
        const params = new URLSearchParams();
        params.set('country', reqCountry);
        params.set('symbol', reqSymbol);
        params.set('range', activeRange);
        const timeoutId = window.setTimeout(() => realChartAbort?.abort(), REAL_CHART_TIMEOUT_MS);
        const authHeaders = await chartAiAuthHeaders();
        fetch(`/api/chart-ai/market/ohlcv.json?${marketDataRequestQuery}&${params.toString()}`, {
          method: 'GET',
          signal,
          credentials: 'omit',
          headers: { ...authHeaders },
        })
          .then((response) => response.json())
          .then((data) => {
            if (seq !== realChartSeq) return;
            const ohlcv = data && data.ohlcv;
            const candles = Array.isArray(ohlcv?.candles) ? ohlcv.candles : [];
            const responseSymbolKey = ohlcv?.instrument
              ? `${String(ohlcv.instrument.country ?? '').toLowerCase()}|${String(ohlcv.instrument.symbol ?? '').toLowerCase()}`
              : '';
            const fail = (title: string, message: string, mode: string) => {
              // Only render the failure if this token is still current (not superseded by a newer selection).
              if (integrity.failChartLoad(token, 'error') === 'stale') return;
              setRealChartState(title, message, mode);
              updateAnalysisAvailability();
            };
            if (!ohlcv || ohlcv.sourceStatus === 'blocked') {
              fail('차트를 표시할 수 없습니다.', '실시간 시세 접근 권한을 확인하는 중입니다. 잠시 후 다시 시도해 주세요.', 'error');
              return;
            }
            if (ohlcv.sourceStatus === 'no-data' || candles.length < 2) {
              fail('표시할 시세 데이터가 없습니다.', `${reqName} ${reqSymbol}의 해당 기간 실제 OHLCV 데이터가 아직 제공되지 않습니다.`, 'no-data');
              return;
            }
            if (ohlcv.sourceStatus !== 'ok') {
              fail('실시간 시세를 불러오지 못했습니다.', '잠시 후 다시 시도해 주세요.', 'unavailable');
              return;
            }
            const outcome = integrity.resolveChartLoad(token, { ok: true, candleCount: candles.length, responseSymbolKey });
            if (outcome === 'stale') return; // a newer selection/load supersedes this response — ignore it
            if (outcome !== 'accepted') {
              setRealChartState('차트를 표시할 수 없습니다.', '요청한 종목과 다른 응답이 확인되어 표시하지 않았습니다.', 'error');
              updateAnalysisAvailability();
              return;
            }
            if (!renderRealChart(ohlcv)) {
              integrity.failChartLoad(token, 'error');
              setRealChartState('차트를 표시할 수 없습니다.', '유효한 시세 데이터를 확인하지 못했습니다.', 'error');
              updateAnalysisAvailability();
              return;
            }
            updateRealChartMeta(ohlcv);
            setRealChartState('', '', 'ready');
            updateAnalysisAvailability();
          })
          .catch((error) => {
            if (seq !== realChartSeq) return;
            if (error && (error as any).name === 'AbortError') return;
            if (integrity.failChartLoad(token, 'error') === 'stale') return;
            setRealChartState('실시간 시세를 불러오지 못했습니다.', '네트워크 상태를 확인한 뒤 다시 시도해 주세요.', 'unavailable');
            updateAnalysisAvailability();
          })
          .finally(() => window.clearTimeout(timeoutId));
      }

      const resetSelectedSummary = () => {
        const out = document.getElementById('chartAiOwnerLocalKisLlmSummaryOutput');
        const status = document.getElementById('chartAiOwnerLocalKisLlmSummaryStatus');
        const btn = document.getElementById('chartAiOwnerLocalKisLlmSummaryButton');
        if (out) { out.hidden = true; out.replaceChildren(); }
        if (status) status.textContent = '대기 중';
        if (btn && useProductionFacingSummaryPresentation) {
          btn.textContent = `MK AI 시세 요약 요청 (${selectedSymbol})`;
        }
      };

      const updateProductionUrlState = () => {
        if (!productionRealChartEnabled) return;
        try {
          const url = new URL(window.location.href);
          url.searchParams.set('symbol', selectedSymbol);
          url.searchParams.set('country', selectedCountry);
          window.history.replaceState({}, '', url.toString());
        } catch {}
      };

      const updateSelection = (record: any) => {
        // Phase 3GG-T-HF3A: a deliberate result selection bumps the selection revision, invalidates the
        // previous active chart + all in-flight requests, and enters the PENDING stage (analyses disabled).
        integrity.selectPending(buildInstrumentFromRecord(record));
        selectedSymbol = record.symbol;
        selectedName = record.nameKo;
        selectedAssetType = record.assetType;
        selectedCountry = record.country === 'US' ? 'US' : 'KR';
        setText('chartAiSelectedName', record.nameKo);
        setText('chartAiSelectedSymbol', record.symbol);
        setText('chartAiSelectedExchange', record.exchange);
        setText('chartAiSelectedAssetType', assetTypeLabel(record.assetType));
        setText('chartAiSelectedCurrency', record.currency);
        setText('chartAiOverviewName', record.nameKo);
        setText('chartAiOverviewSymbol', record.symbol);
        setText('chartAiOverviewMarket', record.exchange);
        setText('chartAiOverviewAssetType', assetTypeLabel(record.assetType));
        setText('chartAiOverviewCurrency', record.currency);
        setText('chartAiOverviewSummary', buildSelectedSymbolOverview(record));
        setText('chartAiMkAiReadinessText', `${record.nameKo} 기준의 MK AI 분석은 차트 데이터 연동 안정화 이후 순차 제공 예정입니다.`);
        ownerLocalConnected = false;
        selectedRecord = record;
        // Peripheral (mock/owner-local) updates are isolated so a gated-out element in the Production
        // DOM can never block the real chart load below.
        try { updateOverviewDataStatus(); } catch {}
        try { updateMkAiPanel(); } catch {}
        try { resetAnalysisTriggers(); } catch {}
        input.value = '';
        if (searchHint) searchHint.hidden = true;
        closeDropdown();
        try { resetOhlcPreview(); } catch {}
        try { resetSelectedSummary(); } catch {}
        try { resetSelectedSimilarity(); } catch {}
        try { resetSelectedMkAi(); } catch {}
        try { resetSelectedMarketIntel(); } catch {}
        if (productionRealChartEnabled) {
          // Phase 3GG-T-HF3A: selecting a result creates a PENDING instrument only — NO OHLCV/analysis
          // request until the user explicitly clicks "이 종목 차트 불러오기". Analyses stay disabled.
          updateProductionUrlState();
          setRealChartState(
            '선택한 종목의 차트를 먼저 불러와 주세요.',
            `${record.nameKo} 종목을 선택했습니다. 아래 버튼을 눌러 실제 지연 OHLCV 차트를 불러오면 분석을 사용할 수 있습니다.`,
            'suggested',
          );
          updateAnalysisAvailability();
        } else {
          renderChart();
        }
        try { resetQuotePreview(); } catch {}
      };

      const renderResultButtons = (open: boolean) => {
        resultsEl.replaceChildren();
        resultCount.textContent = `${visibleRecords.length}개`;
        emptyState.hidden = visibleRecords.length > 0;
        dropdown.hidden = !open;
        searchPanel.classList.toggle('open', open);
        input.setAttribute('aria-expanded', String(open));

        for (const record of visibleRecords) {
          const button = document.createElement('button');
          const isSelected = record.symbol === selectedSymbol;
          button.type = 'button';
          button.className = 'chart-ai-search-result';
          button.dataset.symbol = record.symbol;
          button.setAttribute('role', 'option');
          button.setAttribute('aria-selected', String(isSelected));
          button.classList.toggle('selected', isSelected);

          const name = document.createElement('strong');
          name.className = 'chart-ai-search-result-name';
          name.textContent = record.nameKo;
          const metadata = document.createElement('span');
          metadata.className = 'chart-ai-search-result-meta';
          const countryTag = record.country === 'US' ? '미국' : '국내';
          const kindTag = record.assetType === 'etf' ? 'ETF' : assetTypeLabel(record.assetType);
          metadata.textContent = `${record.symbol} · ${countryTag} · ${record.exchange} · ${kindTag}`;
          button.append(name, metadata);
          button.addEventListener('click', () => updateSelection(record));
          resultsEl.append(button);
        }
      };

      // Phase 3GG-OP-FAST: universal search via the server route, with stale-response protection.
      let searchSeq = 0;
      let searchAbort: AbortController | null = null;
      const runSearch = async (open = true) => {
        if (searchHint) searchHint.hidden = true;
        const query = input.value.trim();
        if (!query) {
          closeDropdown();
          return;
        }
        const seq = ++searchSeq;
        if (searchAbort) searchAbort.abort();
        searchAbort = new AbortController();
        const params = new URLSearchParams({ q: query });
        if (activeFilter !== 'all') params.set('assetType', activeFilter);
        try {
          const authHeaders = await chartAiAuthHeaders();
          const response = await fetch(`/api/chart-ai/instruments/search.json?${params.toString()}`, {
            method: 'GET',
            signal: searchAbort.signal,
            credentials: 'omit',
            headers: { ...authHeaders },
          });
          const data = await response.json();
          if (seq !== searchSeq) return;
          visibleRecords = Array.isArray(data?.results) ? data.results.map(mapApiResult) : [];
          renderResultButtons(open);
        } catch (error) {
          if (seq !== searchSeq) return;
          if (error && (error as any).name === 'AbortError') return;
          visibleRecords = [];
          renderResultButtons(open);
        }
      };

      let searchDebounceId = 0;
      const debouncedSearch = () => {
        window.clearTimeout(searchDebounceId);
        searchDebounceId = window.setTimeout(() => runSearch(true), 180);
      };

      filterButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const filter = button.dataset.assetFilter;
          if (filter !== 'all' && filter !== 'stock' && filter !== 'etf') return;
          activeFilter = filter;
          filterButtons.forEach((candidate) => {
            const active = candidate === button;
            candidate.classList.toggle('active', active);
            candidate.setAttribute('aria-pressed', String(active));
          });
          runSearch(true);
        });
      });

      input.addEventListener('focus', () => {
        if (input.value.trim()) runSearch(true);
      });
      input.addEventListener('input', debouncedSearch);
      input.addEventListener('keydown', (event: KeyboardEvent) => {
        if (event.key === 'Enter') {
          event.preventDefault();
          runBtn.click();
        }
        if (event.key === 'ArrowDown') {
          const firstResult = resultsEl.querySelector<HTMLButtonElement>('.chart-ai-search-result');
          if (firstResult) {
            event.preventDefault();
            firstResult.focus();
          }
        }
        if (event.key === 'Escape') closeDropdown();
      });
      runBtn.addEventListener('click', async () => {
        if (!input.value.trim()) {
          if (searchHint) searchHint.hidden = false;
          closeDropdown();
          return;
        }
        await runSearch(true);
        if (visibleRecords[0]) updateSelection(visibleRecords[0]);
      });

      periodButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const range = button.dataset.range;
          if (productionRealChartEnabled && (range === '1m' || range === '3m' || range === '6m' || range === '1y')) {
            activeRange = range;
            periodButtons.forEach((candidate) => {
              const active = candidate === button;
              candidate.classList.toggle('active', active);
              candidate.setAttribute('aria-pressed', String(active));
            });
            loadRealChart();
            return;
          }
          if (!isChartPeriodKey(button.dataset.period)) return;
          activePeriod = button.dataset.period;
          periodButtons.forEach((candidate) => {
            const active = candidate === button;
            candidate.classList.toggle('active', active);
            candidate.setAttribute('aria-pressed', String(active));
          });
          resetOhlcPreview();
          resetAnalysisTriggers();
          renderChart();
        });
      });

      // Phase 3GG-T-HF1: ZERO-REQUEST entry. Opening the page never auto-selects a symbol and never
      // issues a KIS/OHLCV/search request. With no ?symbol the chart stays idle; with a ?symbol (e.g.
      // arriving from the Portfolio page) we show it as a SUGGESTED selection using client-safe URL
      // labels only, and wait for an explicit "이 종목 차트 불러오기" click before any provider call.
      // Phase 3GG-T-HF3A: a URL ?symbol is a SUGGESTION only. There is NO Samsung/DEFAULT fallback — an
      // unresolved suggestion honestly asks the user to search, and never silently selects another symbol.
      let suggestedInstrument: { symbol: string; name: string; country: 'KR' | 'US' } | null = null;

      const loadSuggestedInstrument = async () => {
        if (!productionRealChartEnabled || !suggestedInstrument) return;
        const sym = suggestedInstrument.symbol;
        const ctry = suggestedInstrument.country;
        const loadBtn = document.getElementById('chartAiRealChartLoadBtn') as HTMLButtonElement | null;
        if (loadBtn) loadBtn.disabled = true;
        setRealChartState('종목 정보를 확인하는 중입니다.', `${suggestedInstrument.name} 종목을 조회하고 있습니다.`, 'loading');
        try {
          const params = new URLSearchParams({ q: sym });
          if (ctry === 'KR' || ctry === 'US') params.set('country', ctry);
          const response = await fetch(`/api/chart-ai/instruments/search.json?${params.toString()}`, {
            method: 'GET',
            credentials: 'omit',
            headers: { ...(await chartAiAuthHeaders()) },
          });
          const data = await response.json();
          const results = Array.isArray(data?.results) ? data.results : [];
          const exact = results.find((r: any) => String(r.symbol).toUpperCase() === sym.toUpperCase()) || results[0];
          if (!exact) {
            suggestedInstrument = null;
            setRealChartState('종목을 찾을 수 없습니다.', '종목명, 티커 또는 종목코드로 검색해 결과를 선택해 주세요.', 'error');
            updateAnalysisAvailability();
            return;
          }
          suggestedInstrument = null;
          updateSelection(mapApiResult(exact)); // → PENDING (no fetch)
          await loadRealChart();                // explicit promotion (one click resolves + loads the chart)
        } catch {
          setRealChartState('종목 정보를 불러오지 못했습니다.', '잠시 후 다시 시도하거나 종목을 검색해 선택해 주세요.', 'error');
        } finally {
          if (loadBtn) loadBtn.disabled = false;
        }
      };

      // Phase 3GG-T-HF3A: the single explicit "load chart" handler. A URL suggestion is resolved first;
      // a search-selected pending instrument loads directly. Either way promotion is explicit.
      const handleExplicitChartLoad = async () => {
        if (!productionRealChartEnabled) return;
        if (suggestedInstrument) { await loadSuggestedInstrument(); return; }
        await loadRealChart();
      };

      const initProductionInstrument = () => {
        if (!productionRealChartEnabled) return;
        // The workspace (sole fetch owner) has now initialized; analyses may become available only after
        // a chart is explicitly loaded. Start from NO INSTRUMENT with every analysis disabled.
        integrity.markWorkspaceReady();
        updateAnalysisAvailability();
        const loadBtn = document.getElementById('chartAiRealChartLoadBtn');
        loadBtn?.addEventListener('click', () => { void handleExplicitChartLoad(); });
        const sym = (chartAiQuery.get('symbol') || '').trim();
        const name = (chartAiQuery.get('name') || '').trim();
        const ctry = (chartAiQuery.get('country') || chartAiQuery.get('market') || '').trim().toUpperCase();
        if (!sym) {
          // Idle: no selection, no provider call until the user searches and selects a result.
          setRealChartState(
            '종목을 검색해 선택하면 실제 차트를 불러옵니다.',
            '종목명, 티커 또는 종목코드로 검색한 뒤 결과를 선택하세요.',
            'idle',
          );
          return;
        }
        // Suggested selection from the URL — client-safe labels only, NO fetch and NO active selection
        // until the explicit click. This is a suggestion, not a pending/active instrument.
        suggestedInstrument = { symbol: sym, name: name || sym, country: ctry === 'US' ? 'US' : 'KR' };
        setRealChartState(
          `${suggestedInstrument.name} 차트를 불러올 준비가 되었습니다.`,
          '아래 버튼을 누르면 실제 지연 OHLCV 차트를 불러옵니다. 페이지를 여는 것만으로는 시세를 요청하지 않습니다.',
          'suggested',
        );
      };

      // ===== Phase 3GG-Q-FAST: real similar-pattern analysis (Production) =====
      {
        const simRoot = document.getElementById('chartAiSimilarityReal');
        const simStartBtn = document.getElementById('chartAiSimilarityStartBtn') as HTMLButtonElement | null;
        const simWindowBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.chart-similarity-window-btn'));
        const simStatus = document.getElementById('chartAiSimilarityStatus');
        const simResults = document.getElementById('chartAiSimilarityResults');
        const simCurrent = document.getElementById('chartAiSimilarityCurrent');
        const simOverlay = document.getElementById('chartAiSimilarityOverlaySvg');
        const simLegend = document.getElementById('chartAiSimilarityLegend');
        const simMatches = document.getElementById('chartAiSimilarityMatches');
        const simAggregate = document.getElementById('chartAiSimilarityAggregate');

        let activeSimWindow = 20;
        let simSeq = 0;
        let simAbort: AbortController | null = null;
        let simInFlight = false;
        const SIM_TIMEOUT_MS = 20000;
        const OVERLAY_COLORS = ['#f59e0b', '#10b981', '#8b5cf6', '#ef4444', '#0ea5e9'];
        const SVG_NS = 'http://www.w3.org/2000/svg';

        const fmtPct = (v: any) =>
          typeof v === 'number' && isFinite(v) ? `${v >= 0 ? '+' : ''}${(v * 100).toFixed(2)}%` : '데이터 부족';
        const fmtScore = (v: any) => (typeof v === 'number' && isFinite(v) ? v.toFixed(1) : '—');
        const setSimState = (state: string) => { if (simRoot) simRoot.dataset.state = state; };
        const showSimStatus = (text: string) => { if (simStatus) { simStatus.textContent = text; simStatus.hidden = !text; } };

        const resetSim = () => {
          simSeq += 1;
          if (simAbort) { simAbort.abort(); simAbort = null; }
          simInFlight = false;
          if (simResults) simResults.hidden = true;
          showSimStatus('');
          setSimState('idle');
          if (simStartBtn) { simStartBtn.disabled = !integrity.canRunAnalysis(); simStartBtn.textContent = '유사 패턴 분석 시작'; }
          [simMatches, simAggregate, simCurrent, simOverlay, simLegend].forEach((el) => el && el.replaceChildren());
        };
        resetSelectedSimilarity = resetSim;

        const renderCurrent = (sim: any) => {
          if (!simCurrent) return;
          simCurrent.replaceChildren();
          const aw = sim.analysisWindow;
          const title = document.createElement('p');
          title.className = 'chart-similarity-current-title';
          title.textContent = '현재 분석 구간';
          const range = document.createElement('p');
          range.className = 'chart-similarity-current-range';
          range.textContent = `${aw.startDate} ~ ${aw.endDate} · ${aw.barCount}거래일`;
          const meta = document.createElement('p');
          meta.className = 'chart-similarity-current-meta';
          meta.textContent = `결정적 유사도 분석(가격 상관·거리·방향) · 과거 데이터 ${sim.historyBarCount}거래일 · 비교 구간 ${sim.candidateCount}개`;
          const note = document.createElement('p');
          note.className = 'chart-similarity-current-note';
          note.textContent = '실제 지연 시세 기반의 과거 구간 비교이며, 외부 AI를 사용하지 않습니다.';
          simCurrent.append(title, range, meta, note);
        };

        const renderOverlay = (sim: any) => {
          if (!simOverlay || !simLegend) return;
          simOverlay.replaceChildren();
          simLegend.replaceChildren();
          const paths: Array<{ label: string; values: number[]; color: string; current: boolean }> = [
            { label: '현재 구간', values: sim.currentNormalizedPath || [], color: '#111827', current: true },
          ];
          (sim.matches || []).slice(0, 5).forEach((m: any, i: number) => {
            paths.push({ label: `#${m.rank} ${m.startDate}`, values: m.normalizedPath || [], color: OVERLAY_COLORS[i % OVERLAY_COLORS.length], current: false });
          });
          const allVals = paths.flatMap((p) => p.values).filter((v) => typeof v === 'number' && isFinite(v));
          if (allVals.length < 2) return;
          const min = Math.min(...allVals);
          const max = Math.max(...allVals);
          const span = Math.max(1e-6, max - min);
          const W = 720, H = 260, padX = 10, padY = 18;
          const len = Math.max(...paths.map((p) => p.values.length), 2);
          const xAt = (i: number) => padX + (i / Math.max(1, len - 1)) * (W - 2 * padX);
          const yAt = (v: number) => padY + (1 - (v - min) / span) * (H - 2 * padY);
          const baseLine = document.createElementNS(SVG_NS, 'line');
          baseLine.setAttribute('x1', String(padX)); baseLine.setAttribute('x2', String(W - padX));
          baseLine.setAttribute('y1', yAt(100).toFixed(1)); baseLine.setAttribute('y2', yAt(100).toFixed(1));
          baseLine.setAttribute('stroke', '#9ca3af'); baseLine.setAttribute('stroke-dasharray', '4 4'); baseLine.setAttribute('stroke-width', '1');
          simOverlay.append(baseLine);
          paths.forEach((p) => {
            const pts = p.values.map((v, i) => `${xAt(i).toFixed(1)},${yAt(v).toFixed(1)}`).join(' ');
            const pl = document.createElementNS(SVG_NS, 'polyline');
            pl.setAttribute('points', pts);
            pl.setAttribute('fill', 'none');
            pl.setAttribute('stroke', p.color);
            pl.setAttribute('stroke-width', p.current ? '2.6' : '1.4');
            pl.setAttribute('stroke-opacity', p.current ? '1' : '0.72');
            pl.setAttribute('stroke-linejoin', 'round');
            simOverlay.append(pl);
          });
          paths.forEach((p) => {
            const item = document.createElement('span');
            item.className = 'chart-similarity-legend-item';
            const sw = document.createElement('span');
            sw.className = 'chart-similarity-legend-swatch';
            sw.style.background = p.color;
            const lbl = document.createElement('span');
            lbl.textContent = p.label;
            item.append(sw, lbl);
            simLegend.append(item);
          });
        };

        const renderMatches = (sim: any) => {
          if (!simMatches) return;
          simMatches.replaceChildren();
          (sim.matches || []).forEach((m: any) => {
            const card = document.createElement('div');
            card.className = 'chart-similarity-match-card';
            card.setAttribute('role', 'listitem');
            const head = document.createElement('div');
            head.className = 'chart-similarity-match-head';
            const rank = document.createElement('span');
            rank.className = 'chart-similarity-match-rank';
            rank.textContent = `#${m.rank}`;
            const score = document.createElement('span');
            score.className = 'chart-similarity-match-score';
            score.textContent = `유사도 ${fmtScore(m.similarityScore)}`;
            head.append(rank, score);
            const dates = document.createElement('p');
            dates.className = 'chart-similarity-match-dates';
            dates.textContent = `${m.startDate} ~ ${m.endDate}`;
            const dl = document.createElement('dl');
            dl.className = 'chart-similarity-match-metrics';
            const addRow = (k: string, v: string) => {
              const dt = document.createElement('dt'); dt.textContent = k;
              const dd = document.createElement('dd'); dd.textContent = v;
              dl.append(dt, dd);
            };
            addRow('이후 5일', fmtPct(m.forwardReturns.d5));
            addRow('이후 20일', fmtPct(m.forwardReturns.d20));
            addRow('이후 60일', fmtPct(m.forwardReturns.d60));
            addRow('최대 낙폭', fmtPct(m.maxDrawdownPct));
            addRow('최대 상승', fmtPct(m.maxUpsidePct));
            card.append(head, dates, dl);
            if (m.dataComplete && !m.dataComplete.d60) {
              const inc = document.createElement('p');
              inc.className = 'chart-similarity-match-incomplete';
              inc.textContent = '일부 이후 구간 데이터가 아직 완성되지 않았습니다.';
              card.append(inc);
            }
            simMatches.append(card);
          });
        };

        const renderAggregate = (sim: any) => {
          if (!simAggregate) return;
          simAggregate.replaceChildren();
          const agg = sim.aggregate || {};
          const title = document.createElement('p');
          title.className = 'chart-similarity-aggregate-title';
          title.textContent = '상위 유사 구간의 과거 이후 성과 (참고용)';
          const dl = document.createElement('dl');
          dl.className = 'chart-similarity-aggregate-metrics';
          const addRow = (k: string, v: string) => {
            const dt = document.createElement('dt'); dt.textContent = k;
            const dd = document.createElement('dd'); dd.textContent = v;
            dl.append(dt, dd);
          };
          addRow('20일 후 상승 마감 구간', `${agg.positiveCountByWindow?.d20 ?? 0} / ${agg.matchCount ?? 0}`);
          addRow('평균 이후 5일', fmtPct(agg.averageForwardReturnByWindow?.d5));
          addRow('중앙값 이후 5일', fmtPct(agg.medianForwardReturnByWindow?.d5));
          addRow('평균 이후 20일', fmtPct(agg.averageForwardReturnByWindow?.d20));
          addRow('중앙값 이후 20일', fmtPct(agg.medianForwardReturnByWindow?.d20));
          addRow('평균 최대 낙폭', fmtPct(agg.averageMaxDrawdownPct));
          const disc = document.createElement('p');
          disc.className = 'chart-similarity-aggregate-disclaimer';
