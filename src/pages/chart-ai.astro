---
import Layout from '../layouts/Layout.astro';

const selectedSymbol = (Astro.url.searchParams.get('symbol') || '').slice(0, 32).toUpperCase();
const selectedName = (Astro.url.searchParams.get('name') || '').slice(0, 160);
const selectedMarketRaw = (Astro.url.searchParams.get('market') || '').slice(0, 12).toUpperCase();
const selectedMarket = selectedMarketRaw === 'US' ? 'US' : 'KR';
const selectedLabel = selectedName || selectedSymbol;
const chartReady = Boolean(selectedSymbol);
---

<Layout title="Chart AI | MK Stock Lab" activePath="/chart-ai">
  <header class="page-header">
    <div>
      <p class="eyebrow">Chart AI</p>
      <h1>차트 AI 분석</h1>
      <p class="lead">종목 차트를 먼저 불러온 뒤 서버 사용량 가드를 통과하면 AI 분석 준비 상태를 확인합니다. 실제 시세, 차트 데이터, AI 모델 호출은 다음 단계에서 연결합니다.</p>
    </div>
  </header>

  <section class="workspace-grid">
    <div class="chart-placeholder chart-workspace" data-chart-workspace data-chart-ready={chartReady ? 'true' : 'false'}>
      <div
        class="chart-prefill-panel"
        data-chart-prefill
        data-symbol={selectedSymbol}
        data-name={selectedName}
        data-market={selectedMarket}
      >
        <p class="eyebrow">종목 검색</p>
        <div class="chart-load-row">
          <label class="chart-search-shell">
            <span>종목명 또는 티커</span>
            <input
              id="chartAiSecurityInput"
              type="search"
              value={selectedLabel}
              placeholder="종목명 또는 티커"
              aria-label="Chart AI 종목명 또는 티커"
            />
          </label>
          <button class="button-link secondary chart-load-button" id="chartAiLoadButton" type="button">
            차트 불러오기
          </button>
        </div>

        <div class="chart-interval-control" role="group" aria-label="차트 기간">
          <button class="active" type="button" data-chart-interval="1D">일봉</button>
          <button type="button" data-chart-interval="1W">주봉</button>
          <button type="button" data-chart-interval="1M">월봉</button>
        </div>
      </div>

      <div class="chart-canvas-shell">
        <p class="eyebrow">차트 영역</p>
        <h2 id="chartAiChartTitle">{chartReady ? `${selectedLabel} · 일봉 차트 준비` : '캔들차트 준비 영역'}</h2>
        <p id="chartAiChartCopy">
          {chartReady
            ? '선택 종목의 차트 플레이스홀더가 준비되었습니다. 실제 시세 데이터와 일봉/주봉/월봉 차트는 다음 단계에서 연결합니다.'
            : '실제 시세 데이터와 일봉/주봉/월봉 차트는 다음 구현 단계에서 연결합니다. 티커를 입력한 뒤 차트 불러오기를 눌러 주세요.'}
        </p>
        <div class="chart-skeleton" aria-hidden="true">
          <span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span>
        </div>
      </div>
    </div>

    <aside class="panel chart-ai-run-panel">
      <p class="eyebrow">분석 패널</p>
      <h2>차트 준비 후 AI 분석 실행</h2>
      <p>이 단계는 서버가 로그인 세션을 검증하고 일일 사용 한도를 확인하는 실행 골격입니다. OpenAI, Gemini, KIS, OpenDART 호출은 아직 실행하지 않습니다.</p>

      <div class="selected-security" id="chartAiSelectedSummary">
        <strong>{chartReady ? selectedLabel : '차트 준비 전'}</strong>
        <span>{chartReady ? `${selectedSymbol} · ${selectedMarket}` : '차트를 먼저 불러오면 AI 분석 실행이 활성화됩니다.'}</span>
      </div>

      <button class="button-link chart-ai-run-button" id="chartAiRunButton" type="button" disabled={!chartReady}>
        AI 분석 실행
      </button>

      <div class="chart-ai-result" id="chartAiResult" data-state="idle" role="status" aria-live="polite">
        <strong>대기 중</strong>
        <p>차트를 준비한 뒤 로그인 상태에서 사용량 가드를 확인할 수 있습니다.</p>
      </div>

      <ul class="status-list">
        <li><span>대상 자산</span><strong>국내 주식, 미국 주식, ETF</strong></li>
        <li><span>일일 한도</span><strong>무료 3회</strong></li>
        <li><span>AI 호출</span><strong class="neutral">연결 전</strong></li>
      </ul>
    </aside>
  </section>

  <script>
    import { analyzeChartAi, ChartAiApiError } from '../lib/chartAiClient';

    const setupChartAiPanel = () => {
      const prefill = document.querySelector<HTMLElement>('[data-chart-prefill]');
      const workspace = document.querySelector<HTMLElement>('[data-chart-workspace]');
      const loadButton = document.getElementById('chartAiLoadButton') as HTMLButtonElement | null;
      const runButton = document.getElementById('chartAiRunButton') as HTMLButtonElement | null;
      const result = document.getElementById('chartAiResult');
      const input = document.getElementById('chartAiSecurityInput') as HTMLInputElement | null;
      const title = document.getElementById('chartAiChartTitle');
      const copy = document.getElementById('chartAiChartCopy');
      const selectedSummary = document.getElementById('chartAiSelectedSummary');
      const intervalButtons = document.querySelectorAll<HTMLButtonElement>('[data-chart-interval]');
      if (!prefill || !workspace || !loadButton || !runButton || !result || !input || !title || !copy || !selectedSummary) return;
      if (runButton.dataset.ready === 'true') return;
      runButton.dataset.ready = 'true';

      const intervalLabel: Record<string, string> = {
        '1D': '일봉',
        '1W': '주봉',
        '1M': '월봉',
      };

      const symbolPattern = /^[A-Za-z0-9._-]{1,32}$/;
      const state = {
        symbol: prefill.dataset.symbol || '',
        name: prefill.dataset.name || '',
        market: prefill.dataset.market === 'US' ? 'US' : 'KR',
        timeframe: '1D',
        ready: Boolean(prefill.dataset.symbol),
      };

      const setResult = (nextState: string, nextTitle: string, message: string) => {
        result.dataset.state = nextState;
        result.replaceChildren();
        const titleElement = document.createElement('strong');
        titleElement.textContent = nextTitle;
        const messageElement = document.createElement('p');
        messageElement.textContent = message;
        result.append(titleElement, messageElement);
      };

      const renderChartState = () => {
        workspace.dataset.chartReady = state.ready ? 'true' : 'false';
        runButton.disabled = !state.ready;
        const label = state.name || state.symbol;

        title.textContent = state.ready ? `${label} · ${intervalLabel[state.timeframe]} 차트 준비` : '캔들차트 준비 영역';
        copy.textContent = state.ready
          ? '선택 종목의 차트 플레이스홀더가 준비되었습니다. 실제 시세 데이터와 일봉/주봉/월봉 차트는 다음 단계에서 연결합니다.'
          : '실제 시세 데이터와 일봉/주봉/월봉 차트는 다음 구현 단계에서 연결합니다. 티커를 입력한 뒤 차트 불러오기를 눌러 주세요.';

        selectedSummary.replaceChildren();
        const summaryTitle = document.createElement('strong');
        summaryTitle.textContent = state.ready ? label : '차트 준비 전';
        const summaryMeta = document.createElement('span');
        summaryMeta.textContent = state.ready ? `${state.symbol} · ${state.market}` : '차트를 먼저 불러오면 AI 분석 실행이 활성화됩니다.';
        selectedSummary.append(summaryTitle, summaryMeta);
      };

      loadButton.addEventListener('click', () => {
        const value = input.value.trim();
        if (!value) {
          setResult('error', '종목 선택 필요', '종목명 또는 티커를 입력해 주세요.');
          return;
        }

        const initialLabel = prefill.dataset.name || prefill.dataset.symbol || '';
        const initialSymbol = prefill.dataset.symbol || '';
        const nextSymbol = initialSymbol && value === initialLabel ? initialSymbol : value.toUpperCase();
        if (!symbolPattern.test(nextSymbol)) {
          setResult('error', '티커 입력 필요', '현재 단계에서는 영문 또는 숫자 티커로 차트 준비 상태를 만들 수 있습니다.');
          return;
        }

        state.symbol = nextSymbol;
        state.name = initialSymbol && value === initialLabel ? prefill.dataset.name || '' : '';
        state.ready = true;
        setResult('idle', '차트 준비 완료', 'AI 분석 실행을 누르면 서버 사용량 가드를 확인합니다.');
        renderChartState();
      });

      intervalButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const timeframe = button.dataset.chartInterval || '1D';
          state.timeframe = timeframe === '1W' || timeframe === '1M' ? timeframe : '1D';
          intervalButtons.forEach((item) => item.classList.toggle('active', item === button));
          renderChartState();
        });
      });

      runButton.addEventListener('click', async () => {
        if (!state.ready || !state.symbol) {
          setResult('error', '차트 준비 필요', '차트를 먼저 불러와 주세요.');
          return;
        }

        runButton.disabled = true;
        setResult('loading', '확인 중', '로그인 세션과 오늘 사용 가능한 분석 횟수를 확인하고 있습니다.');

        try {
          const response = await analyzeChartAi({
            symbol: state.symbol,
            name: state.name || undefined,
            market: state.market,
            timeframe: state.timeframe === '1W' || state.timeframe === '1M' ? state.timeframe : '1D',
          });

          const usage = response.usage;
          const remainingText = typeof usage?.remaining === 'number' ? `남은 횟수 ${usage.remaining}회` : '사용량 확인 완료';
          setResult('success', '서버 가드 통과', `${response.summary || '차트 분석 준비 상태입니다.'} ${remainingText}`);
        } catch (error) {
          if (error instanceof ChartAiApiError) {
            const nextState = error.status === 429 ? 'limit' : error.status === 401 ? 'auth' : 'error';
            setResult(nextState, error.status === 401 ? '로그인 필요' : '요청 실패', error.message);
            return;
          }

          setResult('error', '요청 실패', 'AI 분석 요청을 처리하지 못했습니다.');
        } finally {
          renderChartState();
        }
      });

      renderChartState();
    };

    document.addEventListener('astro:page-load', setupChartAiPanel);
    setupChartAiPanel();
  </script>
</Layout>
