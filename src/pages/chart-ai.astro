---
import Layout from '../layouts/Layout.astro';
import { getClientSafeDomesticSymbolRecords } from '../lib/symbol-master/domesticSymbolMaster';

const clientSafeDomesticSymbols = getClientSafeDomesticSymbolRecords();
const clientSafeDomesticSymbolPayload = JSON.stringify(clientSafeDomesticSymbols)
  .replaceAll('<', '\\u003c');
---

<Layout title="종목 차트 | MK Stock Lab" activePath="/chart-ai">
  <header class="page-header chart-lookup-page-header">
    <div>
      <p class="eyebrow">국내/미국 주식·ETF</p>
      <h1>종목 차트</h1>
      <p class="lead">종목을 조회하고 차트 중심의 기본 정보를 확인하세요. 현재 화면은 안전한 샘플 데이터로 구성되어 있습니다.</p>
    </div>
  </header>

  <main class="chart-lookup-shell">
    <section class="chart-lookup-search" aria-labelledby="chart-lookup-search-heading">
      <div class="chart-ai-symbol-row">
        <label class="chart-search-shell chart-lookup-search-field" for="chartAiInput">
          <span id="chart-lookup-search-heading">종목 검색</span>
          <input
            id="chartAiInput"
            type="search"
            placeholder="종목명 또는 종목코드 입력"
            aria-label="종목명 또는 종목코드 입력"
            aria-controls="chartAiSearchResults"
            aria-autocomplete="list"
            aria-expanded="false"
            role="combobox"
            autocomplete="off"
            spellcheck="false"
          />
        </label>
        <button class="button-link chart-ai-run-btn chart-lookup-submit" id="chartAiRunBtn" type="button">조회</button>
      </div>
      <p class="chart-ai-search-hint" id="chartAiSearchHint" hidden aria-live="polite">종목명 또는 종목코드를 입력해 주세요.</p>

      <div class="chart-lookup-dropdown" id="chartAiSearchDropdown" hidden>
        <div class="chart-ai-results-head">
          <div class="chart-ai-results-summary">
            <strong>검색 결과</strong>
            <span id="chartAiResultCount" aria-live="polite">0개</span>
          </div>
          <div class="chart-ai-filter-bar" role="group" aria-label="종목 유형 필터">
            <button class="chart-ai-filter-btn active" type="button" data-asset-filter="all" aria-pressed="true">전체</button>
            <button class="chart-ai-filter-btn" type="button" data-asset-filter="stock" aria-pressed="false">주식</button>
            <button class="chart-ai-filter-btn" type="button" data-asset-filter="etf" aria-pressed="false">ETF</button>
          </div>
        </div>
        <div
          class="chart-ai-search-results"
          id="chartAiSearchResults"
          role="listbox"
          aria-label="국내 종목 검색 결과"
        ></div>
        <p class="chart-ai-empty-state" id="chartAiEmptyState" hidden aria-live="polite">
          검색 결과가 없습니다. 종목명이나 종목코드를 다시 확인해 주세요.
        </p>
      </div>
    </section>

    <div class="chart-lookup-content-grid">
      <section class="chart-market-panel" aria-labelledby="chart-market-heading">
        <div class="chart-market-rail">
          <div class="chart-market-summary">
            <div class="chart-market-heading-group">
              <p class="chart-market-kicker">차트</p>
              <h2 id="chart-market-heading">샘플 차트</h2>
            </div>
            <div class="chart-market-identity-row" aria-label="선택 종목 기본 정보" aria-live="polite">
              <strong id="chartAiSelectedName">삼성전자</strong>
              <span class="chart-identity-symbol" id="chartAiSelectedSymbol">005930</span>
              <span class="chart-identity-chip" id="chartAiSelectedExchange">KOSPI</span>
              <span class="chart-identity-chip" id="chartAiSelectedAssetType">주식</span>
              <span class="chart-identity-chip" id="chartAiSelectedCurrency">KRW</span>
            </div>
          </div>
          <div class="chart-market-status">
            <span id="chartAiChartStatus">샘플 OHLC·거래량 데이터</span>
            <strong id="chartAiChartStatusStrong">실제 시세 아님</strong>
          </div>
          <p class="chart-market-sample-helper">현재 화면은 기능 체험용 샘플 데이터로 구성되어 있습니다. 실제 투자 판단용 정보가 아닙니다.</p>
        </div>

        <div class="chart-period-controls" role="group" aria-label="차트 기간 선택">
          <button type="button" data-period="1d" aria-pressed="true" class="active">1일</button>
          <button type="button" data-period="1w" aria-pressed="false">1주</button>
          <button type="button" data-period="1m" aria-pressed="false">1개월</button>
          <button type="button" data-period="3m" aria-pressed="false">3개월</button>
          <button type="button" data-period="1y" aria-pressed="false">1년</button>
        </div>

        <div
          class="chart-candlestick-ready"
          id="chartAiMarketChart"
          role="img"
          aria-label="선택 종목의 샘플 캔들 차트와 거래량"
        >
          <div class="chart-plot-heading" aria-hidden="true">
            <span id="chartAiChartPeriodLabel">1일 샘플</span>
          </div>
          <svg
            class="chart-market-svg"
            id="chartAiMarketSvg"
            viewBox="0 0 960 440"
            preserveAspectRatio="none"
            aria-hidden="true"
          ></svg>
          <div class="chart-safety-note">
            <strong>샘플 OHLC·거래량 데이터</strong>
            <span>실제 시세 아님 · 투자 참고용</span>
          </div>
        </div>

      </section>

      <aside class="chart-stock-sidebar">
        <section class="panel chart-company-placeholder" aria-labelledby="chart-company-heading">
          <div class="chart-sidebar-heading">
            <p class="eyebrow">종목 정보</p>
            <h2 id="chart-company-heading">종목 개요</h2>
          </div>
          <dl class="chart-company-fallback-fields">
            <div>
              <dt>종목명</dt>
              <dd id="chartAiOverviewName">삼성전자</dd>
            </div>
            <div>
              <dt>종목코드</dt>
              <dd id="chartAiOverviewSymbol">005930</dd>
            </div>
            <div>
              <dt>시장</dt>
              <dd id="chartAiOverviewMarket">KOSPI</dd>
            </div>
            <div>
              <dt>종목 유형</dt>
              <dd id="chartAiOverviewAssetType">주식</dd>
            </div>
            <div>
              <dt>통화</dt>
              <dd id="chartAiOverviewCurrency">KRW</dd>
            </div>
            <div>
              <dt>데이터 상태</dt>
              <dd id="chartAiOverviewDataStatus">샘플·구조화 데이터</dd>
            </div>
          </dl>
          <p id="chartAiOverviewSummary">삼성전자는 KOSPI에 상장된 국내 주식입니다. 현재 화면에서는 종목 식별 정보와 샘플 차트 구조를 제공합니다.</p>
          <p>정식 기업 데이터 연동 전까지는 참고용 구조 예시로 제공됩니다.</p>
          <p>정식 기업 공시 데이터가 아닌 화면 구성용 요약 정보입니다.</p>
          <small>샘플 정보 · 실제 투자 판단용 정보가 아닙니다.</small>
        </section>

        <section class="panel chart-quote-preview" id="chartAiQuotePreview" aria-labelledby="chart-quote-preview-heading">
          <div class="chart-sidebar-heading">
            <p class="eyebrow" id="chartAiQuotePreviewEyebrow">오너 로컬 전용</p>
            <h2 id="chart-quote-preview-heading">KIS 연결 프리뷰</h2>
          </div>
          <p class="chart-quote-preview-guide" id="chartAiQuotePreviewGuide">공개 화면은 샘플 모드입니다. KIS 연결 프리뷰는 오너 로컬 환경에서만 사용할 수 있습니다.</p>
          <div class="chart-preview-actions">
            <button class="chart-quote-preview-btn" id="chartAiQuotePreviewBtn" type="button" disabled>KIS 시세 프리뷰 확인</button>
            <button class="chart-ohlc-preview-btn" id="chartAiOhlcPreviewBtn" type="button" disabled>KIS 차트 프리뷰 확인</button>
          </div>
          <div class="chart-quote-preview-result" id="chartAiQuotePreviewResult" hidden aria-live="polite"></div>
          <p class="chart-ohlc-preview-message" id="chartAiOhlcPreviewMessage" hidden aria-live="polite"></p>
          <span class="chart-ohlc-preview-tag" id="chartAiOhlcPreviewTag" hidden>지연 시세 · KIS OHLC · KRW</span>
          <small>지연 시세 · 오너 로컬 전용 · 실제 투자 판단용 아님</small>
        </section>

        <button
          class="chart-mk-ai-button chart-sidebar-mk-ai"
          id="chartAiMkAiBtn"
          type="button"
          aria-expanded="false"
          aria-controls="chartAiMkAiNote"
        >MK AI</button>
        <div class="chart-mk-ai-note" id="chartAiMkAiNote" hidden aria-labelledby="chart-mk-ai-heading">
          <div class="chart-sidebar-heading">
            <p class="eyebrow">MK AI</p>
            <h2 id="chart-mk-ai-heading">AI 분석 미리보기</h2>
          </div>
          <span class="chart-identity-chip chart-mk-ai-status" id="chartAiMkAiStatus">샘플 분석</span>
          <p class="chart-mk-ai-connected-note" id="chartAiMkAiConnectedNote" hidden></p>

          <section class="chart-mk-ai-section" aria-labelledby="chart-mk-ai-summary-heading">
            <p class="chart-mk-ai-section-label" id="chart-mk-ai-summary-heading">요약</p>
            <p id="chartAiMkAiSummary">삼성전자는 KOSPI 상장 국내 주식으로, 현재 화면에서는 종목 식별 정보와 샘플 차트 구조를 기준으로 분석 미리보기를 제공합니다.</p>
          </section>

          <section class="chart-mk-ai-section" aria-labelledby="chart-mk-ai-key-heading">
            <p class="chart-mk-ai-section-label" id="chart-mk-ai-key-heading">핵심 해석</p>
            <ul class="chart-mk-ai-bullets" id="chartAiMkAiBullets">
              <li>선택 종목의 시장·통화·종목 유형을 기준으로 차트 분석 화면을 구성합니다.</li>
              <li>샘플 OHLC 데이터로 추세·변동성 표현 구조를 점검할 수 있습니다.</li>
              <li>실제 재무·공시·최신 시세가 반영된 분석은 아직 제공하지 않습니다.</li>
            </ul>
          </section>

          <section class="chart-mk-ai-section" aria-labelledby="chart-mk-ai-scenario-heading">
            <p class="chart-mk-ai-section-label" id="chart-mk-ai-scenario-heading">시나리오 점검</p>
            <p class="chart-mk-ai-scenario-note" id="chartAiMkAiScenarioNote">아래 시나리오는 실제 예측이 아닌 샘플 분석 구조입니다. 실제 투자 판단 전 공시·재무·시세 데이터를 별도로 확인해야 합니다.</p>
            <div class="chart-mk-ai-scenario-list" id="chartAiMkAiScenarioList">
              <article class="chart-mk-ai-scenario-card" data-scenario-tone="positive">
                <p class="chart-mk-ai-scenario-label">긍정 관찰 시나리오</p>
                <p class="chart-mk-ai-scenario-text" id="chartAiMkAiScenarioPositive"></p>
              </article>
              <article class="chart-mk-ai-scenario-card" data-scenario-tone="base">
                <p class="chart-mk-ai-scenario-label">기준 유지 시나리오</p>
                <p class="chart-mk-ai-scenario-text" id="chartAiMkAiScenarioBase"></p>
              </article>
              <article class="chart-mk-ai-scenario-card" data-scenario-tone="caution">
                <p class="chart-mk-ai-scenario-label">주의 점검 시나리오</p>
                <p class="chart-mk-ai-scenario-text" id="chartAiMkAiScenarioCaution"></p>
              </article>
            </div>
            <p class="chart-mk-ai-connected-note" id="chartAiMkAiConnectedScenarioNote" hidden></p>
          </section>

          <details class="chart-mk-ai-details">
            <summary>분석 근거 자세히 보기</summary>
            <div class="chart-mk-ai-section-body">
              <p class="chart-mk-ai-section-label">분석 근거</p>
              <ul class="chart-mk-ai-evidence-list" id="chartAiMkAiEvidenceList">
                <li>종목 식별 정보: 종목명, 종목코드, 시장, 종목 유형, 통화</li>
                <li>차트 데이터: 기능 체험용 샘플 OHLC·거래량 데이터</li>
                <li>연결 상태: public 화면은 샘플 분석, owner-local 연결 성공 시 연결 상태만 반영</li>
              </ul>
              <div class="chart-mk-ai-basis">
                <p class="chart-mk-ai-basis-label">분석 기준 데이터</p>
                <ul class="chart-mk-ai-basis-list" id="chartAiMkAiBasisList">
                  <li>종목 식별 정보</li>
                  <li>샘플 OHLC·거래량 데이터</li>
                </ul>
              </div>
            </div>
          </details>

          <section class="chart-mk-ai-section" aria-labelledby="chart-mk-ai-checklist-heading">
            <p class="chart-mk-ai-section-label" id="chart-mk-ai-checklist-heading">확인 체크리스트</p>
            <ul class="chart-mk-ai-checklist" id="chartAiMkAiChecklist">
              <li>종목 식별 정보가 의도한 종목과 일치하는지 확인</li>
              <li>차트가 샘플 데이터 기준임을 확인</li>
              <li>KIS 연결 프리뷰 사용 시 오너 로컬 연결 상태 확인</li>
              <li>투자 판단 전 실제 공시·재무·시세 데이터 별도 확인</li>
            </ul>
          </section>

          <section class="chart-mk-ai-section" aria-labelledby="chart-mk-ai-risk-heading">
            <p class="chart-mk-ai-section-label" id="chart-mk-ai-risk-heading">리스크 체크리스트</p>
            <ul class="chart-mk-ai-checklist" id="chartAiMkAiRiskChecklist"></ul>
          </section>

          <details class="chart-mk-ai-details">
            <summary>데이터 한계 확인</summary>
            <div class="chart-mk-ai-section-body">
              <p class="chart-mk-ai-section-label">데이터 한계</p>
              <ul class="chart-mk-ai-limitations" id="chartAiMkAiLimitations">
                <li>실제 가격, 거래량, 재무제표, 공시 정보는 분석에 반영하지 않았습니다.</li>
                <li>본 패널은 외부 AI API를 호출하지 않는 샘플 분석 로직입니다.</li>
                <li>매수·매도 추천이나 투자 자문이 아닙니다.</li>
              </ul>
            </div>
          </details>

          <strong>MK AI 분석 준비 중</strong>
          <p id="chartAiMkAiReadinessText">삼성전자 기준의 MK AI 분석은 차트 데이터 연동 안정화 이후 순차 제공 예정입니다.</p>
          <p>현재 분석은 샘플 로직 기반 미리보기입니다.</p>
          <p>실제 투자 판단용 정보가 아니며 매수·매도 추천이 아닙니다.</p>
        </div>
      </aside>
    </div>

    <aside class="chart-lookup-disclaimer" aria-label="데이터 이용 안내">
      <strong>샘플 화면</strong>
      <span>현재 화면은 기능 체험용 샘플 데이터로 구성되어 있습니다. 차트와 종목 정보는 화면 구조 확인용이며 투자 판단이나 매수·매도 추천이 아닙니다.</span>
    </aside>
  </main>

  <script
    id="chartAiDomesticSymbolData"
    type="application/json"
    set:html={clientSafeDomesticSymbolPayload}
  ></script>

  <script>
    import { buildMockedChartGeometry } from '../lib/chart-ai/chartScale';
    import {
      CHART_PERIOD_LABELS,
      createMockedOhlcSeries,
      isChartPeriodKey,
      isValidMockedOhlcSeries,
      type ChartPeriodKey,
      type MockedOhlcPoint,
    } from '../lib/chart-ai/mockedOhlc';
    import { toMockedOhlcPoints, type OwnerLocalOhlcPreviewPoint } from '../lib/chart-ai/ohlcPreviewChart';
    import { searchClientSafeDomesticSymbols } from '../lib/symbol-master/clientSymbolSearch';
    import type { ClientSafeSymbolSearchRecord, DomesticAssetType } from '../lib/symbol-master/types';

    const assetTypeLabel = (assetType: DomesticAssetType): string => {
      if (assetType === 'stock') return '주식';
      if (assetType === 'etf') return 'ETF';
      if (assetType === 'etn') return 'ETN';
      return '기타';
    };

    // Simple final-character Hangul batchim check. Non-Hangul names default to '은'.
    const getTopicParticle = (name: string): string => {
      const lastChar = name.trim().slice(-1);
      const code = lastChar.charCodeAt(0);
      if (code < 0xac00 || code > 0xd7a3) return '은';
      return (code - 0xac00) % 28 === 0 ? '는' : '은';
    };

    const parseClientSafeRecords = (): ClientSafeSymbolSearchRecord[] => {
      const payload = document.getElementById('chartAiDomesticSymbolData')?.textContent ?? '[]';
      try {
        const parsed: unknown = JSON.parse(payload);
        return Array.isArray(parsed) ? parsed as ClientSafeSymbolSearchRecord[] : [];
      } catch {
        return [];
      }
    };

    const setup = () => {
      const input = document.getElementById('chartAiInput') as HTMLInputElement | null;
      const runBtn = document.getElementById('chartAiRunBtn') as HTMLButtonElement | null;
      const searchPanel = document.querySelector<HTMLElement>('.chart-lookup-search');
      const dropdown = document.getElementById('chartAiSearchDropdown');
      const resultsEl = document.getElementById('chartAiSearchResults');
      const resultCount = document.getElementById('chartAiResultCount');
      const emptyState = document.getElementById('chartAiEmptyState');
      const searchHint = document.getElementById('chartAiSearchHint');
      const filterButtons = document.querySelectorAll<HTMLButtonElement>('.chart-ai-filter-btn');
      const periodButtons = document.querySelectorAll<HTMLButtonElement>('[data-period]');
      const mkAiButton = document.getElementById('chartAiMkAiBtn') as HTMLButtonElement | null;
      const mkAiNote = document.getElementById('chartAiMkAiNote');
      const chart = document.getElementById('chartAiMarketChart');
      const chartSvg = document.getElementById('chartAiMarketSvg') as SVGSVGElement | null;
      const records = parseClientSafeRecords();
      let activeFilter: DomesticAssetType | 'all' = 'all';
      let selectedSymbol = '005930';
      let selectedName = '삼성전자';
      let selectedAssetType: DomesticAssetType = 'stock';
      let activePeriod: ChartPeriodKey = '1d';
      let visibleRecords: ClientSafeSymbolSearchRecord[] = [];
      let resetQuotePreview: () => void = () => {};
      let resetOhlcPreview: () => void = () => {};
      let ownerLocalConnected = false;
      let selectedRecord: ClientSafeSymbolSearchRecord | null = records.find((r) => r.symbol === selectedSymbol) ?? null;
      const mkAiBulletsEl = document.getElementById('chartAiMkAiBullets');
      const mkAiBasisEl = document.getElementById('chartAiMkAiBasisList');
      const mkAiEvidenceEl = document.getElementById('chartAiMkAiEvidenceList');
      const mkAiChecklistEl = document.getElementById('chartAiMkAiChecklist');
      const mkAiLimitationsEl = document.getElementById('chartAiMkAiLimitations');
      const mkAiConnectedNoteEl = document.getElementById('chartAiMkAiConnectedNote');
      const mkAiScenarioPositiveEl = document.getElementById('chartAiMkAiScenarioPositive');
      const mkAiScenarioBaseEl = document.getElementById('chartAiMkAiScenarioBase');
      const mkAiScenarioCautionEl = document.getElementById('chartAiMkAiScenarioCaution');
      const mkAiRiskChecklistEl = document.getElementById('chartAiMkAiRiskChecklist');
      const mkAiConnectedScenarioNoteEl = document.getElementById('chartAiMkAiConnectedScenarioNote');

      if (!input || !runBtn || !searchPanel || !dropdown || !resultsEl || !resultCount || !emptyState || !chart || !chartSvg) return;
      if (runBtn.dataset.ready === 'true') return;
      runBtn.dataset.ready = 'true';

      const setText = (id: string, text: string) => {
        const element = document.getElementById(id);
        if (element) element.textContent = text;
      };

      const setChartStatus = (status: string, strongLabel: string) => {
        setText('chartAiChartStatus', status);
        setText('chartAiChartStatusStrong', strongLabel);
      };

      const createSvgElement = <K extends keyof SVGElementTagNameMap>(
        name: K,
        attributes: Record<string, string | number>,
        className?: string,
      ): SVGElementTagNameMap[K] => {
        const element = document.createElementNS('http://www.w3.org/2000/svg', name);
        Object.entries(attributes).forEach(([key, value]) => element.setAttribute(key, String(value)));
        if (className) element.setAttribute('class', className);
        return element;
      };

      const renderChartFromPoints = (points: MockedOhlcPoint[], periodLabel: string, ariaLabel: string) => {
        const geometry = buildMockedChartGeometry(points, activePeriod);
        const gridLayer = createSvgElement('g', {}, 'chart-svg-grid');
        const volumeLayer = createSvgElement('g', {}, 'chart-svg-volume');
        const candleLayer = createSvgElement('g', {}, 'chart-svg-candles');
        const axisLayer = createSvgElement('g', {}, 'chart-svg-axis');

        geometry.priceLabels.forEach(({ y, label }) => {
          if (y === undefined) return;
          gridLayer.append(createSvgElement('line', {
            x1: geometry.plotLeft, y1: y, x2: geometry.plotRight, y2: y,
          }, 'chart-grid-line'));
          const axisText = createSvgElement('text', { x: geometry.plotRight + 14, y: y + 4 }, 'chart-axis-text');
          axisText.textContent = label;
          axisLayer.append(axisText);
        });

        gridLayer.append(createSvgElement('line', {
          x1: geometry.plotLeft,
          y1: geometry.volumeTop - 14,
          x2: geometry.plotRight,
          y2: geometry.volumeTop - 14,
        }, 'chart-volume-divider'));

        geometry.dateLabels.forEach(({ x, label }) => {
          if (x === undefined) return;
          gridLayer.append(createSvgElement('line', {
            x1: x, y1: geometry.priceTop, x2: x, y2: geometry.volumeBottom,
          }, 'chart-grid-line chart-grid-line-vertical'));
          const axisText = createSvgElement('text', { x, y: 430, 'text-anchor': 'middle' }, 'chart-axis-text');
          axisText.textContent = label;
          axisLayer.append(axisText);
        });

        geometry.candles.forEach((candle) => {
          const directionClass = candle.direction === 'up' ? 'is-up' : 'is-down';
          candleLayer.append(createSvgElement('line', {
            x1: candle.x,
            y1: candle.wickTop,
            x2: candle.x,
            y2: candle.wickBottom,
          }, `chart-candle-wick ${directionClass}`));
          candleLayer.append(createSvgElement('rect', {
            x: candle.x - candle.bodyWidth / 2,
            y: candle.bodyTop,
            width: candle.bodyWidth,
            height: candle.bodyHeight,
            rx: 0.8,
          }, `chart-candle-body ${directionClass}`));
          volumeLayer.append(createSvgElement('rect', {
            x: candle.x - candle.bodyWidth / 2,
            y: candle.volumeY,
            width: candle.bodyWidth,
            height: candle.volumeHeight,
            rx: 0.6,
          }, `chart-volume-bar ${directionClass}`));
        });

        chartSvg.setAttribute('viewBox', geometry.viewBox);
        chartSvg.replaceChildren(gridLayer, volumeLayer, candleLayer, axisLayer);
        setText('chartAiChartPeriodLabel', periodLabel);
        chart.setAttribute('aria-label', ariaLabel);
      };

      const renderChart = () => {
        const points = createMockedOhlcSeries(selectedSymbol, activePeriod);
        if (!isValidMockedOhlcSeries(points)) return;
        setChartStatus('샘플 OHLC·거래량 데이터', '실제 시세 아님');
        renderChartFromPoints(
          points,
          `${CHART_PERIOD_LABELS[activePeriod]} 샘플`,
          `${selectedName} ${selectedSymbol}, ${CHART_PERIOD_LABELS[activePeriod]} 선택 종목의 샘플 캔들 차트와 거래량. 실제 시세 아님.`,
        );
      };

      const renderOhlcChart = (rawPoints: OwnerLocalOhlcPreviewPoint[]): boolean => {
        const points = toMockedOhlcPoints(rawPoints);
        if (!isValidMockedOhlcSeries(points)) return false;
        renderChartFromPoints(
          points,
          `${CHART_PERIOD_LABELS[activePeriod]} · KIS OHLC`,
          `${selectedName} ${selectedSymbol}, ${CHART_PERIOD_LABELS[activePeriod]} KIS OHLC 프리뷰 차트와 거래량. 지연 시세, 실제 투자 판단용 아님.`,
        );
        return true;
      };

      const closeDropdown = () => {
        visibleRecords = [];
        resultsEl.replaceChildren();
        resultCount.textContent = '0개';
        emptyState.hidden = true;
        dropdown.hidden = true;
        searchPanel.classList.remove('open');
        input.setAttribute('aria-expanded', 'false');
      };

      const buildSelectedSymbolOverview = (record: ClientSafeSymbolSearchRecord): string => {
        const particle = getTopicParticle(record.nameKo);
        if (record.assetType === 'stock') {
          return `${record.nameKo}${particle} ${record.exchange}에 상장된 국내 주식입니다. 현재 화면에서는 종목 식별 정보와 샘플 차트 구조를 제공합니다.`;
        }
        if (record.assetType === 'etf') {
          return `${record.nameKo}${particle} ${record.exchange}에 상장된 국내 ETF입니다. 현재 화면에서는 종목 식별 정보와 샘플 차트 구조를 제공합니다.`;
        }
        return `${record.nameKo}${particle} 선택된 국내 종목입니다. 현재 화면에서는 종목 식별 정보와 샘플 차트 구조를 제공합니다.`;
      };

      const updateOverviewDataStatus = () => {
        if (!ownerLocalPreview) {
          setText('chartAiOverviewDataStatus', '샘플·구조화 데이터');
          return;
        }
        setText('chartAiOverviewDataStatus', ownerLocalConnected ? '오너 로컬 KIS 연결 확인' : '오너 로컬 연결 대기');
      };

      const buildMockMkAiAnalysis = (
        record: ClientSafeSymbolSearchRecord,
        context: { ownerLocalPreview: boolean; ownerLocalConnected: boolean },
      ): {
        summary: string;
        keyInterpretation: string[];
        evidence: string[];
        checklist: string[];
        limitations: string[];
        basis: string[];
        status: string;
        connectedNote: string | null;
        scenarios: { label: string; tone: 'positive' | 'base' | 'caution'; text: string }[];
        riskChecklist: string[];
        scenarioNote: string;
        connectedScenarioNote: string | null;
      } => {
        const name = record.nameKo;
        const exchange = record.exchange;
        const particle = getTopicParticle(name);
        let summary: string;
        let keyInterpretation: string[];
        let limitations: string[];
        let scenarioTexts: { positive: string; base: string; caution: string };
        let riskChecklist: string[];

        const defaultLimitations = [
          '실제 가격, 거래량, 재무제표, 공시 정보는 분석에 반영하지 않았습니다.',
          '본 패널은 외부 AI API를 호출하지 않는 샘플 분석 로직입니다.',
          '매수·매도 추천이나 투자 자문이 아닙니다.',
        ];

        if (record.assetType === 'stock') {
          summary = `${name}${particle} ${exchange} 상장 국내 주식으로, 현재 화면에서는 종목 식별 정보와 샘플 차트 구조를 기준으로 분석 미리보기를 제공합니다.`;
          keyInterpretation = [
            '선택 종목의 시장·통화·종목 유형을 기준으로 차트 화면을 구성했습니다.',
            '샘플 OHLC 데이터로 차트 표현 구조와 상태 변화를 점검할 수 있습니다.',
            '실제 재무·공시·최신 시세가 반영된 분석은 아직 제공하지 않습니다.',
          ];
          limitations = defaultLimitations;
          scenarioTexts = {
            positive: `${name}의 종목 식별 정보와 차트 구조가 정상적으로 구성된 경우, 향후 실제 재무·공시·시세 데이터가 연결되면 분석 깊이를 확장할 수 있습니다.`,
            base: '현재 단계에서는 샘플 OHLC와 종목 식별 정보를 기준으로 화면 구조와 분석 흐름을 점검합니다.',
            caution: '실제 실적, 공시, 수급, 가격 변동 데이터가 반영되지 않았으므로 투자 판단에는 사용할 수 없습니다.',
          };
          riskChecklist = [
            '실제 시세와 거래량 확인',
            '최근 공시 및 실적 이벤트 확인',
            '재무제표와 밸류에이션 지표 별도 확인',
            '시장·섹터 변동성 확인',
            '샘플 분석과 실제 투자 판단 구분',
          ];
        } else if (record.assetType === 'etf') {
          summary = `${name}${particle} ${exchange} 상장 국내 ETF로, 현재 화면에서는 ETF 식별 정보와 샘플 차트 구조를 기준으로 분석 미리보기를 제공합니다.`;
          keyInterpretation = [
            'ETF 유형에 맞춰 기업 개요가 아닌 종목 구조 중심으로 표시합니다.',
            '샘플 OHLC 데이터로 차트 표현과 데이터 상태를 점검할 수 있습니다.',
            '구성 종목, NAV, 괴리율, 추적오차는 아직 반영하지 않습니다.',
          ];
          limitations = [
            '실제 가격, 거래량, 구성 종목, NAV, 괴리율, 추적오차는 분석에 반영하지 않았습니다.',
            '본 패널은 외부 AI API를 호출하지 않는 ETF 구조 확인용 샘플 분석입니다.',
            '매수·매도 추천이나 투자 자문이 아닙니다.',
          ];
          scenarioTexts = {
            positive: `${name}의 ETF 식별 정보와 차트 구조가 정상적으로 구성된 경우, 향후 구성 종목·NAV·괴리율 데이터 연동 시 분석 범위를 확장할 수 있습니다.`,
            base: '현재 단계에서는 샘플 OHLC와 ETF 식별 정보를 기준으로 화면 구조와 분석 흐름을 점검합니다.',
            caution: '실제 구성 종목, NAV, 괴리율, 추적오차가 반영되지 않았으므로 투자 판단에는 사용할 수 없습니다.',
          };
          riskChecklist = [
            '실제 시세와 거래량 확인',
            '구성 종목 및 기초지수 확인',
            'NAV·괴리율·추적오차 확인',
            '운용보수와 유동성 확인',
            '샘플 분석과 실제 투자 판단 구분',
          ];
        } else {
          summary = `${name}${particle} 선택된 국내 종목으로, 현재 화면에서는 종목 식별 정보와 샘플 차트 구조를 기준으로 분석 미리보기를 제공합니다.`;
          keyInterpretation = [
            '종목 식별 정보와 샘플 차트 구조를 기준으로 화면을 구성합니다.',
            '실제 시세나 투자 판단 지표는 반영하지 않습니다.',
            '향후 데이터 연동 범위가 확정되면 분석 항목을 확장할 수 있습니다.',
          ];
          limitations = defaultLimitations;
          scenarioTexts = {
            positive: `${name}의 종목 식별 정보와 차트 구조가 정상적으로 구성된 경우, 향후 실제 데이터가 연결되면 분석 깊이를 확장할 수 있습니다.`,
            base: '현재 단계에서는 샘플 OHLC와 종목 식별 정보를 기준으로 화면 구조와 분석 흐름을 점검합니다.',
            caution: '실제 시세, 수급, 가격 변동 데이터가 반영되지 않았으므로 투자 판단에는 사용할 수 없습니다.',
          };
          riskChecklist = [
            '실제 시세와 거래량 확인',
            '종목 유형에 맞는 공시·기초자산 정보 확인',
            '샘플 분석과 실제 투자 판단 구분',
          ];
        }

        const evidence = [
          '종목 식별 정보: 종목명, 종목코드, 시장, 종목 유형, 통화',
          '차트 데이터: 기능 체험용 샘플 OHLC·거래량 데이터',
          '연결 상태: public 화면은 샘플 분석, owner-local 연결 성공 시 연결 상태만 반영',
        ];

        const checklist = [
          '종목 식별 정보가 의도한 종목과 일치하는지 확인',
          '차트가 샘플 데이터 기준임을 확인',
          'KIS 연결 프리뷰 사용 시 오너 로컬 연결 상태 확인',
          '투자 판단 전 실제 공시·재무·시세 데이터 별도 확인',
        ];

        const basis = ['종목 식별 정보', '샘플 OHLC·거래량 데이터'];
        let connectedNote: string | null = null;
        let connectedScenarioNote: string | null = null;
        if (context.ownerLocalConnected) {
          basis.push('오너 로컬 KIS 연결 상태');
          connectedNote = '오너 로컬 KIS 연결이 확인된 상태입니다. 단, 본 패널은 아직 샘플 분석 로직으로 표시됩니다.';
          connectedScenarioNote = '오너 로컬 KIS 연결 상태가 확인되었지만, 시나리오와 체크리스트는 아직 샘플 로직 기준입니다.';
        }

        let status = '샘플 분석';
        if (context.ownerLocalPreview) {
          status = context.ownerLocalConnected ? '오너 로컬 데이터 반영' : '오너 로컬 연결 대기';
        }

        const scenarios: { label: string; tone: 'positive' | 'base' | 'caution'; text: string }[] = [
          { label: '긍정 관찰 시나리오', tone: 'positive', text: scenarioTexts.positive },
          { label: '기준 유지 시나리오', tone: 'base', text: scenarioTexts.base },
          { label: '주의 점검 시나리오', tone: 'caution', text: scenarioTexts.caution },
        ];

        const scenarioNote = '아래 시나리오는 실제 예측이 아닌 샘플 분석 구조입니다. 실제 투자 판단 전 공시·재무·시세 데이터를 별도로 확인해야 합니다.';

        return {
          summary,
          keyInterpretation,
          evidence,
          checklist,
          limitations,
          basis,
          status,
          connectedNote,
          scenarios,
          riskChecklist,
          scenarioNote,
          connectedScenarioNote,
        };
      };

      const renderMkAiList = (element: Element | null, items: string[]) => {
        if (!element) return;
        element.replaceChildren(...items.map((text) => {
          const li = document.createElement('li');
          li.textContent = text;
          return li;
        }));
      };

      const updateMkAiPanel = () => {
        if (!selectedRecord) return;
        const analysis = buildMockMkAiAnalysis(selectedRecord, { ownerLocalPreview, ownerLocalConnected });
        setText('chartAiMkAiStatus', analysis.status);
        setText('chartAiMkAiSummary', analysis.summary);
        renderMkAiList(mkAiBulletsEl, analysis.keyInterpretation);
        renderMkAiList(mkAiEvidenceEl, analysis.evidence);
        renderMkAiList(mkAiChecklistEl, analysis.checklist);
        renderMkAiList(mkAiLimitationsEl, analysis.limitations);
        renderMkAiList(mkAiBasisEl, analysis.basis);
        if (mkAiConnectedNoteEl) {
          mkAiConnectedNoteEl.textContent = analysis.connectedNote ?? '';
          mkAiConnectedNoteEl.hidden = !analysis.connectedNote;
        }
        const scenarioByTone = new Map(analysis.scenarios.map((scenario) => [scenario.tone, scenario.text]));
        if (mkAiScenarioPositiveEl) mkAiScenarioPositiveEl.textContent = scenarioByTone.get('positive') ?? '';
        if (mkAiScenarioBaseEl) mkAiScenarioBaseEl.textContent = scenarioByTone.get('base') ?? '';
        if (mkAiScenarioCautionEl) mkAiScenarioCautionEl.textContent = scenarioByTone.get('caution') ?? '';
        renderMkAiList(mkAiRiskChecklistEl, analysis.riskChecklist);
        if (mkAiConnectedScenarioNoteEl) {
          mkAiConnectedScenarioNoteEl.textContent = analysis.connectedScenarioNote ?? '';
          mkAiConnectedScenarioNoteEl.hidden = !analysis.connectedScenarioNote;
        }
      };

      const updateSelection = (record: ClientSafeSymbolSearchRecord) => {
        selectedSymbol = record.symbol;
        selectedName = record.nameKo;
        selectedAssetType = record.assetType;
        setText('chartAiSelectedName', record.nameKo);
        setText('chartAiSelectedSymbol', record.symbol);
        setText('chartAiSelectedExchange', record.exchange);
        setText('chartAiSelectedAssetType', assetTypeLabel(record.assetType));
        setText('chartAiSelectedCurrency', record.currency);
        setText('chartAiOverviewName', record.nameKo);
        setText('chartAiOverviewSymbol', record.symbol);
        setText('chartAiOverviewMarket', record.exchange);
        setText('chartAiOverviewAssetType', assetTypeLabel(record.assetType));
        setText('chartAiOverviewCurrency', record.currency);
        setText('chartAiOverviewSummary', buildSelectedSymbolOverview(record));
        setText('chartAiMkAiReadinessText', `${record.nameKo} 기준의 MK AI 분석은 차트 데이터 연동 안정화 이후 순차 제공 예정입니다.`);
        ownerLocalConnected = false;
        selectedRecord = record;
        updateOverviewDataStatus();
        updateMkAiPanel();
        input.value = '';
        if (searchHint) searchHint.hidden = true;
        closeDropdown();
        resetOhlcPreview();
        renderChart();
        resetQuotePreview();
      };

      const renderResults = (open = true) => {
        if (searchHint) searchHint.hidden = true;
        const query = input.value.trim();
        if (!query) {
          closeDropdown();
          return;
        }

        visibleRecords = searchClientSafeDomesticSymbols(records, {
          query,
          limit: 15,
          assetTypes: activeFilter === 'all' ? undefined : [activeFilter],
          includeStatuses: ['active'],
        });
        resultsEl.replaceChildren();
        resultCount.textContent = `${visibleRecords.length}개`;
        emptyState.hidden = visibleRecords.length > 0;
        dropdown.hidden = !open;
        searchPanel.classList.toggle('open', open);
        input.setAttribute('aria-expanded', String(open));

        for (const record of visibleRecords) {
          const button = document.createElement('button');
          const isSelected = record.symbol === selectedSymbol;
          button.type = 'button';
          button.className = 'chart-ai-search-result';
          button.dataset.symbol = record.symbol;
          button.setAttribute('role', 'option');
          button.setAttribute('aria-selected', String(isSelected));
          button.classList.toggle('selected', isSelected);

          const name = document.createElement('strong');
          name.className = 'chart-ai-search-result-name';
          name.textContent = record.nameKo;
          const metadata = document.createElement('span');
          metadata.className = 'chart-ai-search-result-meta';
          metadata.textContent = record.assetType === 'etf'
            ? `${record.symbol} · ${record.exchange} · ${record.currency}`
            : `${record.symbol} · ${record.exchange} · ${assetTypeLabel(record.assetType)}`;
          button.append(name, metadata);
          button.addEventListener('click', () => updateSelection(record));
          resultsEl.append(button);
        }
      };

      filterButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const filter = button.dataset.assetFilter;
          if (filter !== 'all' && filter !== 'stock' && filter !== 'etf') return;
          activeFilter = filter;
          filterButtons.forEach((candidate) => {
            const active = candidate === button;
            candidate.classList.toggle('active', active);
            candidate.setAttribute('aria-pressed', String(active));
          });
          renderResults(true);
        });
      });

      input.addEventListener('focus', () => renderResults(true));
      input.addEventListener('input', () => renderResults(true));
      input.addEventListener('keydown', (event: KeyboardEvent) => {
        if (event.key === 'Enter') {
          event.preventDefault();
          runBtn.click();
        }
        if (event.key === 'ArrowDown') {
          const firstResult = resultsEl.querySelector<HTMLButtonElement>('.chart-ai-search-result');
          if (firstResult) {
            event.preventDefault();
            firstResult.focus();
          }
        }
        if (event.key === 'Escape') closeDropdown();
      });
      runBtn.addEventListener('click', () => {
        if (!input.value.trim()) {
          if (searchHint) searchHint.hidden = false;
          closeDropdown();
          return;
        }
        renderResults(true);
        if (visibleRecords[0]) updateSelection(visibleRecords[0]);
      });

      periodButtons.forEach((button) => {
        button.addEventListener('click', () => {
          if (!isChartPeriodKey(button.dataset.period)) return;
          activePeriod = button.dataset.period;
          periodButtons.forEach((candidate) => {
            const active = candidate === button;
            candidate.classList.toggle('active', active);
            candidate.setAttribute('aria-pressed', String(active));
          });
          resetOhlcPreview();
          renderChart();
        });
      });

      mkAiButton?.addEventListener('click', () => {
        if (!mkAiNote) return;
        const expanded = mkAiButton.getAttribute('aria-expanded') === 'true';
        mkAiButton.setAttribute('aria-expanded', String(!expanded));
        mkAiNote.hidden = expanded;
      });

      // Owner-local KIS quote preview. Gated: never auto-fetches, and only fetches the gated
      // owner-local preview route when the page URL carries source=owner-local.
      const previewBtn = document.getElementById('chartAiQuotePreviewBtn') as HTMLButtonElement | null;
      const previewResult = document.getElementById('chartAiQuotePreviewResult');
      const previewEyebrow = document.getElementById('chartAiQuotePreviewEyebrow');
      const previewGuide = document.getElementById('chartAiQuotePreviewGuide');
      const ownerLocalPreview = new URLSearchParams(window.location.search).get('source') === 'owner-local';

      if (previewEyebrow && previewGuide) {
        if (ownerLocalPreview) {
          previewEyebrow.textContent = '오너 로컬 KIS 연결 모드';
          previewGuide.textContent = '오너 로컬 환경에서 KIS 연결 프리뷰를 사용할 수 있습니다. 버튼을 눌러 지연 시세와 OHLC를 확인하세요.';
        } else {
          previewEyebrow.textContent = '오너 로컬 전용';
          previewGuide.textContent = '공개 화면은 샘플 모드입니다. KIS 연결 프리뷰는 오너 로컬 환경에서만 사용할 수 있습니다.';
        }
      }
      updateOverviewDataStatus();
      updateMkAiPanel();

      resetQuotePreview = () => {
        if (previewResult) {
          previewResult.hidden = true;
          previewResult.replaceChildren();
        }
      };

      const formatNumber = (value: number | null): string =>
        typeof value === 'number' ? value.toLocaleString('ko-KR') : '—';

      const showPreviewMessage = (text: string, detail?: string) => {
        if (!previewResult) return;
        previewResult.hidden = false;
        previewResult.replaceChildren();
        const message = document.createElement('p');
        message.className = 'chart-quote-preview-msg';
        message.textContent = text;
        previewResult.append(message);
        if (detail) {
          const small = document.createElement('small');
          small.textContent = detail;
          previewResult.append(small);
        }
      };

      const renderPreview = (data: {
        status?: string;
        providerStatus?: string;
        quote?: {
          lastPrice: number | null; previousClose: number | null; change: number | null;
          changeRate: number | null; volume: number | null; asOf: string | null; currency: string;
        } | null;
      }) => {
        if (!previewResult) return;
        if (data.status === 'ok' && data.quote) {
          ownerLocalConnected = true;
          updateOverviewDataStatus();
          updateMkAiPanel();
          const quote = data.quote;
          previewResult.hidden = false;
          previewResult.replaceChildren();
          const rows: Array<[string, string]> = [
            ['현재가', formatNumber(quote.lastPrice)],
            ['전일종가', formatNumber(quote.previousClose)],
            ['전일대비', formatNumber(quote.change)],
            ['등락률', typeof quote.changeRate === 'number' ? `${quote.changeRate}%` : '—'],
            ['거래량', formatNumber(quote.volume)],
            ['기준시각', quote.asOf ?? '—'],
          ];
          const list = document.createElement('dl');
          list.className = 'chart-quote-preview-dl';
          for (const [label, value] of rows) {
            const term = document.createElement('dt');
            term.textContent = label;
            const detail = document.createElement('dd');
            detail.textContent = value;
            list.append(term, detail);
          }
          const tag = document.createElement('p');
          tag.className = 'chart-quote-preview-tag';
          tag.textContent = `지연 시세 · 오너 로컬 전용 · ${quote.currency ?? 'KRW'}`;
          previewResult.append(list, tag);
        } else if (data.status === 'unavailable' || data.status === 'error') {
          showPreviewMessage('현재 KIS 데이터를 불러오지 못했습니다. 샘플 데이터로 계속 표시합니다.');
        } else {
          showPreviewMessage('오너 로컬 환경에서만 KIS 연결 프리뷰를 사용할 수 있습니다.');
        }
      };

      if (previewBtn) {
        if (ownerLocalPreview) {
          previewBtn.disabled = false;
          previewBtn.addEventListener('click', async () => {
            if (selectedAssetType !== 'stock' && selectedAssetType !== 'etf') {
              showPreviewMessage('해당 종목 유형은 아직 프리뷰가 지원되지 않습니다.');
              return;
            }
            previewBtn.disabled = true;
            const previousLabel = previewBtn.textContent;
            previewBtn.textContent = '불러오는 중…';
            try {
              const params = new URLSearchParams({
                symbol: selectedSymbol,
                market: 'KR',
                assetType: selectedAssetType,
                source: 'owner-local',
                preview: 'quote',
              });
              const response = await fetch(`/api/chart-ai/owner-local-quote-preview?${params.toString()}`, {
                headers: { accept: 'application/json' },
              });
              const data = await response.json();
              renderPreview(data);
            } catch {
              showPreviewMessage('현재 KIS 데이터를 불러오지 못했습니다. 샘플 데이터로 계속 표시합니다.');
            } finally {
              previewBtn.disabled = false;
              previewBtn.textContent = previousLabel ?? 'KIS 시세 프리뷰 확인';
            }
          });
        } else {
          previewBtn.disabled = true;
        }
      }

      // Owner-local KIS OHLC preview. Gated: never auto-fetches, and only fetches the gated
      // owner-local OHLC preview route when the page URL carries source=owner-local. On any
      // blocked/unavailable/malformed/insufficient response, falls back to the sample chart with
      // a safe Korean message — never a raw error, provider payload, or stack trace.
      const ohlcPreviewBtn = document.getElementById('chartAiOhlcPreviewBtn') as HTMLButtonElement | null;
      const ohlcPreviewTag = document.getElementById('chartAiOhlcPreviewTag');
      const ohlcPreviewMessage = document.getElementById('chartAiOhlcPreviewMessage');
      const ownerLocalOhlcPreview = new URLSearchParams(window.location.search).get('source') === 'owner-local';

      const showOhlcPreviewMessage = (text: string) => {
        if (!ohlcPreviewMessage) return;
        ohlcPreviewMessage.hidden = false;
        ohlcPreviewMessage.textContent = text;
      };

      const clearOhlcPreviewMessage = () => {
        if (!ohlcPreviewMessage) return;
        ohlcPreviewMessage.hidden = true;
        ohlcPreviewMessage.textContent = '';
      };

      resetOhlcPreview = () => {
        if (ohlcPreviewTag) ohlcPreviewTag.hidden = true;
        clearOhlcPreviewMessage();
      };

      const fallbackToSampleChart = (message: string) => {
        resetOhlcPreview();
        showOhlcPreviewMessage(message);
        renderChart();
      };

      if (ohlcPreviewBtn) {
        if (ownerLocalOhlcPreview) {
          ohlcPreviewBtn.disabled = false;
          ohlcPreviewBtn.addEventListener('click', async () => {
            if (selectedAssetType !== 'stock' && selectedAssetType !== 'etf') {
              fallbackToSampleChart('오너 로컬 환경에서만 KIS 연결 프리뷰를 사용할 수 있습니다.');
              return;
            }
            ohlcPreviewBtn.disabled = true;
            const previousLabel = ohlcPreviewBtn.textContent;
            ohlcPreviewBtn.textContent = '불러오는 중…';
            try {
              const params = new URLSearchParams({
                symbol: selectedSymbol,
                market: 'KR',
                assetType: selectedAssetType,
                period: activePeriod,
                source: 'owner-local',
                preview: 'ohlc',
              });
              const response = await fetch(`/api/chart-ai/owner-local-ohlc-preview?${params.toString()}`, {
                headers: { accept: 'application/json' },
              });
              const data = await response.json();
              if (data?.status === 'ok' && data?.renderable && Array.isArray(data?.points) && data.points.length > 0) {
                const rendered = renderOhlcChart(data.points as OwnerLocalOhlcPreviewPoint[]);
                if (rendered) {
                  ownerLocalConnected = true;
                  updateOverviewDataStatus();
                  updateMkAiPanel();
                  setChartStatus('지연 시세 · KIS OHLC · KRW', '오너 로컬 전용');
                  showOhlcPreviewMessage('KIS OHLC 차트가 반영되었습니다.');
                  if (ohlcPreviewTag) ohlcPreviewTag.hidden = false;
                } else {
                  fallbackToSampleChart('KIS 응답을 차트에 표시할 수 없어 샘플 차트를 유지합니다.');
                }
              } else if (data?.status === 'blocked') {
                fallbackToSampleChart('오너 로컬 환경에서만 KIS 연결 프리뷰를 사용할 수 있습니다.');
              } else {
                fallbackToSampleChart('현재 KIS 데이터를 불러오지 못했습니다. 샘플 데이터로 계속 표시합니다.');
              }
            } catch {
              fallbackToSampleChart('현재 KIS 데이터를 불러오지 못했습니다. 샘플 데이터로 계속 표시합니다.');
            } finally {
              ohlcPreviewBtn.disabled = false;
              ohlcPreviewBtn.textContent = previousLabel ?? 'KIS 차트 프리뷰 확인';
            }
          });
        } else {
          ohlcPreviewBtn.disabled = true;
        }
      }

      renderChart();
    };

    document.addEventListener('astro:page-load', setup);
    setup();
  </script>

