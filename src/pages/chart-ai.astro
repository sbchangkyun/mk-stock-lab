---
import Layout from '../layouts/Layout.astro';
import { getClientSafeDomesticSymbolRecords } from '../lib/symbol-master/domesticSymbolMaster';

const clientSafeDomesticSymbols = getClientSafeDomesticSymbolRecords();
const clientSafeDomesticSymbolPayload = JSON.stringify(clientSafeDomesticSymbols)
  .replaceAll('<', '\\u003c');
---

<Layout title="종목 차트 | MK Stock Lab" activePath="/chart-ai">
  <header class="page-header chart-lookup-page-header">
    <div>
      <p class="eyebrow">국내/미국 주식·ETF</p>
      <h1>종목 차트</h1>
      <p class="lead">종목을 조회하고 차트 중심의 기본 정보를 확인하세요. 현재 화면은 안전한 샘플 데이터로 구성되어 있습니다.</p>
    </div>
  </header>

  <main class="chart-lookup-shell">
    <section class="chart-lookup-search" aria-labelledby="chart-lookup-search-heading">
      <div class="chart-ai-symbol-row">
        <label class="chart-search-shell chart-lookup-search-field" for="chartAiInput">
          <span id="chart-lookup-search-heading">종목 검색</span>
          <input
            id="chartAiInput"
            type="search"
            placeholder="종목명 또는 종목코드 입력"
            aria-label="종목명 또는 종목코드 입력"
            aria-controls="chartAiSearchResults"
            aria-autocomplete="list"
            aria-expanded="false"
            role="combobox"
            autocomplete="off"
            spellcheck="false"
          />
        </label>
        <button class="button-link chart-ai-run-btn chart-lookup-submit" id="chartAiRunBtn" type="button">조회</button>
      </div>

      <div class="chart-lookup-dropdown" id="chartAiSearchDropdown" hidden>
        <div class="chart-ai-results-head">
          <div class="chart-ai-results-summary">
            <strong>검색 결과</strong>
            <span id="chartAiResultCount" aria-live="polite">0개</span>
          </div>
          <div class="chart-ai-filter-bar" role="group" aria-label="종목 유형 필터">
            <button class="chart-ai-filter-btn active" type="button" data-asset-filter="all" aria-pressed="true">전체</button>
            <button class="chart-ai-filter-btn" type="button" data-asset-filter="stock" aria-pressed="false">주식</button>
            <button class="chart-ai-filter-btn" type="button" data-asset-filter="etf" aria-pressed="false">ETF</button>
          </div>
        </div>
        <div
          class="chart-ai-search-results"
          id="chartAiSearchResults"
          role="listbox"
          aria-label="국내 종목 검색 결과"
        ></div>
        <p class="chart-ai-empty-state" id="chartAiEmptyState" hidden aria-live="polite">
          검색 결과가 없습니다. 종목명이나 종목코드를 다시 확인해 주세요.
        </p>
      </div>
    </section>

    <div class="chart-lookup-content-grid">
      <section class="chart-market-panel" aria-labelledby="chart-market-heading">
        <div class="chart-market-rail">
          <div class="chart-market-summary">
            <div class="chart-market-heading-group">
              <p class="chart-market-kicker">차트</p>
              <h2 id="chart-market-heading">샘플 차트</h2>
            </div>
            <div class="chart-market-identity-row" aria-label="선택 종목 기본 정보" aria-live="polite">
              <strong id="chartAiSelectedName">삼성전자</strong>
              <span class="chart-identity-symbol" id="chartAiSelectedSymbol">005930</span>
              <span class="chart-identity-chip" id="chartAiSelectedExchange">KOSPI</span>
              <span class="chart-identity-chip" id="chartAiSelectedAssetType">주식</span>
              <span class="chart-identity-chip" id="chartAiSelectedCurrency">KRW</span>
            </div>
          </div>
          <div class="chart-market-status">
            <span id="chartAiChartStatus">샘플 OHLC·거래량 데이터</span>
            <strong>실제 시세 아님</strong>
          </div>
        </div>

        <div class="chart-period-controls" role="group" aria-label="차트 기간 선택">
          <button type="button" data-period="1d" aria-pressed="true" class="active">1일</button>
          <button type="button" data-period="1w" aria-pressed="false">1주</button>
          <button type="button" data-period="1m" aria-pressed="false">1개월</button>
          <button type="button" data-period="3m" aria-pressed="false">3개월</button>
          <button type="button" data-period="1y" aria-pressed="false">1년</button>
        </div>

        <div class="chart-ohlc-preview-row" id="chartAiOhlcPreviewRow">
          <button type="button" class="chart-ohlc-preview-btn" id="chartAiOhlcPreviewBtn" disabled>KIS OHLC 프리뷰 확인</button>
          <span class="chart-ohlc-preview-tag" id="chartAiOhlcPreviewTag" hidden>지연 시세 · 오너 로컬 OHLC · KRW</span>
        </div>
        <p class="chart-ohlc-preview-guide" id="chartAiOhlcPreviewGuide">오너 로컬 환경에서만 KIS OHLC 프리뷰를 확인할 수 있습니다. (source=owner-local)</p>
        <p class="chart-ohlc-preview-message" id="chartAiOhlcPreviewMessage" hidden aria-live="polite"></p>

        <div
          class="chart-candlestick-ready"
          id="chartAiMarketChart"
          role="img"
          aria-label="선택 종목의 샘플 캔들 차트와 거래량"
        >
          <div class="chart-plot-heading" aria-hidden="true">
            <span id="chartAiChartPeriodLabel">1일 샘플</span>
          </div>
          <svg
            class="chart-market-svg"
            id="chartAiMarketSvg"
            viewBox="0 0 960 440"
            preserveAspectRatio="none"
            aria-hidden="true"
          ></svg>
          <div class="chart-safety-note">
            <strong>샘플 OHLC·거래량 데이터</strong>
            <span>실제 시세 아님 · 투자 참고용</span>
          </div>
        </div>

      </section>

      <aside class="chart-stock-sidebar">
        <section class="panel chart-company-placeholder" aria-labelledby="chart-company-heading">
          <div class="chart-sidebar-heading">
            <p class="eyebrow">샘플 정보</p>
            <h2 id="chart-company-heading">기업 개요</h2>
          </div>
          <p>선택한 종목의 사업 내용과 기본 정보는 이후 companyProfile 데이터와 연결될 예정입니다.</p>
          <small>샘플 정보 · 실제 투자 판단용 아님</small>
        </section>

        <section class="panel chart-quote-preview" id="chartAiQuotePreview" aria-labelledby="chart-quote-preview-heading">
          <div class="chart-sidebar-heading">
            <p class="eyebrow">오너 로컬 전용</p>
            <h2 id="chart-quote-preview-heading">KIS 로컬 프리뷰</h2>
          </div>
          <p class="chart-quote-preview-guide" id="chartAiQuotePreviewGuide">오너 로컬 환경에서만 실제 시세 프리뷰를 확인할 수 있습니다.</p>
          <button class="chart-quote-preview-btn" id="chartAiQuotePreviewBtn" type="button" disabled>KIS 프리뷰 확인</button>
          <div class="chart-quote-preview-result" id="chartAiQuotePreviewResult" hidden aria-live="polite"></div>
          <small>지연 시세 · 오너 로컬 전용 · 실제 투자 판단용 아님</small>
        </section>

        <button
          class="chart-mk-ai-button chart-sidebar-mk-ai"
          id="chartAiMkAiBtn"
          type="button"
          aria-expanded="false"
          aria-controls="chartAiMkAiNote"
        >MK AI</button>
        <div class="chart-mk-ai-note" id="chartAiMkAiNote" hidden>
          <strong>MK AI 분석 준비</strong>
          <p>MK AI 분석은 다음 단계에서 버튼 클릭 후 안내와 함께 시작됩니다.</p>
        </div>
      </aside>
    </div>

    <aside class="chart-lookup-disclaimer" aria-label="데이터 이용 안내">
      <strong>샘플 화면</strong>
      <span>차트와 종목 정보는 화면 구조 확인용이며 투자 판단이나 매수·매도 추천이 아닙니다.</span>
    </aside>
  </main>

  <script
    id="chartAiDomesticSymbolData"
    type="application/json"
    set:html={clientSafeDomesticSymbolPayload}
  ></script>

  <script>
    import { buildMockedChartGeometry } from '../lib/chart-ai/chartScale';
    import {
      CHART_PERIOD_LABELS,
      createMockedOhlcSeries,
      isChartPeriodKey,
      isValidMockedOhlcSeries,
      type ChartPeriodKey,
      type MockedOhlcPoint,
    } from '../lib/chart-ai/mockedOhlc';
    import { toMockedOhlcPoints, type OwnerLocalOhlcPreviewPoint } from '../lib/chart-ai/ohlcPreviewChart';
    import { searchClientSafeDomesticSymbols } from '../lib/symbol-master/clientSymbolSearch';
    import type { ClientSafeSymbolSearchRecord, DomesticAssetType } from '../lib/symbol-master/types';

    const assetTypeLabel = (assetType: DomesticAssetType): string => {
      if (assetType === 'stock') return '주식';
      if (assetType === 'etf') return 'ETF';
      if (assetType === 'etn') return 'ETN';
      return '기타';
    };

    const parseClientSafeRecords = (): ClientSafeSymbolSearchRecord[] => {
      const payload = document.getElementById('chartAiDomesticSymbolData')?.textContent ?? '[]';
      try {
        const parsed: unknown = JSON.parse(payload);
        return Array.isArray(parsed) ? parsed as ClientSafeSymbolSearchRecord[] : [];
      } catch {
        return [];
      }
    };

    const setup = () => {
      const input = document.getElementById('chartAiInput') as HTMLInputElement | null;
      const runBtn = document.getElementById('chartAiRunBtn') as HTMLButtonElement | null;
      const searchPanel = document.querySelector<HTMLElement>('.chart-lookup-search');
      const dropdown = document.getElementById('chartAiSearchDropdown');
      const resultsEl = document.getElementById('chartAiSearchResults');
      const resultCount = document.getElementById('chartAiResultCount');
      const emptyState = document.getElementById('chartAiEmptyState');
      const filterButtons = document.querySelectorAll<HTMLButtonElement>('.chart-ai-filter-btn');
      const periodButtons = document.querySelectorAll<HTMLButtonElement>('[data-period]');
      const mkAiButton = document.getElementById('chartAiMkAiBtn') as HTMLButtonElement | null;
      const mkAiNote = document.getElementById('chartAiMkAiNote');
      const chart = document.getElementById('chartAiMarketChart');
      const chartSvg = document.getElementById('chartAiMarketSvg') as SVGSVGElement | null;
      const records = parseClientSafeRecords();
      let activeFilter: DomesticAssetType | 'all' = 'all';
      let selectedSymbol = '005930';
      let selectedName = '삼성전자';
      let selectedAssetType: DomesticAssetType = 'stock';
      let activePeriod: ChartPeriodKey = '1d';
      let visibleRecords: ClientSafeSymbolSearchRecord[] = [];
      let resetQuotePreview: () => void = () => {};
      let resetOhlcPreview: () => void = () => {};

      if (!input || !runBtn || !searchPanel || !dropdown || !resultsEl || !resultCount || !emptyState || !chart || !chartSvg) return;
      if (runBtn.dataset.ready === 'true') return;
      runBtn.dataset.ready = 'true';

      const setText = (id: string, text: string) => {
        const element = document.getElementById(id);
        if (element) element.textContent = text;
      };

      const createSvgElement = <K extends keyof SVGElementTagNameMap>(
        name: K,
        attributes: Record<string, string | number>,
        className?: string,
      ): SVGElementTagNameMap[K] => {
        const element = document.createElementNS('http://www.w3.org/2000/svg', name);
        Object.entries(attributes).forEach(([key, value]) => element.setAttribute(key, String(value)));
        if (className) element.setAttribute('class', className);
        return element;
      };

      const renderChartFromPoints = (points: MockedOhlcPoint[], periodLabel: string, ariaLabel: string) => {
        const geometry = buildMockedChartGeometry(points, activePeriod);
        const gridLayer = createSvgElement('g', {}, 'chart-svg-grid');
        const volumeLayer = createSvgElement('g', {}, 'chart-svg-volume');
        const candleLayer = createSvgElement('g', {}, 'chart-svg-candles');
        const axisLayer = createSvgElement('g', {}, 'chart-svg-axis');

        geometry.priceLabels.forEach(({ y, label }) => {
          if (y === undefined) return;
          gridLayer.append(createSvgElement('line', {
            x1: geometry.plotLeft, y1: y, x2: geometry.plotRight, y2: y,
          }, 'chart-grid-line'));
          const axisText = createSvgElement('text', { x: geometry.plotRight + 14, y: y + 4 }, 'chart-axis-text');
          axisText.textContent = label;
          axisLayer.append(axisText);
        });

        gridLayer.append(createSvgElement('line', {
          x1: geometry.plotLeft,
          y1: geometry.volumeTop - 14,
          x2: geometry.plotRight,
          y2: geometry.volumeTop - 14,
        }, 'chart-volume-divider'));

        geometry.dateLabels.forEach(({ x, label }) => {
          if (x === undefined) return;
          gridLayer.append(createSvgElement('line', {
            x1: x, y1: geometry.priceTop, x2: x, y2: geometry.volumeBottom,
          }, 'chart-grid-line chart-grid-line-vertical'));
          const axisText = createSvgElement('text', { x, y: 430, 'text-anchor': 'middle' }, 'chart-axis-text');
          axisText.textContent = label;
          axisLayer.append(axisText);
        });

        geometry.candles.forEach((candle) => {
          const directionClass = candle.direction === 'up' ? 'is-up' : 'is-down';
          candleLayer.append(createSvgElement('line', {
            x1: candle.x,
            y1: candle.wickTop,
            x2: candle.x,
            y2: candle.wickBottom,
          }, `chart-candle-wick ${directionClass}`));
          candleLayer.append(createSvgElement('rect', {
            x: candle.x - candle.bodyWidth / 2,
            y: candle.bodyTop,
            width: candle.bodyWidth,
            height: candle.bodyHeight,
            rx: 0.8,
          }, `chart-candle-body ${directionClass}`));
          volumeLayer.append(createSvgElement('rect', {
            x: candle.x - candle.bodyWidth / 2,
            y: candle.volumeY,
            width: candle.bodyWidth,
            height: candle.volumeHeight,
            rx: 0.6,
          }, `chart-volume-bar ${directionClass}`));
        });

        chartSvg.setAttribute('viewBox', geometry.viewBox);
        chartSvg.replaceChildren(gridLayer, volumeLayer, candleLayer, axisLayer);
        setText('chartAiChartPeriodLabel', periodLabel);
        chart.setAttribute('aria-label', ariaLabel);
      };

      const renderChart = () => {
        const points = createMockedOhlcSeries(selectedSymbol, activePeriod);
        if (!isValidMockedOhlcSeries(points)) return;
        renderChartFromPoints(
          points,
          `${CHART_PERIOD_LABELS[activePeriod]} 샘플`,
          `${selectedName} ${selectedSymbol}, ${CHART_PERIOD_LABELS[activePeriod]} 선택 종목의 샘플 캔들 차트와 거래량. 실제 시세 아님.`,
        );
      };

      const renderOhlcChart = (rawPoints: OwnerLocalOhlcPreviewPoint[]): boolean => {
        const points = toMockedOhlcPoints(rawPoints);
        if (!isValidMockedOhlcSeries(points)) return false;
        renderChartFromPoints(
          points,
          `${CHART_PERIOD_LABELS[activePeriod]} · 오너 로컬 OHLC`,
          `${selectedName} ${selectedSymbol}, ${CHART_PERIOD_LABELS[activePeriod]} 오너 로컬 OHLC 프리뷰 차트와 거래량. 지연 시세, 실제 투자 판단용 아님.`,
        );
        return true;
      };

      const closeDropdown = () => {
        visibleRecords = [];
        resultsEl.replaceChildren();
        resultCount.textContent = '0개';
        emptyState.hidden = true;
        dropdown.hidden = true;
        searchPanel.classList.remove('open');
        input.setAttribute('aria-expanded', 'false');
      };

      const updateSelection = (record: ClientSafeSymbolSearchRecord) => {
        selectedSymbol = record.symbol;
        selectedName = record.nameKo;
        selectedAssetType = record.assetType;
        setText('chartAiSelectedName', record.nameKo);
        setText('chartAiSelectedSymbol', record.symbol);
        setText('chartAiSelectedExchange', record.exchange);
        setText('chartAiSelectedAssetType', assetTypeLabel(record.assetType));
        setText('chartAiSelectedCurrency', record.currency);
        input.value = '';
        closeDropdown();
        resetOhlcPreview();
        renderChart();
        resetQuotePreview();
      };

      const renderResults = (open = true) => {
        const query = input.value.trim();
        if (!query) {
          closeDropdown();
          return;
        }

        visibleRecords = searchClientSafeDomesticSymbols(records, {
          query,
          limit: 15,
          assetTypes: activeFilter === 'all' ? undefined : [activeFilter],
          includeStatuses: ['active'],
        });
        resultsEl.replaceChildren();
        resultCount.textContent = `${visibleRecords.length}개`;
        emptyState.hidden = visibleRecords.length > 0;
        dropdown.hidden = !open;
        searchPanel.classList.toggle('open', open);
        input.setAttribute('aria-expanded', String(open));

        for (const record of visibleRecords) {
          const button = document.createElement('button');
          const isSelected = record.symbol === selectedSymbol;
          button.type = 'button';
          button.className = 'chart-ai-search-result';
          button.dataset.symbol = record.symbol;
          button.setAttribute('role', 'option');
          button.setAttribute('aria-selected', String(isSelected));
          button.classList.toggle('selected', isSelected);

          const name = document.createElement('strong');
          name.className = 'chart-ai-search-result-name';
          name.textContent = record.nameKo;
          const metadata = document.createElement('span');
          metadata.className = 'chart-ai-search-result-meta';
          metadata.textContent = record.assetType === 'etf'
            ? `${record.symbol} · ${record.exchange} · ${record.currency}`
            : `${record.symbol} · ${record.exchange} · ${assetTypeLabel(record.assetType)}`;
          button.append(name, metadata);
          button.addEventListener('click', () => updateSelection(record));
          resultsEl.append(button);
        }
      };

      filterButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const filter = button.dataset.assetFilter;
          if (filter !== 'all' && filter !== 'stock' && filter !== 'etf') return;
          activeFilter = filter;
          filterButtons.forEach((candidate) => {
            const active = candidate === button;
            candidate.classList.toggle('active', active);
            candidate.setAttribute('aria-pressed', String(active));
          });
          renderResults(true);
        });
      });

      input.addEventListener('focus', () => renderResults(true));
      input.addEventListener('input', () => renderResults(true));
      input.addEventListener('keydown', (event: KeyboardEvent) => {
        if (event.key === 'Enter') {
          event.preventDefault();
          runBtn.click();
        }
        if (event.key === 'ArrowDown') {
          const firstResult = resultsEl.querySelector<HTMLButtonElement>('.chart-ai-search-result');
          if (firstResult) {
            event.preventDefault();
            firstResult.focus();
          }
        }
        if (event.key === 'Escape') closeDropdown();
      });
      runBtn.addEventListener('click', () => {
        if (!input.value.trim()) {
          closeDropdown();
          return;
        }
        renderResults(true);
        if (visibleRecords[0]) updateSelection(visibleRecords[0]);
      });

      periodButtons.forEach((button) => {
        button.addEventListener('click', () => {
          if (!isChartPeriodKey(button.dataset.period)) return;
          activePeriod = button.dataset.period;
          periodButtons.forEach((candidate) => {
            const active = candidate === button;
            candidate.classList.toggle('active', active);
            candidate.setAttribute('aria-pressed', String(active));
          });
          resetOhlcPreview();
          renderChart();
        });
      });

      mkAiButton?.addEventListener('click', () => {
        if (!mkAiNote) return;
        const expanded = mkAiButton.getAttribute('aria-expanded') === 'true';
        mkAiButton.setAttribute('aria-expanded', String(!expanded));
        mkAiNote.hidden = expanded;
      });

      // Owner-local KIS quote preview. Gated: never auto-fetches, and only fetches the gated
      // owner-local preview route when the page URL carries source=owner-local.
      const previewBtn = document.getElementById('chartAiQuotePreviewBtn') as HTMLButtonElement | null;
      const previewGuide = document.getElementById('chartAiQuotePreviewGuide');
      const previewResult = document.getElementById('chartAiQuotePreviewResult');
      const ownerLocalPreview = new URLSearchParams(window.location.search).get('source') === 'owner-local';

      resetQuotePreview = () => {
        if (previewResult) {
          previewResult.hidden = true;
          previewResult.replaceChildren();
        }
      };

      const formatNumber = (value: number | null): string =>
        typeof value === 'number' ? value.toLocaleString('ko-KR') : '—';

      const showPreviewMessage = (text: string, detail?: string) => {
        if (!previewResult) return;
        previewResult.hidden = false;
        previewResult.replaceChildren();
        const message = document.createElement('p');
        message.className = 'chart-quote-preview-msg';
        message.textContent = text;
        previewResult.append(message);
        if (detail) {
          const small = document.createElement('small');
          small.textContent = detail;
          previewResult.append(small);
        }
      };

      const renderPreview = (data: {
        status?: string;
        providerStatus?: string;
        quote?: {
          lastPrice: number | null; previousClose: number | null; change: number | null;
          changeRate: number | null; volume: number | null; asOf: string | null; currency: string;
        } | null;
      }) => {
        if (!previewResult) return;
        if (data.status === 'ok' && data.quote) {
          const quote = data.quote;
          previewResult.hidden = false;
          previewResult.replaceChildren();
          const rows: Array<[string, string]> = [
            ['현재가', formatNumber(quote.lastPrice)],
            ['전일종가', formatNumber(quote.previousClose)],
            ['전일대비', formatNumber(quote.change)],
            ['등락률', typeof quote.changeRate === 'number' ? `${quote.changeRate}%` : '—'],
            ['거래량', formatNumber(quote.volume)],
            ['기준시각', quote.asOf ?? '—'],
          ];
          const list = document.createElement('dl');
          list.className = 'chart-quote-preview-dl';
          for (const [label, value] of rows) {
            const term = document.createElement('dt');
            term.textContent = label;
            const detail = document.createElement('dd');
            detail.textContent = value;
            list.append(term, detail);
          }
          const tag = document.createElement('p');
          tag.className = 'chart-quote-preview-tag';
          tag.textContent = `지연 시세 · 오너 로컬 전용 · ${quote.currency ?? 'KRW'}`;
          previewResult.append(list, tag);
        } else if (data.status === 'unavailable' || data.status === 'error') {
          showPreviewMessage('일시적으로 시세를 불러올 수 없습니다. 잠시 후 다시 시도해 주세요.', `provider: ${String(data.providerStatus ?? 'unavailable')}`);
        } else {
          showPreviewMessage('오너 로컬 프리뷰 조건이 충족되지 않았습니다.');
        }
      };

      if (previewBtn) {
        if (ownerLocalPreview) {
          previewBtn.disabled = false;
          if (previewGuide) previewGuide.textContent = '오너 로컬 프리뷰가 활성화되었습니다. 선택 종목의 지연 시세를 확인하세요.';
          previewBtn.addEventListener('click', async () => {
            if (selectedAssetType !== 'stock' && selectedAssetType !== 'etf') {
              showPreviewMessage('해당 종목 유형은 아직 프리뷰가 지원되지 않습니다.');
              return;
            }
            previewBtn.disabled = true;
            const previousLabel = previewBtn.textContent;
            previewBtn.textContent = '불러오는 중…';
            try {
              const params = new URLSearchParams({
                symbol: selectedSymbol,
                market: 'KR',
                assetType: selectedAssetType,
                source: 'owner-local',
                preview: 'quote',
              });
              const response = await fetch(`/api/chart-ai/owner-local-quote-preview?${params.toString()}`, {
                headers: { accept: 'application/json' },
              });
              const data = await response.json();
              renderPreview(data);
            } catch {
              showPreviewMessage('일시적으로 시세를 불러올 수 없습니다. 잠시 후 다시 시도해 주세요.');
            } finally {
              previewBtn.disabled = false;
              previewBtn.textContent = previousLabel ?? 'KIS 프리뷰 확인';
            }
          });
        } else {
          previewBtn.disabled = true;
          if (previewGuide) previewGuide.textContent = '오너 로컬 환경에서만 실제 시세 프리뷰를 확인할 수 있습니다. (source=owner-local)';
        }
      }

      // Owner-local KIS OHLC preview. Gated: never auto-fetches, and only fetches the gated
      // owner-local OHLC preview route when the page URL carries source=owner-local. On any
      // blocked/unavailable/malformed/insufficient response, falls back to the sample chart with
      // a safe Korean message — never a raw error, provider payload, or stack trace.
      const ohlcPreviewBtn = document.getElementById('chartAiOhlcPreviewBtn') as HTMLButtonElement | null;
      const ohlcPreviewGuide = document.getElementById('chartAiOhlcPreviewGuide');
      const ohlcPreviewTag = document.getElementById('chartAiOhlcPreviewTag');
      const ohlcPreviewMessage = document.getElementById('chartAiOhlcPreviewMessage');
      const ownerLocalOhlcPreview = new URLSearchParams(window.location.search).get('source') === 'owner-local';

      const showOhlcPreviewMessage = (text: string) => {
        if (!ohlcPreviewMessage) return;
        ohlcPreviewMessage.hidden = false;
        ohlcPreviewMessage.textContent = text;
      };

      const clearOhlcPreviewMessage = () => {
        if (!ohlcPreviewMessage) return;
        ohlcPreviewMessage.hidden = true;
        ohlcPreviewMessage.textContent = '';
      };

      resetOhlcPreview = () => {
        if (ohlcPreviewTag) ohlcPreviewTag.hidden = true;
        clearOhlcPreviewMessage();
      };

      const fallbackToSampleChart = (message: string) => {
        resetOhlcPreview();
        showOhlcPreviewMessage(message);
        renderChart();
      };

      if (ohlcPreviewBtn) {
        if (ownerLocalOhlcPreview) {
          ohlcPreviewBtn.disabled = false;
          if (ohlcPreviewGuide) ohlcPreviewGuide.textContent = '오너 로컬 OHLC 프리뷰가 활성화되었습니다. 버튼을 눌러 선택 종목의 OHLC 데이터를 확인하세요.';
          ohlcPreviewBtn.addEventListener('click', async () => {
            if (selectedAssetType !== 'stock' && selectedAssetType !== 'etf') {
              fallbackToSampleChart('오너 로컬 OHLC 프리뷰 조건이 충족되지 않았습니다.');
              return;
            }
            ohlcPreviewBtn.disabled = true;
            const previousLabel = ohlcPreviewBtn.textContent;
            ohlcPreviewBtn.textContent = '불러오는 중…';
            try {
              const params = new URLSearchParams({
                symbol: selectedSymbol,
                market: 'KR',
                assetType: selectedAssetType,
                period: activePeriod,
                source: 'owner-local',
                preview: 'ohlc',
              });
              const response = await fetch(`/api/chart-ai/owner-local-ohlc-preview?${params.toString()}`, {
                headers: { accept: 'application/json' },
              });
              const data = await response.json();
              if (data?.status === 'ok' && data?.renderable && Array.isArray(data?.points) && data.points.length > 0) {
                const rendered = renderOhlcChart(data.points as OwnerLocalOhlcPreviewPoint[]);
                if (rendered) {
                  clearOhlcPreviewMessage();
                  if (ohlcPreviewTag) ohlcPreviewTag.hidden = false;
                } else {
                  fallbackToSampleChart('표시 가능한 OHLC 데이터가 부족하여 샘플 차트를 유지합니다.');
                }
              } else if (data?.status === 'blocked') {
                fallbackToSampleChart('오너 로컬 OHLC 프리뷰 조건이 충족되지 않았습니다.');
              } else {
                fallbackToSampleChart('KIS OHLC 데이터를 일시적으로 불러올 수 없습니다.');
              }
            } catch {
              fallbackToSampleChart('KIS OHLC 데이터를 일시적으로 불러올 수 없습니다.');
            } finally {
              ohlcPreviewBtn.disabled = false;
              ohlcPreviewBtn.textContent = previousLabel ?? 'KIS OHLC 프리뷰 확인';
            }
          });
        } else {
          ohlcPreviewBtn.disabled = true;
          if (ohlcPreviewGuide) ohlcPreviewGuide.textContent = '오너 로컬 환경에서만 KIS OHLC 프리뷰를 확인할 수 있습니다. (source=owner-local)';
        }
      }

      renderChart();
    };

    document.addEventListener('astro:page-load', setup);
    setup();
  </script>

