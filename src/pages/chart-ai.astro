---
import Layout from '../layouts/Layout.astro';
import { getClientSafeDomesticSymbolRecords } from '../lib/symbol-master/domesticSymbolMaster';
import { scanSimilarity } from '../lib/chartSimilarity';
import type { SimilarityMatch } from '../lib/chartSimilarity';
import { buildSyntheticOhlcvFixture } from '../data/chartSimilarity/syntheticOhlcvFixture';
import { runSimilarPatternAgent } from '../lib/server/chart-ai/similar-pattern-agent.mjs';
import { createSimilarPatternFixtureInput } from '../lib/server/chart-ai/similar-pattern-agent.fixture.mjs';
import { runMkAgent } from '../lib/server/chart-ai/mk-agent.mjs';
import { createMkAgentFixtureInput } from '../lib/server/chart-ai/mk-agent.fixture.mjs';
import { evaluateProductionChartAiBetaAccess } from '../lib/server/chart-ai/protected-preview-beta-guard.mjs';

// Phase 3GG-N-FAST: server-side Production runtime detection, using the same dual-source
// (import.meta.env then process.env) read order already used by kisClient.ts and the H route, so
// this reflects the real deployed runtime rather than a client-guessable value. Reuses the
// existing, already-authorized production beta guard (unchanged) rather than duplicating its
// VERCEL_ENV + flag conditions -- betaQueryOptIn is fixed to true here because this decides the
// Production *default page visibility*, not an individual request's query opt-in.
type ImportMetaWithEnv = ImportMeta & { env?: Record<string, string | undefined> };
const readServerEnvValue = (name: string): string | undefined => {
  const fromImportMeta = (import.meta as ImportMetaWithEnv).env?.[name];
  if (typeof fromImportMeta === 'string' && fromImportMeta.trim().length > 0) return fromImportMeta;
  return process.env[name];
};
const isVercelProductionRuntime = readServerEnvValue('VERCEL_ENV') === 'production';
const productionChartAiDefaultAccess = evaluateProductionChartAiBetaAccess({
  betaQueryOptIn: true,
  env: {
    VERCEL_ENV: readServerEnvValue('VERCEL_ENV'),
    CHART_AI_ENABLE_PRODUCTION_CHART_AI_BETA: readServerEnvValue('CHART_AI_ENABLE_PRODUCTION_CHART_AI_BETA'),
  },
});
const productionChartAiDefaultEnabled = productionChartAiDefaultAccess.allowed === true;

const clientSafeDomesticSymbols = getClientSafeDomesticSymbolRecords();
const clientSafeDomesticSymbolPayload = JSON.stringify(clientSafeDomesticSymbols)
  .replaceAll('<', '\\u003c');

// Mocked/sample similarity result: deterministic engine run over synthetic fixture data only.
// No KIS, no API, no fetch. See docs/planning/phase_3ex_d_similarity_result_ui_mocked_integration_result_v0.1.md.
const similarityFixtureBars = buildSyntheticOhlcvFixture();
const similarityResult = scanSimilarity(similarityFixtureBars, {
  baseWindow: 20,
  forwardWindows: [5, 20],
  topK: 5,
  similarityMethod: 'return_correlation_rmse',
  excludeRecentBars: 40,
});
const similarityTopMatches = similarityResult.matches;
const similarityStats = similarityResult.summaryStats;
const similarityCurrentWindow = similarityResult.currentWindow;

const formatSimilarityScore = (value: number): string => `${value.toFixed(2)}점`;
const formatForwardReturnPct = (value: number | null | undefined): string =>
  typeof value === 'number' && Number.isFinite(value)
    ? `${value >= 0 ? '+' : ''}${(value * 100).toFixed(2)}%`
    : '데이터 부족';
const formatDrawdownPct = (value: number | null | undefined): string =>
  typeof value === 'number' && Number.isFinite(value) ? `${(value * 100).toFixed(2)}%` : '-';

// Local SVG overlay geometry: no external chart library, computed once at build/render time.
const OVERLAY_WIDTH = 640;
const OVERLAY_HEIGHT = 200;
const buildOverlayPath = (
  points: Array<{ index: number; value: number }>,
  minValue: number,
  maxValue: number,
): string => {
  if (points.length === 0) return '';
  const n = points.length;
  const xStep = n > 1 ? OVERLAY_WIDTH / (n - 1) : 0;
  const range = maxValue - minValue || 1;
  return points
    .map((point, i) => {
      const x = round2(i * xStep);
      const y = round2(OVERLAY_HEIGHT - ((point.value - minValue) / range) * OVERLAY_HEIGHT);
      return `${i === 0 ? 'M' : 'L'}${x},${y}`;
    })
    .join(' ');
};
function round2(value: number): number {
  return Math.round(value * 100) / 100;
}

const overlaySeries: Array<{ label: string; tone: string; path: Array<{ index: number; value: number }> }> = [
  { label: '현재 구간', tone: 'current', path: similarityResult.currentNormalizedPath },
  ...similarityTopMatches.slice(0, 3).map((match: SimilarityMatch, i: number) => ({
    label: `유사 구간 ${i + 1}`,
    tone: `match-${i + 1}`,
    path: match.normalizedPath,
  })),
];
const overlayValues = overlaySeries.flatMap((series) => series.path.map((point) => point.value));
const overlayMin = overlayValues.length > 0 ? Math.min(...overlayValues) : 0;
const overlayMax = overlayValues.length > 0 ? Math.max(...overlayValues) : 100;
const overlayDrawnSeries = overlaySeries.map((series) => ({
  ...series,
  d: buildOverlayPath(series.path, overlayMin, overlayMax),
}));

// Phase 3FF-A-UI-A: owner-local deterministic agent panel data. Fixture-only, no live KIS,
// no LLM. Computed once server-side at render time; never fetched client-side. Visibility is
// gated purely client-side (see setup() below) behind an explicit localhost + query-param
// opt-in, mirroring the ownerLocalMocked / ownerLocalAuthUsageBridge panels above.
const ownerLocalDeterministicSimilarPatternResult = runSimilarPatternAgent(createSimilarPatternFixtureInput());
const ownerLocalDeterministicMkAgentResult = runMkAgent(createMkAgentFixtureInput());

const formatDeterministicReturnPct = (value: number | null | undefined): string =>
  typeof value === 'number' && Number.isFinite(value) ? `${value >= 0 ? '+' : ''}${value.toFixed(2)}%` : '데이터 부족';

const OWNER_LOCAL_DETERMINISTIC_SAFETY_NOTICES = [
  '이 결과는 fixture 기반 owner-local 검증용입니다.',
  '실제 KIS 데이터가 아닙니다.',
  'LLM을 호출하지 않습니다.',
  '투자 참고용이며 매수·매도 추천이 아닙니다.',
];

const spDeterministicOk = ownerLocalDeterministicSimilarPatternResult.ok === true;
const spDeterministicSummary = spDeterministicOk ? ownerLocalDeterministicSimilarPatternResult.summary : null;
const spDeterministicTopMatch = spDeterministicOk ? (ownerLocalDeterministicSimilarPatternResult.matches[0] ?? null) : null;
const spDeterministicOutcomes = spDeterministicOk ? ownerLocalDeterministicSimilarPatternResult.aggregateOutcomes : null;

const ownerLocalDeterministicSimilarPatternView = {
  ok: spDeterministicOk,
  market: spDeterministicSummary?.market ?? '-',
  symbol: spDeterministicSummary?.symbol ?? '-',
  baseWindow: spDeterministicSummary?.baseWindow ?? 0,
  topK: spDeterministicSummary?.topK ?? 0,
  matchCount: spDeterministicSummary?.matchCount ?? 0,
  topMatchScore: spDeterministicTopMatch ? formatSimilarityScore(spDeterministicTopMatch.similarityScore) : '-',
  topMatchLabel: spDeterministicTopMatch?.scoreLabel ?? '-',
  averageReturnD5: spDeterministicOutcomes ? formatDeterministicReturnPct(spDeterministicOutcomes.averageForwardReturnD5Pct) : '데이터 부족',
  averageReturnD20: spDeterministicOutcomes ? formatDeterministicReturnPct(spDeterministicOutcomes.averageForwardReturnD20Pct) : '데이터 부족',
  positiveCountD5: spDeterministicOutcomes?.positiveCountD5 ?? 0,
  negativeCountD5: spDeterministicOutcomes?.negativeCountD5 ?? 0,
  positiveCountD20: spDeterministicOutcomes?.positiveCountD20 ?? 0,
  negativeCountD20: spDeterministicOutcomes?.negativeCountD20 ?? 0,
};

const mkDeterministicOk = ownerLocalDeterministicMkAgentResult.ok === true;
const mkDeterministicReport = mkDeterministicOk ? ownerLocalDeterministicMkAgentResult.report : null;

const ownerLocalDeterministicMkAgentView = {
  ok: mkDeterministicOk,
  agentName: mkDeterministicOk ? ownerLocalDeterministicMkAgentResult.agentName : 'MK 에이전트',
  oneLineSummary: mkDeterministicReport?.oneLineSummary ?? '',
  summaryBullets: mkDeterministicReport?.summaryBullets ?? [],
  sections: mkDeterministicReport?.sections ?? [],
  usageNotice: mkDeterministicReport?.usageNotice ?? '오픈베타에서는 계정당 하루 3회까지 사용할 수 있어요.',
  disclaimer: mkDeterministicReport?.disclaimer ?? '이 분석은 참고용이며 매수·매도 추천이 아닙니다. 투자 자문이 아닙니다. 최종 투자 판단의 책임은 이용자 본인에게 있습니다.',
};

// Phase 3FG-D: owner-local, hidden-by-default static UI shell for the guarded productization
// scaffold's decision states (Phase 3FG-A/3FG-B/3FG-C). Purely static copy — no scaffold
// import, no scaffold execution, no fetch, no API route call. Mirrors the 8-state mapping from
// docs/planning/phase_3fg_c_owner_local_guarded_productization_ui_readiness_plan_v0.1.md
// (Section 8). Visibility is gated purely client-side (see setup() below) behind an explicit
// localhost + query-param opt-in, mirroring the ownerLocalDeterministicAgents panel above.
type GuardedProductizationStaticShellState = {
  id: string;
  stateLabel: string;
  koreanLabel: string;
  allowed: boolean;
  staticStatus: string;
  explanation: string;
  requiredApproval: string | null;
  safetyNote: string;
  noExecutionStatement: string;
};

