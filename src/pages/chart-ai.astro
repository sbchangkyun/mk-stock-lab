    explanation: '현재 단계에서는 실제 분석 실행이 아니라 안전 경계 확인용 화면입니다. 모든 실제 상품화 게이트는 꺼져 있습니다.',
    requiredApproval: null,
    safetyNote: '참고용이며 매수·매도 추천이 아닙니다. 투자 자문이 아닙니다.',
    noExecutionStatement: '이 상태에서는 실제 실행이 전혀 발생하지 않습니다.',
  },
  {
    id: 'owner-local-without-acknowledgement',
    stateLabel: 'Owner-local without scaffoldOnlyAcknowledged',
    koreanLabel: '소유자-로컬 승인 대기',
    allowed: false,
    staticStatus: '차단됨 (Blocked)',
    explanation: '이 화면은 명시적 승인(scaffoldOnlyAcknowledged) 전까지 차단 상태입니다.',
    requiredApproval: null,
    safetyNote: '참고용이며 매수·매도 추천이 아닙니다. 투자 자문이 아닙니다.',
    noExecutionStatement: '이 상태에서는 실제 실행이 전혀 발생하지 않습니다.',
  },
  {
    id: 'owner-local-scaffold-only-allowed',
    stateLabel: 'Owner-local with explicit scaffoldOnlyAcknowledged',
    koreanLabel: '스캐폴드 전용 허용 상태 (실제 실행 아님)',
    allowed: true,
    staticStatus: '스캐폴드 전용 허용 (실제 실행 아님)',
    explanation: '이 상태는 실제 상품화 실행이 아니라 스캐폴드 전용 경계 확인 결과입니다.',
    requiredApproval: null,
    safetyNote: '참고용이며 매수·매도 추천이 아닙니다. 투자 자문이 아닙니다. 과거 유사 흐름은 미래 성과를 보장하지 않습니다.',
    noExecutionStatement:
      '실제 런타임 활성화가 아닙니다. 퍼블릭/베타 접근을 활성화하지 않습니다. 실시간 KIS를 활성화하지 않습니다. LLM을 활성화하지 않습니다. 사용량을 차감하지 않습니다. 유료/광고 권한을 해제하지 않습니다.',
  },
  {
    id: 'beta-attempt-blocked',
    stateLabel: 'Beta attempt blocked',
    koreanLabel: '베타 차단',
    allowed: false,
    staticStatus: '차단됨 (Blocked)',
    explanation: '베타 활성화는 아직 승인되지 않았습니다.',
    requiredApproval: 'Beta/public activation approval',
    safetyNote: '참고용이며 매수·매도 추천이 아닙니다. 투자 자문이 아닙니다.',
    noExecutionStatement: '이 상태에서는 실제 실행이 전혀 발생하지 않습니다.',
  },
  {
    id: 'public-attempt-blocked',
    stateLabel: 'Public attempt blocked',
    koreanLabel: '퍼블릭 차단',
    allowed: false,
    staticStatus: '차단됨 (Blocked)',
    explanation: '퍼블릭 활성화는 아직 승인되지 않았습니다.',
    requiredApproval: 'Beta/public activation approval',
    safetyNote: '참고용이며 매수·매도 추천이 아닙니다. 투자 자문이 아닙니다.',
    noExecutionStatement: '이 상태에서는 실제 실행이 전혀 발생하지 않습니다.',
  },
  {
    id: 'live-kis-attempt-blocked',
    stateLabel: 'Live KIS attempt blocked',
    koreanLabel: '실시간 KIS 차단',
    allowed: false,
    staticStatus: '차단됨 (Blocked)',
    explanation: '실시간 시세 연동은 아직 승인되지 않았습니다.',
    requiredApproval: 'Live KIS approval',
    safetyNote: '참고용이며 매수·매도 추천이 아닙니다. 투자 자문이 아닙니다.',
    noExecutionStatement: '이 상태에서는 실제 실행이 전혀 발생하지 않습니다.',
  },
  {
    id: 'llm-attempt-blocked',
    stateLabel: 'LLM attempt blocked',
    koreanLabel: 'LLM 차단',
    allowed: false,
    staticStatus: '차단됨 (Blocked)',
    explanation: 'LLM 기반 분석은 아직 승인되지 않았습니다.',
    requiredApproval: 'LLM approval',
    safetyNote: '참고용이며 매수·매도 추천이 아닙니다. 투자 자문이 아닙니다.',
    noExecutionStatement: '이 상태에서는 실제 실행이 전혀 발생하지 않습니다.',
  },
  {
    id: 'real-auth-attempt-blocked',
    stateLabel: 'Real auth attempt blocked',
    koreanLabel: '실제 인증 차단',
    allowed: false,
    staticStatus: '차단됨 (Blocked)',
    explanation: '실제 인증 런타임은 아직 승인되지 않았습니다.',
    requiredApproval: 'Real auth runtime approval',
    safetyNote: '참고용이며 매수·매도 추천이 아닙니다. 투자 자문이 아닙니다.',
    noExecutionStatement: '이 상태에서는 실제 실행이 전혀 발생하지 않습니다.',
  },
];

const GUARDED_PRODUCTIZATION_STATIC_SHELL_SAFETY_NOTICES = [
  '참고용',
  '매수·매도 추천이 아닙니다',
  '투자 자문이 아닙니다',
  '과거 유사 흐름은 미래 성과를 보장하지 않습니다.',
  '현재 단계에서는 실제 분석 실행이 아니라 안전 경계 확인용 화면입니다.',
  '모든 실제 상품화 게이트는 꺼져 있습니다.',
];

const GUARDED_PRODUCTIZATION_STATIC_SHELL_BOUNDARIES = [
  'No live KIS',
  'No LLM',
  'No public/beta activation',
  'No API route activation',
  'No Supabase/DB real runtime',
  'No env/session/JWT/cookie/header parsing',
];

// Phase 3GG-F-FAST: static safety-copy list for the owner-local KIS current_price integration
// panel (Phase 3GG-E-INTEGRATE). Text-only presentational polish -- no fetch, no scaffold
// import, no live KIS/LLM activation logic here.
const OWNER_LOCAL_KIS_INTEGRATION_SAFETY_NOTICES = [
  '로컬 전용 테스트입니다.',
  '투자 자문이 아닙니다.',
  'current_price(현재가) 조회만 지원합니다.',
  '원본 응답 데이터와 인증 정보는 표시되지 않습니다.',
];
---

<Layout title="종목 차트 | MK Stock Lab" activePath="/chart-ai">
  <div
    class="chart-ai-auth-shell"
    data-chart-ai-auth-state="authenticated"
    data-chart-ai-master-mode="false"
    data-chart-ai-cooldown-bypass="false"
    data-chart-ai-production-default={String(productionChartAiDefaultEnabled)}
  >
  <header class="page-header chart-lookup-page-header">
    <div>
      <p class="eyebrow">국내/미국 주식·ETF</p>
      <h1>종목 차트</h1>
      <p class="lead">
        {isVercelProductionRuntime
          ? '종목을 조회하고 차트 중심의 기본 정보를 확인하세요.'
          : '종목을 조회하고 차트 중심의 기본 정보를 확인하세요. 현재 화면은 안전한 샘플 데이터로 구성되어 있습니다.'}
      </p>
    </div>
  </header>

  <!-- Portfolio-aligned lock state: the section itself is the single access card. -->
  <section
    class="chart-ai-auth-gate chart-ai-auth-gate-card portfolio-aligned-lock-state"
    data-chart-ai-auth-gate="locked"
    data-chart-ai-auth-gate-card
    aria-labelledby="chart-ai-auth-gate-title"
    aria-live="polite"
    hidden
  >
    <div class="chart-ai-auth-lock-visual" aria-hidden="true">🔐</div>
    <div class="chart-ai-auth-gate-copy">
      <p class="eyebrow">접속 필요</p>
      <h2 id="chart-ai-auth-gate-title">로그인이 필요합니다</h2>
      <p>회원가입 또는 로그인 후 Chart AI 분석 기능을 사용할 수 있습니다.</p>
    </div>
    <button class="primary-action chart-ai-auth-gate-cta" data-chart-ai-auth-gate-cta type="button">
      회원가입 / 로그인
    </button>
  </section>

  <main class="chart-lookup-shell" data-chart-ai-auth-body hidden>
    <p class="chart-ai-master-mode-notice" data-chart-ai-master-notice hidden>
      마스터 권한으로 재분석 대기 시간이 적용되지 않습니다.
    </p>
    <section class="chart-lookup-search" aria-labelledby="chart-lookup-search-heading">
      <div class="chart-ai-symbol-row">
        <label class="chart-search-shell chart-lookup-search-field" for="chartAiInput">
          <span id="chart-lookup-search-heading">국내·미국 주식 및 ETF 검색</span>
          <input
            id="chartAiInput"
            type="search"
            placeholder="종목명, 티커 또는 종목코드를 입력하세요"
            aria-label="종목명, 티커 또는 종목코드를 입력하세요"
            aria-controls="chartAiSearchResults"
            aria-autocomplete="list"
            aria-expanded="false"
            role="combobox"
            autocomplete="off"
            spellcheck="false"
          />
        </label>
        <button class="button-link chart-ai-run-btn chart-lookup-submit" id="chartAiRunBtn" type="button">조회</button>
      </div>
      <p class="chart-ai-search-hint" id="chartAiSearchHint" hidden aria-live="polite">종목명 또는 종목코드를 입력해 주세요.</p>

      <div class="chart-lookup-dropdown" id="chartAiSearchDropdown" hidden>
        <div class="chart-ai-results-head">
          <div class="chart-ai-results-summary">
            <strong>검색 결과</strong>
            <span id="chartAiResultCount" aria-live="polite">0개</span>
          </div>
          <div class="chart-ai-filter-bar" role="group" aria-label="종목 유형 필터">
            <button class="chart-ai-filter-btn active" type="button" data-asset-filter="all" aria-pressed="true">전체</button>
            <button class="chart-ai-filter-btn" type="button" data-asset-filter="stock" aria-pressed="false">주식</button>
            <button class="chart-ai-filter-btn" type="button" data-asset-filter="etf" aria-pressed="false">ETF</button>
          </div>
        </div>
        <div
          class="chart-ai-search-results"
          id="chartAiSearchResults"
          role="listbox"
          aria-label="국내·미국 종목 검색 결과"
        ></div>
        <p class="chart-ai-empty-state" id="chartAiEmptyState" hidden aria-live="polite">
          검색 결과가 없습니다. 종목명이나 종목코드를 다시 확인해 주세요.
        </p>
      </div>
    </section>

    <div class={`chart-lookup-content-grid${isVercelProductionRuntime ? ' chart-lookup-content-grid--solo' : ''}`}>
      <section class="chart-market-panel" {...(isVercelProductionRuntime ? { 'aria-label': '종목 차트' } : { 'aria-labelledby': 'chart-market-heading' })}>
        <div class="chart-market-rail">
          <div class="chart-market-summary">
            {!isVercelProductionRuntime && (
            <div class="chart-market-heading-group">
              <p class="chart-market-kicker">차트</p>
              <h2 id="chart-market-heading">샘플 차트</h2>
            </div>
            )}
            <div class="chart-market-identity-row" aria-label="선택 종목 기본 정보" aria-live="polite">
              <strong id="chartAiSelectedName">종목 미선택</strong>
              <span class="chart-identity-symbol" id="chartAiSelectedSymbol">—</span>
              <span class="chart-identity-chip" id="chartAiSelectedExchange">—</span>
              <span class="chart-identity-chip" id="chartAiSelectedAssetType">—</span>
              <span class="chart-identity-chip" id="chartAiSelectedCurrency">—</span>
            </div>
            {isVercelProductionRuntime && (
            <div class="chart-market-price-row" id="chartAiHeaderPriceRow" hidden>
              <span class="chart-header-price" id="chartAiHeaderPrice">—</span>
              <span class="chart-header-change" id="chartAiHeaderChangeAmount">—</span>
