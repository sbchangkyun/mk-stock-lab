---
import Layout from '../layouts/Layout.astro';

const labCards = [
  { title: '국회의원 보유 주식', href: '/lab/congress-stocks', phase: 'Phase 8', description: '국회의원 재산 공개 기반 주식 보유 현황 리서치 화면입니다.' },
  { title: '국민연금 포트폴리오', href: '/lab/nps-portfolio', phase: 'Phase 8', description: '국민연금 보유 종목 리서치 화면입니다.' },
  { title: 'S&P 500 섹터', href: '/lab/sp500-sectors', phase: 'Phase 6', description: '연간 섹터 수익률 비교 화면입니다.' },
  { title: '자산군 수익률', href: '/lab/asset-class-returns', phase: 'Phase 6', description: '여러 자산군의 연간 수익률 비교 화면입니다.' },
];
---

<Layout title="Lab | MK Stock Lab" activePath="/lab">
  <header class="page-header">
    <div>
      <p class="eyebrow">Lab</p>
      <h1>공개 투자 데이터 Lab</h1>
      <p class="lead">Lab 페이지는 데이터 표, 차트, 방법론, FAQ, 관련 카드가 포함된 공개 콘텐츠 형식으로 확장됩니다.</p>
    </div>
  </header>

  <section class="grid-4">
    {labCards.map((card) => (
      <a class="route-card" href={card.href}>
        <p class="eyebrow">{card.phase}</p>
        <h2>{card.title}</h2>
        <p>{card.description}</p>
      </a>
    ))}
  </section>
</Layout>
