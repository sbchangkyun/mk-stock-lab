---
import Layout from '../layouts/Layout.astro';
import LabReturnMatrix from '../components/LabReturnMatrix.astro';
import matrices from '../data/labReturnMatrices.json';
import labModules from '../data/labStaticModules.json';

const { assetMatrix, sectorMatrix } = matrices;

const futureModules = labModules.modules.filter(
  (m) => m.id === 'congress-stocks' || m.id === 'nps-holdings'
);
---

<Layout title="Lab | MK Stock Lab" activePath="/lab">
  <header class="page-header">
    <div>
      <p class="eyebrow">Lab</p>
      <h1>리서치 Lab</h1>
      <p class="lead">공개 시장 데이터를 활용한 리서치 시각화 화면입니다. 현재 화면은 예시 데이터로 구성되어 있으며, 데이터 연동 전 화면입니다.</p>
    </div>
    <span class="lab-hero-note">예시 데이터 · 데이터 연동 전</span>
  </header>

  <div class="lab-shell">

    <!-- Primary: Asset-class return matrix -->
    <LabReturnMatrix data={assetMatrix} sectionId="lab-asset-matrix-heading" />

    <!-- Secondary: S&P 500 sector return matrix -->
    <LabReturnMatrix data={sectorMatrix} sectionId="lab-sector-matrix-heading" />

    <!-- Future research modules (demoted) -->
    <section class="lab-future-modules" aria-labelledby="lab-future-heading">
      <h2 id="lab-future-heading" class="lab-future-heading">향후 리서치 모듈</h2>
      <p class="lab-future-desc">공개 데이터 연동 후 추가 예정인 리서치 모듈입니다.</p>
      <div class="lab-future-grid">
        {futureModules.map((mod) => (
          <div class="lab-future-card">
            <div class="lab-future-card-header">
              <p class="eyebrow">{mod.category}</p>
              <span class="lab-future-badge">연동 예정</span>
            </div>
            <h3 class="lab-future-title">{mod.title}</h3>
            <p class="lab-future-copy">{mod.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Data policy disclaimer -->
    <aside class="panel lab-disclaimer" aria-label="데이터 정책">
      <p class="eyebrow">데이터 정책</p>
      <ul class="lab-disclaimer-list">
        <li>이 화면의 모든 수치는 <strong>예시 데이터</strong>입니다. 실제 시장 데이터와 무관합니다.</li>
        <li>실제 투자 판단에 사용할 수 없습니다.</li>
        <li>특정 종목의 매수 또는 매도를 권고하지 않습니다.</li>
        <li>데이터 연동 후에는 실제 정보로 교체될 예정입니다.</li>
      </ul>
    </aside>

  </div>
</Layout>
