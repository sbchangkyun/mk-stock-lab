---
import Layout from '../../layouts/Layout.astro';

const sectors = [
  'S&P 500 Index',
  'S&P 500 Information Technology Index',
  'S&P 500 Consumer Discretionary Index',
  'S&P 500 Communication Services Index',
  'S&P 500 Industrials Index',
  'S&P 500 Energy Index',
  'S&P 500 Financials Index',
  'S&P 500 Materials Index',
  'S&P 500 Health Care Index',
  'S&P 500 Utilities Index',
  'S&P 500 Consumer Staples Index',
  'S&P 500 Real Estate Index',
];
---

<Layout title="S&P 500 섹터 | MK Stock Lab" activePath="/lab">
  <p class="breadcrumb"><a href="/lab">Lab</a> / S&amp;P 500 섹터</p>
  <header class="page-header">
    <div>
      <p class="eyebrow">Phase 6 Lab 페이지</p>
      <h1>S&amp;P 500 섹터 수익률</h1>
      <p class="lead">연간 섹터 수익률 데이터, 차트, 방법론, FAQ, 관련 ETF 카드는 Lab MVP 1에서 추가합니다.</p>
    </div>
  </header>

  <table class="data-table">
    <thead>
      <tr><th>필수 지수</th><th>상태</th></tr>
    </thead>
    <tbody>
      {sectors.map((sector) => (
        <tr><td>{sector}</td><td>예정</td></tr>
      ))}
    </tbody>
  </table>
</Layout>
