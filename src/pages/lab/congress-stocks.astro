---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Congress Stocks | MK Stock Lab" activePath="/lab">
  <p class="breadcrumb"><a href="/lab">Lab</a> / Congress Stocks</p>
  <header class="page-header">
    <div>
      <p class="eyebrow">Phase 8 Lab page</p>
      <h1>Congress stocks disclosure shell</h1>
      <p class="lead">PDF extraction, listed stock normalization, unlisted stock separation, and audit fields will be added in the Lab MVP 2 phase.</p>
    </div>
  </header>

  <section class="section-stack">
    <div class="panel">
      <h2>Content structure</h2>
      <p>Breadcrumb, top ad area, title, data date, key visualization, summary table, methodology, FAQ, related cards, and footer.</p>
    </div>
    <table class="data-table">
      <thead>
        <tr><th>Field</th><th>Planned value</th></tr>
      </thead>
      <tbody>
        <tr><td>Disclosure date</td><td>2026-03-26</td></tr>
        <tr><td>Report base date</td><td>2025-12-31</td></tr>
        <tr><td>Aggregation</td><td>Lawmaker, spouse, and lineal family holdings</td></tr>
      </tbody>
    </table>
  </section>
</Layout>
