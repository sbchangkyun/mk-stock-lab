---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="NPS Portfolio | MK Stock Lab" activePath="/lab">
  <p class="breadcrumb"><a href="/lab">Lab</a> / NPS Portfolio</p>
  <header class="page-header">
    <div>
      <p class="eyebrow">Phase 8 Lab page</p>
      <h1>NPS portfolio research shell</h1>
      <p class="lead">OpenDART domestic data and manual US holdings data will be connected after the API and Lab data phases.</p>
    </div>
  </header>

  <section class="grid-3">
    <div class="panel">
      <h2>Large holding</h2>
      <p>Report type chip placeholder for domestic disclosures.</p>
    </div>
    <div class="panel">
      <h2>Executive or major shareholder</h2>
      <p>Report type chip placeholder for domestic disclosures.</p>
    </div>
    <div class="panel">
      <h2>US holdings</h2>
      <p>Manual CSV and reference link placeholder for MVP.</p>
    </div>
  </section>
</Layout>
