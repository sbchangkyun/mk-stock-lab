---
import Layout from '../../layouts/Layout.astro';
import LabReturnMatrix from '../../components/LabReturnMatrix.astro';
import matrices from '../../data/labReturnMatrices.json';

const { assetMatrix } = matrices;
---

<Layout title="자산군 수익률 비교 | MK Stock Lab" activePath="/lab">
  <div class="lab-detail-shell">
    <a href="/lab" class="lab-detail-backlink">← Lab</a>

    <header class="lab-detail-header">
      <div class="lab-detail-header-text">
        <p class="eyebrow">자산 배분 리서치</p>
        <h1>자산군 수익률 비교</h1>
        <p class="lead">{assetMatrix.description}</p>
      </div>
      <span class="lab-detail-badge">예시 데이터 · 데이터 연동 전</span>
    </header>

    <LabReturnMatrix data={assetMatrix} sectionId="asset-matrix-section" />

    <aside class="lab-data-policy" aria-label="데이터 정책">
      <p class="eyebrow">데이터 정책</p>
      <ul>
        <li>이 화면의 모든 수치는 <strong>예시 데이터</strong>입니다. 실제 시장 데이터와 무관합니다.</li>
        <li>실제 투자 판단에 사용할 수 없습니다.</li>
        <li>자동화된 투자 권고를 제공하지 않습니다.</li>
        <li>데이터 연동 후에는 실제 정보로 교체될 예정입니다.</li>
      </ul>
    </aside>

    <section class="lab-detail-related" aria-labelledby="related-asset-heading">
      <h2 id="related-asset-heading" class="lab-related-heading">다른 Lab 보기</h2>
      <div class="lab-related-grid">
        <a href="/lab/sp500-sectors" class="lab-related-card">
          <span class="eyebrow">미국 시장 리서치</span>
          <span class="lab-related-title">S&amp;P 500 섹터별 수익률</span>
        </a>
        <a href="/lab/congress-stocks" class="lab-related-card">
          <span class="eyebrow">공시 기반 리서치</span>
          <span class="lab-related-title">국회의원 보유 주식</span>
          <span class="lab-related-badge">연동 예정</span>
        </a>
        <a href="/lab/nps-holdings" class="lab-related-card">
          <span class="eyebrow">기관 투자자 리서치</span>
          <span class="lab-related-title">국민연금 보유 현황</span>
          <span class="lab-related-badge">연동 예정</span>
        </a>
      </div>
    </section>
  </div>
</Layout>
