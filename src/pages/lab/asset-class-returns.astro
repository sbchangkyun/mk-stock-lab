---
import Layout from '../../layouts/Layout.astro';

const assets = [
  ['S&P500', 'S&P 500 Index', 'SPY, VOO, IVV'],
  ['Bitcoin', 'Bitcoin BTC', 'IBIT, FBTC'],
  ['NASDAQ100', 'NASDAQ-100 Index', 'QQQ, QQQM'],
  ['KOSPI', 'KOSPI Index', '226490'],
  ['Gold', 'LBMA Gold Price PM', 'GLD, IAU, GLDM'],
  ['글로벌 주식', 'FTSE Global All Cap Index', 'VT, ACWI'],
  ['REITs', 'MSCI US REIT Index', 'VNQ, SCHH, IYR'],
  ['미국 제외 글로벌', 'FTSE Global All Cap ex US Index', 'VXUS, IXUS'],
  ['신흥국 주식', 'FTSE Emerging Markets Index', 'VWO, IEMG, EEM'],
  ['하이일드 채권', 'Markit iBoxx USD Liquid High Yield', 'HYG, JNK'],
  ['종합 채권', 'Bloomberg US Aggregate Bond Index', 'AGG, BND'],
  ['단기 T-bills', 'ICE BofA 0-3M US Treasury Bill', 'BIL, SGOV, SHV'],
];
---

<Layout title="자산군 수익률 | MK Stock Lab" activePath="/lab">
  <p class="breadcrumb"><a href="/lab">Lab</a> / 자산군 수익률</p>
  <header class="page-header">
    <div>
      <p class="eyebrow">Phase 6 Lab 페이지</p>
      <h1>자산군 수익률 비교</h1>
      <p class="lead">Bitcoin은 이 교차 자산 수익률 비교에서만 다룹니다. 가상자산은 검색, Chart AI, 포트폴리오 기능에서는 제외됩니다.</p>
    </div>
  </header>

  <table class="data-table">
    <thead>
      <tr><th>자산군</th><th>추적 지수</th><th>대표 ETF</th></tr>
    </thead>
    <tbody>
      {assets.map(([asset, index, etfs]) => (
        <tr><td>{asset}</td><td>{index}</td><td>{etfs}</td></tr>
      ))}
    </tbody>
  </table>
</Layout>
