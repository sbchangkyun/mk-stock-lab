                <input type="url" id="mpMobileBannerLinkUrl3" placeholder="https://" maxlength="1000" autocomplete="off">
              </div>
              <div class="mp-banner-field">
                <label for="mpMobileBannerAlt3">대체 텍스트</label>
                <input type="text" id="mpMobileBannerAlt3" placeholder="배너 설명" maxlength="120" autocomplete="off">
              </div>
              <div class="mp-banner-preview" id="mpMobileBannerPreview3" hidden>
                <img src="" alt="모바일 배너 미리보기" id="mpMobileBannerPreviewImg3" loading="lazy">
              </div>
            </div>

            <div class="mp-banner-slot" id="mpMobileBannerSlot4">
              <div class="mp-banner-slot-header">
                <input type="checkbox" id="mpMobileBannerActive4" aria-label="모바일 슬롯 4 활성화">
                <span class="mp-banner-slot-title">모바일 배너 슬롯 4</span>
              </div>
              <div class="mp-banner-field">
                <label for="mpMobileBannerImageUrl4">이미지 URL</label>
                <input type="url" id="mpMobileBannerImageUrl4" placeholder="https://" maxlength="1000" autocomplete="off">
              </div>
              <div class="mp-banner-field">
                <label for="mpMobileBannerLinkUrl4">연결 URL <span class="mp-field-hint">(비워 두면 링크 없음)</span></label>
                <input type="url" id="mpMobileBannerLinkUrl4" placeholder="https://" maxlength="1000" autocomplete="off">
              </div>
              <div class="mp-banner-field">
                <label for="mpMobileBannerAlt4">대체 텍스트</label>
                <input type="text" id="mpMobileBannerAlt4" placeholder="배너 설명" maxlength="120" autocomplete="off">
              </div>
              <div class="mp-banner-preview" id="mpMobileBannerPreview4" hidden>
                <img src="" alt="모바일 배너 미리보기" id="mpMobileBannerPreviewImg4" loading="lazy">
              </div>
            </div>

            <div class="mp-banner-slot" id="mpMobileBannerSlot5">
              <div class="mp-banner-slot-header">
                <input type="checkbox" id="mpMobileBannerActive5" aria-label="모바일 슬롯 5 활성화">
                <span class="mp-banner-slot-title">모바일 배너 슬롯 5</span>
              </div>
              <div class="mp-banner-field">
                <label for="mpMobileBannerImageUrl5">이미지 URL</label>
                <input type="url" id="mpMobileBannerImageUrl5" placeholder="https://" maxlength="1000" autocomplete="off">
              </div>
              <div class="mp-banner-field">
                <label for="mpMobileBannerLinkUrl5">연결 URL <span class="mp-field-hint">(비워 두면 링크 없음)</span></label>
                <input type="url" id="mpMobileBannerLinkUrl5" placeholder="https://" maxlength="1000" autocomplete="off">
              </div>
              <div class="mp-banner-field">
                <label for="mpMobileBannerAlt5">대체 텍스트</label>
                <input type="text" id="mpMobileBannerAlt5" placeholder="배너 설명" maxlength="120" autocomplete="off">
              </div>
              <div class="mp-banner-preview" id="mpMobileBannerPreview5" hidden>
                <img src="" alt="모바일 배너 미리보기" id="mpMobileBannerPreviewImg5" loading="lazy">
              </div>
            </div>

            <div class="mp-banner-admin-actions">
              <button class="mp-add-btn" type="button" id="mpMobileBannerSaveBtn">저장</button>
              <button class="header-button secondary" type="button" id="mpMobileBannerReloadBtn">다시 불러오기</button>
              <span class="mp-banner-save-msg" id="mpMobileBannerSaveMsg" role="status" aria-live="polite" hidden></span>
            </div>
          </section>
        </div><!-- /mpBannerAccordionBody -->
      </section>
    </aside><!-- /mp-admin-rail -->

  </div><!-- /mp-page-layout -->
</Layout>

<script>
  import { getBrowserSupabaseClient, isSupabaseConfigured } from '../lib/supabase';
  import {
    getHomeMobileBanners,
    getHomeRailBanners,
    isCurrentUserSiteAdmin,
    saveHomeMobileBanners,
    saveHomeRailBanners,
  } from '../lib/siteSettingsClient';

  const setupMyPage = async () => {
    const emailEl = document.getElementById('mpEmail');
    const lastAccessEl = document.getElementById('mpLastAccess');
    const loginMethodEl = document.getElementById('mpLoginMethod');

    if (isSupabaseConfigured()) {
      const supabase = getBrowserSupabaseClient();
      if (supabase) {
        const { data } = await supabase.auth.getSession();
        if (data.session?.user) {
          const user = data.session.user;

          if (user.email && emailEl) {
            emailEl.textContent = user.email;
            emailEl.classList.remove('mp-placeholder');
          }

          if (user.last_sign_in_at && lastAccessEl) {
            lastAccessEl.textContent = new Date(user.last_sign_in_at).toLocaleString('ko-KR');
            lastAccessEl.classList.remove('mp-placeholder');
          }

          // Resolve login provider from identities (most reliable) with app_metadata fallback
          if (loginMethodEl) {
            const providers = new Set<string>();
            if (Array.isArray((user as any).identities)) {
              for (const id of (user as any).identities as Array<{ provider?: string }>) {
                if (id.provider) providers.add(id.provider);
              }
            }
            if (providers.size === 0 && (user as any).app_metadata?.provider) {
              providers.add((user as any).app_metadata.provider as string);
            }
            const hasEmail = providers.has('email');
            const hasGoogle = providers.has('google');
            let label = providers.size > 0 ? [...providers].join(' + ') : '확인 불가';
            if (hasEmail && hasGoogle) label = '이메일 + Google';
            else if (hasEmail) label = '이메일 로그인';
            else if (hasGoogle) label = 'Google 로그인';
            loginMethodEl.textContent = label;
            loginMethodEl.classList.remove('mp-placeholder');
          }
        }
      }
    }

    // --- Watchlist news alert search/save shell (in-memory, no persistence) ---
    const watchlistItems: string[] = [];
    const MAX_WATCHLIST = 5;

    const renderWatchlist = () => {
      const list = document.getElementById('mpWatchlistList') as HTMLUListElement | null;
      const emptyEl = document.getElementById('mpWatchlistEmpty') as HTMLElement | null;
      const headerEl = document.getElementById('mpWatchlistHeader') as HTMLElement | null;
      if (!list) return;

      if (watchlistItems.length === 0) {
        list.classList.add('hidden');
        headerEl?.classList.add('hidden');
        emptyEl?.classList.remove('hidden');
      } else {
        list.classList.remove('hidden');
        headerEl?.classList.remove('hidden');
        emptyEl?.classList.add('hidden');
        list.innerHTML = '';
        watchlistItems.forEach((item, idx) => {
          const li = document.createElement('li');
          li.className = 'mp-watchlist-item';
          const span = document.createElement('span');
          span.textContent = item;
          const btn = document.createElement('button');
          btn.className = 'mp-watchlist-remove-btn';
          btn.type = 'button';
          btn.textContent = '삭제';
          btn.setAttribute('aria-label', `${item} 삭제`);
          btn.addEventListener('click', () => {
            watchlistItems.splice(idx, 1);
            renderWatchlist();
          });
          li.appendChild(span);
          li.appendChild(btn);
          list.appendChild(li);
        });
      }
    };

    const watchlistInput = document.getElementById('mpWatchlistInput') as HTMLInputElement | null;
    const watchlistAddBtn = document.getElementById('mpWatchlistAddBtn') as HTMLButtonElement | null;
    const watchlistNotice = document.getElementById('mpWatchlistNotice') as HTMLElement | null;

    watchlistAddBtn?.addEventListener('click', () => {
      const val = watchlistInput?.value.trim() ?? '';
      if (!val || watchlistItems.length >= MAX_WATCHLIST || watchlistItems.includes(val)) return;
      watchlistItems.push(val);
      if (watchlistInput) watchlistInput.value = '';
      renderWatchlist();
      watchlistNotice?.classList.remove('hidden');
    });

    renderWatchlist();

    // --- Price alert on/off toggle (UI only, no persistence) ---
    const priceAlertToggle = document.getElementById('mpPriceAlertToggle') as HTMLInputElement | null;
    const priceAlertBody = document.getElementById('mpPriceAlertBody') as HTMLElement | null;

    if (priceAlertToggle && priceAlertBody) {
      const syncPriceAlertBody = () => {
        priceAlertBody.classList.toggle('mp-notif-body--disabled', !priceAlertToggle.checked);
      };
      priceAlertToggle.addEventListener('change', syncPriceAlertBody);
      syncPriceAlertBody();
    }

    // --- Withdrawal confirmation flow ---
    const withdrawalBtn = document.getElementById('mpWithdrawalBtn') as HTMLButtonElement | null;
    const confirmPanel = document.getElementById('mpWithdrawalConfirm') as HTMLElement | null;
    const okBtn = document.getElementById('mpWithdrawalOk') as HTMLButtonElement | null;
    const cancelBtn = document.getElementById('mpWithdrawalCancel') as HTMLButtonElement | null;
    const noticeEl = document.getElementById('mpWithdrawalNotice') as HTMLElement | null;

    withdrawalBtn?.addEventListener('click', () => {
      confirmPanel?.classList.remove('hidden');
      noticeEl?.classList.add('hidden');
      okBtn?.focus();
    });

    cancelBtn?.addEventListener('click', () => {
      confirmPanel?.classList.add('hidden');
      withdrawalBtn?.focus();
    });

    okBtn?.addEventListener('click', () => {
      confirmPanel?.classList.add('hidden');
      noticeEl?.classList.remove('hidden');
    });

    // --- Target-price alert add form (UI only, no persistence) ---
    const addAlertBtn = document.getElementById('mpAddAlertBtn') as HTMLButtonElement | null;
    const alertForm = document.getElementById('mpAlertForm') as HTMLElement | null;
    const alertSaveBtn = document.getElementById('mpAlertSaveBtn') as HTMLButtonElement | null;
    const alertNotice = document.getElementById('mpAlertNotice') as HTMLElement | null;

    addAlertBtn?.addEventListener('click', () => {
      alertForm?.classList.remove('hidden');
      addAlertBtn.classList.add('hidden');
    });

    alertSaveBtn?.addEventListener('click', () => {
      alertNotice?.classList.remove('hidden');
    });
  };

  const setupBannerAdmin = async () => {
    const panel = document.getElementById('mpBannerAdminPanel') as HTMLElement | null;
    if (!panel || panel.dataset.setup === 'true') return;
    panel.dataset.setup = 'true';

    const isAdmin = await isCurrentUserSiteAdmin();
    if (!isAdmin) return;

    // Reveal admin section
    panel.removeAttribute('hidden');

    // Activate page-level two-column grid (account left, admin rail right on desktop)
    const pageLayout = panel.closest('.mp-page-layout') as HTMLElement | null;
    pageLayout?.classList.add('mp-page-layout--admin-visible');

    // --- Accordion ---
    const accordionToggle = document.getElementById('mpBannerAccordionToggle') as HTMLButtonElement | null;
    const accordionBody = document.getElementById('mpBannerAccordionBody') as HTMLElement | null;
    const accordionSummary = document.getElementById('mpBannerAccordionSummary') as HTMLElement | null;

    const setAccordion = (open: boolean) => {
      if (!accordionToggle || !accordionBody) return;
      accordionToggle.setAttribute('aria-expanded', String(open));
      accordionToggle.textContent = open ? '접기' : '펼치기';
      accordionBody.hidden = !open;
    };

    accordionToggle?.addEventListener('click', () => {
      setAccordion(accordionToggle.getAttribute('aria-expanded') !== 'true');
    });

    const slotNumbers = [1, 2, 3, 4, 5] as const;
    type BannerFormPrefix = 'mpBanner' | 'mpMobileBanner';
    type BannerFormValue = {
      slot: (typeof slotNumbers)[number];
      imageUrl: string;
      linkUrl: string;
      alt: string;
      active: boolean;
    };

    const countActiveFromForm = (prefix: BannerFormPrefix) =>
      slotNumbers.filter((slot) => {
        const activeEl = document.getElementById(`${prefix}Active${slot}`) as HTMLInputElement | null;
        const imageUrlEl = document.getElementById(`${prefix}ImageUrl${slot}`) as HTMLInputElement | null;
        return activeEl?.checked && (imageUrlEl?.value ?? '').trim();
      }).length;

    const updateSummaryFromForm = () => {
      if (!accordionSummary) return;
      accordionSummary.textContent =
        `PC ${countActiveFromForm('mpBanner')}개 · 모바일 ${countActiveFromForm('mpMobileBanner')}개`;
    };

    const populateSlots = (
      banners: BannerFormValue[] | null,
      prefix: BannerFormPrefix,
      fallbackAlt: string,
    ) => {
      if (!banners) return;
      for (const banner of banners) {
        const slot = banner.slot;
        const activeEl = document.getElementById(`${prefix}Active${slot}`) as HTMLInputElement | null;
        const imageUrlEl = document.getElementById(`${prefix}ImageUrl${slot}`) as HTMLInputElement | null;
        const linkUrlEl = document.getElementById(`${prefix}LinkUrl${slot}`) as HTMLInputElement | null;
        const altEl = document.getElementById(`${prefix}Alt${slot}`) as HTMLInputElement | null;
        const previewEl = document.getElementById(`${prefix}Preview${slot}`) as HTMLElement | null;
        const previewImgEl = document.getElementById(`${prefix}PreviewImg${slot}`) as HTMLImageElement | null;

        if (activeEl) activeEl.checked = banner.active;
        if (imageUrlEl) imageUrlEl.value = banner.imageUrl;
        if (linkUrlEl) linkUrlEl.value = banner.linkUrl;
        if (altEl) altEl.value = banner.alt;

        if (previewImgEl && previewEl) {
          if (banner.imageUrl && /^https?:\/\//i.test(banner.imageUrl)) {
            previewImgEl.src = banner.imageUrl;
            previewImgEl.alt = banner.alt || fallbackAlt;
            previewEl.removeAttribute('hidden');
          } else {
            previewImgEl.removeAttribute('src');
            previewEl.setAttribute('hidden', '');
          }
        }
      }
    };

    const reload = async () => {
      const [desktopBanners, mobileBanners] = await Promise.all([
        getHomeRailBanners(),
        getHomeMobileBanners(),
      ]);
      populateSlots(desktopBanners, 'mpBanner', '배너 미리보기');
      populateSlots(mobileBanners, 'mpMobileBanner', '모바일 배너 미리보기');
      updateSummaryFromForm();
    };

    const collectSlots = (prefix: BannerFormPrefix): BannerFormValue[] =>
      slotNumbers.map((slot) => {
        const activeEl = document.getElementById(`${prefix}Active${slot}`) as HTMLInputElement | null;
        const imageUrlEl = document.getElementById(`${prefix}ImageUrl${slot}`) as HTMLInputElement | null;
        const linkUrlEl = document.getElementById(`${prefix}LinkUrl${slot}`) as HTMLInputElement | null;
        const altEl = document.getElementById(`${prefix}Alt${slot}`) as HTMLInputElement | null;
        return {
          slot,
          active: activeEl?.checked ?? false,
          imageUrl: (imageUrlEl?.value ?? '').trim(),
          linkUrl: (linkUrlEl?.value ?? '').trim(),
          alt: (altEl?.value ?? '').trim(),
        };
      });

    const messageTimers = new WeakMap<HTMLElement, ReturnType<typeof setTimeout>>();
    const showMsg = (messageEl: HTMLElement | null, message: string, ok: boolean) => {
      if (!ok) setAccordion(true);
      if (!messageEl) return;
      messageEl.textContent = message;
      messageEl.className = `mp-banner-save-msg${ok ? ' mp-banner-save-msg--ok' : ' mp-banner-save-msg--err'}`;
      messageEl.removeAttribute('hidden');
      const existingTimer = messageTimers.get(messageEl);
      if (existingTimer !== undefined) clearTimeout(existingTimer);
      messageTimers.set(
        messageEl,
        setTimeout(() => { messageEl.setAttribute('hidden', ''); }, 4000),
      );
    };

    const desktopSaveBtn = document.getElementById('mpBannerSaveBtn') as HTMLButtonElement | null;
    const desktopReloadBtn = document.getElementById('mpBannerReloadBtn') as HTMLButtonElement | null;
    const desktopMsgEl = document.getElementById('mpBannerSaveMsg') as HTMLElement | null;
    const mobileSaveBtn = document.getElementById('mpMobileBannerSaveBtn') as HTMLButtonElement | null;
    const mobileReloadBtn = document.getElementById('mpMobileBannerReloadBtn') as HTMLButtonElement | null;
    const mobileMsgEl = document.getElementById('mpMobileBannerSaveMsg') as HTMLElement | null;

    desktopSaveBtn?.addEventListener('click', async () => {
      const result = await saveHomeRailBanners(collectSlots('mpBanner'));
      showMsg(desktopMsgEl, result.message, result.ok);
      if (result.ok) updateSummaryFromForm();
    });

    mobileSaveBtn?.addEventListener('click', async () => {
      const result = await saveHomeMobileBanners(collectSlots('mpMobileBanner'));
      showMsg(mobileMsgEl, result.message, result.ok);
      if (result.ok) updateSummaryFromForm();
    });

    desktopReloadBtn?.addEventListener('click', reload);
    mobileReloadBtn?.addEventListener('click', reload);

    const bindPreviews = (prefix: BannerFormPrefix) => {
      for (const slot of slotNumbers) {
        const imageUrlEl = document.getElementById(`${prefix}ImageUrl${slot}`) as HTMLInputElement | null;
        const previewEl = document.getElementById(`${prefix}Preview${slot}`) as HTMLElement | null;
        const previewImgEl = document.getElementById(`${prefix}PreviewImg${slot}`) as HTMLImageElement | null;
        imageUrlEl?.addEventListener('input', () => {
          const url = imageUrlEl.value.trim();
          if (url && /^https?:\/\//i.test(url) && previewImgEl && previewEl) {
            previewImgEl.src = url;
            previewEl.removeAttribute('hidden');
          } else if (previewImgEl && previewEl) {
            previewImgEl.removeAttribute('src');
            previewEl.setAttribute('hidden', '');
          }
        });
      }
    };

    bindPreviews('mpBanner');
    bindPreviews('mpMobileBanner');
    await reload();
  };

  document.addEventListener('astro:page-load', () => { void setupMyPage(); void setupBannerAdmin(); });
  void setupMyPage();
  void setupBannerAdmin();
</script>
