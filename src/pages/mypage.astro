---
import Layout from '../layouts/Layout.astro';
---

<Layout title="마이페이지 | MK Stock Lab" activePath="/mypage">
  <header class="page-header">
    <div>
      <p class="eyebrow">My Page</p>
      <h1>마이페이지</h1>
      <p class="lead">계정 정보와 서비스 이용 설정을 확인하는 공간입니다.</p>
    </div>
  </header>

  <div class="mp-sections">

    <!-- A. Account Summary -->
    <section class="panel mp-section" aria-labelledby="mp-account-heading">
      <h2 id="mp-account-heading" class="mp-section-title">내 계정</h2>
      <dl class="mp-info-list">
        <div class="mp-info-row">
          <dt>이메일</dt>
          <dd id="mpEmail" class="mp-placeholder">로그인 계정 확인 중</dd>
        </div>
        <div class="mp-info-row">
          <dt>로그인 방식</dt>
          <dd>Google 로그인</dd>
        </div>
        <div class="mp-info-row">
          <dt>가입일</dt>
          <dd class="mp-placeholder">확인 예정</dd>
        </div>
        <div class="mp-info-row">
          <dt>마지막 접속 일시</dt>
          <dd id="mpLastAccess" class="mp-placeholder">확인 예정</dd>
        </div>
        <div class="mp-info-row">
          <dt>구독 상태</dt>
          <dd>구독 안함</dd>
        </div>
      </dl>
    </section>

    <!-- B. Service section (공지사항, 이벤트/혜택 only) -->
    <section class="panel mp-section" aria-labelledby="mp-prefs-heading">
      <h2 id="mp-prefs-heading" class="mp-section-title">서비스 이용 설정</h2>
      <ul class="mp-pref-list">
        <li class="mp-pref-row">
          <span class="mp-pref-label">공지사항</span>
          <span class="mp-badge">준비 중</span>
        </li>
        <li class="mp-pref-row">
          <span class="mp-pref-label">이벤트/혜택</span>
          <span class="mp-badge">향후 제공 예정</span>
        </li>
      </ul>
    </section>

    <!-- C. My Data (포트폴리오, 관심 종목 only) -->
    <section class="panel mp-section" aria-labelledby="mp-data-heading">
      <h2 id="mp-data-heading" class="mp-section-title">내 데이터</h2>
      <ul class="mp-pref-list">
        <li class="mp-pref-row">
          <span class="mp-pref-label">포트폴리오</span>
          <span class="mp-badge">향후 제공 예정</span>
        </li>
        <li class="mp-pref-row">
          <span class="mp-pref-label">관심 종목</span>
          <span class="mp-badge">향후 제공 예정</span>
        </li>
      </ul>
    </section>

    <!-- D. Notification Settings -->
    <section class="panel mp-section" aria-labelledby="mp-notif-heading">
      <h2 id="mp-notif-heading" class="mp-section-title">알림 설정</h2>

      <!-- Telegram placeholder -->
      <div class="mp-notif-row">
        <div>
          <p class="mp-pref-label">내 텔레그램 연동</p>
          <p class="mp-notif-desc">텔레그램 알림을 받으려면 봇 연동이 필요합니다.</p>
        </div>
        <span class="mp-badge">준비 중</span>
      </div>

      <!-- 관심종목 뉴스 알림 — search/save shell (in-memory only) -->
      <div class="mp-notif-block">
        <div class="mp-notif-block-header">
          <span class="mp-pref-label" id="lbl-watchlist-news">관심종목 뉴스 알림</span>
          <label class="mp-toggle">
            <input type="checkbox" class="mp-toggle-input" aria-labelledby="lbl-watchlist-news" />
            <span class="mp-toggle-track" aria-hidden="true"></span>
          </label>
        </div>
        <p class="mp-notif-desc">관심종목 뉴스 알림을 받을 종목을 추가하세요. 최대 5개까지 등록할 수 있습니다.</p>
        <p class="mp-watchlist-search-label">관심종목 검색</p>
        <div class="mp-watchlist-search-row">
          <input class="mp-watchlist-input" type="text" id="mpWatchlistInput"
            placeholder="종목명 또는 종목코드를 입력하세요." aria-label="관심종목 검색"
            maxlength="20" autocomplete="off" />
          <button class="mp-watchlist-add-btn" type="button" id="mpWatchlistAddBtn">관심종목 저장</button>
        </div>
        <p class="mp-watchlist-section-label hidden" id="mpWatchlistHeader">저장된 관심종목</p>
        <ul class="mp-watchlist-list hidden" id="mpWatchlistList" aria-live="polite" aria-label="저장된 관심종목 목록"></ul>
        <p class="mp-watchlist-empty" id="mpWatchlistEmpty">등록된 관심종목이 없습니다.</p>
        <p class="mp-alert-notice hidden" id="mpWatchlistNotice" role="status" aria-live="polite">실제 뉴스 알림 저장 기능은 준비 중입니다.</p>
      </div>

      <!-- 내 포트 종목 뉴스 알림 -->
      <div class="mp-notif-row">
        <span class="mp-pref-label" id="lbl-portfolio-news">내 포트 종목 뉴스 알림</span>
        <label class="mp-toggle">
          <input type="checkbox" class="mp-toggle-input" aria-labelledby="lbl-portfolio-news" />
          <span class="mp-toggle-track" aria-hidden="true"></span>
        </label>
      </div>

      <!-- 관심종목 지정가 알림 — with on/off toggle -->
      <div class="mp-notif-block">
        <div class="mp-notif-block-header">
          <span class="mp-pref-label">관심종목 지정가 알림</span>
          <span class="mp-badge">최대 5개</span>
        </div>
        <div class="mp-notif-inner-row">
          <span class="mp-pref-label" id="lbl-price-alert-toggle">알림 사용</span>
          <label class="mp-toggle">
            <input type="checkbox" class="mp-toggle-input" id="mpPriceAlertToggle" aria-labelledby="lbl-price-alert-toggle" />
            <span class="mp-toggle-track" aria-hidden="true"></span>
          </label>
        </div>
        <div class="mp-notif-body mp-notif-body--disabled" id="mpPriceAlertBody">
          <p class="mp-notif-desc">지정가 알림은 최대 5개까지 준비할 수 있습니다.</p>
          <button class="mp-add-btn" type="button" id="mpAddAlertBtn">+ 추가</button>
          <div class="mp-alert-form hidden" id="mpAlertForm">
            <div class="mp-alert-form-row">
              <input class="mp-alert-input" type="text" inputmode="numeric" maxlength="6"
                placeholder="종목코드 6자리" aria-label="종목코드" autocomplete="off" />
              <input class="mp-alert-input" type="text" inputmode="decimal"
                placeholder="지정가" aria-label="지정가" autocomplete="off" />
              <button class="mp-alert-save-btn" type="button" id="mpAlertSaveBtn">저장</button>
            </div>
            <p class="mp-alert-notice hidden" id="mpAlertNotice" role="status" aria-live="polite">저장 기능은 준비 중입니다.</p>
          </div>
        </div>
      </div>

      <!-- 이벤트/혜택 알림 -->
      <div class="mp-notif-row">
        <span class="mp-pref-label" id="lbl-event-notif">이벤트/혜택 알림</span>
        <label class="mp-toggle">
          <input type="checkbox" class="mp-toggle-input" aria-labelledby="lbl-event-notif" />
          <span class="mp-toggle-track" aria-hidden="true"></span>
        </label>
      </div>

      <!-- 공지사항 알림 -->
      <div class="mp-notif-row">
        <span class="mp-pref-label" id="lbl-announce-notif">공지사항 알림</span>
        <label class="mp-toggle">
          <input type="checkbox" class="mp-toggle-input" aria-labelledby="lbl-announce-notif" />
          <span class="mp-toggle-track" aria-hidden="true"></span>
        </label>
      </div>
    </section>

    <!-- E. Legal and Support -->
    <section class="panel mp-section" aria-labelledby="mp-legal-heading">
      <h2 id="mp-legal-heading" class="mp-section-title">법적 고지 및 지원</h2>
      <ul class="mp-link-list">
        <li><a href="/privacy">개인정보처리방침</a></li>
        <li><a href="/terms">이용약관</a></li>
        <li>
          <a href="https://forms.gle/WAVSxaotdes6T5yJA" target="_blank" rel="noopener noreferrer">제휴문의</a>
        </li>
      </ul>
    </section>

    <!-- F. Danger Zone -->
    <section class="panel mp-section mp-danger-zone" aria-labelledby="mp-danger-heading">
      <h2 id="mp-danger-heading" class="mp-section-title mp-danger-title">계정 관리</h2>
      <p class="mp-danger-desc">계정을 영구적으로 삭제합니다. 이 작업은 되돌릴 수 없습니다.</p>
      <div class="mp-withdrawal-area">
        <button class="mp-danger-btn" type="button" id="mpWithdrawalBtn">회원탈퇴</button>
        <div class="mp-withdrawal-confirm hidden" id="mpWithdrawalConfirm" role="alertdialog"
          aria-modal="true" aria-labelledby="mpWithdrawalConfirmMsg">
          <p class="mp-withdrawal-message" id="mpWithdrawalConfirmMsg">정말 회원 탈퇴하시겠습니까? 회원탈퇴하면 등록/활동 정보가 모두 삭제됩니다.</p>
          <div class="mp-withdrawal-actions">
            <button class="mp-confirm-btn" type="button" id="mpWithdrawalOk">확인</button>
            <button class="header-button secondary" type="button" id="mpWithdrawalCancel">취소</button>
          </div>
        </div>
        <p class="mp-withdrawal-notice hidden" id="mpWithdrawalNotice" role="status" aria-live="polite">회원탈퇴 기능은 준비 중입니다.</p>
      </div>
    </section>

  </div>
</Layout>

<script>
  import { getBrowserSupabaseClient, isSupabaseConfigured } from '../lib/supabase';

  const setupMyPage = async () => {
    // Populate email and last sign-in time from the existing client-side auth session
    const emailEl = document.getElementById('mpEmail');
    const lastAccessEl = document.getElementById('mpLastAccess');

    if (isSupabaseConfigured()) {
      const supabase = getBrowserSupabaseClient();
      if (supabase) {
        const { data } = await supabase.auth.getSession();
        if (data.session?.user) {
          const user = data.session.user;
          if (user.email && emailEl) {
            emailEl.textContent = user.email;
            emailEl.classList.remove('mp-placeholder');
          }
          if (user.last_sign_in_at && lastAccessEl) {
            lastAccessEl.textContent = new Date(user.last_sign_in_at).toLocaleString('ko-KR');
            lastAccessEl.classList.remove('mp-placeholder');
          }
        }
      }
    }

    // --- Watchlist news alert search/save shell (in-memory, no persistence) ---
    const watchlistItems: string[] = [];
    const MAX_WATCHLIST = 5;

    const renderWatchlist = () => {
      const list = document.getElementById('mpWatchlistList') as HTMLUListElement | null;
      const emptyEl = document.getElementById('mpWatchlistEmpty') as HTMLElement | null;
      const headerEl = document.getElementById('mpWatchlistHeader') as HTMLElement | null;
      if (!list) return;

      if (watchlistItems.length === 0) {
        list.classList.add('hidden');
        headerEl?.classList.add('hidden');
        emptyEl?.classList.remove('hidden');
      } else {
        list.classList.remove('hidden');
        headerEl?.classList.remove('hidden');
        emptyEl?.classList.add('hidden');
        list.innerHTML = '';
        watchlistItems.forEach((item, idx) => {
          const li = document.createElement('li');
          li.className = 'mp-watchlist-item';
          const span = document.createElement('span');
          span.textContent = item;
          const btn = document.createElement('button');
          btn.className = 'mp-watchlist-remove-btn';
          btn.type = 'button';
          btn.textContent = '삭제';
          btn.setAttribute('aria-label', `${item} 삭제`);
          btn.addEventListener('click', () => {
            watchlistItems.splice(idx, 1);
            renderWatchlist();
          });
          li.appendChild(span);
          li.appendChild(btn);
          list.appendChild(li);
        });
      }
    };

    const watchlistInput = document.getElementById('mpWatchlistInput') as HTMLInputElement | null;
    const watchlistAddBtn = document.getElementById('mpWatchlistAddBtn') as HTMLButtonElement | null;
    const watchlistNotice = document.getElementById('mpWatchlistNotice') as HTMLElement | null;

    watchlistAddBtn?.addEventListener('click', () => {
      const val = watchlistInput?.value.trim() ?? '';
      if (!val || watchlistItems.length >= MAX_WATCHLIST || watchlistItems.includes(val)) return;
      watchlistItems.push(val);
      if (watchlistInput) watchlistInput.value = '';
      renderWatchlist();
      watchlistNotice?.classList.remove('hidden');
    });

    renderWatchlist();

    // --- Price alert on/off toggle (UI only, no persistence) ---
    const priceAlertToggle = document.getElementById('mpPriceAlertToggle') as HTMLInputElement | null;
    const priceAlertBody = document.getElementById('mpPriceAlertBody') as HTMLElement | null;

    if (priceAlertToggle && priceAlertBody) {
      const syncPriceAlertBody = () => {
        priceAlertBody.classList.toggle('mp-notif-body--disabled', !priceAlertToggle.checked);
      };
      priceAlertToggle.addEventListener('change', syncPriceAlertBody);
      syncPriceAlertBody();
    }

    // --- Withdrawal confirmation flow ---
    const withdrawalBtn = document.getElementById('mpWithdrawalBtn') as HTMLButtonElement | null;
    const confirmPanel = document.getElementById('mpWithdrawalConfirm') as HTMLElement | null;
    const okBtn = document.getElementById('mpWithdrawalOk') as HTMLButtonElement | null;
    const cancelBtn = document.getElementById('mpWithdrawalCancel') as HTMLButtonElement | null;
    const noticeEl = document.getElementById('mpWithdrawalNotice') as HTMLElement | null;

    withdrawalBtn?.addEventListener('click', () => {
      confirmPanel?.classList.remove('hidden');
      noticeEl?.classList.add('hidden');
      okBtn?.focus();
    });

    cancelBtn?.addEventListener('click', () => {
      confirmPanel?.classList.add('hidden');
      withdrawalBtn?.focus();
    });

    okBtn?.addEventListener('click', () => {
      confirmPanel?.classList.add('hidden');
      noticeEl?.classList.remove('hidden');
    });

    // --- Target-price alert add form (UI only, no persistence) ---
    const addAlertBtn = document.getElementById('mpAddAlertBtn') as HTMLButtonElement | null;
    const alertForm = document.getElementById('mpAlertForm') as HTMLElement | null;
    const alertSaveBtn = document.getElementById('mpAlertSaveBtn') as HTMLButtonElement | null;
    const alertNotice = document.getElementById('mpAlertNotice') as HTMLElement | null;

    addAlertBtn?.addEventListener('click', () => {
      alertForm?.classList.remove('hidden');
      addAlertBtn.classList.add('hidden');
    });

    alertSaveBtn?.addEventListener('click', () => {
      alertNotice?.classList.remove('hidden');
    });
  };

  document.addEventListener('astro:page-load', () => { void setupMyPage(); });
  void setupMyPage();
</script>
