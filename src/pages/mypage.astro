              <img src="" alt="배너 미리보기" id="mpBannerPreviewImg5" loading="lazy">
            </div>
          </div>

          <div class="mp-banner-admin-actions">
            <button class="mp-add-btn" type="button" id="mpBannerSaveBtn">저장</button>
            <button class="header-button secondary" type="button" id="mpBannerReloadBtn">다시 불러오기</button>
            <span class="mp-banner-save-msg" id="mpBannerSaveMsg" role="status" aria-live="polite" hidden></span>
          </div>
          </section>

          <section class="mp-banner-subsection mp-banner-subsection--mobile" aria-labelledby="mp-mobile-banner-heading">
            <div class="mp-banner-subsection-heading">
              <h3 id="mp-mobile-banner-heading">모바일 Home 배너</h3>
              <span class="mp-banner-size-guide">720×225</span>
            </div>
            <p class="mp-notif-desc">모바일 Home 전용 배너 URL을 등록합니다. 화면 너비 859px 이하에서만 표시됩니다.</p>

            <div class="mp-banner-slot" id="mpMobileBannerSlot1">
              <div class="mp-banner-slot-header">
                <input type="checkbox" id="mpMobileBannerActive1" aria-label="모바일 슬롯 1 활성화">
