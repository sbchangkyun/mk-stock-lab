---
/* src/components/Seibro/HoldingChart.astro */
---
<div class="seibro-card">
    <h3>📊 종목별 보관 비중 (Top 10)</h3>
    <canvas id="holdingPieChart" style="max-height: 400px;"></canvas>
</div>

<script>
    import Chart from 'chart.js/auto';

    // 1. 데이터 구조 정의
    interface SeibroData {
        ticker: string;
        stock_name: string; // 🌟 종목명 추가
        holding_value: number;
    }

    async function initPieChart() {
        const res = await fetch('/api/holdings');
        const data: SeibroData[] = await res.json(); // 🌟 타입 지정
        const ctx = document.getElementById('holdingPieChart') as HTMLCanvasElement;
        
        if (!ctx || !data.length) return;

        const top10 = data.slice(0, 10);
        
        new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: top10.map((d: SeibroData) => {
                    const name = d.stock_name;
                    return name.length > 15 ? name.substring(0, 15) + '...' : name;
                }),

                datasets: [{
                    data: top10.map((d: SeibroData) => d.holding_value), // 🌟 타입 에러 해결
                    backgroundColor: ['#304FFE', '#f44336', '#4CAF50', '#FFC107', '#9C27B0', '#00BCD4', '#FF5722', '#607D8B', '#8BC34A', '#E91E63']
                }]
            },
            options: { 
                responsive: true,
                maintainAspectRatio: false, // 🌟 컨테이너 크기에 맞춤
                plugins: { legend: { position: 'right' } }
            }
        });
    }
    initPieChart();
</script>