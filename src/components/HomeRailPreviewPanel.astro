---
import homeAdBanners from '../data/homeAdBanners.json';

const activeBanners = homeAdBanners
  .filter((banner) => banner.isActive)
  .sort((a, b) => a.displayOrder - b.displayOrder);

const hasMultipleBanners = activeBanners.length > 1;
---

{
  activeBanners.length > 0 && (
    <section
      class:list={['home-rail-preview-panel', { 'is-carousel': hasMultipleBanners }]}
      data-home-rail-preview-panel
      data-count={activeBanners.length}
      aria-label="Home rail preview fallback panel"
    >
      <div class="home-rail-preview-copy">
        <p class="eyebrow">HOME RAIL PREVIEW</p>
        <h2>Sample banner preview</h2>
        <p>Preview mode only: 2 sample banners / 5s rotation.</p>
      </div>

      <div class="home-rail-preview-stage">
        <div class="home-rail-preview-viewport">
          <div class="home-rail-preview-track" data-preview-banner-track data-preview-banner-index="0">
            {activeBanners.map((banner, index) => {
              const fallbackLabel = `Sample Banner ${String(index + 1).padStart(2, '0')}`;
              return (
                <article
                  class="home-rail-preview-card"
                  data-preview-banner-card
                  data-preview-banner-index={index}
                  aria-label={banner.alt}
                >
                  <span class="home-rail-preview-fallback">{fallbackLabel}</span>
                  <img
                    src={banner.imageSrc}
                    alt={banner.alt}
                    width="160"
                    height="600"
                    loading="eager"
                    onerror="this.hidden=true"
                  />
                </article>
              );
            })}
          </div>
        </div>
        <div class="home-rail-preview-thumbs" aria-label="Preview banner list">
          {activeBanners.map((banner, index) => {
            const fallbackLabel = `Sample Banner ${String(index + 1).padStart(2, '0')}`;
            return (
              <div class="home-rail-preview-thumb">
                <span>{fallbackLabel}</span>
                <img src={banner.imageSrc} alt="" width="40" height="150" loading="eager" onerror="this.hidden=true" />
              </div>
            );
          })}
        </div>
      </div>
    </section>
  )
}

{
  hasMultipleBanners && (
    <script>
      const setupHomeRailPreviewPanel = () => {
        const panels = document.querySelectorAll<HTMLElement>('[data-home-rail-preview-panel].is-carousel');
        panels.forEach((panel) => {
          const track = panel.querySelector<HTMLElement>('[data-preview-banner-track]');
          const cards = panel.querySelectorAll<HTMLElement>('[data-preview-banner-card]');
          if (!track || cards.length < 2 || panel.dataset.ready === 'true') return;

          panel.dataset.ready = 'true';
          let activeIndex = 0;
          let intervalId: number | null = null;
          const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

          const render = () => {
            track.dataset.previewBannerIndex = String(activeIndex);
            track.style.transitionDuration = reduceMotion.matches ? '0ms' : '320ms';
            track.style.transform = `translateX(-${activeIndex * 100}%)`;
          };

          const start = () => {
            if (intervalId !== null) return;
            intervalId = window.setInterval(() => {
              activeIndex = (activeIndex + 1) % cards.length;
              render();
            }, 5000);
          };

          const stop = () => {
            if (intervalId === null) return;
            window.clearInterval(intervalId);
            intervalId = null;
          };

          panel.addEventListener('mouseenter', stop);
          panel.addEventListener('mouseleave', start);
          reduceMotion.addEventListener('change', render);
          render();
          start();
        });
      };

      document.addEventListener('astro:page-load', setupHomeRailPreviewPanel);
      setupHomeRailPreviewPanel();
    </script>
  )
}
