---
/* src/components/Portfolio.astro */
---

<!-- ① 비로그인 상태: 기본으로 표시 -->
<div id="portfolio-login-gate">
    <div class="login-gate-box">
        <div class="login-gate-icon">🔐</div>
        <h3 class="login-gate-title">로그인이 필요합니다</h3>
        <p class="login-gate-desc">
            포트폴리오 기능은<br />
            회원가입/로그인 후 이용할 수 있습니다.
        </p>
        <button
            class="login-gate-btn"
            onclick="if(window.openAuthModal) window.openAuthModal()"
        >
            회원가입 / 로그인
        </button>
    </div>
</div>

<!-- ② 로그인 완료 상태: main.js가 세션 확인 후 표시 -->
<div id="portfolio-content" style="display: none;">
    <div class="portfolio-dashboard benchmark-theme">
        <section id="portfolio-summary-card" class="portfolio-summary-card" style="display:none;"></section>
        <div class="portfolio-header">
            <div>
                <h2 class="portfolio-title">포트폴리오</h2>
            </div>
            <button
                id="btn-create-portfolio"
                class="portfolio-create-btn"
                onmouseover="this.style.opacity='0.85'"
                onmouseout="this.style.opacity='1'"
            >
                + 생성
            </button>
        </div>

        <div id="portfolio-empty-state" class="portfolio-empty">
            <p>아직 생성된 포트폴리오가 없습니다.</p>
        </div>
        <div id="portfolio-list" class="portfolio-list" style="display: none;"></div>
    </div>
</div>

<style>
    /* ── 비로그인 게이트 ───────────────────────────── */
    #portfolio-login-gate {
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding: 40px 20px 60px;
    }

    .login-gate-box {
        width: 100%;
        max-width: 480px;
        text-align: center;
        padding: 48px 32px;
        border: 2px dashed var(--border-color);
        border-radius: 16px;
        background: var(--container-bg);
    }

    .login-gate-icon {
        font-size: 52px;
        margin-bottom: 16px;
        line-height: 1;
    }

    .login-gate-title {
        font-size: 20px;
        font-weight: 800;
        color: var(--text-main);
        margin: 0 0 10px 0;
    }

    .login-gate-desc {
        font-size: 14px;
        color: var(--text-sub);
        line-height: 1.7;
        margin: 0 0 28px 0;
    }

    .login-gate-btn {
        display: inline-block;
        padding: 13px 36px;
        background: #1A237E;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: opacity 0.2s, transform 0.15s;
        letter-spacing: 0.02em;
    }

    .login-gate-btn:hover {
        opacity: 0.88;
        transform: translateY(-1px);
    }

    .login-gate-btn:active {
        transform: translateY(0);
    }

    /* ── 로그인 후 대시보드 ────────────────────────── */
    .portfolio-dashboard {
        padding: 20px;
        max-width: 1000px;
        margin: 0 auto;
    }

    .benchmark-theme {
        background: transparent;
        border-radius: 18px;
        box-shadow: none;
        border: none;
    }

    .portfolio-summary-card {
        border-radius: 28px;
        padding: 24px;
        margin-bottom: 16px;
        color: #fff;
        background: linear-gradient(135deg, #3167ff 0%, #7a2cff 100%);
        box-shadow: 0 8px 24px rgba(61, 92, 255, 0.35);
    }

    .summary-label {
        margin: 0;
        font-size: 12px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.75);
        letter-spacing: 0.06em;
    }

    .summary-total {
        margin: 6px 0 22px;
        font-size: 44px;
        font-weight: 800;
        line-height: 1;
    }

    .summary-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px;
        border-top: 1px solid rgba(255, 255, 255, 0.2);
        padding-top: 12px;
    }

    .summary-item-title {
        font-size: 12px;
        color: rgba(255, 255, 255, 0.75);
        margin: 0;
    }

    .summary-item-value {
        font-size: 25px;
        font-weight: 700;
        margin: 2px 0 0;
    }

    .portfolio-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 20px;
    }

    .portfolio-title {
        margin: 0;
        font-size: 18px;
        color: var(--text-main);
        letter-spacing: 0;
    }

    .portfolio-subtitle {
        margin: 2px 0 0;
        font-size: 12px;
        color: var(--text-sub);
    }

    .portfolio-create-btn {
        padding: 8px 16px;
        background: #2754de;
        color: white;
        border: none;
        border-radius: 999px;
        cursor: pointer;
        font-weight: bold;
        transition: opacity 0.2s;
    }

    .portfolio-empty {
        text-align: center;
        padding: 50px;
        background: var(--nav-hover);
        border-radius: 12px;
        border: 2px dashed var(--border-color);
    }

    .portfolio-empty p {
        font-size: 18px;
        color: var(--text-sub);
        font-weight: bold;
        margin: 0;
    }

    .portfolio-list {
        display: grid;
        grid-template-columns: 1fr;
        gap: 14px;
    }

    .portfolio-card {
        border: 1px solid var(--border-color);
        border-radius: 28px;
        padding: 16px;
        background: var(--container-bg);
        color: var(--text-main);
    }

    .portfolio-card p {
        margin: 6px 0 0 0;
        font-size: 12px;
        color: var(--text-sub);
    }

    .portfolio-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 8px;
    }

    .portfolio-card-title {
        margin: 0;
        padding: 0;
        border: none;
        background: transparent;
        text-align: left;
        cursor: pointer;
        color: var(--text-main);
        font-weight: 700;
        font-size: 22px;
    }

    .portfolio-card-title:hover {
        text-decoration: underline;
    }

    .portfolio-actions {
        display: flex;
        gap: 6px;
    }

    .portfolio-action-btn {
        border: 1px solid var(--border-color);
        background: var(--container-bg);
        color: var(--text-sub);
        border-radius: 999px;
        padding: 5px 10px;
        font-size: 12px;
        cursor: pointer;
    }

    .portfolio-action-btn:hover {
        opacity: 0.8;
    }

    .portfolio-main-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 8px;
    }

    .portfolio-value {
        font-size: 28px;
        font-weight: 800;
        color: var(--text-main);
    }

    .portfolio-profit {
        font-size: 16px;
        color: #ff6d6d;
        font-weight: 700;
    }

    .portfolio-items {
        margin-top: 12px;
        display: none;
        flex-direction: column;
        gap: 10px;
    }

    .portfolio-card.is-open .portfolio-items {
        display: flex;
    }

    .portfolio-item-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: var(--nav-hover);
        border: 1px solid var(--border-color);
        border-radius: 14px;
        padding: 10px 12px;
    }

    .portfolio-item-name {
        font-weight: 700;
        color: var(--text-main);
        font-size: 14px;
    }

    .portfolio-item-meta {
        font-size: 12px;
        color: var(--text-sub);
    }
</style>

<script>
    import { supabase } from "../lib/supabase";

    const createBtn = document.getElementById('btn-create-portfolio');
    const emptyState = document.getElementById('portfolio-empty-state');
    const listContainer = document.getElementById('portfolio-list');
    const summaryCard = document.getElementById('portfolio-summary-card');
    const escapeHtml = (value: string = '') =>
        value
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
    const encodeData = (value: string = '') => encodeURIComponent(value);
    const decodeData = (value: string = '') => decodeURIComponent(value);
    const currencyFormatter = new Intl.NumberFormat('ko-KR');
    const formatMoney = (value: number) => `${currencyFormatter.format(Math.round(value || 0))}원`;
    const calcPortfolioValue = (portfolio: any) =>
        (portfolio.portfolio_items || []).reduce((sum: number, item: any) =>
            sum + (Number(item.quantity) * Number(item.avg_price || 0)), 0
        );

    const renderSummary = (portfolios: any[]) => {
        if (!summaryCard) return;
        if (!portfolios || portfolios.length === 0) {
            summaryCard.style.display = 'none';
            summaryCard.innerHTML = '';
            return;
        }

        const totalAssets = portfolios.reduce((sum, portfolio) => sum + calcPortfolioValue(portfolio), 0);
        const totalItems = portfolios.reduce((sum, portfolio) => sum + (portfolio.portfolio_items?.length || 0), 0);
        const profit = 0;

        summaryCard.style.display = 'block';
        summaryCard.innerHTML = `
            <p class="summary-label">TOTAL ASSETS SUMMARY</p>
            <p class="summary-total">${formatMoney(totalAssets)}</p>
            <div class="summary-grid">
                <div>
                    <p class="summary-item-title">INVESTMENT</p>
                    <p class="summary-item-value">${formatMoney(totalAssets)}</p>
                </div>
                <div style="text-align:right;">
                    <p class="summary-item-title">PROFIT (${totalItems}종목)</p>
                    <p class="summary-item-value">+${formatMoney(profit)}</p>
                </div>
            </div>
        `;
    };

    const renderPortfolioList = (portfolios: any[]) => {
        if (!emptyState || !listContainer) return;

        if (!portfolios || portfolios.length === 0) {
            emptyState.style.display = 'block';
            listContainer.style.display = 'none';
            listContainer.innerHTML = '';
            renderSummary([]);
            return;
        }

        emptyState.style.display = 'none';
        listContainer.style.display = 'grid';
        renderSummary(portfolios);
        listContainer.innerHTML = portfolios.map((portfolio) => `
            <article class="portfolio-card is-open">
                <div class="portfolio-card-header">
                    <button
                        class="portfolio-card-title js-open-add-stock"
                        data-portfolio-id="${portfolio.id}"
                        data-portfolio-name="${encodeData(portfolio.name)}"
                    >
                        ${escapeHtml(portfolio.name)}
                    </button>
                    <div class="portfolio-actions">
                        <button class="portfolio-action-btn js-rename" data-portfolio-id="${portfolio.id}" data-portfolio-name="${encodeData(portfolio.name)}">수정</button>
                        <button class="portfolio-action-btn js-delete" data-portfolio-id="${portfolio.id}" data-portfolio-name="${encodeData(portfolio.name)}">삭제</button>
                    </div>
                </div>
                <div class="portfolio-main-row">
                    <div>
                        <p>생성일: ${new Date(portfolio.created_at).toLocaleDateString('ko-KR')}</p>
                        <p>보유 종목: ${portfolio.portfolio_items?.length || 0}개</p>
                    </div>
                    <div style="text-align:right;">
                        <div class="portfolio-value">${formatMoney(calcPortfolioValue(portfolio))}</div>
                        <div class="portfolio-profit">+0.00%</div>
                    </div>
                </div>
                <div class="portfolio-items">
                    ${(portfolio.portfolio_items?.length || 0) === 0
                        ? `<div class="portfolio-item-row"><div class="portfolio-item-meta">데이터가 존재하지 않습니다.</div></div>`
                        : portfolio.portfolio_items.map((item: any) => `
                            <div class="portfolio-item-row">
                                <div>
                                    <div class="portfolio-item-name">${escapeHtml(item.name || item.symbol || 'UNKNOWN')}</div>
                                    <div class="portfolio-item-meta">수량 ${Number(item.quantity || 0).toLocaleString()} · 평단 ${Number(item.avg_price || 0).toLocaleString()} ${escapeHtml(item.currency || '')}</div>
                                </div>
                                <div class="portfolio-item-meta">${formatMoney(Number(item.quantity || 0) * Number(item.avg_price || 0))}</div>
                            </div>
                        `).join('')
                    }
                </div>
            </article>
        `).join('');
    };

    const loadPortfolios = async () => {
        const sb = (window as any).supabase;
        if (!sb) return;

        const { data: { session } } = await sb.auth.getSession();
        if (!session) {
            renderPortfolioList([]);
            return;
        }

        const { data, error } = await sb
            .from('portfolios')
            .select(`
                id,
                name,
                created_at,
                portfolio_items (
                    id,
                    name,
                    quantity,
                    avg_price,
                    currency
                )
            `)
            .eq('user_id', session.user.id)
            .order('created_at', { ascending: false });

        if (error) {
            console.error('Portfolio Load Error:', error);
            return;
        }

        renderPortfolioList(data || []);
    };

    createBtn?.addEventListener('click', async () => {
        const sb = (window as any).supabase;

        if (!sb) {
            return alert("데이터베이스 연결에 실패했습니다. 페이지를 새로고침(F5) 후 다시 시도해주세요.");
        }

        try {
            const { data: { session } } = await sb.auth.getSession();
            if (!session) return alert("로그인이 필요합니다.");

            const name = window.prompt("새 포트폴리오 이름을 입력하세요.");
            if (!name || name.trim() === "") return;

            const { error } = await sb
                .from('portfolios')
                .insert([{ name: name.trim(), user_id: session.user.id }]);

            if (error) throw error;

            alert(`'${name.trim()}' 포트폴리오가 생성되었습니다!`);
            await loadPortfolios();
        } catch (err: any) {
            console.error("Portfolio Create Error:", err);
            alert("생성 실패: " + err.message);
        }
    });

    // ✅ [추가] 인증 상태 변화 실시간 감지 (로그아웃 시 로그인 게이트로 복귀)
    // 상단에서 import한 supabase 객체를 사용합니다.
    supabase?.auth.onAuthStateChange((event, session) => {
        const loginGate = document.getElementById('portfolio-login-gate');
        const content = document.getElementById('portfolio-content');

        if (session) {
            // 로그인 완료 → 포트폴리오 콘텐츠 표시
            if (loginGate) loginGate.style.display = 'none';
            if (content) content.style.display = 'block';
            loadPortfolios();
        } else {
            // 로그아웃 → 로그인 안내 게이트로 복귀
            if (loginGate) loginGate.style.display = 'flex';
            if (content) content.style.display = 'none';
            renderPortfolioList([]);
        }
    });

    listContainer?.addEventListener('click', async (event) => {
        const target = event.target as HTMLElement;
        const button = target.closest('button');
        if (!button) return;

        const sb = (window as any).supabase;
        if (!sb) {
            alert('데이터베이스 연결에 실패했습니다.');
            return;
        }

        const portfolioId = button.dataset.portfolioId || '';
        const portfolioName = decodeData(button.dataset.portfolioName || '');
        if (!portfolioId) return;

        if (button.classList.contains('js-open-add-stock')) {
            const hiddenInput = document.getElementById('currentPortfolioId') as HTMLInputElement | null;
            if (hiddenInput) hiddenInput.value = portfolioId;
            const nameSpan = document.getElementById('modalPortfolioName');
            if (nameSpan) nameSpan.textContent = portfolioName;

            const modal = document.getElementById('addStockModal');
            if (!modal) {
                alert('종목 추가 모달을 찾지 못했습니다. 새로고침 후 다시 시도해주세요.');
                return;
            }
            modal?.classList.remove('hidden');
            modal?.classList.add('flex');
            return;
        }

        if (button.classList.contains('js-rename')) {
            const nextName = window.prompt('새 포트폴리오 이름을 입력하세요.', portfolioName);
            if (!nextName || nextName.trim() === '' || nextName.trim() === portfolioName) return;

            const { error } = await sb
                .from('portfolios')
                .update({ name: nextName.trim() })
                .eq('id', portfolioId);

            if (error) {
                alert('이름 수정 실패: ' + error.message);
                return;
            }
            await loadPortfolios();
            return;
        }

        if (button.classList.contains('js-delete')) {
            const confirmed = window.confirm(`'${portfolioName}' 포트폴리오를 삭제할까요?\n보유 종목도 함께 삭제됩니다.`);
            if (!confirmed) return;

            const { error: itemDeleteError } = await sb
                .from('portfolio_items')
                .delete()
                .eq('portfolio_id', portfolioId);

            if (itemDeleteError) {
                alert('보유 종목 삭제 실패: ' + itemDeleteError.message);
                return;
            }

            const { error: portfolioDeleteError } = await sb
                .from('portfolios')
                .delete()
                .eq('id', portfolioId);

            if (portfolioDeleteError) {
                alert('포트폴리오 삭제 실패: ' + portfolioDeleteError.message);
                return;
            }
            await loadPortfolios();
        }
    });

    loadPortfolios();
</script>