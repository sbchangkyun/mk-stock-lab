---
/* src/components/Nav.astro - 최적화 버전 */
---
<nav class="nav-menu-wrapper">
    <ul class="nav-menu">
        <li class="nav-item" onclick="handleNav(this, '차트', '/')">차트</li>
        <li class="nav-item" onclick="handleNav(this, '경제 뉴스', '/')">경제 뉴스</li>
        <li class="nav-item" onclick="handleNav(this, '크립토 뉴스', '/')">크립토 뉴스</li>
        <li class="nav-item" onclick="handleNav(this, '실시간', '/')">실시간</li>
        <li class="nav-item" id="nav-seibro" onclick="location.href='/seibro'">수급 분석</li>

</ul>


    </ul>
</nav>

<script is:inline>
    window.handleNav = function(element, menuName, targetPath) {
        const isHomePage = window.location.pathname === '/' || window.location.pathname === '/index.html';
        
        // 1. 수급 분석 페이지에서 클릭한 경우
        if (window.location.pathname.includes('seibro')) {
            if (menuName === '수급 분석') return; // 현재 페이지면 무시
            // 메인으로 이동하며 메뉴 이름을 전달
            window.location.href = `/?menu=${encodeURIComponent(menuName)}`;
            return;
        }

        // 2. 메인 페이지에서 클릭한 경우 (SPA 방식 탭 전환)
        if (isHomePage) {
            if (window.changeMenu) {
                window.changeMenu(element, menuName);
            }
        } else {
            // 그 외 페이지(혹시 모를 에러 방지용)
            window.location.href = `/?menu=${encodeURIComponent(menuName)}`;
        }
    };        

    // ✅ [추가] /seibro 페이지 진입 시 '수급 분석' 메뉴에 active 클래스 적용
    document.addEventListener('DOMContentLoaded', function() {
        if (window.location.pathname.includes('seibro')) {
            document.querySelectorAll('.nav-item').forEach(item => item.classList.remove('active'));
            const seibroNav = document.getElementById('nav-seibro');
            if (seibroNav) seibroNav.classList.add('active');
        }
    });
</script>