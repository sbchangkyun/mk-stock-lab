---
type HeatmapItem = {
  label: string;
  change: number;
  weight: number;
};

type ScatterPoint = {
  label: string;
  trend: number;
  momentum: number;
};

type MarketSection = {
  slug: string;
  title: string;
  subtitle: string;
  heatmap: HeatmapItem[];
  scatter: ScatterPoint[];
  portfolioOnly?: boolean;
};

const sections: MarketSection[] = [
  {
    slug: 'kospi200',
    title: 'KOSPI200',
    subtitle: '샘플 데이터 · 실시간 데이터 연동 전 단계',
    heatmap: [
      { label: '005930', change: 1.8, weight: 3 },
      { label: '000660', change: 3.1, weight: 2 },
      { label: '373220', change: -1.4, weight: 2 },
      { label: '005380', change: 0.4, weight: 1 },
      { label: '035420', change: -0.8, weight: 1 },
      { label: '068270', change: 2.2, weight: 1 },
    ],
    scatter: [
      { label: '005930', trend: 5.6, momentum: 1.2 },
      { label: '000660', trend: 7.2, momentum: 4.4 },
      { label: '373220', trend: -2.3, momentum: -1.8 },
      { label: '005380', trend: 3.1, momentum: -0.7 },
      { label: '035420', trend: -4.2, momentum: 1.9 },
    ],
  },
  {
    slug: 'kosdaq150',
    title: 'KOSDAQ150',
    subtitle: '샘플 데이터 · 실시간 데이터 연동 전 단계',
    heatmap: [
      { label: '247540', change: 2.7, weight: 2 },
      { label: '086520', change: -2.1, weight: 2 },
      { label: '091990', change: 1.1, weight: 1 },
      { label: '066970', change: -0.4, weight: 1 },
      { label: '035900', change: 0.2, weight: 1 },
      { label: '196170', change: 3.3, weight: 1 },
    ],
    scatter: [
      { label: '247540', trend: 6.3, momentum: 3.5 },
      { label: '086520', trend: -3.4, momentum: -2.6 },
      { label: '091990', trend: 2.2, momentum: 0.8 },
      { label: '066970', trend: -1.7, momentum: 1.1 },
      { label: '196170', trend: 4.9, momentum: 4.1 },
    ],
  },
  {
    slug: 'sp500',
    title: 'S&P500',
    subtitle: '샘플 데이터 · 실시간 데이터 연동 전 단계',
    heatmap: [
      { label: 'AAPL', change: 0.9, weight: 2 },
      { label: 'MSFT', change: 1.5, weight: 2 },
      { label: 'NVDA', change: 4.2, weight: 3 },
      { label: 'AMZN', change: -0.7, weight: 1 },
      { label: 'META', change: 2.1, weight: 1 },
      { label: 'JPM', change: -1.2, weight: 1 },
    ],
    scatter: [
      { label: 'AAPL', trend: 3.2, momentum: 0.6 },
      { label: 'MSFT', trend: 4.8, momentum: 1.4 },
      { label: 'NVDA', trend: 8.1, momentum: 5.2 },
      { label: 'AMZN', trend: 1.6, momentum: -1.3 },
      { label: 'JPM', trend: -0.8, momentum: -1.5 },
    ],
  },
  {
    slug: 'nasdaq100',
    title: 'NASDAQ100',
    subtitle: '샘플 데이터 · 실시간 데이터 연동 전 단계',
    heatmap: [
      { label: 'NVDA', change: 4.2, weight: 3 },
      { label: 'TSLA', change: -3.4, weight: 2 },
      { label: 'AVGO', change: 2.6, weight: 2 },
