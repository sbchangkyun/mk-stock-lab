---
import { marketPeriods, marketUniverses, type MarketConstituent, type MarketPeriodId, type MarketUniverseId } from '../data/marketTreemapSamples';

type Rect = {
  x: number;
  y: number;
  width: number;
  height: number;
};

type TreemapTile = Rect & {
  key: string;
  clipId: string;
  symbol: string;
  name: string;
  sector: string;
  value: number;
  changePct: number;
};

type TreemapSector = Rect & {
  key: string;
  label: string;
  value: number;
  tiles: TreemapTile[];
};

type DashboardView = {
  id: string;
  universeId: MarketUniverseId;
  periodId: MarketPeriodId;
  universeLabel: string;
  periodLabel: string;
  asOf: string;
  currency: string;
  treemapId: string;
  scatterId: string;
  sectors: TreemapSector[];
  scatterPoints: Array<{
    symbol: string;
    name: string;
    sector: string;
    x: number;
    y: number;
    momentum: number;
    trend: number;
    changePct: number;
    color: string;
  }>;
  gainers: number;
  decliners: number;
};

const treemapWidth = 860;
const treemapHeight = 420;
const scatterWidth = 560;
const scatterHeight = 340;
const plot = { x: 76, y: 58, width: 394, height: 222 };

const clamp = (value: number, min: number, max: number) => Math.max(min, Math.min(max, value));
const formatChange = (value: number) => `${value > 0 ? '+' : ''}${value.toFixed(1)}%`;
const formatValue = (value: number, currency: string) => `${value.toLocaleString('en-US')} ${currency}`;
const safeToken = (value: string) => value.replace(/[^a-zA-Z0-9_-]/g, '-');

const colorForChange = (changePct: number) => {
  if (changePct >= 6) return '#9d1c22';
  if (changePct >= 3) return '#c93434';
  if (changePct >= 0.8) return '#e76f51';
  if (changePct <= -6) return '#174ea6';
  if (changePct <= -3) return '#2563eb';
  if (changePct <= -0.8) return '#5b8def';
  return '#9aa4b2';
};

const returnForPeriod = (item: MarketConstituent, multiplier: number) =>
  clamp(item.baseChangePct * multiplier + item.trend * Math.max(0, multiplier - 1) * 0.16, -12, 12);

const layoutWeighted = <T extends { value: number }>(
  items: T[],
  rect: Rect,
  vertical: boolean,
) => {
  const total = items.reduce((sum, item) => sum + Math.max(1, item.value), 0);
  let offset = 0;

  return items.map((item, index) => {
    const remainingItems = items.length - index;
    const isLast = remainingItems === 1;
    const ratio = Math.max(1, item.value) / total;
    const length = vertical ? rect.width : rect.height;
    const size = isLast ? length - offset : Math.max(24, length * ratio);
    const child = vertical
      ? { x: rect.x + offset, y: rect.y, width: size, height: rect.height }
      : { x: rect.x, y: rect.y + offset, width: rect.width, height: size };

    offset += size;
    return { item, rect: child };
  });
};

const insetRect = (rect: Rect, inset: number) => ({
  x: rect.x + inset,
  y: rect.y + inset,
  width: Math.max(0, rect.width - inset * 2),
  height: Math.max(0, rect.height - inset * 2),
});

const buildTreemap = (items: MarketConstituent[], multiplier: number): TreemapSector[] => {
  const sectorMap = new Map<string, MarketConstituent[]>();
  items.forEach((item) => {
    const sectorItems = sectorMap.get(item.sector) ?? [];
    sectorItems.push(item);
    sectorMap.set(item.sector, sectorItems);
  });

  const sectors = [...sectorMap.entries()]
    .map(([label, sectorItems]) => ({
      label,
      value: sectorItems.reduce((sum, item) => sum + item.value, 0),
      items: sectorItems.sort((a, b) => b.value - a.value),
    }))
    .sort((a, b) => b.value - a.value);

  return layoutWeighted(sectors, { x: 0, y: 0, width: treemapWidth, height: treemapHeight }, true).map(({ item: sector, rect }, sectorIndex) => {
    const sectorRect = insetRect(rect, 4);
    const tileArea = {
      x: sectorRect.x + 4,
      y: sectorRect.y + 30,
      width: Math.max(0, sectorRect.width - 8),
      height: Math.max(0, sectorRect.height - 34),
    };
    const verticalTiles = tileArea.height > tileArea.width;
    const tiles = layoutWeighted(sector.items, tileArea, verticalTiles).map(({ item, rect: tileRect }, tileIndex) => ({
      ...insetRect(tileRect, 2),
      key: `${sector.label}-${item.symbol}-${tileIndex}`,
      clipId: safeToken(`clip-${sector.label}-${item.symbol}-${tileIndex}`),
      symbol: item.symbol,
      name: item.name,
      sector: item.sector,
      value: item.value,
      changePct: returnForPeriod(item, multiplier),
    }));

    return {
      ...sectorRect,
      key: `${sector.label}-${sectorIndex}`,
      label: sector.label,
      value: sector.value,
      tiles,
    };
  });
};

const buildScatterPoints = (items: MarketConstituent[], multiplier: number) =>
  items.map((item) => {
    const trend = clamp(item.trend * (0.55 + multiplier * 0.12), -10, 10);
    const momentum = clamp(item.momentum * (0.72 + multiplier * 0.1), -10, 10);
    const x = plot.x + ((trend + 10) / 20) * plot.width;
    const y = plot.y + ((10 - momentum) / 20) * plot.height;
    const changePct = returnForPeriod(item, multiplier);

    return {
      symbol: item.symbol,
      name: item.name,
      sector: item.sector,
      x: clamp(x, plot.x + 8, plot.x + plot.width - 8),
      y: clamp(y, plot.y + 8, plot.y + plot.height - 8),
      momentum,
      trend,
      changePct,
      color: colorForChange(changePct),
    };
  });

const dashboards: DashboardView[] = marketUniverses.flatMap((universe) =>
  marketPeriods.map((period) => {
    const id = `${universe.id}-${period.id}`;
    const sectors = buildTreemap(universe.constituents, period.multiplier);
    const allTiles = sectors.flatMap((sector) => sector.tiles);

    return {
      id,
      universeId: universe.id,
      periodId: period.id,
      universeLabel: universe.label,
      periodLabel: period.label,
      asOf: universe.asOf,
      currency: universe.currency,
      treemapId: `market-${universe.id}-${period.id}-treemap`,
      scatterId: `market-${universe.id}-${period.id}-scatter`,
      sectors,
      scatterPoints: buildScatterPoints(universe.constituents, period.multiplier),
      gainers: allTiles.filter((tile) => tile.changePct > 0.5).length,
      decliners: allTiles.filter((tile) => tile.changePct < -0.5).length,
    };
  }),
);

const firstView = dashboards[0];
const cameraPath =
  'M4 7.5h3l1.3-2h7.4l1.3 2h3a1.5 1.5 0 0 1 1.5 1.5v9A1.5 1.5 0 0 1 20 19.5H4A1.5 1.5 0 0 1 2.5 18V9A1.5 1.5 0 0 1 4 7.5Zm8 9a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm0-1.8a2.2 2.2 0 1 1 0-4.4 2.2 2.2 0 0 1 0 4.4Z';
const expandPath = 'M4 9V4h5v2H7.4l3.1 3.1-1.4 1.4L6 7.4V9H4Zm11 0V7.4l-3.1 3.1-1.4-1.4L13.6 6H12V4h5v5h-2ZM4 15h2v1.6l3.1-3.1 1.4 1.4L7.4 18H9v2H4v-5Zm13 0v5h-5v-2h1.6l-3.1-3.1 1.4-1.4 3.1 3.1V15h2Z';
---

<header class="page-header market-page-header">
  <div>
    <p class="eyebrow">Market</p>
    <h1>시장</h1>
    <p class="lead">
      선택한 시장을 하나의 Treemap과 모멘텀 산점도로 비교하는 provider-free 대시보드입니다. 현재 수치는 샘플 데이터이며 실시간 연동은 다음 단계에서 다룹니다.
    </p>
  </div>
</header>

<section class="market-dashboard" data-market-dashboard data-active-universe={firstView.universeId} data-active-period={firstView.periodId}>
  <div class="market-control-panel" aria-label="시장 대시보드 선택">
    <div class="market-control-group">
      <span class="market-control-label">시장</span>
      <div class="market-tab-list" role="tablist" aria-label="시장 선택">
        {marketUniverses.map((universe, index) => (
          <button
            class:list={['market-tab-button', index === 0 && 'is-active']}
            type="button"
            role="tab"
            aria-selected={index === 0 ? 'true' : 'false'}
            data-market-universe-tab={universe.id}
          >
            {universe.label}
          </button>
        ))}
      </div>
    </div>
    <div class="market-control-group">
      <span class="market-control-label">기간</span>
      <div class="market-tab-list compact" role="tablist" aria-label="기간 선택">
        {marketPeriods.map((period, index) => (
          <button
            class:list={['market-tab-button', index === 0 && 'is-active']}
            type="button"
            role="tab"
            aria-selected={index === 0 ? 'true' : 'false'}
            data-market-period-tab={period.id}
          >
            {period.label}
          </button>
        ))}
      </div>
    </div>
  </div>

  <div class="market-dashboard-stage">
    {dashboards.map((view, index) => (
      <section
        class:list={['market-dashboard-panel', index !== 0 && 'hidden']}
        data-market-panel
        data-market-universe={view.universeId}
        data-market-period={view.periodId}
        aria-hidden={index === 0 ? 'false' : 'true'}
      >
        <div class="market-summary-row">
          <div>
            <p class="eyebrow">Treemap Dashboard</p>
            <h2>{view.universeLabel} · {view.periodLabel}</h2>
          </div>
          <div class="market-summary-metrics" aria-label={`${view.universeLabel} summary`}>
            <span><strong>{view.gainers}</strong> 상승</span>
            <span><strong>{view.decliners}</strong> 하락</span>
            <span>{view.asOf}</span>
          </div>
        </div>

        <div class="market-dashboard-grid">
          <article class="market-chart-card market-treemap-card" id={view.treemapId} data-exportable-card>
            <div class="market-card-header">
              <div>
                <h3>{view.universeLabel} Treemap</h3>
                <p>섹터별로 묶고 시가총액 비중으로 타일 크기를 배치한 샘플 Treemap입니다.</p>
              </div>
              <div class="market-card-actions" data-card-actions>
                <button
                  class="chart-export-button"
                  type="button"
                  data-expand-card
                  data-expand-target={view.treemapId}
                  data-export-filename={`mk-stock-lab-market-${view.universeId}-${view.periodId}-treemap`}
                  aria-label="크게 보기"
                  title="크게 보기"
                >
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d={expandPath} /></svg>
                </button>
                <button
                  class="chart-export-button"
                  type="button"
                  data-export-card
                  data-export-target={view.treemapId}
                  data-export-filename={`mk-stock-lab-market-${view.universeId}-${view.periodId}-treemap`}
                  aria-label="이미지로 저장"
                  title="이미지로 저장"
                >
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d={cameraPath} /></svg>
                </button>
              </div>
            </div>

            <svg class="market-treemap-svg" viewBox={`0 0 ${treemapWidth} ${treemapHeight}`} role="img" aria-label={`${view.universeLabel} ${view.periodLabel} Treemap`}>
              <rect x="0" y="0" width={treemapWidth} height={treemapHeight} rx="18" fill="#f7f9fc" />
              {view.sectors.map((sector) => (
                <g>
                  <rect x={sector.x} y={sector.y} width={sector.width} height={sector.height} rx="14" fill="#eef3f8" stroke="#d8e2ee" />
                  <text x={sector.x + 12} y={sector.y + 20} class="market-treemap-sector-label">{sector.label}</text>
                  {sector.tiles.map((tile) => (
                    <g>
                      <title>{`${tile.symbol} ${tile.name} ${formatChange(tile.changePct)} · ${formatValue(tile.value, view.currency)}`}</title>
                      <clipPath id={`${view.id}-${tile.clipId}`}>
                        <rect x={tile.x} y={tile.y} width={tile.width} height={tile.height} rx="8" />
                      </clipPath>
                      <rect
                        x={tile.x}
                        y={tile.y}
                        width={tile.width}
                        height={tile.height}
                        rx="8"
                        fill={colorForChange(tile.changePct)}
                        stroke="#ffffff"
                        stroke-width="1.6"
                      />
                      {(tile.width > 54 && tile.height > 30) && (
                        <g clip-path={`url(#${view.id}-${tile.clipId})`}>
                          <text x={tile.x + 8} y={tile.y + 17} class="market-treemap-symbol">{tile.symbol}</text>
                          {tile.height > 48 && <text x={tile.x + 8} y={tile.y + 36} class="market-treemap-change">{formatChange(tile.changePct)}</text>}
                        </g>
                      )}
                    </g>
                  ))}
                </g>
              ))}
            </svg>

            <div class="market-legend" aria-label="수익률 색상 범례">
              <span><i class="negative"></i>-3% 이하</span>
              <span><i class="flat"></i>중립</span>
              <span><i class="positive"></i>+3% 이상</span>
            </div>
          </article>

          <article class="market-chart-card market-scatter-card" id={view.scatterId} data-exportable-card>
            <div class="market-card-header">
              <div>
                <h3>{view.universeLabel} Momentum / Trend</h3>
                <p>같은 시장과 기간의 단기 모멘텀과 장기 트렌드를 비교합니다.</p>
              </div>
              <div class="market-card-actions" data-card-actions>
                <button
                  class="chart-export-button"
                  type="button"
                  data-expand-card
                  data-expand-target={view.scatterId}
                  data-export-filename={`mk-stock-lab-market-${view.universeId}-${view.periodId}-scatter`}
                  aria-label="크게 보기"
                  title="크게 보기"
                >
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d={expandPath} /></svg>
                </button>
                <button
                  class="chart-export-button"
                  type="button"
                  data-export-card
                  data-export-target={view.scatterId}
                  data-export-filename={`mk-stock-lab-market-${view.universeId}-${view.periodId}-scatter`}
                  aria-label="이미지로 저장"
                  title="이미지로 저장"
                >
                  <svg viewBox="0 0 24 24" aria-hidden="true"><path d={cameraPath} /></svg>
                </button>
              </div>
            </div>
            <svg class="market-scatter-chart" viewBox={`0 0 ${scatterWidth} ${scatterHeight}`} role="img" aria-label={`${view.universeLabel} ${view.periodLabel} momentum trend scatter`}>
              <rect x="0" y="0" width={scatterWidth} height={scatterHeight} rx="16" fill="#ffffff" />
              <rect x={plot.x} y={plot.y} width={plot.width} height={plot.height} rx="10" fill="#f7f9fc" stroke="#d8e2ee" />
              <line x1={plot.x + plot.width / 2} y1={plot.y} x2={plot.x + plot.width / 2} y2={plot.y + plot.height} stroke="#aeb8c6" stroke-width="1" />
              <line x1={plot.x} y1={plot.y + plot.height / 2} x2={plot.x + plot.width} y2={plot.y + plot.height / 2} stroke="#aeb8c6" stroke-width="1" />
              <text x={plot.x} y="30" class="scatter-axis-label">단기 모멘텀</text>
              <text x={plot.x + plot.width / 2} y="324" text-anchor="middle" class="scatter-axis-label">장기 트렌드</text>
              <text x={plot.x + plot.width - 102} y={plot.y + 24} class="scatter-quadrant">강한 추세</text>
              <text x={plot.x + 16} y={plot.y + 24} class="scatter-quadrant">반등 후보</text>
              <text x={plot.x + plot.width - 112} y={plot.y + plot.height - 16} class="scatter-quadrant">추세 둔화</text>
              <text x={plot.x + 16} y={plot.y + plot.height - 16} class="scatter-quadrant">약한 흐름</text>
              {view.scatterPoints.map((point) => (
                <g class="scatter-point" transform={`translate(${point.x} ${point.y})`}>
                  <title>{`${point.symbol} ${point.name} · Momentum ${point.momentum.toFixed(1)} · Trend ${point.trend.toFixed(1)}`}</title>
                  <circle r="6.5" fill={point.color} stroke="#ffffff" stroke-width="2" />
                  <text x="10" y="4">{point.symbol}</text>
                </g>
              ))}
            </svg>
          </article>
        </div>
      </section>
    ))}
  </div>
</section>

<div class="market-card-modal hidden" id="marketCardModal" aria-hidden="true">
  <div class="market-card-modal-backdrop" data-close-expanded-card></div>
  <div class="market-card-modal-panel" role="dialog" aria-modal="true" aria-label="크게 보기">
    <div class="market-card-modal-actions" data-card-actions>
      <button class="chart-export-button" type="button" id="marketModalExportButton" aria-label="이미지로 저장" title="이미지로 저장">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d={cameraPath} /></svg>
      </button>
      <button class="chart-export-button" type="button" data-close-expanded-card aria-label="닫기" title="닫기">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" /></svg>
      </button>
    </div>
    <div class="market-card-modal-content" id="marketCardModalContent" data-exportable-card></div>
  </div>
</div>

<script>
  import { exportCardAsPng, setupCardImageExport } from '../lib/exportCardImage';

  const setupMarketDashboardControls = () => {
    const dashboard = document.querySelector<HTMLElement>('[data-market-dashboard]');
    if (!dashboard || dashboard.dataset.controlsReady === 'true') return;
    dashboard.dataset.controlsReady = 'true';

    const universeTabs = Array.from(dashboard.querySelectorAll<HTMLButtonElement>('[data-market-universe-tab]'));
    const periodTabs = Array.from(dashboard.querySelectorAll<HTMLButtonElement>('[data-market-period-tab]'));
    const panels = Array.from(dashboard.querySelectorAll<HTMLElement>('[data-market-panel]'));

    const setActive = (universe: string, period: string) => {
      dashboard.dataset.activeUniverse = universe;
      dashboard.dataset.activePeriod = period;

      universeTabs.forEach((tab) => {
        const active = tab.dataset.marketUniverseTab === universe;
        tab.classList.toggle('is-active', active);
        tab.setAttribute('aria-selected', active ? 'true' : 'false');
      });

      periodTabs.forEach((tab) => {
        const active = tab.dataset.marketPeriodTab === period;
        tab.classList.toggle('is-active', active);
        tab.setAttribute('aria-selected', active ? 'true' : 'false');
      });

      panels.forEach((panel) => {
        const active = panel.dataset.marketUniverse === universe && panel.dataset.marketPeriod === period;
        panel.classList.toggle('hidden', !active);
        panel.setAttribute('aria-hidden', active ? 'false' : 'true');
      });
    };

    universeTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const universe = tab.dataset.marketUniverseTab;
        const period = dashboard.dataset.activePeriod;
        if (universe && period) setActive(universe, period);
      });
    });

    periodTabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const universe = dashboard.dataset.activeUniverse;
        const period = tab.dataset.marketPeriodTab;
        if (universe && period) setActive(universe, period);
      });
    });
  };

  const setupMarketCardModal = () => {
    const modal = document.getElementById('marketCardModal');
    const content = document.getElementById('marketCardModalContent');
    const exportButton = document.getElementById('marketModalExportButton') as HTMLButtonElement | null;
    if (!modal || !content || modal.dataset.ready === 'true') return;
    modal.dataset.ready = 'true';

    let currentFilename = 'mk-stock-lab-market-card';

    const close = () => {
      modal.classList.add('hidden');
      modal.setAttribute('aria-hidden', 'true');
      content.replaceChildren();
      document.body.classList.remove('modal-open');
    };

    const open = (card: HTMLElement, filename: string) => {
      const clone = card.cloneNode(true) as HTMLElement;
      clone.removeAttribute('id');
      clone.querySelectorAll('[data-card-actions]').forEach((node) => node.remove());
      content.replaceChildren(clone);
      currentFilename = filename;
      modal.classList.remove('hidden');
      modal.setAttribute('aria-hidden', 'false');
      document.body.classList.add('modal-open');
    };

    document.querySelectorAll<HTMLButtonElement>('[data-expand-card]').forEach((button) => {
      if (button.dataset.expandReady === 'true') return;
      button.dataset.expandReady = 'true';
      button.addEventListener('click', () => {
        const targetId = button.dataset.expandTarget;
        const target = targetId ? document.getElementById(targetId) : null;
        if (!target) return;
        open(target, button.dataset.exportFilename || targetId || 'mk-stock-lab-market-card');
      });
    });

    document.querySelectorAll<HTMLElement>('[data-close-expanded-card]').forEach((closeTarget) => {
      if (closeTarget.dataset.closeReady === 'true') return;
      closeTarget.dataset.closeReady = 'true';
      closeTarget.addEventListener('click', close);
    });

    exportButton?.addEventListener('click', async () => {
      const target = content.querySelector<HTMLElement>('.market-chart-card');
      if (!target) return;
      exportButton.disabled = true;
      try {
        await exportCardAsPng(target, currentFilename);
      } catch {
        window.alert('이미지 저장을 완료하지 못했습니다. Chrome에서 다시 시도해 주세요.');
      } finally {
        exportButton.disabled = false;
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !modal.classList.contains('hidden')) close();
    });
  };

  document.addEventListener('astro:page-load', () => {
    setupCardImageExport();
    setupMarketDashboardControls();
    setupMarketCardModal();
  });
  setupCardImageExport();
  setupMarketDashboardControls();
  setupMarketCardModal();
</script>
