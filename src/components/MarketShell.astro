  {
    slug: 'my-portfolio',
    title: 'My Portfolio holdings',
    subtitle: '로그인 후 보유 종목 연동 예정 · 현재는 샘플 셸',
    portfolioOnly: true,
    heatmap: [
      { label: '보유 A', change: 1.2, weight: 2 },
      { label: '보유 B', change: -0.8, weight: 1 },
      { label: '보유 C', change: 0.3, weight: 1 },
      { label: '보유 D', change: 2.4, weight: 1 },
