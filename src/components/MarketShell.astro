const tileClass = (change: number) => (change > 0.5 ? 'up' : change < -0.5 ? 'down' : 'flat');
const pointX = (trend: number) => Math.max(34, Math.min(346, 190 + trend * 18));
const pointY = (momentum: number) => Math.max(36, Math.min(224, 130 - momentum * 18));
const pointClass = (point: ScatterPoint) => (point.trend >= 0 && point.momentum >= 0 ? 'strong' : point.trend < 0 && point.momentum < 0 ? 'weak' : 'mixed');
---

<header class="page-header">
  <div>
    <p class="eyebrow">Market</p>
    <h1>시장</h1>
    <p class="lead">시장별 Heatmap과 단기 모멘텀 대비 장기 트렌드 산점도를 비교하는 provider-free 셸입니다. 현재 수치는 샘플 데이터이며 실시간 데이터 연동은 다음 단계입니다.</p>
  </div>
</header>

<section class="market-section-stack">
  {sections.map((section) => (
    <section class="market-section" data-market-section={section.slug}>
      <div class="market-section-header">
        <div>
          <p class="eyebrow">Sample Market View</p>
          <h2>{section.title}</h2>
          <p>{section.subtitle}</p>
        </div>
        {section.portfolioOnly && <span class="market-status-pill">로그인 연동 예정</span>}
      </div>

      <div class="market-card-grid">
        <article class="market-chart-card" id={`market-${section.slug}-heatmap`} data-exportable-card>
          <div class="market-card-header">
            <div>
              <h3>{section.title} Heatmap</h3>
              <p>샘플 데이터 · 색상은 등락률 방향을 나타냅니다.</p>
            </div>
            <button
              class="chart-export-button"
              type="button"
              data-export-card
              data-export-target={`market-${section.slug}-heatmap`}
              data-export-filename={`mk-stock-lab-market-${section.slug}-heatmap`}
              aria-label="이미지로 저장"
              title="이미지로 저장"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 7.5h3l1.3-2h7.4l1.3 2h3a1.5 1.5 0 0 1 1.5 1.5v9A1.5 1.5 0 0 1 20 19.5H4A1.5 1.5 0 0 1 2.5 18V9A1.5 1.5 0 0 1 4 7.5Zm8 9a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm0-1.8a2.2 2.2 0 1 1 0-4.4 2.2 2.2 0 0 1 0 4.4Z" />
              </svg>
            </button>
          </div>
          <div class="market-heatmap-grid" aria-label={`${section.title} heatmap sample`}>
            {section.heatmap.map((item) => (
              <div class:list={['market-heatmap-tile', tileClass(item.change)]} style={`--tile-span:${item.weight}`}>
                <strong>{item.label}</strong>
                <span>{item.change > 0 ? '+' : ''}{item.change.toFixed(1)}%</span>
              </div>
            ))}
          </div>
        </article>

        <article class="market-chart-card" id={`market-${section.slug}-scatter`} data-exportable-card>
          <div class="market-card-header">
            <div>
              <h3>{section.title} Momentum / Trend</h3>
              <p>단기 모멘텀(Y)과 장기 트렌드(X)를 비교하는 샘플 산점도입니다.</p>
            </div>
            <button
              class="chart-export-button"
              type="button"
              data-export-card
              data-export-target={`market-${section.slug}-scatter`}
              data-export-filename={`mk-stock-lab-market-${section.slug}-scatter`}
              aria-label="이미지로 저장"
              title="이미지로 저장"
            >
              <svg viewBox="0 0 24 24" aria-hidden="true">
                <path d="M4 7.5h3l1.3-2h7.4l1.3 2h3a1.5 1.5 0 0 1 1.5 1.5v9A1.5 1.5 0 0 1 20 19.5H4A1.5 1.5 0 0 1 2.5 18V9A1.5 1.5 0 0 1 4 7.5Zm8 9a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm0-1.8a2.2 2.2 0 1 1 0-4.4 2.2 2.2 0 0 1 0 4.4Z" />
              </svg>
            </button>
          </div>
          <svg class="market-scatter-chart" viewBox="0 0 380 260" role="img" aria-label={`${section.title} momentum trend scatter sample`}>
            <rect x="40" y="28" width="300" height="204" rx="8" class="scatter-plot-bg" />
            <line x1="190" y1="28" x2="190" y2="232" class="scatter-axis" />
            <line x1="40" y1="130" x2="340" y2="130" class="scatter-axis" />
            <text x="332" y="250" class="scatter-axis-label">장기 트렌드</text>
            <text x="8" y="36" class="scatter-axis-label">단기 모멘텀</text>
            <text x="238" y="52" class="scatter-quadrant">강한 추세</text>
            <text x="58" y="52" class="scatter-quadrant">반등 후보</text>
            <text x="214" y="218" class="scatter-quadrant">추세 둔화</text>
            <text x="58" y="218" class="scatter-quadrant">약한 흐름</text>
            {section.scatter.map((point) => (
              <g class:list={['scatter-point', pointClass(point)]} transform={`translate(${pointX(point.trend)} ${pointY(point.momentum)})`}>
                <circle r="6" />
                <text x="9" y="4">{point.label}</text>
              </g>
            ))}
          </svg>
        </article>
      </div>
    </section>
  ))}
</section>

<script>
  import { setupCardImageExport } from '../lib/exportCardImage';

  document.addEventListener('astro:page-load', setupCardImageExport);
  setupCardImageExport();
</script>
