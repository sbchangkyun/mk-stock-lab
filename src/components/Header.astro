---
import AuthModal from './Auth/AuthModal.astro';
---

<header class="site-header">
  <a class="brand-mark" href="/" aria-label="MK Stock Lab home">
    <span class="brand-symbol">MK</span>
    <span class="brand-text">
      <strong>MK Stock Lab</strong>
      <small>Investment Data Platform</small>
    </span>
  </a>

  <div class="header-actions">
    <button class="icon-button" id="themeToggle" type="button" aria-label="Toggle theme">
      <svg id="themeIcon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 4a8 8 0 1 0 8 8 6 6 0 0 1-8-8Z"></path>
      </svg>
    </button>
    <button class="header-button" id="open-login-btn" type="button">Login</button>
    <button class="header-button secondary hidden" id="logout-btn" type="button">Logout</button>
  </div>
</header>

<AuthModal />

<script>
  import { bootstrapProfileForCurrentSession, dispatchProfileBootstrapStatus } from '../lib/profileBootstrap';
  import { getBrowserSupabaseClient, isSupabaseConfigured } from '../lib/supabase';

  const updateAuthButtons = (user: unknown) => {
    const loginButton = document.getElementById('open-login-btn');
    const logoutButton = document.getElementById('logout-btn');
    if (!loginButton || !logoutButton) return;

    loginButton.classList.toggle('hidden', Boolean(user));
    logoutButton.classList.toggle('hidden', !user);
  };

  const syncProfileBootstrap = async (session: unknown) => {
    if (!session) {
      dispatchProfileBootstrapStatus({
        status: 'signed_out',
        profileReady: false,
        message: 'Login is required.',
      });
      return;
    }

    await bootstrapProfileForCurrentSession();
  };

  const setupHeaderAuth = async () => {
    const state = window as Window & { mkHeaderAuthReady?: boolean };
    if (state.mkHeaderAuthReady) return;
    state.mkHeaderAuthReady = true;

    const loginButton = document.getElementById('open-login-btn');
    const logoutButton = document.getElementById('logout-btn');

    loginButton?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('mk:open-auth'));
    });

    if (!isSupabaseConfigured()) {
      updateAuthButtons(null);
      dispatchProfileBootstrapStatus({
        status: 'disabled',
        profileReady: false,
        message: 'Supabase public configuration is unavailable.',
      });
      return;
    }

    const supabase = getBrowserSupabaseClient();
    if (!supabase) return;

    logoutButton?.addEventListener('click', async () => {
      await supabase.auth.signOut();
      updateAuthButtons(null);
      await syncProfileBootstrap(null);
    });

    const { data } = await supabase.auth.getSession();
    updateAuthButtons(data.session?.user ?? null);
    await syncProfileBootstrap(data.session);

    supabase.auth.onAuthStateChange((_event, session) => {
      updateAuthButtons(session?.user ?? null);
      void syncProfileBootstrap(session);
    });
  };

  document.addEventListener('astro:page-load', setupHeaderAuth);
  setupHeaderAuth();
</script>
