---
import AuthModal from './Auth/AuthModal.astro';
---

<header class="site-header">
  <a class="brand-mark" href="/" aria-label="MK Stock Lab 홈">
    <img class="brand-logo" src="/logo.svg" alt="MK Stock Lab 로고" width="48" height="48" />
    <span class="brand-text">
      <strong>MK Stock Lab</strong>
      <small>투자 데이터 플랫폼</small>
    </span>
  </a>

  <div class="header-actions">
    <button class="icon-button" id="themeToggle" type="button" aria-label="테마 전환">
      <svg id="themeIcon" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 4a8 8 0 1 0 8 8 6 6 0 0 1-8-8Z"></path>
      </svg>
    </button>
    <button class="header-button" id="open-login-btn" type="button">로그인</button>
    <button class="header-button secondary hidden" id="logout-btn" type="button">로그아웃</button>
  </div>
</header>

<AuthModal />

<script>
  import { bootstrapProfileForCurrentSession, dispatchProfileBootstrapStatus } from '../lib/profileBootstrap';
  import { getBrowserSupabaseClient, isSupabaseConfigured } from '../lib/supabase';

  type HeaderAuthState = 'signed_in' | 'signed_out' | 'unavailable';
  const AUTH_UI_HINT_KEY = 'mk-stock-lab-auth-ui-hint';

  const readAuthUiHint = () => {
    try {
      return window.localStorage.getItem(AUTH_UI_HINT_KEY);
    } catch {
      return null;
    }
  };

  const writeAuthUiHint = (status: HeaderAuthState) => {
    try {
      if (status === 'signed_in') {
        window.localStorage.setItem(AUTH_UI_HINT_KEY, 'signed_in');
        return;
      }

      if (status === 'signed_out') {
        window.localStorage.setItem(AUTH_UI_HINT_KEY, 'signed_out');
        return;
      }

      if (status === 'unavailable') {
        window.localStorage.removeItem(AUTH_UI_HINT_KEY);
      }
    } catch {
      // Local storage can be unavailable in private or constrained browser contexts.
    }
  };

  const dispatchHeaderAuthState = (status: HeaderAuthState) => {
    window.dispatchEvent(new CustomEvent('mk:auth-state', { detail: { status } }));
  };

  const updateAuthButtons = (status: HeaderAuthState) => {
    const loginButton = document.getElementById('open-login-btn');
    const logoutButton = document.getElementById('logout-btn') as HTMLButtonElement | null;
    if (!loginButton || !logoutButton) return;

    if (status === 'signed_in') {
      writeAuthUiHint(status);
      loginButton.classList.add('hidden');
      loginButton.removeAttribute('disabled');
      logoutButton.classList.remove('hidden');
      dispatchHeaderAuthState(status);
      return;
    }

    writeAuthUiHint(status);
    loginButton.textContent = status === 'unavailable' ? '설정 필요' : '로그인';
    loginButton.removeAttribute('disabled');
    loginButton.classList.remove('hidden');
    logoutButton.classList.add('hidden');
    dispatchHeaderAuthState(status);
  };

  const syncProfileBootstrap = async (session: unknown) => {
    if (!session) {
      dispatchProfileBootstrapStatus({
        status: 'signed_out',
        profileReady: false,
        message: '로그인이 필요합니다.',
      });
      return;
    }

    await bootstrapProfileForCurrentSession();
  };

  const setupHeaderAuth = async () => {
    const loginButton = document.getElementById('open-login-btn') as HTMLButtonElement | null;
    const logoutButton = document.getElementById('logout-btn') as HTMLButtonElement | null;
    if (!loginButton || !logoutButton || loginButton.dataset.authReady === 'true') return;
    loginButton.dataset.authReady = 'true';
    updateAuthButtons(readAuthUiHint() === 'signed_in' ? 'signed_in' : 'signed_out');

    loginButton?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('mk:open-auth'));
    });

    if (!isSupabaseConfigured()) {
      updateAuthButtons('unavailable');
      dispatchProfileBootstrapStatus({
        status: 'public_config_missing',
        profileReady: false,
        message: '로그인 설정이 아직 완료되지 않았습니다.',
      });
      return;
    }

    const supabase = getBrowserSupabaseClient();
    if (!supabase) return;

    logoutButton?.addEventListener('click', async () => {
      updateAuthButtons('signed_out');
      await supabase.auth.signOut();
      await syncProfileBootstrap(null);
    });

    const { data } = await supabase.auth.getSession();
    updateAuthButtons(data.session ? 'signed_in' : 'signed_out');
    await syncProfileBootstrap(data.session);

    supabase.auth.onAuthStateChange((_event, session) => {
      updateAuthButtons(session ? 'signed_in' : 'signed_out');
      void syncProfileBootstrap(session);
    });
  };

  document.addEventListener('astro:page-load', setupHeaderAuth);
  setupHeaderAuth();
</script>
