---
import GoogleLogin from './GoogleLogin.astro';
---

<div class="modal-overlay hidden" id="auth-modal" role="dialog" aria-modal="true" aria-labelledby="auth-title">
  <div class="modal-panel">
    <div class="modal-header">
      <div>
        <p class="eyebrow">MK Stock Lab</p>
        <h2 id="auth-title">로그인</h2>
      </div>
      <button class="icon-button" id="close-auth-modal" type="button" aria-label="로그인 창 닫기">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M6 6l12 12M18 6 6 18"></path>
        </svg>
      </button>
    </div>

    <GoogleLogin />

    <div class="divider">또는</div>

    <form class="auth-form" id="auth-form">
      <label class="signup-only hidden" id="auth-nickname-label">
        닉네임
        <input id="auth-nickname" type="text" autocomplete="nickname" maxlength="120" placeholder="서비스에서 사용할 이름" />
      </label>
      <label>
        이메일
        <input id="auth-email" type="email" autocomplete="email" required placeholder="name@example.com" />
      </label>
      <label>
        비밀번호
        <input id="auth-password" type="password" autocomplete="current-password" required placeholder="비밀번호" />
      </label>
      <label class="signup-only hidden" id="auth-password-confirm-label">
        비밀번호 확인
        <input id="auth-password-confirm" type="password" autocomplete="new-password" placeholder="비밀번호 재입력" />
      </label>
      <p class="auth-error hidden" id="auth-error" role="alert"></p>
      <button class="primary-action" type="submit" id="auth-submit">로그인</button>
      <button class="text-button auth-reset-link" type="button" id="show-reset-panel">비밀번호를 잊으셨나요?</button>
    </form>

    <div class="auth-reset-panel hidden" id="auth-reset-panel" aria-label="비밀번호 재설정">
      <p class="auth-reset-desc">등록하신 이메일 주소로 비밀번호 재설정 링크를 보내드립니다.</p>
      <form class="auth-form" id="auth-reset-form">
        <label>
          이메일
          <input id="auth-reset-email" type="email" autocomplete="email" placeholder="name@example.com" />
        </label>
        <p class="auth-error hidden" id="auth-reset-error" role="alert"></p>
        <p class="auth-reset-success hidden" id="auth-reset-success" role="status"></p>
        <button class="primary-action" type="submit" id="auth-reset-submit">비밀번호 재설정 메일 보내기</button>
        <button class="text-button" type="button" id="auth-reset-back">로그인으로 돌아가기</button>
      </form>
    </div>

    <p class="modal-note" id="auth-modal-note">
      <span id="auth-mode-copy">계정이 없으신가요?</span>
      <button class="text-button" id="toggle-auth-mode" type="button">회원가입</button>
    </p>
  </div>
</div>

<script>
  import { bootstrapProfileForCurrentSession } from '../../lib/profileBootstrap';
  import { getBrowserSupabaseClient, isSupabaseConfigured } from '../../lib/supabase';

  const modal = document.getElementById('auth-modal');
  const closeButton = document.getElementById('close-auth-modal');
  const form = document.getElementById('auth-form') as HTMLFormElement | null;
  const title = document.getElementById('auth-title');
  const submitButton = document.getElementById('auth-submit');
  const toggleButton = document.getElementById('toggle-auth-mode');
  const modeCopy = document.getElementById('auth-mode-copy');
  const nicknameLabel = document.getElementById('auth-nickname-label');
  const passwordConfirmLabel = document.getElementById('auth-password-confirm-label');
  const nicknameInput = document.getElementById('auth-nickname') as HTMLInputElement | null;
  const emailInput = document.getElementById('auth-email') as HTMLInputElement | null;
  const passwordInput = document.getElementById('auth-password') as HTMLInputElement | null;
  const passwordConfirmInput = document.getElementById('auth-password-confirm') as HTMLInputElement | null;
  const errorMessage = document.getElementById('auth-error');
  const showResetLink = document.getElementById('show-reset-panel') as HTMLButtonElement | null;
  const resetPanel = document.getElementById('auth-reset-panel') as HTMLElement | null;
  const resetForm = document.getElementById('auth-reset-form') as HTMLFormElement | null;
  const resetEmailInput = document.getElementById('auth-reset-email') as HTMLInputElement | null;
  const resetErrorEl = document.getElementById('auth-reset-error') as HTMLElement | null;
  const resetSuccessEl = document.getElementById('auth-reset-success') as HTMLElement | null;
  const resetSubmitBtn = document.getElementById('auth-reset-submit') as HTMLButtonElement | null;
  const resetBackBtn = document.getElementById('auth-reset-back') as HTMLButtonElement | null;
  const modalNote = document.getElementById('auth-modal-note') as HTMLElement | null;
  let signupMode = false;

  const setError = (message: string) => {
    if (!errorMessage) return;
    errorMessage.textContent = message;
    errorMessage.classList.toggle('hidden', !message);
  };

  const setResetError = (msg: string) => {
    if (!resetErrorEl) return;
    resetErrorEl.textContent = msg;
    resetErrorEl.classList.toggle('hidden', !msg);
  };

  const setResetSuccess = (msg: string) => {
    if (!resetSuccessEl) return;
    resetSuccessEl.textContent = msg;
    resetSuccessEl.classList.toggle('hidden', !msg);
  };

  const setMode = (nextMode: boolean) => {
    signupMode = nextMode;
    if (title) title.textContent = signupMode ? '회원가입' : '로그인';
    if (submitButton) submitButton.textContent = signupMode ? '회원가입' : '로그인';
    if (toggleButton) toggleButton.textContent = signupMode ? '로그인하기' : '회원가입';
    if (modeCopy) modeCopy.textContent = signupMode ? '이미 계정이 있으신가요?' : '계정이 없으신가요?';
    nicknameLabel?.classList.toggle('hidden', !signupMode);
    passwordConfirmLabel?.classList.toggle('hidden', !signupMode);
    if (nicknameInput) nicknameInput.required = signupMode;
    if (passwordConfirmInput) passwordConfirmInput.required = signupMode;
    if (passwordInput) passwordInput.autocomplete = signupMode ? 'new-password' : 'current-password';
    showResetLink?.classList.toggle('hidden', signupMode);
    setError('');
  };

  const showReset = () => {
    if (resetEmailInput && emailInput?.value) {
      resetEmailInput.value = emailInput.value;
    }
    setResetError('');
    setResetSuccess('');
    form?.classList.add('hidden');
    showResetLink?.classList.add('hidden');
    modalNote?.classList.add('hidden');
    resetPanel?.classList.remove('hidden');
  };

  const hideReset = () => {
    resetPanel?.classList.add('hidden');
    form?.classList.remove('hidden');
    modalNote?.classList.remove('hidden');
    showResetLink?.classList.toggle('hidden', signupMode);
  };

  const closeModal = () => {
    modal?.classList.add('hidden');
    form?.reset();
    setError('');
  };

  const openModal = () => {
    setMode(false);
    hideReset();
    modal?.classList.remove('hidden');
  };

  window.addEventListener('mk:open-auth', openModal);
  closeButton?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (event) => {
    if (event.target === modal) closeModal();
  });
  toggleButton?.addEventListener('click', () => setMode(!signupMode));
  showResetLink?.addEventListener('click', showReset);
  resetBackBtn?.addEventListener('click', hideReset);

  resetForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    setResetError('');
    setResetSuccess('');

    if (!isSupabaseConfigured()) {
      setResetError('재설정 메일 발송에 실패했습니다. 잠시 후 다시 시도해 주세요.');
      return;
    }

    const supabase = getBrowserSupabaseClient();
    if (!supabase) {
      setResetError('재설정 메일 발송에 실패했습니다. 잠시 후 다시 시도해 주세요.');
      return;
    }

    const email = resetEmailInput?.value.trim() ?? '';
    if (!email || !email.includes('@')) {
      setResetError('유효한 이메일 주소를 입력해 주세요.');
      return;
    }

    if (resetSubmitBtn) resetSubmitBtn.setAttribute('disabled', 'true');

    const redirectTo = `${window.location.origin}/reset-password`;
    await supabase.auth.resetPasswordForEmail(email, { redirectTo });

    if (resetSubmitBtn) resetSubmitBtn.removeAttribute('disabled');
    setResetSuccess('입력하신 이메일로 비밀번호 재설정 링크를 발송했습니다. 메일함을 확인해 주세요.');
  });

  const validateSignup = () => {
    const nickname = nicknameInput?.value.trim() ?? '';
    const email = emailInput?.value.trim() ?? '';
    const password = passwordInput?.value ?? '';
    const passwordConfirm = passwordConfirmInput?.value ?? '';

    if (!nickname) return '닉네임을 입력해 주세요.';
    if (!email) return '이메일을 입력해 주세요.';
    if (!password) return '비밀번호를 입력해 주세요.';
    if (!passwordConfirm) return '비밀번호 확인을 입력해 주세요.';
    if (password !== passwordConfirm) return '비밀번호가 일치하지 않습니다.';
    return '';
  };

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    setError('');

    if (!isSupabaseConfigured()) {
      setError('로그인 설정이 아직 완료되지 않았습니다.');
      return;
    }

    const supabase = getBrowserSupabaseClient();
    if (!supabase) return;

    const email = emailInput?.value.trim() ?? '';
    const password = passwordInput?.value ?? '';
    const nickname = nicknameInput?.value.trim() ?? '';

    if (signupMode) {
      const validationError = validateSignup();
      if (validationError) {
        setError(validationError);
        return;
      }
    }

    if (submitButton) submitButton.setAttribute('disabled', 'true');
    const { error } = signupMode
      ? await supabase.auth.signUp({
          email,
          password,
          options: {
            data: { name: nickname },
          },
        })
      : await supabase.auth.signInWithPassword({ email, password });

    if (submitButton) submitButton.removeAttribute('disabled');
    if (error) {
      setError('인증 정보를 확인해 주세요.');
      return;
    }

    await bootstrapProfileForCurrentSession();
    closeModal();
  });
</script>
