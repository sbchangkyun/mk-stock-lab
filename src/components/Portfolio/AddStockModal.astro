---
// src/components/Portfolio/AddStockModal.astro
---

<div id="addStockModal" class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm hidden z-[100] items-center justify-center p-4">
  <div class="bg-white dark:bg-slate-900 w-full max-w-md rounded-2xl shadow-2xl border border-slate-200 dark:border-slate-800 overflow-hidden transform transition-all">

    <!-- 헤더 -->
    <div class="px-6 py-4 border-b border-slate-100 dark:border-slate-800 flex justify-between items-center bg-slate-50/50 dark:bg-slate-800/50">
      <div>
        <h2 class="text-xl font-bold text-slate-800 dark:text-white">종목 추가</h2>
        <p class="text-xs text-slate-400 mt-0.5">
          그룹:&nbsp;<span id="modalPortfolioName" class="text-indigo-500 dark:text-indigo-400 font-semibold"></span>
        </p>
      </div>
      <button id="closeModalIcon" class="text-slate-400 hover:text-slate-600 dark:hover:text-slate-200 transition-colors p-1 rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- 현재 선택된 포트폴리오 ID를 저장하는 hidden input -->
    <input type="hidden" id="currentPortfolioId" value="" />

    <!-- 바디 -->
    <div class="p-6 space-y-5">

      <!-- 종목 검색 -->
      <div>
        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">종목 검색</label>
        <div class="relative">
          <input
            type="text"
            id="stockSearch"
            placeholder="삼성전자, TSLA, 005930..."
            autocomplete="off"
            class="w-full bg-slate-50 dark:bg-slate-800 border-none rounded-xl px-4 py-3 text-slate-900 dark:text-white placeholder-slate-400 focus:ring-2 focus:ring-indigo-500 transition-all"
          />
          <div
            id="searchResults"
            class="absolute w-full mt-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl shadow-xl max-h-48 overflow-y-auto hidden z-10"
          ></div>
        </div>
      </div>

      <!-- 수량 / 평균단가 -->
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">보유 수량</label>
          <input
            type="number"
            id="stockQuantity"
            step="0.000001"
            min="0"
            placeholder="0.0"
            class="w-full bg-slate-50 dark:bg-slate-800 border-none rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:ring-2 focus:ring-indigo-500 transition-all"
          />
        </div>
        <div>
          <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">평균 단가</label>
          <input
            type="number"
            id="stockAvgPrice"
            min="0"
            placeholder="0.0"
            class="w-full bg-slate-50 dark:bg-slate-800 border-none rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:ring-2 focus:ring-indigo-500 transition-all"
          />
        </div>
      </div>

      <!-- 통화 단위 -->
      <div>
        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wider mb-2">통화 단위</label>
        <select
          id="stockCurrency"
          class="w-full bg-slate-50 dark:bg-slate-800 border-none rounded-xl px-4 py-3 text-slate-900 dark:text-white focus:ring-2 focus:ring-indigo-500 transition-all appearance-none"
        >
          <option value="KRW">KRW (원화)</option>
          <option value="USD">USD (달러)</option>
        </select>
      </div>

      <!-- 버튼 -->
      <div class="flex gap-3 pt-2">
        <button
          id="closeModal"
          class="flex-1 px-4 py-3 bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 font-bold rounded-xl hover:bg-slate-200 dark:hover:bg-slate-700 transition-all"
        >
          취소
        </button>
        <button
          id="saveStock"
          class="flex-[2] px-4 py-3 bg-indigo-600 text-white font-bold rounded-xl hover:bg-indigo-700 shadow-lg shadow-indigo-200 dark:shadow-none transition-all active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          포트폴리오에 담기
        </button>
      </div>

    </div>
  </div>
</div>

<script>
  import { addPortfolioItem } from '../../lib/supabase';

  const modal = document.getElementById('addStockModal');

  // ── 모달 닫기 ──────────────────────────────────────
  const closeModal = () => {
    modal?.classList.add('hidden');
    modal?.classList.remove('flex');
    document.body.style.overflow = '';
    // 입력 필드 초기화
    (document.getElementById('stockSearch') as HTMLInputElement).value = '';
    (document.getElementById('stockQuantity') as HTMLInputElement).value = '';
    (document.getElementById('stockAvgPrice') as HTMLInputElement).value = '';
    (document.getElementById('stockCurrency') as HTMLSelectElement).value = 'KRW';
    (document.getElementById('currentPortfolioId') as HTMLInputElement).value = '';
  };

  [document.getElementById('closeModal'), document.getElementById('closeModalIcon')]
    .forEach(btn => btn?.addEventListener('click', closeModal));

  // 바깥 영역 클릭 시 닫기
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // ── 종목 저장 ──────────────────────────────────────
  document.getElementById('saveStock')?.addEventListener('click', async () => {
    const saveBtn = document.getElementById('saveStock') as HTMLButtonElement;

    const portfolioId = (document.getElementById('currentPortfolioId') as HTMLInputElement).value;
    const symbol     = (document.getElementById('stockSearch')     as HTMLInputElement).value.trim();
    const quantity   = (document.getElementById('stockQuantity')   as HTMLInputElement).value;
    const avgPrice   = (document.getElementById('stockAvgPrice')   as HTMLInputElement).value;
    const currency   = (document.getElementById('stockCurrency')   as HTMLSelectElement).value;

    // 입력값 검증
    if (!portfolioId) {
      alert('포트폴리오 그룹을 선택해주세요.');
      return;
    }
    if (!symbol) {
      alert('종목 심볼을 입력해주세요.');
      return;
    }
    if (!quantity || parseFloat(quantity) <= 0) {
      alert('올바른 보유 수량을 입력해주세요.');
      return;
    }
    if (!avgPrice || parseFloat(avgPrice) <= 0) {
      alert('올바른 평균 단가를 입력해주세요.');
      return;
    }

    saveBtn.disabled = true;
    saveBtn.innerText = '저장 중...';

    try {
      await addPortfolioItem(portfolioId, {
        symbol,
        name: symbol, // 종목명은 심볼로 임시 저장 (API 연동 후 갱신 예정)
        quantity,
        avgPrice,
        currency,
      });
      alert(`✅ "${symbol}" 종목이 포트폴리오에 저장되었습니다!`);
      closeModal();
      window.location.reload();
    } catch (e: any) {
      alert('❌ 저장 실패: ' + (e?.message || '알 수 없는 오류가 발생했습니다.'));
    } finally {
      saveBtn.disabled = false;
      saveBtn.innerText = '포트폴리오에 담기';
    }
  });
</script>