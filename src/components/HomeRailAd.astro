---
import homeAdBanners from '../data/homeAdBanners.json';

const activeBanners = homeAdBanners
  .filter((banner) => banner.isActive)
  .sort((a, b) => a.displayOrder - b.displayOrder);

const hasMultipleBanners = activeBanners.length > 1;
---

{
  activeBanners.length > 0 && (
    <aside
      class:list={['home-rail-ad', { 'is-carousel': hasMultipleBanners }]}
      data-home-rail-ad
      data-count={activeBanners.length}
      aria-label="Home sample banner rail"
    >
      <div class="home-rail-viewport">
        <div class="home-rail-track">
          {activeBanners.map((banner) => (
            <a class="home-rail-card" href={banner.href} aria-label={banner.alt}>
              <img src={banner.imageSrc} alt={banner.alt} width="160" height="600" loading="lazy" />
            </a>
          ))}
        </div>
      </div>
    </aside>
  )
}

<script>
  import { getHomeRailBanners } from '../lib/siteSettingsClient';
  import { isSupabaseConfigured } from '../lib/supabase';

  // Set up carousel rotation for a rail element.
  // Stores the interval ID on the element so loadManagedBanners can cancel it.
  const setupRailCarousel = (rail: HTMLElement) => {
    const track = rail.querySelector<HTMLElement>('.home-rail-track');
    const cards = rail.querySelectorAll<HTMLElement>('.home-rail-card');
    if (
      !rail.classList.contains('is-carousel') ||
      !track ||
      cards.length < 2 ||
      rail.dataset.ready === 'true'
    ) return;

    rail.dataset.ready = 'true';
    let activeIndex = 0;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)');

    const render = () => {
      track.style.transitionDuration = reduceMotion.matches ? '0ms' : '320ms';
      track.style.transform = `translateX(-${activeIndex * 100}%)`;
    };

    const startCarousel = () => {
      if ((rail as any)._railIntervalId !== undefined) return;
      (rail as any)._railIntervalId = window.setInterval(() => {
        activeIndex = (activeIndex + 1) % cards.length;
        render();
      }, 5000);
    };

    const stopCarousel = () => {
      if ((rail as any)._railIntervalId === undefined) return;
      window.clearInterval((rail as any)._railIntervalId as number);
      delete (rail as any)._railIntervalId;
    };

    rail.addEventListener('mouseenter', stopCarousel);
    rail.addEventListener('mouseleave', startCarousel);
    reduceMotion.addEventListener('change', render);
    render();
    startCarousel();
  };

  const initRail = () => {
    document.querySelectorAll<HTMLElement>('[data-home-rail-ad]').forEach(setupRailCarousel);
  };

  const loadManagedBanners = async () => {
    if (!isSupabaseConfigured()) return;
    const banners = await getHomeRailBanners();
    // Only render banners that are active, have a non-empty imageUrl, and a valid https? scheme.
    const active = (banners ?? []).filter(
      (b) => b.active && b.imageUrl.trim() && /^https?:\/\//i.test(b.imageUrl.trim())
    );
    if (active.length === 0) return;

    const rail = document.querySelector<HTMLElement>('[data-home-rail-ad]');
    if (!rail) return;
    const track = rail.querySelector<HTMLElement>('.home-rail-track');
    if (!track) return;

    // Tear down any existing carousel before replacing content
    if ((rail as any)._railIntervalId !== undefined) {
      window.clearInterval((rail as any)._railIntervalId as number);
      delete (rail as any)._railIntervalId;
    }
    rail.removeAttribute('data-ready');
    track.style.transform = '';
    track.style.transitionDuration = '';

    // Replace track content with active managed banners only (no blank slots)
    track.innerHTML = '';
    for (const b of active) {
      const safeAlt = (b.alt || 'MK Stock Lab 배너').slice(0, 120);
      const safeImageUrl = b.imageUrl.trim();
      let card: HTMLElement;
      if (b.linkUrl && /^https?:\/\//i.test(b.linkUrl)) {
        const a = document.createElement('a');
        a.href = b.linkUrl;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.className = 'home-rail-card';
        a.setAttribute('aria-label', safeAlt);
        card = a;
      } else {
        const div = document.createElement('div');
        div.className = 'home-rail-card';
        div.setAttribute('role', 'img');
        div.setAttribute('aria-label', safeAlt);
        card = div;
      }
      const img = document.createElement('img');
      img.src = safeImageUrl;
      img.alt = safeAlt;
      img.width = 160;
      img.height = 600;
      img.loading = 'lazy';
      card.appendChild(img);
      track.appendChild(card);
    }

    // Update rail state based on active count
    if (active.length >= 2) {
      rail.classList.add('is-carousel');
    } else {
      rail.classList.remove('is-carousel');
    }
    rail.dataset.count = String(active.length);
    rail.setAttribute('aria-label', 'Home banner rail');

    // Re-initialize carousel rotation for the managed banners
    if (active.length >= 2) {
      setupRailCarousel(rail);
    }
  };

  document.addEventListener('astro:page-load', () => {
    initRail();
    void loadManagedBanners();
  });
  initRail();
  void loadManagedBanners();
</script>
