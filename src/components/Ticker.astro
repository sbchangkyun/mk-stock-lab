---
const tickerItems = [
  { label: 'S&P 500', value: 'US large cap' },
  { label: 'Nasdaq 100', value: 'Growth index' },
  { label: 'Dow Jones', value: 'Blue chips' },
  { label: 'KOSPI', value: 'Korea main board' },
  { label: 'KOSDAQ', value: 'Korea growth board' },
  { label: 'USD/KRW', value: 'FX watch' },
  { label: 'Dollar Index', value: 'Macro gauge' },
  { label: 'Gold', value: 'Safe-haven asset' },
  { label: 'WTI Oil', value: 'Energy benchmark' },
];
---

<div class="ticker-belt" id="ticker_area" aria-label="Market ticker">
  <div class="ticker-track">
    {tickerItems.map((item) => (
      <span class="ticker-chip">
        <strong>{item.label}</strong>
        <span>{item.value}</span>
      </span>
    ))}
  </div>
</div>

<script is:inline>
  function renderMarketTicker(theme) {
    const area = document.getElementById('ticker_area');
    if (!area) return;
    area.dataset.theme = theme || 'light';
    area.dataset.ready = 'true';
  }

  window.renderMarketTicker = renderMarketTicker;
  window.addEventListener('DOMContentLoaded', () => {
    renderMarketTicker(localStorage.getItem('theme') || 'light');
  });
</script>
