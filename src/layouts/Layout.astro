---
import Header from '../components/Header.astro';
import Ticker from '../components/Ticker.astro';
import Nav from '../components/Nav.astro';
import SlideAd from '../components/SlideAd.astro';
import Footer from '../components/Footer.astro';
import '../styles/style.css';

const {
  title = 'MK Stock Lab',
  description = '국내외 주식과 ETF 투자자를 위한 투자 데이터 플랫폼.',
  activePath = Astro.url.pathname,
  pageClass = '',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/icon-192.png" />
    <meta name="theme-color" content="#0f4fd8" />
  </head>
  <body class={pageClass}>
    <SlideAd />
    <Header />
    <Ticker />
    <Nav currentPath={activePath} />
    <main class="site-main">
      <slot />
    </main>
    <Footer />
    <script>
      import '../scripts/main.js';
    </script>
  </body>
</html>
